      label "Изоляция"
    error
      executing
        command "❌ Ошибка выполнения команды {{commandName}}"
  language
    en "Английский"
    ru "Русский"
    zh "Китайский"
    hi "Хинди"
  version
    ai
      agents "AI-агенты"
    browsers "Браузеры"
    browser
