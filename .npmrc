# Make npm resilient to transient registry network failures (issue #1903).
# GitHub-hosted runners occasionally drop the connection mid-download
# (`npm error code ECONNRESET` / `npm error network aborted`). These settings
# raise npm's own built-in retry budget for registry requests so a single
# dropped socket does not fail the install. The scripts/npm-install-with-retry.mjs
# wrapper retries the whole install on top of this for full process aborts.
fetch-retries=5
fetch-retry-factor=2
fetch-retry-mintimeout=10000
fetch-retry-maxtimeout=120000
fetch-timeout=300000
