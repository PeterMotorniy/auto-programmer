[2026-04-18T17:28:46.246Z] [INFO]         "type": "tool_result",
[2026-04-18T17:28:46.246Z] [INFO]         "content": "1\tname: Checks and release\n2\t\n3\ton:\n4\t  push:\n5\t    branches:\n6\t      - main\n7\t  pull_request:\n8\t    types: [opened, synchronize, reopened]\n9\t    # Only trigger for files the CI pipeline cares about (Issue #1582)\n10\t    # Uses positive matching (consistent with detect-code-changes.mjs from Issue #1528)\n11\t    # so unknown file types (.gitkeep, .txt, .log, images, etc.) are naturally excluded\n12\t    paths:\n13\t      - '**.mjs'\n14\t      - '**.js'\n15\t      - '**.sh'\n16\t      - '**.json'\n17\t      - '**.yml'\n18\t      - '**.yaml'\n19\t      - '**.md'\n20\t      - '.changeset/**'\n21\t      - '.github/**'\n22\t      - 'Dockerfile'\n23\t      - 'coolify/Dockerfile'\n24\t      - '.dockerignore'\n25\t      - 'helm/**'\n26\t      - '.prettierrc'\n27\t      - '.prettierignore'\n28\t      - '.eslintrc*'\n29\t  # Manual release support - consolidated here to work with npm trusted publishing\n30\t  # npm only allows ONE workflow file as trusted publisher, so all publishing\n31\t  # must go through this workflow (release.yml)\n32\t  workflow_dispatch:\n33\t    inputs:\n34\t      release_mode:\n35\t        description: 'Manual release mode'\n36\t        required: true\n37\t        type: choice\n38\t        default: 'instant'\n39\t        options:\n40\t          - instant\n41\t          - changeset-pr\n42\t      bump_type:\n43\t        description: 'Manual release type'\n44\t        required: true\n45\t        type: choice\n46\t        options:\n47\t          - patch\n48\t          - minor\n49\t          - major\n50\t      description:\n51\t        description: 'Manual release description (optional)'\n52\t        required: false\n53\t        type: string\n54\t\n55\t# Concurrency: Only one workflow run per branch at a time\n56\t# - For main branch (releases): cancel older runs to prevent blocking newer releases\n57\t#   When multiple commits are pushed quickly, we want the latest to release, not wait\n58\t# - For PR branches: queue runs to avoid cancelling checks on force-pushes\n59\t# IMPORTANT: Docker jobs use !cancelled() instead of always() to ensure they respect\n60\t# concurrency cancellation. Using always() prevents workflow cancellation entirely.\n61\t# See: docs/case-studies/issue-1274/README.md and docs/case-studies/issue-1278/README.md\n62\tconcurrency:\n63\t  group: ${{ github.workflow }}-${{ github.ref }}\n64\t  cancel-in-progress: ${{ github.ref == 'refs/heads/main' }}\n65\t\n66\tenv: # Force Node.js 24 for actions without native support. See issue #1417.\n67\t  FORCE_JAVASCRIPT_ACTIONS_TO_NODE24: true\n68\t\n69\tjobs:\n70\t  # === DETECT CHANGES ===\n71\t  detect-changes:\n72\t    runs-on: ubuntu-latest\n73\t    outputs:\n74\t      mjs-changed: ${{ steps.changes.outputs.mjs }}\n75\t      package-changed: ${{ steps.changes.outputs.package }}\n76\t      docs-changed: ${{ steps.changes.outputs.docs }}\n77\t      workflow-changed: ${{ steps.changes.outputs.workflow }}\n78\t      docker-changed: ${{ steps.changes.outputs.docker }}\n79\t      any-code-changed: ${{ steps.changes.outputs.code }}\n80\t      helm-changed: ${{ steps.changes.outputs.helm }}\n81\t\n82\t    steps:\n83\t      - uses: actions/checkout@v5\n84\t        with:\n85\t          fetch-depth: 2\n86\t\n87\t      - name: Detect changes\n88\t        id: changes\n89\t        env:\n90\t          GITHUB_EVENT_NAME: ${{ github.event_name }}\n91\t          GITHUB_BASE_SHA: ${{ github.event.pull_request.base.sha }}\n92\t          GITHUB_HEAD_SHA: ${{ github.event.pull_request.head.sha }}\n93\t        run: node scripts/detect-code-changes.mjs\n94\t\n95\t  # === VERSION CHANGE CHECK ===\n96\t  # Prohibit manual version changes in package.json - versions should only be changed by CI/CD\n97\t  # Only runs when code or package.json changed (Issue #1436: skip for unrelated file changes)\n98\t  version-check:\n99\t    name: Check for Manual Version Changes\n100\t    runs-on: ubuntu-latest\n101\t    needs: [detect-changes]\n102\t    if: github.event_name == 'pull_request' && (needs.detect-changes.outputs.any-code-changed == 'true' || needs.detect-changes.outputs.package-changed == 'true')\n103\t    steps:\n104\t      - uses: actions/checkout@v5\n105\t        with:\n106\t          fetch-depth: 0\n107\t\n108\t      - name: Check for version changes in package.json\n109\t        env:\n110\t          GITHUB_HEAD_REF: ${{ github.head_ref }}\n111\t          GITHUB_BASE_REF: ${{ github.base_ref }}\n112\t        run: node scripts/check-version.mjs\n113\t\n114\t  # === CHANGESET CHECK - only runs on PRs with code changes ===\n115\t  # Docs-only PRs (./docs folder, markdown files) don't require changesets\n116\t  changeset-check:\n117\t    name: Check for Changesets\n118\t    runs-on: ubuntu-latest\n119\t    needs: [detect-changes]\n120\t    if: github.event_name == 'pull_request' && needs.detect-changes.outputs.any-code-changed == 'true'\n121\t    steps:\n122\t      - uses: actions/checkout@v5\n123\t        with:\n124\t          fetch-depth: 0\n125\t\n126\t      - name: Setup Node.js\n127\t        uses: actions/setup-node@v5\n128\t        with:\n129\t          node-version: '24.x'\n130\t\n131\t      - name: Install dependencies\n132\t        run: npm install\n133\t\n134\t      - name: Check for changesets\n135\t        env:\n136\t          # Pass PR context to the validation script\n137\t          GITHUB_BASE_REF: ${{ github.base_ref }}\n138\t          GITHUB_BASE_SHA: ${{ github.event.pull_request.base.sha }}\n139\t          GITHUB_HEAD_SHA: ${{ github.event.pull_request.head.sha }}\n140\t        run: |\n141\t          # Skip changeset check for automated version PRs\n142\t          if [[ \"${{ github.head_ref }}\" == \"changeset-release/\"* ]]; then\n143\t            echo \"Skipping changeset check for automated release PR\"\n144\t            exit 0\n145\t          fi\n146\t\n147\t          # Run changeset validation script\n148\t          # This validates that exactly ONE changeset was ADDED by this PR\n149\t          # Pre-existing changesets from other merged PRs are ignored\n150\t          node scripts/validate-changeset.mjs\n151\t\n152\t  # === FAST CHECKS (FAIL FAST) ===\n153\t  # These checks run quickly (~7-21 seconds each) and should pass before long-running tests\n154\t\n155\t  # === COMPILATION & SYNTAX CHECKS ===\n156\t  test-compilation:\n157\t    runs-on: ubuntu-latest\n158\t    needs: [detect-changes, changeset-check]\n159\t    # Run if: push event, OR changeset-check succeeded, OR changeset-check was skipped (docs-only PR)\n160\t    if: always() && (github.event_name == 'push' || needs.changeset-check.result == 'success' || needs.changeset-check.result == 'skipped') && (needs.detect-changes.outputs.any-code-changed == 'true' || needs.detect-changes.outputs.workflow-changed == 'true')\n161\t\n162\t    steps:\n163\t      - name: Checkout repository\n164\t        uses: actions/checkout@v5\n165\t\n166\t      - name: Setup Node.js\n167\t        uses: actions/setup-node@v5\n168\t        with:\n169\t          node-version: 24.x\n170\t\n171\t      - name: Test solve.mjs compilation\n172\t        run: |\n173\t          echo \"Testing solve.mjs compilation...\"\n174\t          timeout 30s node --check src/solve.mjs\n175\t          echo \"solve.mjs compiles successfully\"\n176\t\n177\t      - name: Test hive.mjs compilation\n178\t        run: |\n179\t          echo \"Testing hive.mjs compilation...\"\n180\t          timeout 30s node --check src/hive.mjs\n181\t          echo \"hive.mjs compiles successfully\"\n182\t\n183\t      - name: Check Node.js syntax for all .mjs files\n184\t        run: bash scripts/check-mjs-syntax.sh\n185\t\n186\t  # === ESLINT CODE QUALITY CHECK ===\n187\t  # Lint runs independently of changeset-check - it's a fast check that should always run\n188\t  # See: docs/case-studies/issue-1023 for why this dependency was removed\n189\t  # IMPORTANT: ESLint now includes max-lines rule (1500 lines) to synchronize with check-file-line-limits\n190\t  # See docs/case-studies/issue-1141 for why fresh merge simulation is critical\n191\t  lint:\n192\t    runs-on: ubuntu-latest\n193\t    needs: [detect-changes]\n194\t    if: needs.detect-changes.outputs.mjs-changed == 'true' || needs.detect-changes.outputs.docs-changed == 'true' || needs.detect-changes.outputs.package-changed == 'true' || needs.detect-changes.outputs.workflow-changed == 'true'\n195\t\n196\t    steps:\n197\t      - name: Checkout repository\n198\t        uses: actions/checkout@v5\n199\t        with:\n200\t          # For PRs, fetch enough history to merge with base branch\n201\t          fetch-depth: 0\n202\t\n203\t      - name: Simulate fresh merge with base branch (PR only)\n204\t        if: github.event_name == 'pull_request'\n205\t        env:\n206\t          BASE_REF: ${{ github.base_ref }}\n207\t        run: bash scripts/simulate-fresh-merge.sh\n208\t\n209\t      - name: Setup Node.js\n210\t        uses: actions/setup-node@v5\n211\t        with:\n212\t          node-version: 24.x\n213\t\n214\t      - name: Install dependencies\n215\t        run: npm ci\n216\t\n217\t      - name: Run Prettier format check\n218\t        run: |\n219\t          echo \"Running Prettier format check...\"\n220\t          npm run format:check\n221\t          echo \"Prettier format check passed\"\n222\t\n223\t      - name: Run ESLint\n224\t        run: |\n225\t          echo \"Running ESLint code quality checks...\"\n226\t          npm run lint\n227\t          echo \"ESLint checks passed\"\n228\t\n229\t      - name: Run code duplication check\n230\t        run: |\n231\t          echo \"Running jscpd code duplication detection...\"\n232\t          npm run check:duplication\n233\t          echo \"Code duplication check passed\"\n234\t\n235\t  # === FILE LINE LIMIT CHECK ===\n236\t  # IMPORTANT: This check must validate the ACTUAL merge result, not a stale merge preview.\n237\t  # See docs/case-studies/issue-1141 for why this is critical.\n238\t  check-file-line-limits:\n239\t    runs-on: ubuntu-latest\n240\t    needs: [detect-changes, changeset-check]\n241\t    # Run if: push event, OR changeset-check succeeded, OR changeset-check was skipped (docs-only PR)\n242\t    if: always() && (github.event_name == 'push' || needs.changeset-check.result == 'success' || needs.changeset-check.result == 'skipped') && (needs.detect-changes.outputs.mjs-changed == 'true' || needs.detect-changes.outputs.workflow-changed == 'true')\n243\t\n244\t    steps:\n245\t      - name: Checkout repository\n246\t        uses: actions/checkout@v5\n247\t        with:\n248\t          # For PRs, fetch enough history to merge with base branch\n249\t          fetch-depth: 0\n250\t\n251\t      - name: Simulate fresh merge with base branch (PR only)\n252\t        if: github.event_name == 'pull_request'\n253\t        env:\n254\t          BASE_REF: ${{ github.base_ref }}\n255\t        run: bash scripts/simulate-fresh-merge.sh\n256\t\n257\t      - name: Check file line limits (.mjs files and release.yml)\n258\t        run: bash scripts/check-file-line-limits.sh\n259\t\n260\t  # === LONG-RUNNING CHECKS ===\n261\t  # These checks take significant time (30s to 4+ minutes) and only run after all fast checks pass\n262\t\n263\t  # === UNIT TESTS ===\n264\t  test-suites:\n265\t    runs-on: ubuntu-latest\n266\t    needs: [detect-changes, changeset-check, test-compilation, lint, check-file-line-limits]\n267\t    if: |\n268\t      always() &&\n269\t      !cancelled() &&\n270\t      !contains(needs.*.result, 'failure') &&\n271\t      (github.event_name == 'push' || needs.changeset-check.result == 'success' || needs.changeset-check.result == 'skipped') &&\n272\t      needs.test-compilation.result == 'success' &&\n273\t      (needs.lint.result == 'success' || needs.lint.result == 'skipped') &&\n274\t      (needs.check-file-line-limits.result == 'success' || needs.check-file-line-limits.result == 'skipped') &&\n275\t      (needs.detect-changes.outputs.any-code-changed == 'true' || needs.detect-changes.outputs.workflow-changed == 'true')\n276\t\n277\t    steps:\n278\t      - uses: actions/checkout@v5\n279\t\n280\t      - name: Use Node.js 20.x\n281\t        uses: actions/setup-node@v5\n282\t        with:\n283\t          node-version: 24.x\n284\t\n285\t      - name: Install dependencies\n286\t        run: npm install\n287\t\n288\t      - name: Run test suite for solve.mjs\n289\t        run: |\n290\t          echo \"Running test suite for solve.mjs...\"\n291\t          node tests/test-solve.mjs\n292\t\n293\t      - name: Run test suite for hive.mjs\n294\t        run: |\n295\t          echo \"Running test suite for hive.mjs...\"\n296\t          node tests/test-hive.mjs\n297\t\n298\t      - name: Run test suite for memory-check.mjs\n299\t        run: |\n300\t          echo \"Running test suite for memory-check.mjs...\"\n301\t          node tests/test-memory-check.mjs\n302\t\n303\t      - name: Run branch name validation test (Issue #647)\n304\t        run: |\n305\t          echo \"Running test suite for branch name validation...\"\n306\t          node tests/test-branch-name-validation.mjs\n307\t\n308\t      - name: Run feedback lines regression test (Issue #168)\n309\t        run: |\n310\t          echo \"Running feedback lines regression test...\"\n311\t          node tests/test-feedback-lines-simple.mjs\n312\t\n313\t      - name: Run feedback lines integration test (Issue #168)\n314\t        env:\n315\t          GITHUB_TOKEN: ${{ secrets.TEST_GITHUB_USER_TOKEN || secrets.GITHUB_TOKEN }}\n316\t          TEST_GITHUB_USERNAME: ${{ secrets.TEST_GITHUB_USERNAME }}\n317\t          TEST_GITHUB_USER_TOKEN: ${{ secrets.TEST_GITHUB_USER_TOKEN }}\n318\t        run: |\n319\t          echo \"Running feedback lines integration test with real repository...\"\n320\t          node tests/test-feedback-lines-integration.mjs\n321\t\n322\t      - name: Run Sentry integration test\n323\t        run: |\n324\t          echo \"Running test suite for Sentry integration...\"\n325\t          node tests/test-sentry.mjs\n326\t\n327\t      - name: Run telegram-bot dry-run test (Issue #487)\n328\t        run: |\n329\t          echo \"Running test suite for telegram-bot --dry-run mode...\"\n330\t          node tests/test-telegram-bot-dry-run.mjs\n331\t\n332\t      - name: Run telegram-bot hero Links Notation test (Issue #623)\n333\t        run: |\n334\t          echo \"Running test suite for telegram-bot hero example with Links Notation...\"\n335\t          node tests/test-telegram-bot-hero-links-notation.mjs\n336\t\n337\t      - name: Run hive command silent failure test (Issue #504)\n338\t        run: |\n339\t          echo \"Running test suite for hive command silent failures...\"\n340\t          node tests/test-hive-no-silent-failure.mjs\n341\t\n342\t      - name: Run GitHub linking keyword detection test (Issue #568)\n343\t        run: |\n344\t          echo \"Running test suite for GitHub linking keyword detection...\"\n345\t          node tests/test-github-linking.mjs\n346\t\n347\t      - name: Run Telegram Markdown escaping test (Issue #580)\n348\t        run: |\n349\t          echo \"Running test suite for Telegram Markdown escaping...\"\n350\t          node tests/test-telegram-markdown-escaping.mjs\n351\t\n352\t      - name: Run lenv-reader test (Issue #604)\n353\t        run: |\n354\t          echo \"Running test suite for lenv-reader.lib.mjs...\"\n355\t          node tests/test-lenv-reader.mjs\n356\t\n357\t      - name: Run lino test (Issue #1086)\n358\t        run: |\n359\t          echo \"Running test suite for lino.lib.mjs...\"\n360\t          node tests/test-lino.mjs\n361\t\n362\t      - name: Run Telegram URL extraction test (Issue #603)\n363\t        run: |\n364\t          echo \"Running test suite for Telegram URL extraction...\"\n365\t          node tests/test-telegram-url-extraction.mjs\n366\t\n367\t      - name: Run Telegram URL validation test (Issue #630)\n368\t        run: |\n369\t          echo \"Running test suite for Telegram URL validation...\"\n370\t          node tests/test-telegram-validate-url.mjs\n371\t\n372\t      - name: Run Unicode sanitization test (Issue #1324)\n373\t        run: |\n374\t          echo \"Running test suite for Unicode sanitization...\"\n375\t          node tests/test-unicode-sanitization.mjs\n376\t\n377\t      - name: Run interactive mode test (Issue #800)\n378\t        run: |\n379\t          echo \"Running test suite for interactive mode...\"\n380\t          node tests/test-interactive-mode.mjs\n381\t\n382\t      - name: Run start-screen test (Issue #539)\n383\t        run: |\n384\t          echo \"Running test suite for start-screen.mjs...\"\n385\t          node tests/test-start-screen.mjs\n386\t\n387\t      - name: Run buildCostInfoString test (Issue #1015)\n388\t        run: |\n389\t          echo \"Running test suite for buildCostInfoString...\"\n390\t          node tests/test-build-cost-info-string.mjs\n391\t\n392\t      - name: Run token sanitization test (Issue #1037)\n393\t        run: |\n394\t          echo \"Running test suite for token sanitization...\"\n395\t          node tests/test-token-sanitization.mjs\n396\t\n397\t      - name: Run agent token usage test (Issues #1250, #1313)\n398\t        run: |\n399\t          echo \"Running test suite for agent token accumulation logic...\"\n400\t          node tests/test-agent-token-usage.mjs\n401\t\n402\t      - name: Run Telegram special character handling test (Issue #1070)\n403\t        run: |\n404\t          echo \"Running test suite for Telegram special character handling...\"\n405\t          node tests/test-telegram-special-char-handling.mjs\n406\t\n407\t      - name: Run usage limit test (Issues #942, #1122)\n408\t        run: |\n409\t          echo \"Running test suite for usage limit detection and parsing...\"\n410\t          node tests/test-usage-limit.mjs\n411\t\n412\t      - name: Run stderr warning detection test (Issue #1337)\n413\t        run: |\n414\t          echo \"Running test suite for stderr warning detection (isStderrError)...\"\n415\t          node tests/test-issue-1337-stderr-warning-detection.mjs\n416\t\n417\t      - name: Run hive-solve option parity test (Issue #1209)\n418\t        run: |\n419\t          echo \"Running test suite for hive-solve option parity...\"\n420\t          node tests/test-hive-solve-option-parity.mjs\n421\t\n422\t      - name: Run fork parent validation test (Issue #1518)\n423\t        run: |\n424\t          echo \"Running test suite for fork parent validation...\"\n425\t          node tests/test-fork-parent-validation.mjs\n426\t\n427\t      - name: Run pre-PR failure notifier test (Issue #1640)\n428\t        run: |\n429\t          echo \"Running test suite for pre-PR failure notifications...\"\n430\t          node tests/test-pre-pr-failure-notifier-1640.mjs\n431\t\n432\t      - name: Run docs-code options sync test (Issue #1518)\n433\t        run: |\n434\t          echo \"Running test suite for documentation-code options sync...\"\n435\t          node tests/test-docs-options-sync.mjs\n436\t\n437\t      - name: Run detect-code-changes test (Issue #1528)\n438\t        run: |\n439\t          echo \"Running test suite for CI/CD change detection...\"\n440\t          node tests/test-detect-code-changes-1528.mjs\n441\t\n442\t      - name: Run isolation runner test (Issue #380)\n443\t        run: |\n444\t          echo \"Running test suite for isolation runner...\"\n445\t          node tests/test-isolation-runner.mjs\n446\t\n447\t      - name: Run session monitor isolation test (Issue #380)\n448\t        run: |\n449\t          echo \"Running test suite for session monitor isolation support...\"\n450\t          node tests/test-session-monitor-isolation.mjs\n451\t\n452\t      - name: Run isolation screen fallback test (Issue #1545)\n453\t        run: |\n454\t          echo \"Running test suite for isolation screen fallback...\"\n455\t          node tests/test-isolation-screen-fallback-1545.mjs\n456\t\n457\t      - name: Run isolation screen integration test (Issue #1545)\n458\t        run: |\n459\t          echo \"Running integration tests for isolation screen session monitoring...\"\n460\t          node tests/test-isolation-screen-integration-1545.mjs\n461\t\n462\t  # === EXECUTION TESTS ===\n463\t  test-execution:\n464\t    runs-on: ubuntu-latest\n465\t    needs: [detect-changes, changeset-check, test-compilation, lint, check-file-line-limits]\n466\t    if: |\n467\t      always() &&\n468\t      !cancelled() &&\n469\t      !contains(needs.*.result, 'failure') &&\n470\t      (github.event_name == 'push' || needs.changeset-check.result == 'success' || needs.changeset-check.result == 'skipped') &&\n471\t      needs.test-compilation.result == 'success' &&\n472\t      (needs.lint.result == 'success' || needs.lint.result == 'skipped') &&\n473\t      (needs.check-file-line-limits.result == 'success' || needs.check-file-line-limits.result == 'skipped') &&\n474\t      (needs.detect-changes.outputs.any-code-changed == 'true' || needs.detect-changes.outputs.workflow-changed == 'true')\n475\t\n476\t    steps:\n477\t      - uses: actions/checkout@v5\n478\t\n479\t      - name: Use Node.js 20.x\n480\t        uses: actions/setup-node@v5\n481\t        with:\n482\t          node-version: 24.x\n483\t\n484\t      - name: Install dependencies\n485\t        run: npm install\n486\t\n487\t      - name: Test solve.mjs execution\n488\t        run: |\n489\t          echo \"Testing solve.mjs basic execution...\"\n490\t          timeout 10s ./src/solve.mjs --help || echo \"Help command completed\"\n491\t          echo \"solve.mjs executes without critical errors\"\n492\t          timeout 10s ./src/solve.mjs --version || true\n493\t\n494\t      - name: Verify log files contain version and command (Issue #517)\n495\t        run: bash scripts/verify-log-file-contents.sh\n496\t\n497\t      - name: Test hive.mjs execution\n498\t        run: |\n499\t          echo \"Testing hive.mjs basic execution...\"\n500\t          timeout 10s ./src/hive.mjs --help || echo \"Help command completed\"\n501\t          echo \"hive.mjs executes without critical errors\"\n502\t          timeout 10s ./src/hive.mjs --version || true\n503\t\n504\t      - name: Test telegram-bot.mjs execution\n505\t        run: |\n506\t          echo \"Testing telegram-bot.mjs basic execution...\"\n507\t          timeout 10s ./src/telegram-bot.mjs --help || echo \"Help command completed\"\n508\t          echo \"telegram-bot.mjs executes without critical errors\"\n509\t\n510\t          echo \"\"\n511\t          echo \"Testing telegram-bot.mjs --dry-run with issue #487 command...\"\n512\t          timeout 10s ./src/telegram-bot.mjs \\\n513\t            --token \"test_token_123\" \\\n514\t            --allowed-chats \"(-1002975819706 -1002861722681)\" \\\n515\t            --no-hive \\\n516\t            --solve-overrides $'( \\n  --auto-continue\\n  --attach-logs\\n  --verbose\\n  --no-tool-check\\n)' \\\n517\t            --dry-run\n518\t          echo \"Issue #487 command passes with --dry-run\"\n519\t\n520\t      - name: Test memory-check.mjs execution\n521\t        run: |\n522\t          ./src/memory-check.mjs --help\n523\t          ./src/memory-check.mjs --min-memory 10 --min-disk-space 100 --json\n524\t\n525\t      - name: Test global command installation\n526\t        run: bash scripts/test-global-commands.sh\n527\t\n528\t      - name: Test hive dry-run with solve integration\n529\t        run: |\n530\t          echo \"Testing hive dry-run mode with solve command integration...\"\n531\t          timeout 30s ./src/hive.mjs https://github.com/test/repo --dry-run --skip-claude-check --once --max-issues 1 2>&1 | tee hive_dry_run.log || true\n532\t\n533\t          if grep -q \"solve.*--dry-run.*--skip-claude-check\" hive_dry_run.log; then\n534\t            echo \"hive correctly passes --dry-run and --skip-claude-check flags to solve command\"\n535\t          else\n536\t            echo \"Could not verify flag propagation in dry-run mode (may be due to no issues found)\"\n537\t          fi\n538\t\n539\t          echo \"\"\n540\t          echo \"Testing solve.mjs with --dry-run and --skip-claude-check flags...\"\n541\t          timeout 10s ./src/solve.mjs https://github.com/test/repo/issues/1 --dry-run --skip-claude-check 2>&1 | head -20 || true\n542\t          echo \"solve.mjs accepts --dry-run and --skip-claude-check flags\"\n543\t\n544\t      - name: Test --auto-fork option\n545\t        run: bash scripts/test-auto-fork-option.sh\n546\t\n547\t  # === MEMORY CHECKS - LINUX ===\n548\t  memory-check-linux:\n549\t    runs-on: ubuntu-latest\n550\t    needs: [detect-changes, changeset-check, test-compilation, lint, check-file-line-limits]\n551\t    if: |\n552\t      always() &&\n553\t      !cancelled() &&\n554\t      !contains(needs.*.result, 'failure') &&\n555\t      (github.event_name == 'push' || needs.changeset-check.result == 'success' || needs.changeset-check.result == 'skipped') &&\n556\t      needs.test-compilation.result == 'success' &&\n557\t      (needs.lint.result == 'success' || needs.lint.result == 'skipped') &&\n558\t      (needs.check-file-line-limits.result == 'success' || needs.check-file-line-limits.result == 'skipped') &&\n559\t      (needs.detect-changes.outputs.any-code-changed == 'true' || needs.detect-changes.outputs.workflow-changed == 'true')\n560\t\n561\t    steps:\n562\t      - uses: actions/checkout@v5\n563\t\n564\t      - name: Use Node.js 20.x\n565\t        uses: actions/setup-node@v5\n566\t        with:\n567\t          node-version: 24.x\n568\t\n569\t      - name: System info\n570\t        run: |\n571\t          echo \"=== System Information ===\"\n572\t          uname -a\n573\t          echo \"\"\n574\t          echo \"=== Memory Information ===\"\n575\t          free -h\n576\t          echo \"\"\n577\t          echo \"=== Disk Information ===\"\n578\t          df -h\n579\t          echo \"\"\n580\t          echo \"=== CPU Information ===\"\n581\t          lscpu | head -20\n582\t\n583\t      - name: Run memory-check tests\n584\t        run: |\n585\t          chmod +x tests/test-memory-check.mjs\n586\t          node tests/test-memory-check.mjs\n587\t\n588\t      - name: Test memory-check with various thresholds\n589\t        run: |\n590\t          echo \"Testing with low thresholds (should pass)...\"\n591\t          ./src/memory-check.mjs --min-memory 10 --min-disk-space 100 --json\n592\t\n593\t          echo \"\"\n594\t          echo \"Testing verbose output...\"\n595\t          ./src/memory-check.mjs --min-memory 10 --min-disk-space 100\n596\t\n597\t          echo \"\"\n598\t          echo \"Testing quiet mode...\"\n599\t          ./src/memory-check.mjs --min-memory 10 --min-disk-space 100 --quiet --json\n600\t\n601\t      - name: Test memory-check failure conditions\n602\t        run: |\n603\t          echo \"Testing with impossible memory requirement (should fail)...\"\n604\t          if ./src/memory-check.mjs --min-memory 999999 --exit-on-failure --quiet --json; then\n605\t            echo \"ERROR: Should have failed with impossible memory requirement\"\n606\t            exit 1\n607\t          else\n608\t            echo \"Correctly failed with impossible memory requirement\"\n609\t          fi\n610\t\n611\t          echo \"\"\n612\t          echo \"Testing with impossible disk requirement (should fail)...\"\n613\t          if ./src/memory-check.mjs --min-disk-space 999999999 --exit-on-failure --quiet --json; then\n614\t            echo \"ERROR: Should have failed with impossible disk requirement\"\n615\t            exit 1\n616\t          else\n617\t            echo \"Correctly failed with impossible disk requirement\"\n618\t          fi\n619\t\n620\t  # === DOCUMENTATION VALIDATION (FAST) ===\n621\t  validate-docs:\n622\t    runs-on: ubuntu-latest\n623\t    needs: [detect-changes, changeset-check]\n624\t    # Run if: push event, OR changeset-check succeeded, OR changeset-check was skipped (docs-only PR)\n625\t    if: always() && (github.event_name == 'push' || needs.changeset-check.result == 'success' || needs.changeset-check.result == 'skipped') && needs.detect-changes.outputs.docs-changed == 'true'\n626\t\n627\t    steps:\n628\t      - uses: actions/checkout@v5\n629\t\n630\t      - name: Use Node.js 20.x\n631\t        uses: actions/setup-node@v5\n632\t        with:\n633\t          node-version: 24.x\n634\t\n635\t      - name: Validate documentation files\n636\t        run: |\n637\t          echo \"Running documentation validation tests...\"\n638\t          chmod +x tests/docs-validation.mjs\n639\t          node tests/docs-validation.mjs\n640\t\n641\t  # === DOCKER PR CHECK ===\n642\t  docker-pr-check:\n643\t    runs-on: ubuntu-latest\n644\t    needs: [detect-changes, changeset-check, test-compilation, lint, check-file-line-limits]\n645\t    # Run if: changeset-check succeeded OR was skipped (docs-only PR), and required checks passed\n646\t    if: |\n647\t      always() &&\n648\t      !cancelled() &&\n649\t      !contains(needs.*.result, 'failure') &&\n650\t      github.event_name == 'pull_request' &&\n651\t      (needs.changeset-check.result == 'success' || needs.changeset-check.result == 'skipped') &&\n652\t      (needs.test-compilation.result == 'success' || needs.test-compilation.result == 'skipped') &&\n653\t      (needs.lint.result == 'success' || needs.lint.result == 'skipped') &&\n654\t      (needs.check-file-line-limits.result == 'success' || needs.check-file-line-limits.result == 'skipped') &&\n655\t      (needs.detect-changes.outputs.docker-changed == 'true' || needs.detect-changes.outputs.workflow-changed == 'true')\n656\t\n657\t    env:\n658\t      REGISTRY: docker.io\n659\t      IMAGE_NAME: konard/hive-mind\n660\t\n661\t    steps:\n662\t      - name: Checkout repository\n663\t        uses: actions/checkout@v5\n664\t\n665\t      - name: Free up disk space\n666\t        run: node scripts/free-disk-space.mjs\n667\t\n668\t      - name: Show sandbox base image version\n669\t        run: |\n670\t          SANDBOX_VERSION=$(grep '^FROM konard/sandbox:' Dockerfile | sed 's/FROM konard\\/sandbox://')\n671\t          echo \"Sandbox base image version: konard/sandbox:${SANDBOX_VERSION}\"\n672\t          echo \"This pinned version ensures stable, reproducible builds.\"\n673\t\n674\t      - name: Build Docker image\n675\t        run: |\n676\t          SANDBOX_VERSION=$(grep '^FROM konard/sandbox:' Dockerfile | sed 's/FROM konard\\/sandbox://')\n677\t          echo \"Building Docker image from konard/sandbox:${SANDBOX_VERSION} base...\"\n678\t          echo \"Note: General-purpose tools are inherited from pinned konard/sandbox:${SANDBOX_VERSION}\"\n679\t          echo \"This image adds AI-specific tools on top of the sandbox base.\"\n680\t          echo \"\"\n681\t\n682\t          # Note: Multi-platform builds (amd64+arm64) are tested in docker-publish job during release\n683\t          # PR checks only validate amd64 using standard docker build (not buildx) to ensure\n684\t          # the image is properly loaded into Docker daemon for container verification\n685\t          docker build --progress=plain -t ${{ env.IMAGE_NAME }}:test . 2>&1 | tee build-output.log\n686\t\n687\t          echo \"\"\n688\t          echo \"Docker image built successfully\"\n689\t          docker images | grep -E \"${{ env.IMAGE_NAME }}|REPOSITORY\"\n690\t\n691\t      - name: Verify build completed without errors\n692\t        run: |\n693\t          echo \"Checking build logs for critical errors...\"\n694\t\n695\t          # Check for unbound variable errors (indicates shell script issues with set -u compatibility)\n696\t          if grep -E 'unbound variable' build-output.log; then\n697\t            echo \"ERROR: Unbound variable error detected in Docker build\"\n698\t            echo \"This typically indicates a shell script issue with set -u compatibility\"\n699\t            grep -E 'unbound variable' build-output.log || true\n700\t            exit 1\n701\t          fi\n702\t\n703\t          echo \"Build log check completed\"\n704\t\n705\t      - name: Verify system & development tools in running container\n706\t        run: |\n707\t          SANDBOX_VERSION=$(grep '^FROM konard/sandbox:' Dockerfile | sed 's/FROM konard\\/sandbox://')\n708\t          echo \"=== Verifying hive-mind Docker image ===\"\n709\t          echo \"Base: konard/sandbox:${SANDBOX_VERSION} (pinned) + AI-specific tools\"\n710\t          echo \"\"\n711\t\n712\t          # Run verification script inside container (mounts script as read-only volume)\n713\t          # Verifies: sandbox user setup (/workspace access), all dev tools, AI-specific tools\n714\t          # See scripts/verify-docker-image.sh for the full list of checks\n715\t          docker run --rm \\\n716\t            -v \"$(pwd)/scripts/verify-docker-image.sh:/verify-docker-image.sh:ro\" \\\n717\t            ${{ env.IMAGE_NAME }}:test \\\n718\t            bash /verify-docker-image.sh\n719\t\n720\t          echo \"\"\n721\t          echo \"All system & development tools verification checks passed!\"\n722\t\n723\t  # === HELM PR CHECK (FAST) ===\n724\t  helm-pr-check:\n725\t    runs-on: ubuntu-latest\n726\t    needs: [detect-changes, changeset-check]\n727\t    # Only runs when helm chart, package.json, or workflow files changed (Issue #1436)\n728\t    if: always() && github.event_name == 'pull_request' && (needs.changeset-check.result == 'success' || needs.changeset-check.result == 'skipped') && (needs.detect-changes.outputs.helm-changed == 'true' || needs.detect-changes.outputs.package-changed == 'true' || needs.detect-changes.outputs.workflow-changed == 'true')\n729\t\n730\t    steps:\n731\t      - name: Checkout repository\n732\t        uses: actions/checkout@v5\n733\t        with:\n734\t          fetch-depth: 0\n735\t\n736\t      - name: Install Helm\n737\t        uses: azure/setup-helm@v4\n738\t        with:\n739\t          version: v3.14.0\n740\t\n741\t      - name: Get package version\n742\t        id: package-version\n743\t        run: |\n744\t          VERSION=$(node -p \"require('./package.json').version\")\n745\t          echo \"version=$VERSION\" >> $GITHUB_OUTPUT\n746\t          echo \"Package version: $VERSION\"\n747\t\n748\t      - name: Lint Helm chart\n749\t        run: |\n750\t          echo \"Linting Helm chart...\"\n751\t          helm lint helm/hive-mind\n752\t          echo \"Helm chart validation passed\"\n753\t\n754\t      - name: Verify Chart.yaml structure\n755\t        run: bash scripts/verify-chart-yaml.sh\n756\t\n757\t  # === RELEASE - only runs on main after tests pass ===\n758\t  release:\n759\t    name: Release\n760\t    needs: [detect-changes, lint, test-suites, test-execution, memory-check-linux]\n761\t    if: always() && github.ref == 'refs/heads/main' && github.event_name == 'push' && !contains(needs.*.result, 'failure') && (needs.lint.result == 'success' || needs.lint.result == 'skipped') && (needs.test-suites.result == 'success' || needs.test-suites.result == 'skipped') && (needs.test-execution.result == 'success' || needs.test-execution.result == 'skipped') && (needs.memory-check-linux.result == 'success' || needs.memory-check-linux.result == 'skipped') && (needs.detect-changes.outputs.any-code-changed == 'true' || needs.detect-changes.outputs.docker-changed == 'true' || needs.detect-changes.outputs.workflow-changed == 'true')\n762\t    runs-on: ubuntu-latest\n763\t    outputs:\n764\t      published: ${{ steps.publish.outputs.published }}\n765\t      published_version: ${{ steps.publish.outputs.published_version }}\n766\t    # Permissions required for npm OIDC trusted publishing\n767\t    permissions:\n768\t      contents: write\n769\t      pull-requests: write\n770\t      id-token: write\n771\t    steps:\n772\t      - uses: actions/checkout@v5\n773\t        with:\n774\t          fetch-depth: 0\n775\t\n776\t      - name: Setup Node.js\n777\t        uses: actions/setup-node@v5\n778\t        with:\n779\t          node-version: '24.x'\n780\t          registry-url: 'https://registry.npmjs.org'\n781\t\n782\t      - name: Install dependencies\n783\t        run: npm install\n784\t\n785\t      - name: Update npm for OIDC trusted publishing\n786\t        run: node scripts/setup-npm.mjs\n787\t\n788\t      - name: Check for changesets\n789\t        id: check_changesets\n790\t        run: |\n791\t          # Count changeset files (excluding README.md and config.json)\n792\t          CHANGESET_COUNT=$(find .changeset -name \"*.md\" ! -name \"README.md\" | wc -l)\n793\t          echo \"Found $CHANGESET_COUNT changeset file(s)\"\n794\t          echo \"has_changesets=$([[ $CHANGESET_COUNT -gt 0 ]] && echo 'true' || echo 'false')\" >> $GITHUB_OUTPUT\n795\t          echo \"changeset_count=$CHANGESET_COUNT\" >> $GITHUB_OUTPUT\n796\t\n797\t      - name: Harmonize changeset bump types\n798\t        if: steps.check_changesets.outputs.has_changesets == 'true' && steps.check_changesets.outputs.changeset_count > 1\n799\t        run: |\n800\t          echo \"Multiple changesets detected, harmonizing bump types...\"\n801\t          node scripts/merge-changesets.mjs\n802\t\n803\t      - name: Version packages and commit to main\n804\t        if: steps.check_changesets.outputs.has_changesets == 'true'\n805\t        id: version\n806\t        run: node scripts/version-and-commit.mjs --mode changeset\n807\t\n808\t      - name: Publish to npm\n809\t        # Run if version was committed OR if a previous attempt already committed (for re-runs)\n810\t        if: steps.version.outputs.version_committed == 'true' || steps.version.outputs.already_released == 'true'\n811\t        id: publish_npm\n812\t        run: node scripts/publish-to-npm.mjs --should-pull\n813\t\n814\t      - name: Set publish outputs\n815\t        # This step explicitly sets the outputs using shell (more reliable than Node.js appendFileSync)\n816\t        # It runs after npm publish and reads the script's outputs to pass them along\n817\t        id: publish\n818\t        if: steps.publish_npm.outputs.published == 'true' || steps.publish_npm.outputs.already_published == 'true'\n819\t        run: |\n820\t          echo \"published=true\" >> $GITHUB_OUTPUT\n821\t          echo \"published_version=${{ steps.publish_npm.outputs.published_version }}\" >> $GITHUB_OUTPUT\n822\t          echo \"Docker publish will be triggered with version: ${{ steps.publish_npm.outputs.published_version }}\"\n823\t\n824\t      - name: Create GitHub Release\n825\t        if: steps.publish.outputs.published == 'true'\n826\t        env:\n827\t          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}\n828\t        run: node scripts/create-github-release.mjs --release-version \"${{ steps.publish.outputs.published_version }}\" --repository \"${{ github.repository }}\"\n829\t\n830\t      - name: Format GitHub release notes\n831\t        if: steps.publish.outputs.published == 'true'\n832\t        env:\n833\t          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}\n834\t        run: node scripts/format-github-release.mjs --release-version \"${{ steps.publish.outputs.published_version }}\" --repository \"${{ github.repository }}\" --commit-sha \"${{ github.sha }}\"\n835\t\n836\t      - name: Post-publish - Upload Source Maps to Sentry\n837\t        if: steps.publish.outputs.published == 'true'\n838\t        env:\n839\t          SENTRY_AUTH_TOKEN: ${{ secrets.SENTRY_AUTH_TOKEN }}\n840\t        run: |\n841\t          echo \"Uploading source maps to Sentry for published packages...\"\n842\t          chmod +x scripts/upload-sourcemaps.mjs\n843\t          node scripts/upload-sourcemaps.mjs\n844\t\n845\t  # === DOCKER PUBLISH ===\n846\t  # Multi-platform builds using native runners (no QEMU). See: docs/case-studies/issue-982/\n847\t  # ARM64 may be slow: actions/runner-images#11790, actions/partner-runner-images#101\n848\t  # See also: docs/case-studies/issue-998/README.md\n849\t  docker-publish:\n850\t    name: Docker Publish (${{ matrix.platform }})\n851\t    needs: [release]\n852\t    # !cancelled() allows concurrency cancellation. See: docs/case-studies/issue-1278/\n853\t    if: \"!cancelled() && needs.release.result == 'success' && needs.release.outputs.published == 'true'\"\n854\t    # Timeout 60 min: arm64 can take 26+ min. See: docs/case-studies/issue-1415/README.md\n855\t    timeout-minutes: 60\n856\t    strategy:\n857\t      fail-fast: false\n858\t      matrix:\n859\t        include:\n860\t          - platform: linux/amd64\n861\t            runner: ubuntu-latest\n862\t            cache_suffix: amd64\n863\t          - platform: linux/arm64\n864\t            runner: ubuntu-24.04-arm # Native ARM64, no QEMU. See: docs/case-studies/issue-998/\n865\t            cache_suffix: arm64\n866\t    runs-on: ${{ matrix.runner }}\n867\t    permissions:\n868\t      contents: read\n869\t      packages: write\n870\t\n871\t    env:\n872\t      REGISTRY: docker.io\n873\t      IMAGE_NAME: konard/hive-mind\n874\t\n875\t    outputs:\n876\t      digest-amd64: ${{ steps.build.outputs.digest }}\n877\t      digest-arm64: ${{ steps.build.outputs.digest }}\n878\t\n879\t    steps:\n880\t      - name: Checkout repository\n881\t        uses: actions/checkout@v5\n882\t\n883\t      - name: Free up disk space\n884\t        run: node scripts/free-disk-space.mjs\n885\t\n886\t      - name: Wait for NPM package availability\n887\t        # Only run on first matrix job to avoid duplicate waits\n888\t        if: matrix.platform == 'linux/amd64'\n889\t        run: node scripts/wait-for-npm.mjs --release-version \"${{ needs.release.outputs.published_version }}\"\n890\t\n891\t      - name: Set up Docker Buildx\n892\t        uses: docker/setup-buildx-action@v4\n893\t\n894\t      - name: Log in to Docker Hub\n895\t        uses: docker/login-action@v4\n896\t        with:\n897\t          username: ${{ secrets.DOCKERHUB_USERNAME }}\n898\t          password: ${{ secrets.DOCKERHUB_TOKEN }}\n899\t\n900\t      - name: Extract metadata (tags, labels) for Docker\n901\t        id: meta\n902\t        uses: docker/metadata-action@v6\n903\t        with:\n904\t          images: ${{ env.IMAGE_NAME }}\n905\t          # Set version label to actual release version, not Git ref \"main\" (issue #1419)\n906\t          labels: |\n907\t            org.opencontainers.image.version=${{ needs.release.outputs.published_version }}\n908\t\n909\t      - name: Build and push by digest\n910\t        id: build\n911\t        uses: docker/build-push-action@v7\n912\t        with:\n913\t          context: .\n914\t          file: ./Dockerfile\n915\t          platforms: ${{ matrix.platform }}\n916\t          labels: ${{ steps.meta.outputs.labels }}\n917\t          # Registry cache for faster parallel export. See: docs/case-studies/issue-1415/README.md\n918\t          cache-from: type=registry,ref=${{ env.IMAGE_NAME }}:buildcache-${{ matrix.cache_suffix }}\n919\t          cache-to: type=registry,ref=${{ env.IMAGE_NAME }}:buildcache-${{ matrix.cache_suffix }},mode=max,image-manifest=true,ignore-error=true\n920\t          outputs: type=image,name=${{ env.IMAGE_NAME }},push-by-digest=true,name-canonical=true,push=true\n921\t\n922\t      - name: Export digest\n923\t        run: |\n924\t          mkdir -p /tmp/digests\n925\t          digest=\"${{ steps.build.outputs.digest }}\"\n926\t          touch \"/tmp/digests/${digest#sha256:}\"\n927\t          echo \"Digest for ${{ matrix.platform }}: $digest\"\n928\t\n929\t      - name: Upload digest\n930\t        uses: actions/upload-artifact@v7\n931\t        with:\n932\t          name: digests-${{ matrix.platform == 'linux/amd64' && 'amd64' || 'arm64' }}\n933\t          path: /tmp/digests/*\n934\t          if-no-files-found: error\n935\t          retention-days: 1\n936\t\n937\t  # Merge multi-platform manifests after all platform builds complete\n938\t  docker-publish-merge:\n939\t    name: Docker Publish (Merge)\n940\t    needs: [release, docker-publish]\n941\t    # Use !cancelled() instead of always() to allow concurrency cancellation.\n942\t    # See: docs/case-studies/issue-1278/README.md for why this change was necessary.\n943\t    if: \"!cancelled() && needs.release.result == 'success' && needs.docker-publish.result == 'success' && needs.release.outputs.published == 'true'\"\n944\t    runs-on: ubuntu-latest\n945\t    permissions:\n946\t      contents: read\n947\t      packages: write\n948\t\n949\t    env:\n950\t      IMAGE_NAME: konard/hive-mind\n951\t\n952\t    steps:\n953\t      - name: Download digests\n954\t        uses: actions/download-artifact@v8\n955\t        with:\n956\t          path: /tmp/digests\n957\t          pattern: digests-*\n958\t          merge-multiple: true\n959\t\n960\t      - name: Set up Docker Buildx\n961\t        uses: docker/setup-buildx-action@v4\n962\t\n963\t      - name: Log in to Docker Hub\n964\t        uses: docker/login-action@v4\n965\t        with:\n966\t          username: ${{ secrets.DOCKERHUB_USERNAME }}\n967\t          password: ${{ secrets.DOCKERHUB_TOKEN }}\n968\t\n969\t      - name: Extract metadata (tags, labels) for Docker\n970\t        id: meta\n971\t        uses: docker/metadata-action@v6\n972\t        with:\n973\t          images: ${{ env.IMAGE_NAME }}\n974\t          tags: |\n975\t            type=raw,value=${{ needs.release.outputs.published_version }}\n976\t            type=raw,value=latest\n977\t          # Set version label to actual release version, not Git ref \"main\" (issue #1419)\n978\t          labels: |\n979\t            org.opencontainers.image.version=${{ needs.release.outputs.published_version }}\n980\t\n981\t      - name: Create manifest list and push\n982\t        working-directory: /tmp/digests\n983\t        run: |\n984\t          echo \"Creating multi-platform manifest...\"\n985\t          echo \"Tags: ${{ steps.meta.outputs.tags }}\"\n986\t          echo \"Digests:\"\n987\t          ls -la\n988\t          docker buildx imagetools create $(jq -cr '.tags | map(\"-t \" + .) | join(\" \")' <<< \"$DOCKER_METADATA_OUTPUT_JSON\") \\\n989\t            $(printf '${{ env.IMAGE_NAME }}@sha256:%s ' *)\n990\t\n991\t      - name: Inspect image\n992\t        run: |\n993\t          echo \"Inspecting multi-platform image...\"\n994\t          docker buildx imagetools inspect ${{ env.IMAGE_NAME }}:${{ needs.release.outputs.published_version }}\n995\t\n996\t      - name: Verify published image\n997\t        run: |\n998\t          echo \"Docker image published successfully\"\n999\t          echo \"Image: ${{ env.IMAGE_NAME }}\"\n1000\t          echo \"Tags: ${{ steps.meta.outputs.tags }}\"\n1001\t\n1002\t  # === HELM CHART RELEASE ===\n1003\t  helm-release:\n1004\t    name: Helm Release\n1005\t    needs: [release, docker-publish-merge]\n1006\t    # Use !cancelled() instead of always() to allow concurrency cancellation.\n1007\t    # See: docs/case-studies/issue-1278/README.md for why this change was necessary.\n1008\t    if: \"!cancelled() && needs.release.result == 'success' && needs.docker-publish-merge.result == 'success' && needs.release.outputs.published == 'true'\"\n1009\t    runs-on: ubuntu-latest\n1010\t    permissions:\n1011\t      contents: write\n1012\t      packages: write\n1013\t      pages: write\n1014\t      id-token: write\n1015\t\n1016\t    steps:\n1017\t      - name: Checkout repository\n1018\t        uses: actions/checkout@v5\n1019\t        with:\n1020\t          fetch-depth: 0\n1021\t\n1022\t      - name: Install Helm\n1023\t        uses: azure/setup-helm@v4\n1024\t        with:\n1025\t          version: v3.14.0\n1026\t\n1027\t      - name: Release Helm chart\n1028\t        run: node scripts/helm-release.mjs --release-version \"${{ needs.release.outputs.published_version }}\"\n1029\t\n1030\t      - name: Upload chart to release\n1031\t        uses: softprops/action-gh-release@v2\n1032\t        with:\n1033\t          tag_name: v${{ needs.release.outputs.published_version }}\n1034\t          files: .helm-packages/*.tgz\n1035\t\n1036\t  # === MANUAL INSTANT RELEASE ===\n1037\t  instant-release:\n1038\t    name: Instant Release\n1039\t    if: github.event_name == 'workflow_dispatch' && github.event.inputs.release_mode == 'instant'\n1040\t    runs-on: ubuntu-latest\n1041\t    outputs:\n1042\t      published: ${{ steps.publish.outputs.published }}\n1043\t      published_version: ${{ steps.publish.outputs.published_version }}\n1044\t    permissions:\n1045\t      contents: write\n1046\t      pull-requests: write\n1047\t      id-token: write\n1048\t    steps:\n1049\t      - uses: actions/checkout@v5\n1050\t        with:\n1051\t          fetch-depth: 0\n1052\t\n1053\t      - name: Setup Node.js\n1054\t        uses: actions/setup-node@v5\n1055\t        with:\n1056\t          node-version: '24.x'\n1057\t          registry-url: 'https://registry.npmjs.org'\n1058\t\n1059\t      - name: Install dependencies\n1060\t        run: npm install\n1061\t\n1062\t      - name: Update npm for OIDC trusted publishing\n1063\t        run: node scripts/setup-npm.mjs\n1064\t\n1065\t      - name: Version packages and commit to main\n1066\t        id: version\n1067\t        run: node scripts/version-and-commit.mjs --mode instant --bump-type \"${{ github.event.inputs.bump_type }}\" --description \"${{ github.event.inputs.description }}\"\n1068\t\n1069\t      - name: Publish to npm\n1070\t        if: steps.version.outputs.version_committed == 'true' || steps.version.outputs.already_released == 'true'\n1071\t        id: publish_npm\n1072\t        run: node scripts/publish-to-npm.mjs\n1073\t\n1074\t      - name: Set publish outputs\n1075\t        # This step explicitly sets the outputs using shell (more reliable than Node.js appendFileSync)\n1076\t        id: publish\n1077\t        if: steps.publish_npm.outputs.published == 'true' || steps.publish_npm.outputs.already_published == 'true'\n1078\t        run: |\n1079\t          echo \"published=true\" >> $GITHUB_OUTPUT\n1080\t          echo \"published_version=${{ steps.publish_npm.outputs.published_version }}\" >> $GITHUB_OUTPUT\n1081\t          echo \"Docker publish will be triggered with version: ${{ steps.publish_npm.outputs.published_version }}\"\n1082\t\n1083\t      - name: Create GitHub Release\n1084\t        if: steps.publish.outputs.published == 'true'\n1085\t        env:\n1086\t          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}\n1087\t        run: node scripts/create-github-release.mjs --release-version \"${{ steps.publish.outputs.published_version }}\" --repository \"${{ github.repository }}\"\n1088\t\n1089\t      - name: Format GitHub release notes\n1090\t        if: steps.publish.outputs.published == 'true'\n1091\t        env:\n1092\t          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}\n1093\t        run: node scripts/format-github-release.mjs --release-version \"${{ steps.publish.outputs.published_version }}\" --repository \"${{ github.repository }}\" --commit-sha \"${{ github.sha }}\"\n1094\t\n1095\t  # === DOCKER PUBLISH FOR INSTANT RELEASE ===\n1096\t  # Same multi-platform setup as docker-publish above (native runners, no QEMU).\n1097\t  # See: docs/case-studies/issue-982/README.md and docs/case-studies/issue-998/README.md\n1098\t  docker-publish-instant:\n1099\t    name: Docker Publish Instant (${{ matrix.platform }})\n1100\t    needs: [instant-release]\n1101\t    # Use !cancelled() instead of always() to allow concurrency cancellation.\n1102\t    # See: docs/case-studies/issue-1278/README.md for why this change was necessary.\n1103\t    if: \"!cancelled() && needs.instant-release.result == 'success' && needs.instant-release.outputs.published == 'true'\"\n1104\t    # Timeout 60 min: arm64 can take 26+ min. See: docs/case-studies/issue-1415/README.md\n1105\t    timeout-minutes: 60\n1106\t    strategy:\n1107\t      fail-fast: false\n1108\t      matrix:\n1109\t        include:\n1110\t          - platform: linux/amd64\n1111\t            runner: ubuntu-latest\n1112\t            cache_suffix: amd64\n1113\t          - platform: linux/arm64\n1114\t            runner: ubuntu-24.04-arm # Native ARM64, no QEMU. See: docs/case-studies/issue-998/\n1115\t            cache_suffix: arm64\n1116\t    runs-on: ${{ matrix.runner }}\n1117\t    permissions:\n1118\t      contents: read\n1119\t      packages: write\n1120\t\n1121\t    env:\n1122\t      REGISTRY: docker.io\n1123\t      IMAGE_NAME: konard/hive-mind\n1124\t\n1125\t    steps:\n1126\t      - name: Checkout repository\n1127\t        uses: actions/checkout@v5\n1128\t\n1129\t      - name: Free up disk space\n1130\t        run: node scripts/free-disk-space.mjs\n1131\t\n1132\t      - name: Wait for NPM package availability\n1133\t        # Only run on first matrix job to avoid duplicate waits\n1134\t        if: matrix.platform == 'linux/amd64'\n1135\t        run: node scripts/wait-for-npm.mjs --release-version \"${{ needs.instant-release.outputs.published_version }}\"\n1136\t\n1137\t      - name: Set up Docker Buildx\n1138\t        uses: docker/setup-buildx-action@v4\n1139\t\n1140\t      - name: Log in to Docker Hub\n1141\t        uses: docker/login-action@v4\n1142\t        with:\n1143\t          username: ${{ secrets.DOCKERHUB_USERNAME }}\n1144\t          password: ${{ secrets.DOCKERHUB_TOKEN }}\n1145\t\n1146\t      - name: Extract metadata (tags, labels) for Docker\n1147\t        id: meta\n1148\t        uses: docker/metadata-action@v6\n1149\t        with:\n1150\t          images: ${{ env.IMAGE_NAME }}\n1151\t          # Set version label to actual release version, not Git ref \"main\" (issue #1419)\n1152\t          labels: |\n1153\t            org.opencontainers.image.version=${{ needs.instant-release.outputs.published_version }}\n1154\t\n1155\t      - name: Build and push by digest\n1156\t        id: build\n1157\t        uses: docker/build-push-action@v7\n1158\t        with:\n1159\t          context: .\n1160\t          file: ./Dockerfile\n1161\t          platforms: ${{ matrix.platform }}\n1162\t          labels: ${{ steps.meta.outputs.labels }}\n1163\t          # Registry cache for faster parallel export. See: docs/case-studies/issue-1415/README.md\n1164\t          cache-from: type=registry,ref=${{ env.IMAGE_NAME }}:buildcache-${{ matrix.cache_suffix }}\n1165\t          cache-to: type=registry,ref=${{ env.IMAGE_NAME }}:buildcache-${{ matrix.cache_suffix }},mode=max,image-manifest=true,ignore-error=true\n1166\t          outputs: type=image,name=${{ env.IMAGE_NAME }},push-by-digest=true,name-canonical=true,push=true\n1167\t\n1168\t      - name: Export digest\n1169\t        run: |\n1170\t          mkdir -p /tmp/digests\n1171\t          digest=\"${{ steps.build.outputs.digest }}\"\n1172\t          touch \"/tmp/digests/${digest#sha256:}\"\n1173\t          echo \"Digest for ${{ matrix.platform }}: $digest\"\n1174\t\n1175\t      - name: Upload digest\n1176\t        uses: actions/upload-artifact@v7\n1177\t        with:\n1178\t          name: digests-instant-${{ matrix.platform == 'linux/amd64' && 'amd64' || 'arm64' }}\n1179\t          path: /tmp/digests/*\n1180\t          if-no-files-found: error\n1181\t          retention-days: 1\n1182\t\n1183\t  # Merge multi-platform manifests after all platform builds complete (instant release)\n1184\t  docker-publish-instant-merge:\n1185\t    name: Docker Publish Instant (Merge)\n1186\t    needs: [instant-release, docker-publish-instant]\n1187\t    # Use !cancelled() instead of always() to allow concurrency cancellation.\n1188\t    # See: docs/case-studies/issue-1278/README.md for why this change was necessary.\n1189\t    if: \"!cancelled() && needs.instant-release.result == 'success' && needs.docker-publish-instant.result == 'success' && needs.instant-release.outputs.published == 'true'\"\n1190\t    runs-on: ubuntu-latest\n1191\t    permissions:\n1192\t      contents: read\n1193\t      packages: write\n1194\t\n1195\t    env:\n1196\t      IMAGE_NAME: konard/hive-mind\n1197\t\n1198\t    steps:\n1199\t      - name: Download digests\n1200\t        uses: actions/download-artifact@v8\n1201\t        with:\n1202\t          path: /tmp/digests\n1203\t          pattern: digests-instant-*\n1204\t          merge-multiple: true\n1205\t\n1206\t      - name: Set up Docker Buildx\n1207\t        uses: docker/setup-buildx-action@v4\n1208\t\n1209\t      - name: Log in to Docker Hub\n1210\t        uses: docker/login-action@v4\n1211\t        with:\n1212\t          username: ${{ secrets.DOCKERHUB_USERNAME }}\n1213\t          password: ${{ secrets.DOCKERHUB_TOKEN }}\n1214\t\n1215\t      - name: Extract metadata (tags, labels) for Docker\n1216\t        id: meta\n1217\t        uses: docker/metadata-action@v6\n1218\t        with:\n1219\t          images: ${{ env.IMAGE_NAME }}\n1220\t          tags: |\n1221\t            type=raw,value=${{ needs.instant-release.outputs.published_version }}\n1222\t            type=raw,value=latest\n1223\t          # Set version label to actual release version, not Git ref \"main\" (issue #1419)\n1224\t          labels: |\n1225\t            org.opencontainers.image.version=${{ needs.instant-release.outputs.published_version }}\n1226\t\n1227\t      - name: Create manifest list and push\n1228\t        working-directory: /tmp/digests\n1229\t        run: |\n1230\t          echo \"Creating multi-platform manifest...\"\n1231\t          echo \"Tags: ${{ steps.meta.outputs.tags }}\"\n1232\t          echo \"Digests:\"\n1233\t          ls -la\n1234\t          docker buildx imagetools create $(jq -cr '.tags | map(\"-t \" + .) | join(\" \")' <<< \"$DOCKER_METADATA_OUTPUT_JSON\") \\\n1235\t            $(printf '${{ env.IMAGE_NAME }}@sha256:%s ' *)\n1236\t\n1237\t      - name: Inspect image\n1238\t        run: |\n1239\t          echo \"Inspecting multi-platform image...\"\n1240\t          docker buildx imagetools inspect ${{ env.IMAGE_NAME }}:${{ needs.instant-release.outputs.published_version }}\n1241\t\n1242\t      - name: Verify published image\n1243\t        run: |\n1244\t          echo \"Docker image published successfully\"\n1245\t          echo \"Image: ${{ env.IMAGE_NAME }}\"\n1246\t          echo \"Tags: ${{ steps.meta.outputs.tags }}\"\n1247\t\n1248\t  # === HELM CHART RELEASE FOR INSTANT RELEASE ===\n1249\t  helm-release-instant:\n1250\t    name: Helm Release (Instant)\n1251\t    needs: [instant-release, docker-publish-instant-merge]\n1252\t    # Use !cancelled() instead of always() to allow concurrency cancellation.\n1253\t    # See: docs/case-studies/issue-1278/README.md for why this change was necessary.\n1254\t    if: \"!cancelled() && needs.instant-release.result == 'success' && needs.docker-publish-instant-merge.result == 'success' && needs.instant-release.outputs.published == 'true'\"\n1255\t    runs-on: ubuntu-latest\n1256\t    permissions:\n1257\t      contents: write\n1258\t      packages: write\n1259\t      pages: write\n1260\t      id-token: write\n1261\t\n1262\t    steps:\n1263\t      - name: Checkout repository\n1264\t        uses: actions/checkout@v5\n1265\t        with:\n1266\t          fetch-depth: 0\n1267\t\n1268\t      - name: Install Helm\n1269\t        uses: azure/setup-helm@v4\n1270\t        with:\n1271\t          version: v3.14.0\n1272\t\n1273\t      - name: Release Helm chart\n1274\t        run: node scripts/helm-release.mjs --release-version \"${{ needs.instant-release.outputs.published_version }}\"\n1275\t\n1276\t      - name: Upload chart to release\n1277\t        uses: softprops/action-gh-release@v2\n1278\t        with:\n1279\t          tag_name: v${{ needs.instant-release.outputs.published_version }}\n1280\t          files: .helm-packages/*.tgz\n1281\t\n1282\t  # === MANUAL CHANGESET PR ===\n1283\t  changeset-pr:\n1284\t    name: Create Changeset PR\n1285\t    if: github.event_name == 'workflow_dispatch' && github.event.inputs.release_mode == 'changeset-pr'\n1286\t    runs-on: ubuntu-latest\n1287\t    permissions:\n1288\t      contents: write\n1289\t      pull-requests: write\n1290\t    steps:\n1291\t      - uses: actions/checkout@v5\n1292\t        with:\n1293\t          fetch-depth: 0\n1294\t\n1295\t      - name: Setup Node.js\n1296\t        uses: actions/setup-node@v5\n1297\t        with:\n1298\t          node-version: '24.x'\n1299\t\n1300\t      - name: Install dependencies\n1301\t        run: npm install\n1302\t\n1303\t      - name: Create changeset file\n1304\t        run: node scripts/create-manual-changeset.mjs --bump-type \"${{ github.event.inputs.bump_type }}\" --description \"${{ github.event.inputs.description }}\"\n1305\t\n1306\t      - name: Format changeset with Prettier\n1307\t        run: |\n1308\t          npx prettier --write \".changeset/*.md\" || true\n1309\t          echo \"Formatted changeset files\"\n1310\t\n1311\t      - name: Create Pull Request\n1312\t        uses: peter-evans/create-pull-request@v8\n1313\t        with:\n1314\t          token: ${{ secrets.GITHUB_TOKEN }}\n1315\t          commit-message: 'chore: add changeset for manual ${{ github.event.inputs.bump_type }} release'\n1316\t          branch: changeset-manual-release-${{ github.run_id }}\n1317\t          delete-branch: true\n1318\t          title: 'chore: manual ${{ github.event.inputs.bump_type }} release'\n1319\t          body: |\n1320\t            ## Manual Release Request\n1321\t\n1322\t            This PR was created by a manual workflow trigger to prepare a **${{ github.event.inputs.bump_type }}** release.\n1323\t\n1324\t            ### Release Details\n1325\t            - **Type:** ${{ github.event.inputs.bump_type }}\n1326\t            - **Description:** ${{ github.event.inputs.description || 'Manual release' }}\n1327\t            - **Triggered by:** @${{ github.actor }}\n1328\t\n1329\t            ### Next Steps\n1330\t            1. Review the changeset in this PR\n1331\t            2. Merge this PR to main\n1332\t            3. The automated release workflow will create a version PR\n1333\t            4. Merge the version PR to publish to npm and create a GitHub release\n1334\t"
