[2026-04-18T17:28:22.361Z] [INFO]         "content": "1\t#!/usr/bin/env node\n2\t\n3\timport assert from 'node:assert/strict';\n4\timport fs from 'node:fs/promises';\n5\timport os from 'node:os';\n6\timport path from 'node:path';\n7\t\n8\timport { ensureClaudeQuietConfig, REQUIRED_CLAUDE_QUIET_ENV, REQUIRED_CLAUDE_QUIET_SETTINGS, REQUIRED_CLAUDE_QUIET_ATTRIBUTION, REQUIRED_CLAUDE_QUIET_PERMISSIONS } from '../src/claude-quiet-config.lib.mjs';\n9\timport { getClaudeEnv } from '../src/config.lib.mjs';\n10\t\n11\tconst claudeEnv = getClaudeEnv();\n12\tfor (const [name, value] of Object.entries(REQUIRED_CLAUDE_QUIET_ENV)) {\n13\t  assert.equal(claudeEnv[name], value, `getClaudeEnv should force ${name}=${value}`);\n14\t}\n15\t\n16\t// CLAUDE_CODE_DISABLE_GIT_INSTRUCTIONS must NOT be forced — built-in git/PR\n17\t// guidance is useful for our solve runs (per maintainer feedback on PR #1643).\n18\t// The includeGitInstructions setting is what turns it on.\n19\tassert.ok(!Object.prototype.hasOwnProperty.call(REQUIRED_CLAUDE_QUIET_ENV, 'CLAUDE_CODE_DISABLE_GIT_INSTRUCTIONS'), 'REQUIRED_CLAUDE_QUIET_ENV must not disable git instructions — includeGitInstructions keeps them on');\n20\t\n21\tconst claudeLibContent = await fs.readFile(path.join(process.cwd(), 'src/claude.lib.mjs'), 'utf-8');\n22\tassert.ok(claudeLibContent.includes('ensureClaudeQuietConfig({ log })'), 'claude.lib should verify global Claude quiet config before launching Claude');\n23\tassert.ok(claudeLibContent.includes('--dangerously-skip-permissions'), 'claude.lib should still pass --dangerously-skip-permissions as belt-and-suspenders for the bypassPermissions defaultMode');\n24\t\n25\tconst tmp = await fs.mkdtemp(path.join(os.tmpdir(), 'claude-quiet-config-'));\n26\ttry {\n27\t  const settingsPath = path.join(tmp, 'settings.json');\n28\t  await fs.writeFile(\n29\t    settingsPath,\n30\t    JSON.stringify({\n31\t      theme: 'dark',\n32\t      disallowedTools: ['CustomTool'],\n33\t      attribution: {\n34\t        commit: 'custom-commit-trailer',\n35\t      },\n36\t      permissions: {\n37\t        additionalDirectories: ['/tmp/preserved'],\n38\t      },\n39\t      env: {\n40\t        CUSTOM_SETTING: 'preserved',\n41\t        CLAUDE_CODE_DISABLE_AUTO_MEMORY: '0',\n42\t      },\n43\t    })\n44\t  );\n45\t\n46\t  const logs = [];\n47\t  const result = await ensureClaudeQuietConfig({ settingsPath, log: async line => logs.push(line) });\n48\t  const written = JSON.parse(await fs.readFile(settingsPath, 'utf-8'));\n49\t\n50\t  assert.equal(result.changed, true, 'first merge should update missing or incorrect target keys');\n51\t  assert.ok(\n52\t    logs.some(line => line.includes('Claude Code quiet config updated')),\n53\t    'merge should log the effective quiet configuration'\n54\t  );\n55\t  assert.equal(written.theme, 'dark', 'unrelated settings should be preserved');\n56\t  assert.deepEqual(written.disallowedTools, ['CustomTool'], 'existing unrelated arrays should be preserved');\n57\t  assert.deepEqual(written.permissions.additionalDirectories, ['/tmp/preserved'], 'unrelated permissions subkeys should be preserved');\n58\t  assert.equal(written.env.CUSTOM_SETTING, 'preserved', 'unrelated env values should be preserved');\n59\t  for (const [name, value] of Object.entries(REQUIRED_CLAUDE_QUIET_ENV)) {\n60\t    assert.equal(written.env[name], value, `settings env should force ${name}=${value}`);\n61\t  }\n62\t  for (const [name, value] of Object.entries(REQUIRED_CLAUDE_QUIET_SETTINGS)) {\n63\t    assert.deepEqual(written[name], value, `settings should force ${name}=${JSON.stringify(value)}`);\n64\t  }\n65\t  for (const [name, value] of Object.entries(REQUIRED_CLAUDE_QUIET_ATTRIBUTION)) {\n66\t    assert.equal(written.attribution[name], value, `attribution should force ${name}=${JSON.stringify(value)}`);\n67\t  }\n68\t  for (const [name, value] of Object.entries(REQUIRED_CLAUDE_QUIET_PERMISSIONS)) {\n69\t    assert.equal(written.permissions[name], value, `permissions should force ${name}=${JSON.stringify(value)}`);\n70\t  }\n71\t  assert.equal(Object.prototype.hasOwnProperty.call(written.env, 'CLAUDE_CODE_DISABLE_GIT_INSTRUCTIONS'), false, 'settings env should NOT set CLAUDE_CODE_DISABLE_GIT_INSTRUCTIONS — git instructions are kept on via includeGitInstructions');\n72\t\n73\t  const secondResult = await ensureClaudeQuietConfig({ settingsPath, log: async () => {} });\n74\t  assert.equal(secondResult.changed, false, 'second merge should verify without rewriting already-correct config');\n75\t} finally {\n76\t  await fs.rm(tmp, { recursive: true, force: true });\n77\t}\n78\t\n79\t// Dockerfile-level verification. The quiet Claude Code configuration is applied\n80\t// by scripts/configure-claude-quiet-defaults.mjs (which reuses the canonical\n81\t// maps + idempotent merge helpers from the src/ libs tested above), so the\n82\t// Dockerfiles only need to (a) set the required env vars via `ENV` and\n83\t// (b) invoke the shared script. All key/value coverage is enforced by the\n84\t// end-to-end script run below.\n85\tfor (const file of ['Dockerfile', 'coolify/Dockerfile']) {\n86\t  const content = await fs.readFile(path.join(process.cwd(), file), 'utf-8');\n87\t  for (const [name, value] of Object.entries(REQUIRED_CLAUDE_QUIET_ENV)) {\n88\t    assert.ok(content.includes(`${name}=${value}`), `${file} should set ${name}=${value} via ENV`);\n89\t  }\n90\t  assert.ok(!content.includes('CLAUDE_CODE_DISABLE_GIT_INSTRUCTIONS'), `${file} should not set CLAUDE_CODE_DISABLE_GIT_INSTRUCTIONS — built-in git instructions are kept on`);\n91\t  assert.ok(content.includes('scripts/configure-claude-quiet-defaults.mjs'), `${file} should invoke scripts/configure-claude-quiet-defaults.mjs to seed ~/.claude/settings.json`);\n92\t  assert.ok(content.includes('claude-quiet-config.lib.mjs') && content.includes('useless-tools.lib.mjs'), `${file} should COPY the src libs that the configure script reuses`);\n93\t  assert.ok(content.includes('issue #1642'), `${file} should reference issue #1642`);\n94\t}\n95\t\n96\t// End-to-end: running scripts/configure-claude-quiet-defaults.mjs against a\n97\t// fresh settings file must produce exactly the keys/values required for every\n98\t// category (env, settings, attribution, permissions, disallowedTools).\n99\tconst { spawn } = await import('node:child_process');\n100\tconst runScript = async settingsPath =>\n101\t  new Promise((resolve, reject) => {\n102\t    const child = spawn(process.execPath, ['scripts/configure-claude-quiet-defaults.mjs', '--settings-path', settingsPath], { stdio: 'pipe' });\n103\t    let stdout = '';\n104\t    let stderr = '';\n105\t    child.stdout.on('data', chunk => {\n106\t      stdout += chunk.toString();\n107\t    });\n108\t    child.stderr.on('data', chunk => {\n109\t      stderr += chunk.toString();\n110\t    });\n111\t    child.on('error', reject);\n112\t    child.on('close', code => (code === 0 ? resolve({ stdout, stderr }) : reject(new Error(`exit ${code}: ${stderr || stdout}`))));\n113\t  });\n114\t\n115\tconst { USELESS_CLAUDE_BUILTIN_TOOLS, USELESS_MCP_TOOL_NAME_PREFIXES } = await import('../src/useless-tools.lib.mjs');\n116\t\n117\tconst scriptTmp = await fs.mkdtemp(path.join(os.tmpdir(), 'claude-quiet-config-script-'));\n118\ttry {\n119\t  const settingsPath = path.join(scriptTmp, 'settings.json');\n120\t  const { stdout: firstStdout } = await runScript(settingsPath);\n121\t  assert.ok(firstStdout.includes('Configured quiet Claude Code defaults'), 'script should print final summary line');\n122\t  const written = JSON.parse(await fs.readFile(settingsPath, 'utf-8'));\n123\t  for (const [name, value] of Object.entries(REQUIRED_CLAUDE_QUIET_ENV)) {\n124\t    assert.equal(written.env[name], value, `script should configure env.${name}=${value}`);\n125\t  }\n126\t  for (const [name, value] of Object.entries(REQUIRED_CLAUDE_QUIET_SETTINGS)) {\n127\t    assert.deepEqual(written[name], value, `script should configure ${name}=${JSON.stringify(value)}`);\n128\t  }\n129\t  for (const [name, value] of Object.entries(REQUIRED_CLAUDE_QUIET_ATTRIBUTION)) {\n130\t    assert.equal(written.attribution[name], value, `script should configure attribution.${name}=${JSON.stringify(value)}`);\n131\t  }\n132\t  for (const [name, value] of Object.entries(REQUIRED_CLAUDE_QUIET_PERMISSIONS)) {\n133\t    assert.equal(written.permissions[name], value, `script should configure permissions.${name}=${JSON.stringify(value)}`);\n134\t  }\n135\t  for (const tool of USELESS_CLAUDE_BUILTIN_TOOLS) {\n136\t    assert.ok(written.disallowedTools.includes(tool), `script should add ${tool} to disallowedTools`);\n137\t  }\n138\t  for (const prefix of USELESS_MCP_TOOL_NAME_PREFIXES) {\n139\t    assert.ok(written.disallowedTools.includes(`${prefix}__*`), `script should add ${prefix}__* to disallowedTools`);\n140\t  }\n141\t  // Idempotency: a second run must not duplicate tools or rewrite anything.\n142\t  await runScript(settingsPath);\n143\t  const written2 = JSON.parse(await fs.readFile(settingsPath, 'utf-8'));\n144\t  assert.deepEqual(written2.disallowedTools, written.disallowedTools, 'second run should not duplicate disallowedTools entries');\n145\t} finally {\n146\t  await fs.rm(scriptTmp, { recursive: true, force: true });\n147\t}\n148\t\n149\tconsole.log('Claude quiet configuration tests passed');\n150\t"
