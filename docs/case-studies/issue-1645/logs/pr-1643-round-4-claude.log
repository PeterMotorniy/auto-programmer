[2026-04-18T17:28:11.700Z] [INFO]         "content": "1\t#!/usr/bin/env node\n2\t\n3\t/**\n4\t * Configure quiet, deterministic Claude Code defaults in a target\n5\t * `settings.json` (typically `~/.claude/settings.json` or the pre-seeded\n6\t * `/workspace/.claude/settings.json` inside our Docker images).\n7\t *\n8\t * Replaces the long inline `node -e \"...\"` block that used to live in both\n9\t * Dockerfiles. Reuses the canonical required env/settings/attribution/\n10\t * permissions maps and the idempotent merge helpers from:\n11\t *   - src/claude-quiet-config.lib.mjs (quiet env + settings)\n12\t *   - src/useless-tools.lib.mjs      (disallowedTools block-list)\n13\t *\n14\t * Usage:\n15\t *   node scripts/configure-claude-quiet-defaults.mjs [--settings-path <path>]\n16\t *\n17\t * Defaults `--settings-path` to `${HOME}/.claude/settings.json`.\n18\t *\n19\t * See issues #1627 and #1642.\n20\t */\n21\t\n22\timport path from 'node:path';\n23\timport os from 'node:os';\n24\t\n25\timport { ensureClaudeQuietConfig } from '../src/claude-quiet-config.lib.mjs';\n26\timport { ensureDisallowedToolsInSettings } from '../src/useless-tools.lib.mjs';\n27\t\n28\tconst parseArgs = argv => {\n29\t  const args = { settingsPath: null };\n30\t  for (let i = 0; i < argv.length; i++) {\n31\t    const arg = argv[i];\n32\t    if (arg === '--settings-path' || arg === '-s') {\n33\t      args.settingsPath = argv[++i];\n34\t    } else if (arg.startsWith('--settings-path=')) {\n35\t      args.settingsPath = arg.slice('--settings-path='.length);\n36\t    } else if (arg === '--help' || arg === '-h') {\n37\t      args.help = true;\n38\t    }\n39\t  }\n40\t  return args;\n41\t};\n42\t\n43\tconst args = parseArgs(process.argv.slice(2));\n44\t\n45\tif (args.help) {\n46\t  console.log('Usage: node scripts/configure-claude-quiet-defaults.mjs [--settings-path <path>]');\n47\t  process.exit(0);\n48\t}\n49\t\n50\tconst settingsPath = args.settingsPath || path.join(os.homedir(), '.claude', 'settings.