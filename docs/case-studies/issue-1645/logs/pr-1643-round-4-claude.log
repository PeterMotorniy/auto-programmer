[2026-04-18T17:28:16.517Z] [INFO]         "content": "1\t# Hive Mind Docker image\n2\t# Inherits from konard/sandbox which provides all general-purpose development tools\n3\t# This image adds AI-specific tools (Claude CLI, OpenAI Codex, Playwright MCP, etc.)\n4\t#\n5\t# Architecture (see issue #1394, #1499, #1505 and sandbox#73, sandbox#74):\n6\t#   konard/sandbox (pinned version)\n7\t#     └── All general dev tools: Node.js, Bun, Deno, Python, Go, Rust, Java, PHP, etc.\n8\t#     └── Playwright browsers pre-installed (chromium, firefox, webkit, msedge, chrome)\n9\t#     └── /workspace directory owned by sandbox user\n10\t#   hive-mind (konard/hive-mind)\n11\t#     └── Inherits sandbox, adds AI coding assistants and Playwright MCP\n12\t#     └── Runs entirely as sandbox user (no USER root needed)\n13\t#\n14\t# Sandbox image version: pinned to a specific release for stable, reproducible builds.\n15\t# To upgrade: update the version tag below and in coolify/Dockerfile.\n16\t# Latest sandbox releases: https://hub.docker.com/r/konard/sandbox/tags\n17\t#\n18\t# Build: docker build -t konard/hive-mind .\n19\t\n20\tFROM konard/sandbox:1.6.0\n21\t\n22\t# --- Environment variables ---\n23\t# Set environment variables EARLY so they're available in subsequent RUN commands\n24\t# All paths use /workspace (shared directory owned by sandbox:sandbox)\n25\tENV HOME=/workspace\n26\tENV NVM_DIR=\"/workspace/.nvm\"\n27\tENV PYENV_ROOT=\"/workspace/.pyenv\"\n28\tENV BUN_INSTALL=\"/workspace/.bun\"\n29\tENV DENO_INSTALL=\"/workspace/.deno\"\n30\tENV CARGO_HOME=\"/workspace/.cargo\"\n31\tENV GOROOT=\"/workspace/.go\"\n32\tENV GOPATH=\"/workspace/.go/path\"\n33\tENV SDKMAN_DIR=\"/workspace/.sdkman\"\n34\tENV PERLBREW_ROOT=\"/workspace/.perl5\"\n35\tENV RBENV_ROOT=\"/workspace/.rbenv\"\n36\t\n37\t# Quiet, deterministic Claude Code defaults for autonomous solve runs (issue #1642)\n38\tENV CLAUDE_CODE_DISABLE_AUTO_MEMORY=1 \\\n39\t    CLAUDE_CODE_DISABLE_CRON=1 \\\n40\t    CLAUDE_CODE_DISABLE_TERMINAL_TITLE=1 \\\n41\t    CLAUDE_CODE_DISABLE_CLAUDE_MDS=1 \\\n42\t    CLAUDE_CODE_DISABLE_FAST_MODE=1 \\\n43\t    CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY=1 \\\n44\t    CLAUDE_CODE_DISABLE_MOUSE=1 \\\n45\t    CLAUDE_CODE_ENABLE_AWAY_SUMMARY=0 \\\n46\t    CLAUDE_CODE_ENABLE_TASKS=1 \\\n47\t    CLAUDE_CODE_MAX_TOOL_USE_CONCURRENCY=4 \\\n48\t    CLAUDE_CODE_RESUME_INTERRUPTED_TURN=1 \\\n49\t    DISABLE_FEEDBACK_COMMAND=1\n50\t\n51\t# Opam environment variables for Rocq/Coq theorem prover\n52\tENV OPAM_SWITCH_PREFIX=\"/workspace/.opam/default\"\n53\tENV CAML_LD_LIBRARY_PATH=\"/workspace/.opam/default/lib/stublibs:/workspace/.opam/default/lib/ocaml/stublibs:/workspace/.opam/default/lib/ocaml\"\n54\tENV OCAML_TOPLEVEL_PATH=\"/workspace/.opam/default/lib/toplevel\"\n55\t\n56\t# Comprehensive PATH including all tools\n57\t# Note: Node.js path is added dynamically since NVM version may vary\n58\t# Note: ~/.local/bin is included for user-installed binaries (e.g., opam binary from sandbox rocq image)\n59\tENV PATH=\"/home/linuxbrew/.linuxbrew/opt/php@8.3/bin:/home/linuxbrew/.linuxbrew/opt/php@8.3/sbin:/home/linuxbrew/.linuxbrew/bin:/workspace/.pyenv/bin:/workspace/.pyenv/shims:/workspace/.rbenv/bin:/workspace/.rbenv/shims:/workspace/.swift/usr/bin:/workspace/.elan/bin:/workspace/.opam/default/bin:/workspace/.local/bin:/workspace/.cargo/bin:/workspace/.deno/bin:/workspace/.bun/bin:/workspace/.go/bin:/workspace/.go/path/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin\"\n60\t\n61\t# Run entirely as sandbox user — no USER root needed (see issue #1505)\n62\tUSER sandbox\n63\tWORKDIR /workspace\n64\t\n65\t# Create a stable symlink to the active Node.js version's bin directory\n66\t# This allows us to add it to PATH without knowing the specific version\n67\tRUN NODE_VERSION_DIR=$(ls -d /workspace/.nvm/versions/node/v* 2>/dev/null | head -1) && \\\n68\t    if [ -n \"$NODE_VERSION_DIR\" ] && [ -d \"$NODE_VERSION_DIR/bin\" ]; then \\\n69\t      ln -sf \"$NODE_VERSION_DIR/bin\" /workspace/.node-bin; \\\n70\t    fi\n71\t\n72\tENV PATH=\"/workspace/.node-bin:${PATH}\"\n73\t\n74\t# --- Install opam binary ---\n75\t# The sandbox full image copies ~/.opam (opam switch data) from the rocq stage\n76\t# but does NOT copy the opam binary from ~/.local/bin. Install it as sandbox user.\n77\t# See: https://github.com/link-foundation/sandbox/issues/74\n78\tRUN mkdir -p /workspace/.local/bin && \\\n79\t    ARCH=\"$(uname -m)\" && \\\n80\t    case \"$ARCH\" in \\\n81\t      x86_64)  OPAM_ARCH=\"x86_64\" ;; \\\n82\t      aarch64) OPAM_ARCH=\"arm64\" ;; \\\n83\t      *)       OPAM_ARCH=\"$ARCH\" ;; \\\n84\t    esac && \\\n85\t    OPAM_TAG=$(curl -fsSIL -o /dev/null -w '%{url_effective}' https://github.com/ocaml/opam/releases/latest | sed 's|.*/||') && \\\n86\t    curl -fsSL \"https://github.com/ocaml/opam/releases/download/${OPAM_TAG}/opam-${OPAM_TAG}-${OPAM_ARCH}-linux\" -o /workspace/.local/bin/opam && \\\n87\t    chmod +x /workspace/.local/bin/opam\n88\t\n89\t# --- AI-specific packages installation ---\n90\t# These are the tools that differentiate hive-mind from the generic sandbox\n91\t# Global bun packages for AI coding assistants and workflow utilities\n92\t# Every install must fail the build on error — no silent fallbacks (see issue #1505)\n93\t\n94\t# Install Claude Code through Anthropic's native installer. Bun blocks the\n95\t# @anthropic-ai/claude-code postinstall that links the native binary (issue #1633).\n96\tRUN curl -fsSL https://claude.ai/install.sh -o /tmp/claude-code-install.sh && \\\n97\t    bash /tmp/claude-code-install.sh && \\\n98\t    rm /tmp/claude-code-install.sh && \\\n99\t    claude --version\n100\t\n101\t# Install AI coding assistant CLIs\n102\tRUN bun install -g @openai/codex && \\\n103\t    bun install -g @qwen-code/qwen-code && \\\n104\t    bun install -g @google/gemini-cli && \\\n105\t    bun install -g @github/copilot && \\\n106\t    bun install -g opencode-ai\n107\t\n108\t# Install hive-mind workflow utilities\n109\t# Note: start-command provides `$` CLI for isolation modes (--isolation screen/tmux/docker)\n110\t# The sandbox base image includes screen. For tmux/docker isolation, ensure they are\n111\t# available in the base image or install them separately.\n112\tRUN bun install -g @link-assistant/hive-mind && \\\n113\t    bun install -g @link-assistant/claude-profiles && \\\n114\t    bun install -g @link-assistant/agent && \\\n115\t    bun install -g start-command && \\\n116\t    bun install -g gh-setup-git-identity && \\\n117\t    bun install -g gh-pull-all && \\\n118\t    bun install -g gh-load-issue && \\\n119\t    bun install -g gh-load-pull-request && \\\n120\t    bun install -g gh-upload-log\n121\t\n122\t# --- Playwright MCP Setup ---\n123\t# Sandbox 1.6.0 pre-installs Playwright browsers and @playwright/test (sandbox#74).\n124\t# We only add @playwright/mcp (AI-specific MCP server for Claude/Codex).\n125\t# --force handles the shared 'playwright' binary conflict between packages.\n126\tRUN npm install -g @playwright/mcp@latest --no-fund --force\n127\t\n128\t# Configure Playwright MCP for Claude CLI — fail the build if registration fails (issue #1514)\n129\tRUN if command -v claude &>/dev/null; then \\\n130\t      claude mcp add playwright -s user -- npx -y @playwright/mcp@latest --isolated --headless --no-sandbox --timeout-action=600000 --viewport-size 1920x1080; \\\n131\t    fi\n132\t\n133\t# Configure Playwright MCP for Codex CLI with the same server settings\n134\tRUN if command -v codex &>/dev/null; then \\\n135\t      codex mcp add playwright -- npx -y @playwright/mcp@latest --isolated --headless --no-sandbox --timeout-action=600000 --viewport-size 1920x1080; \\\n136\t    fi\n137\t\n138\t# --- Disable noisy/unused Claude Code features and tools (issue #1627, issue #1642) ---\n139\t# Autonomous headless hive-mind runs never benefit from tools that wait for\n140\t# human interaction (AskUserQuestion, EnterPlanMode) or that register local\n141\t# session cron jobs (CronCreate/List/Delete) or create worktrees\n142\t# (EnterWorktree/ExitWorktree) or fire mobile notifications\n143\t# (PushNotification) or kick off remote agent triggers (RemoteTrigger)\n144\t# or create notebook cells (NotebookEdit) or monitor processes (Monitor) or\n145\t# self-schedule wakeups (ScheduleWakeup). Pre-seed the user-scope\n146\t# ~/.claude/settings.json disallowedTools list so that even interactive\n147\t# claude sessions in this image do not surface them.\n148\t# The three claude.ai OAuth connectors (Gmail/Google Drive/Google Calendar)\n149\t# cannot be removed via `claude mcp remove` because they are not registered\n150\t# under user/local/project scope; solve.mjs filters them at run time using\n151\t# --strict-mcp-config --mcp-config <temp-file>.\n152\t#\n153\t# The configuration is applied by scripts/configure-claude-quiet-defaults.mjs,\n154\t# which reuses the canonical required env/settings/attribution/permissions\n155\t# maps and the idempotent merge helpers from\n156\t# src/claude-quiet-config.lib.mjs and src/useless-tools.lib.mjs so the\n157\t# Dockerfile, solve command, and tests stay in lock-step.\n158\tCOPY --chown=sandbox:sandbox \\\n159\t    src/claude-quiet-config.lib.mjs \\\n160\t    src/useless-tools.lib.mjs \\\n161\t    /workspace/.hive-mind-bake/src/\n162\tCOPY --chown=sandbox:sandbox \\\n163\t    scripts/configure-claude-quiet-defaults.mjs \\\n164\t    /workspace/.hive-mind-bake/scripts/\n165\tRUN mkdir -p /workspace/.claude && \\\n166\t    node /workspace/.hive-mind-bake/scripts/configure-claude-quiet-defaults.mjs \\\n167\t        --settings-path /workspace/.claude/settings.json && \\\n168\t    rm -rf /workspace/.hive-mind-bake\n169\t\n170\tSHELL [\"/bin/bash\", \"-c\"]\n171\tCMD [\"/bin/bash\"]\n172\t"
