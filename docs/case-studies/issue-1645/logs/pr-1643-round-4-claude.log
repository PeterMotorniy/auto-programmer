[2026-04-18T17:28:18.929Z] [INFO]       {
[2026-04-18T17:28:18.929Z] [INFO]         "tool_use_id": "toolu_0153tuNZWzke7BVfcAuU7LJx",
[2026-04-18T17:28:18.929Z] [INFO]         "type": "tool_result",
[2026-04-18T17:28:18.929Z] [INFO]         "content": "1\t# Hive Mind Coolify Docker image\n2\t# Inherits from konard/sandbox which provides all general-purpose development tools\n3\t# This image adds AI-specific tools and application code for Coolify deployment\n4\t#\n5\t# Architecture (see issue #1394, #1499, #1505 and sandbox#73, sandbox#74):\n6\t#   konard/sandbox (pinned version)\n7\t#     └── All general dev tools: Node.js, Bun, Deno, Python, Go, Rust, Java, PHP, etc.\n8\t#     └── Playwright browsers pre-installed (chromium, firefox, webkit, msedge, chrome)\n9\t#     └── /workspace directory owned by sandbox user\n10\t#   hive-mind (this Dockerfile)\n11\t#     └── Inherits sandbox, adds AI coding assistants, Playwright MCP, and app code\n12\t#     └── Runs entirely as sandbox user (no USER root needed for tool installs)\n13\t#\n14\t# Sandbox image version: pinned to a specific release for stable, reproducible builds.\n15\t# To upgrade: update the version tag below and in the root Dockerfile.\n16\t# Latest sandbox releases: https://hub.docker.com/r/konard/sandbox/tags\n17\t#\n18\t# Build: docker build -f coolify/Dockerfile -t konard/hive-mind .\n19\t\n20\tFROM konard/sandbox:1.6.0\n21\t\n22\t# --- Environment variables ---\n23\t# Set environment variables EARLY so they're available in subsequent RUN commands\n24\t# All paths use /workspace (shared directory owned by sandbox:sandbox)\n25\tENV HOME=/workspace\n26\tENV NVM_DIR=\"/workspace/.nvm\"\n27\tENV PYENV_ROOT=\"/workspace/.pyenv\"\n28\tENV BUN_INSTALL=\"/workspace/.bun\"\n29\tENV DENO_INSTALL=\"/workspace/.deno\"\n30\tENV CARGO_HOME=\"/workspace/.cargo\"\n31\tENV GOROOT=\"/workspace/.go\"\n32\tENV GOPATH=\"/workspace/.go/path\"\n33\tENV SDKMAN_DIR=\"/workspace/.sdkman\"\n34\tENV PERLBREW_ROOT=\"/workspace/.perl5\"\n35\tENV RBENV_ROOT=\"/workspace/.rbenv\"\n36\t\n37\t# Quiet, deterministic Claude Code defaults for autonomous solve runs (issue #1642)\n38\tENV CLAUDE_CODE_DISABLE_AUTO_MEMORY=1 \\\n39\t    CLAUDE_CODE_DISABLE_CRON=1 \\\n40\t    CLAUDE_CODE_DISABLE_TERMINAL_TITLE=1 \\\n41\t    CLAUDE_CODE_DISABLE_CLAUDE_MDS=1 \\\n42\t    CLAUDE_CODE_DISABLE_FAST_MODE=1 \\\n43\t    CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY=1 \\\n44\t    CLAUDE_CODE_DISABLE_MOUSE=1 \\\n45\t    CLAUDE_CODE_ENABLE_AWAY_SUMMARY=0 \\\n46\t    CLAUDE_CODE_ENABLE_TASKS=1 \\\n47\t    CLAUDE_CODE_MAX_TOOL_USE_CONCURRENCY=4 \\\n48\t    CLAUDE_CODE_RESUME_INTERRUPTED_TURN=1 \\\n49\t    DISABLE_FEEDBACK_COMMAND=1\n50\t\n51\tENV OPAM_SWITCH_PREFIX=\"/workspace/.opam/default\"\n52\tENV CAML_LD_LIBRARY_PATH=\"/workspace/.opam/default/lib/stublibs:/workspace/.opam/default/lib/ocaml/stublibs:/workspace/.opam/default/lib/ocaml\"\n53\tENV OCAML_TOPLEVEL_PATH=\"/workspace/.opam/default/lib/toplevel\"\n54\t\n55\t# Comprehensive PATH including all tools\n56\t# Note: ~/.local/bin is included for user-installed binaries (e.g., opam binary from sandbox rocq image)\n57\tENV PATH=\"/home/linuxbrew/.linuxbrew/opt/php@8.3/bin:/home/linuxbrew/.linuxbrew/opt/php@8.3/sbin:/home/linuxbrew/.linuxbrew/bin:/workspace/.pyenv/bin:/workspace/.pyenv/shims:/workspace/.rbenv/bin:/workspace/.rbenv/shims:/workspace/.swift/usr/bin:/workspace/.elan/bin:/workspace/.opam/default/bin:/workspace/.local/bin:/workspace/.cargo/bin:/workspace/.deno/bin:/workspace/.bun/bin:/workspace/.go/bin:/workspace/.go/path/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin\"\n58\t\n59\t# Run entirely as sandbox user — no USER root needed (see issue #1505)\n60\tUSER sandbox\n61\tWORKDIR /workspace\n62\t\n63\t# Create stable symlink to Node.js bin directory\n64\tRUN NODE_VERSION_DIR=$(ls -d /workspace/.nvm/versions/node/v* 2>/dev/null | head -1) && \\\n65\t    if [ -n \"$NODE_VERSION_DIR\" ] && [ -d \"$NODE_VERSION_DIR/bin\" ]; then \\\n66\t      ln -sf \"$NODE_VERSION_DIR/bin\" /workspace/.node-bin; \\\n67\t    fi\n68\t\n69\tENV PATH=\"/workspace/.node-bin:${PATH}\"\n70\t\n71\t# --- Install opam binary ---\n72\t# The sandbox full image copies ~/.opam (opam switch data) from the rocq stage\n73\t# but does NOT copy the opam binary from ~/.local/bin. Install it as sandbox user.\n74\t# See: https://github.com/link-foundation/sandbox/issues/74\n75\tRUN mkdir -p /workspace/.local/bin && \\\n76\t    ARCH=\"$(uname -m)\" && \\\n77\t    case \"$ARCH\" in \\\n78\t      x86_64)  OPAM_ARCH=\"x86_64\" ;; \\\n79\t      aarch64) OPAM_ARCH=\"arm64\" ;; \\\n80\t      *)       OPAM_ARCH=\"$ARCH\" ;; \\\n81\t    esac && \\\n82\t    OPAM_TAG=$(curl -fsSIL -o /dev/null -w '%{url_effective}' https://github.com/ocaml/opam/releases/latest | sed 's|.*/||') && \\\n83\t    curl -fsSL \"https://github.com/ocaml/opam/releases/download/${OPAM_TAG}/opam-${OPAM_TAG}-${OPAM_ARCH}-linux\" -o /workspace/.local/bin/opam && \\\n84\t    chmod +x /workspace/.local/bin/opam\n85\t\n86\t# --- AI-specific packages installation ---\n87\t# Every install must fail the build on error — no silent fallbacks (see issue #1505)\n88\t\n89\t# Install Claude Code through Anthropic's native installer. Bun blocks the\n90\t# @anthropic-ai/claude-code postinstall that links the native binary (issue #1633).\n91\tRUN curl -fsSL https://claude.ai/install.sh -o /tmp/claude-code-install.sh && \\\n92\t    bash /tmp/claude-code-install.sh && \\\n93\t    rm /tmp/claude-code-install.sh && \\\n94\t    claude --version\n95\t\n96\t# Install AI coding assistant CLIs\n97\tRUN bun install -g @openai/codex && \\\n98\t    bun install -g @qwen-code/qwen-code && \\\n99\t    bun install -g @google/gemini-cli && \\\n100\t    bun install -g @github/copilot && \\\n101\t    bun install -g opencode-ai\n102\t\n103\t# Install hive-mind workflow utilities\n104\t# Note: start-command provides `$` CLI for isolation modes (--isolation screen/tmux/docker)\n105\t# The sandbox base image includes screen. For tmux/docker isolation, ensure they are\n106\t# available in the base image or install them separately.\n107\tRUN bun install -g @link-assistant/hive-mind && \\\n108\t    bun install -g @link-assistant/claude-profiles && \\\n109\t    bun install -g @link-assistant/agent && \\\n110\t    bun install -g start-command && \\\n111\t    bun install -g gh-setup-git-identity && \\\n112\t    bun install -g gh-pull-all && \\\n113\t    bun install -g gh-load-issue && \\\n114\t    bun install -g gh-load-pull-request && \\\n115\t    bun install -g gh-upload-log\n116\t\n117\t# --- Playwright MCP Setup ---\n118\t# Sandbox 1.6.0 pre-installs Playwright browsers and @playwright/test (sandbox#74).\n119\t# We only add @playwright/mcp (AI-specific MCP server for Claude/Codex).\n120\t# --force handles the shared 'playwright' binary conflict between packages.\n121\tRUN npm install -g @playwright/mcp@latest --no-fund --force\n122\t\n123\t# Configure Playwright MCP for Claude CLI — fail the build if registration fails (issue #1514)\n124\tRUN if command -v claude &>/dev/null; then \\\n125\t      claude mcp add playwright -s user -- npx -y @playwright/mcp@latest --isolated --headless --no-sandbox --timeout-action=600000 --viewport-size 1920x1080; \\\n126\t    fi\n127\t\n128\t# Configure Playwright MCP for Codex CLI with the same server settings\n129\tRUN if command -v codex &>/dev/null; then \\\n130\t      codex mcp add playwright -- npx -y @playwright/mcp@latest --isolated --headless --no-sandbox --timeout-action=600000 --viewport-size 1920x1080; \\\n131\t    fi\n132\t\n133\t# --- Disable noisy/unused Claude Code features and tools (issue #1627, issue #1642) ---\n134\t# Autonomous headless hive-mind runs never benefit from tools that wait for\n135\t# human interaction or leave persistent side effects. Pre-seed the\n136\t# user-scope ~/.claude/settings.json disallowedTools list so that even\n137\t# interactive claude sessions in this image do not surface them. The three\n138\t# claude.ai OAuth connectors (Gmail/Google Drive/Google Calendar) cannot be\n139\t# removed via `claude mcp remove` because they are not registered under\n140\t# user/local/project scope; solve.mjs filters them at run time using\n141\t# --strict-mcp-config --mcp-config <temp-file>.\n142\t#\n143\t# The configuration is applied by scripts/configure-claude-quiet-defaults.mjs,\n144\t# which reuses the canonical required env/settings/attribution/permissions\n145\t# maps and the idempotent merge helpers from\n146\t# src/claude-quiet-config.lib.mjs and src/useless-tools.lib.mjs so the\n147\t# Dockerfile, solve command, and tests stay in lock-step.\n148\tCOPY --chown=sandbox:sandbox \\\n149\t    src/claude-quiet-config.lib.mjs \\\n150\t    src/useless-tools.lib.mjs \\\n151\t    /workspace/.hive-mind-bake/src/\n152\tCOPY --chown=sandbox:sandbox \\\n153\t    scripts/configure-claude-quiet-defaults.mjs \\\n154\t    /workspace/.hive-mind-bake/scripts/\n155\tRUN mkdir -p /workspace/.claude && \\\n156\t    node /workspace/.hive-mind-bake/scripts/configure-claude-quiet-defaults.mjs \\\n157\t        --settings-path /workspace/.claude/settings.json && \\\n158\t    rm -rf /workspace/.hive-mind-bake\n159\t\n160\t# --- Application Setup ---\n161\t# Minimal USER root: only for creating /app directory and copying files.\n162\t# All /workspace operations run as sandbox user to prevent permission issues (issue #1505).\n163\tUSER root\n164\tWORKDIR /app\n165\t\n166\t# Copy application files from repo root\n167\tCOPY --chown=sandbox:sandbox . .\n168\t\n169\t# Ensure scripts are executable\n170\tRUN chmod +x *.mjs 2>/dev/null || true && \\\n171\t    chmod +x src/*.mjs 2>/dev/null || true\n172\t\n173\t# Create /app subdirectories (root-owned parent)\n174\tRUN mkdir -p /app/claude-logs /app/claude-sessions /app/output && \\\n175\t    chown -R sandbox:sandbox /app\n176\t\n177\t# Copy and configure startup script\n178\tCOPY --chown=root:root coolify/start.sh /app/start.sh\n179\tRUN chmod +x /app/start.sh\n180\t\n181\t# Switch to sandbox user for /workspace operations and runtime\n182\tUSER sandbox\n183\t\n184\t# Create necessary /workspace directories\n185\tRUN mkdir -p /workspace/.claude/plugins /workspace/.config\n186\t\n187\t# Create bash profile for sandbox user\n188\t# Note: .node-bin is a symlink to the active Node.js version's bin directory\n189\tRUN echo 'export PATH=\"/workspace/.node-bin:/workspace/.bun/bin:/workspace/.cargo/bin:/workspace/.elan/bin:/workspace/.opam/default/bin:/home/linuxbrew/.linuxbrew/bin:$PATH\"' >> /workspace/.bashrc && \\\n190\t    echo 'export BUN_INSTALL=\"/workspace/.bun\"' >> /workspace/.bashrc\n191\t\n192\t# Create git config file for sandbox user\n193\tRUN echo \"[user]\" > /workspace/.gitconfig && \\\n194\t    echo \"  name = Hive-Mind Bot\" >> /workspace/.gitconfig && \\\n195\t    echo \"  email = hive-mind@localhost\" >> /workspace/.gitconfig && \\\n196\t    echo \"[init]\" >> /workspace/.gitconfig && \\\n197\t    echo \"  defaultBranch = main\" >> /workspace/.gitconfig && \\\n198\t    echo \"[safe]\" >> /workspace/.gitconfig && \\\n199\t    echo \"  directory = *\" >> /workspace/.gitconfig\n200\t\n201\t# Runtime configuration\n202\tENV NODE_ENV=production\n203\tENV PORT=3000\n204\tENV MONITOR_TAG=\"help wanted\"\n205\tENV CONCURRENCY=2\n206\tENV INTERVAL=300\n207\tENV MODEL=sonnet\n208\t\n209\t# Health check\n210\tHEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \\\n211\t    CMD pgrep -f \"hive.mjs\\|tail\" > /dev/null || exit 1\n212\t\n213\tSHELL [\"/bin/bash\", \"-c\"]\n214\tENTRYPOINT [\"/app/start.sh\"]\n215\t"
