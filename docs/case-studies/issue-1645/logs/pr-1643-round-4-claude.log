[2026-04-18T17:34:37.793Z] [INFO]         "content": "1\t#!/usr/bin/env bash\n2\t# check-file-line-limits.sh\n3\t#\n4\t# Enforces a 1500-line limit on all .mjs files and on release.yml.\n5\t#\n6\t# Usage:\n7\t#   bash scripts/check-file-line-limits.sh\n8\t#\n9\t# Exit code 0 = all files within limit; non-zero = one or more violations.\n10\t\n11\tset -euo pipefail\n12\t\n13\tLIMIT=1500\n14\t# Issue #1593: Warning threshold to catch files approaching the limit before they exceed it.\n15\t# This mitigates the concurrent PR merge race condition where two PRs each pass CI individually\n16\t# but their combined changes push a file over the limit after both merge to main.\n17\t# See docs/case-studies/issue-1593 for the full analysis.\n18\tWARN_THRESHOLD=1350\n19\tFAILURES=()\n20\tWARNINGS=()\n21\t\n22\techo \"Checking that all .mjs files are under ${LIMIT} lines...\"\n23\t\n24\twhile IFS= read -r -d '' file; do\n25\t  line_count=$(wc -l < \"$file\")\n26\t  echo \"$file: $line_count lines\"\n27\t  if [ \"$line_count\" -gt \"$LIMIT\" ]; then\n28\t    echo \"ERROR: $file has $line_count lines (limit: ${LIMIT})\"\n29\t    echo \"::error file=$file::File has $line_count lines (limit: ${LIMIT})\"\n30\t    FAILURES+=(\"$file\")\n31\t  elif [ \"$line_count\" -gt \"$WARN_THRESHOLD\" ]; then\n32\t    echo \"WARNING: $file has $line_count lines (approaching limit of ${LIMIT}, warning threshold: ${WARN_THRESHOLD})\"\n33\t    echo \"::warning file=$file::File has $line_count lines (approaching limit of ${LIMIT}). Consider extracting code to keep under ${WARN_THRESHOLD} lines to prevent concurrent PR merge issues (see issue #1593).\"\n34\t    WARNINGS+=(\"$file\")\n35\t  fi\n36\tdone < <(find . -name \"*.mjs\" -type f -print0)\n37\t\n38\techo \"\"\n39\techo \"Checking that .github/workflows/release.yml is under ${LIMIT} lines...\"\n40\tRELEASE_YML=\".github/workflows/release.yml\"\n41\tif [ -f \"$RELEASE_YML\" ]; then\n42\t  line_count=$(wc -l < \"$RELEASE_YML\")\n43\t  echo \"$RELEASE_YML: $line_count lines\"\n44\t  if [ \"$line_count\" -gt \"$LIMIT\" ]; then\n45\t    echo \"ERROR: $RELEASE_YML has $line_count lines (limit: ${LIMIT})\"\n46\t    echo \"::error file=$RELEASE_YML::File has $line_count lines (limit: ${LIMIT}). Move inline scripts to ./scripts/ folder.\"\n47\t    FAILURES+=(\"$RELEASE_YML\")\n48\t  elif [ \"$line_count\" -gt \"$WARN_THRESHOLD\" ]; then\n49\t    echo \"WARNING: $RELEASE_YML has $line_count lines (approaching limit of ${LIMIT}, warning threshold: ${WARN_THRESHOLD})\"\n50\t    echo \"::warning file=$RELEASE_YML::File has $line_count lines (approaching limit of ${LIMIT}). Consider moving inline scripts to ./scripts/ folder.\"\n51\t    WARNINGS+=(\"$RELEASE_YML\")\n52\t  fi\n53\telse\n54\t  echo \"WARNING: $RELEASE_YML not found, skipping\"\n55\tfi\n56\t\n57\techo \"\"\n58\tif [ \"${#WARNINGS[@]}\" -gt 0 ]; then\n59\t  echo \"The following files are approaching the ${LIMIT} line limit (>${WARN_THRESHOLD} lines):\"\n60\t  printf '  %s\\n' \"${WARNINGS[@]}\"\n61\t  echo \"\"\n62\t  echo \"Consider extracting code to prevent concurrent PR merge limit violations (see issue #1593).\"\n63\t  echo \"\"\n64\tfi\n65\tif [ \"${#FAILURES[@]}\" -gt 0 ]; then\n66\t  echo \"The following files exceed the ${LIMIT} line limit:\"\n67\t  printf '  %s\\n' \"${FAILURES[@]}\"\n68\t  echo \"\"\n69\t  echo \"Move large inline scripts to the ./scripts/ folder to reduce file size.\"\n70\t  exit 1\n71\telse\n72\t  echo \"All checked files are within the ${LIMIT} line limit!\"\n73\tfi\n74\t"
