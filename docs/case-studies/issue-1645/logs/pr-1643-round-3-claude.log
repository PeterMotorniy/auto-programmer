settings.json'; \\\nconst blocked = ['AskUserQuestion','CronCreate','CronDelete','CronList','EnterPlanMode','EnterWorktree','ExitPlanMode','ExitWorktree','Monitor','NotebookEdit','PushNotification','RemoteTrigger','ScheduleWakeup','mcp__claude_ai_Gmail__*','mcp__claude_ai_Google_Drive__*','mcp__claude_ai_Google_Calendar__*']; \\\nconst quietEnv = { CLAUDE_CODE_DISABLE_AUTO_MEMORY: '1', CLAUDE_CODE_DISABLE_CRON: '1', CLAUDE_CODE_DISABLE_TERMINAL_TITLE: '1', CLAUDE_CODE_DISABLE_CLAUDE_MDS: '1', CLAUDE_CODE_DISABLE_FAST_MODE: '1', CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY: '1', CLAUDE_CODE_DISABLE_MOUSE: '1', CLAUDE_CODE_ENABLE_AWAY_SUMMARY: '0', CLAUDE_CODE_ENABLE_TASKS: '1', CLAUDE_CODE_MAX_TOOL_USE_CONCURRENCY: '4', CLAUDE_CODE_RESUME_INTERRUPTED_TURN: '1', DISABLE_FEEDBACK_COMMAND: '1' }; \\\nconst quietSettings = { autoMemoryEnabled: false, spinnerTipsEnabled: false, awaySummaryEnabled: false, feedbackSurveyRate: 0, includeCoAuthoredBy: false, includeGitInstructions: true, prefersReducedMotion: true, showThinkingSummaries: false, skipDangerousModePermissionPrompt: true, viewMode: 'verbose' }; \\\nconst quietAttribution = { commit: '', pr: '' }; \\\nconst quietPermissions = { defaultMode: 'bypassPermissions' }; \\\nlet s = {}; \\\ntry { s = JSON.parse(fs.readFileSync(p, 'utf-8')); } catch (e) {} \\\nif (!s || typeof s !== 'object' || Array.isArray(s)) s = {}; \\\nfor (const [key, value] of Object.entries(quietSettings)) s[key] = value; \\\ns.attribution = s.attribution && typeof s.attribution === 'object' && !Array.isArray(s.attribution) ? s.attribution : {}; \\\nfor (const [key, value] of Object.entries(quietAttribution)) s.attribution[key] = value; \\\ns.permissions = s.permissions && typeof s.permissions === 'object' && !Array.isArray(s.permissions) ? s.permissions : {}; \\\nfor (const [key, value] of Object.entries(quietPermissions)) s.permissions[key] = value; \\\ns.env = s.env && typeof s.env === 'object' && !Array.isArray(s.env) ? s.env : {}; \\\nfor (const [key, value] of Object.entries(quietEnv)) s.env[key] = value; \\\nconst existing = Array.isArray(s.disallowedTools) ? s.disallowedTools : []; \\\nconst merged = [...existing]; \\\nfor (const t of blocked) if (!merged.includes(t)) merged.push(t); \\\ns.disallowedTools = merged; \\\nfs.writeFileSync(p, JSON.stringify(s, null, 2)); \\\nconsole.log('Configured quiet Claude Code defaults and', merged.length, 'disallowedTools in', p); \\\n\"\n\n# --- Application Setup ---",
