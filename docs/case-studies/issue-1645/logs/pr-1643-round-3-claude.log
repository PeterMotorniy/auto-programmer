[2026-04-18T17:04:39.804Z] [INFO]         "tool_use_id": "toolu_017eakzMaPyomzMddVuBmnyR",
[2026-04-18T17:04:39.804Z] [INFO]         "type": "tool_result",
[2026-04-18T17:04:39.804Z] [INFO]         "content": "1\t#!/usr/bin/env node\n2\t/**\n3\t * Useless Tools Disable Tests\n4\t *\n5\t * Tests for src/useless-tools.lib.mjs — the block-list of Claude Code\n6\t * built-in tools and MCP servers that have no value (and may be harmful)\n7\t * in autonomous headless hive-mind runs.\n8\t *\n9\t * Run with: node tests/useless-tools.test.mjs\n10\t *\n11\t * @see https://github.com/link-assistant/hive-mind/issues/1627\n12\t */\n13\t\n14\timport assert from 'node:assert/strict';\n15\timport fs from 'node:fs/promises';\n16\timport os from 'node:os';\n17\timport path from 'node:path';\n18\t\n19\timport { USELESS_CLAUDE_BUILTIN_TOOLS, USELESS_MCP_SERVER_NAME_PREFIXES, USELESS_MCP_TOOL_NAME_PREFIXES, buildDisallowedToolsList, buildFilteredMcpConfig, ensureDisallowedToolsInSettings, filterMcpServersObject, isUselessMcpServerName } from '../src/useless-tools.lib.mjs';\n20\t\n21\tlet testsPassed = 0;\n22\tlet testsFailed = 0;\n23\t\n24\tasync function asyncTest(name, fn) {\n25\t  try {\n26\t    await fn();\n27\t    console.log(`✅ ${name}`);\n28\t    testsPassed++;\n29\t  } catch (error) {\n30\t    console.log(`❌ ${name}`);\n31\t    console.log(`   Error: ${error.message}`);\n32\t    testsFailed++;\n33\t  }\n34\t}\n35\t\n36\tfunction test(name, fn) {\n37\t  try {\n38\t    fn();\n39\t    console.log(`✅ ${name}`);\n40\t    testsPassed++;\n41\t  } catch (error) {\n42\t    console.log(`❌ ${name}`);\n43\t    console.log(`   Error: ${error.message}`);\n44\t    testsFailed++;\n45\t  }\n46\t}\n47\t\n48\tasync function runTests() {\n49\t  console.log('\\n📋 Useless Tools Disable Tests (issue #1627)\\n');\n50\t\n51\t  // ============================================================================\n52\t  // Constants\n53\t  // ============================================================================\n54\t\n55\t  test('USELESS_CLAUDE_BUILTIN_TOOLS contains exactly the expected tools', () => {\n56\t    const expected = ['AskUserQuestion', 'CronCreate', 'CronDelete', 'CronList', 'EnterPlanMode', 'EnterWorktree', 'ExitPlanMode', 'ExitWorktree', 'Monitor', 'NotebookEdit', 'PushNotification', 'RemoteTrigger', 'ScheduleWakeup'];\n57\t    assert.deepEqual([...USELESS_CLAUDE_BUILTIN_TOOLS].sort(), expected.sort());\n58\t  });\n59\t\n60\t  test('USELESS_CLAUDE_BUILTIN_TOOLS is frozen', () => {\n61\t    assert.ok(Object.isFrozen(USELESS_CLAUDE_BUILTIN_TOOLS), 'USELESS_CLAUDE_BUILTIN_TOOLS should be frozen');\n62\t  });\n63\t\n64\t  test('USELESS_MCP_SERVER_NAME_PREFIXES contains all three claude.ai connectors', () => {\n65\t    assert.deepEqual([...USELESS_MCP_SERVER_NAME_PREFIXES].sort(), ['claude.ai gmail', 'claude.ai google calendar', 'claude.ai google drive'].sort());\n66\t  });\n67\t\n68\t  test('USELESS_MCP_TOOL_NAME_PREFIXES contains mcp__claude_ai_* for all three connectors', () => {\n69\t    assert.deepEqual([...USELESS_MCP_TOOL_NAME_PREFIXES].sort(), ['mcp__claude_ai_Gmail', 'mcp__claude_ai_Google_Calendar', 'mcp__claude_ai_Google_Drive'].sort());\n70\t  });\n71\t\n72\t  // ============================================================================\n73\t  // isUselessMcpServerName\n74\t  // ============================================================================\n75\t\n76\t  test('isUselessMcpServerName matches all three claude.ai connectors case-insensitively', () => {\n77\t    assert.equal(isUselessMcpServerName('claude.ai Gmail'), true);\n78\t    assert.equal(isUselessMcpServerName('claude.ai Google Drive'), true);\n79\t    assert.equal(isUselessMcpServerName('claude.ai Google Calendar'), true);\n80\t    assert.equal(isUselessMcpServerName('CLAUDE.AI GMAIL'), true);\n81\t  });\n82\t\n83\t  test('isUselessMcpServerName does NOT match Playwright or unrelated servers', () => {\n84\t    assert.equal(isUselessMcpServerName('playwright'), false);\n85\t    assert.equal(isUselessMcpServerName('my-custom-server'), false);\n86\t    assert.equal(isUselessMcpServerName(''), false);\n87\t    assert.equal(isUselessMcpServerName(null), false);\n88\t    assert.equal(isUselessMcpServerName(undefined), false);\n89\t  });\n90\t\n91\t  // ============================================================================\n92\t  // filterMcpServersObject\n93\t  // ============================================================================\n94\t\n95\t  test('filterMcpServersObject removes all three claude.ai connectors', () => {\n96\t    const input = {\n97\t      'claude.ai Gmail': { url: 'https://gmail.mcp.claude.com/mcp' },\n98\t      'claude.ai Google Drive': { url: 'https://drivemcp.googleapis.com/mcp/v1' },\n99\t      'claude.ai Google Calendar': { url: 'https://gcal.mcp.claude.com/mcp' },\n100\t      playwright: { command: 'npx', args: ['-y', '@playwright/mcp@latest'] },\n101\t      'other-server': { url: 'https://example.com/mcp' },\n102\t    };\n103\t    const filtered = filterMcpServersObject(input);\n104\t    assert.deepEqual(Object.keys(filtered).sort(), ['other-server', 'playwright'].sort());\n105\t  });\n106\t\n107\t  test('filterMcpServersObject handles empty and invalid inputs', () => {\n108\t    assert.deepEqual(filterMcpServersObject({}), {});\n109\t    assert.deepEqual(filterMcpServersObject(null), {});\n110\t    assert.deepEqual(filterMcpServersObject(undefined), {});\n111\t  });\n112\t\n113\t  // ============================================================================\n114\t  // buildDisallowedToolsList\n115\t  // ============================================================================\n116\t\n117\t  test('buildDisallowedToolsList returns all block-listed built-ins', () => {\n118\t    const list = buildDisallowedToolsList();\n119\t    for (const tool of USELESS_CLAUDE_BUILTIN_TOOLS) {\n120\t      assert.ok(list.includes(tool), `list should include ${tool}`);\n121\t    }\n122\t  });\n123\t\n124\t  test('buildDisallowedToolsList returns wildcard MCP tool patterns', () => {\n125\t    const list = buildDisallowedToolsList();\n126\t    assert.ok(list.includes('mcp__claude_ai_Gmail__*'));\n127\t    assert.ok(list.includes('mcp__claude_ai_Google_Drive__*'));\n128\t    assert.ok(list.includes('mcp__claude_ai_Google_Calendar__*'));\n129\t  });\n130\t\n131\t  test('buildDisallowedToolsList matches the exact length expected', () => {\n132\t    const list = buildDisallowedToolsList();\n133\t    assert.equal(list.length, USELESS_CLAUDE_BUILTIN_TOOLS.length + USELESS_MCP_TOOL_NAME_PREFIXES.length);\n134\t  });\n135\t\n136\t  // ============================================================================\n137\t  // buildFilteredMcpConfig\n138\t  // ============================================================================\n139\t\n140\t  await asyncTest('buildFilteredMcpConfig writes a JSON file excluding useless connectors', async () => {\n141\t    // Create a fake HOME with a claude.json that has mixed servers.\n142\t    const fakeHome = await fs.mkdtemp(path.join(os.tmpdir(), 'useless-tools-test-'));\n143\t    const claudeJsonPath = path.join(fakeHome, '.claude.json');\n144\t    const input = {\n145\t      mcpServers: {\n146\t        'claude.ai Gmail': { url: 'https://gmail.mcp.claude.com/mcp' },\n147\t        'claude.ai Google Drive': { url: 'https://drivemcp.googleapis.com/mcp/v1' },\n148\t        'claude.ai Google Calendar': { url: 'https://gcal.mcp.claude.com/mcp' },\n149\t        playwright: { command: 'npx', args: ['-y', '@playwright/mcp@latest'] },\n150\t        'other-server': { url: 'https://example.com/mcp' },\n151\t      },\n152\t    };\n153\t    await fs.writeFile(claudeJsonPath, JSON.stringify(input));\n154\t\n155\t    const originalHome = process.env.HOME;\n156\t    process.env.HOME = fakeHome;\n157\t    try {\n158\t      const configPath = await buildFilteredMcpConfig({ log: null });\n159\t      assert.ok(configPath, 'should return a path');\n160\t      const written = JSON.parse(await fs.readFile(configPath, 'utf-8'));\n161\t      assert.deepEqual(Object.keys(written.mcpServers).sort(), ['other-server', 'playwright'].sort(), 'should keep non-blocklisted servers');\n162\t      // Clean up the temp config.\n163\t      await fs.rm(configPath, { force: true });\n164\t    } finally {\n165\t      process.env.HOME = originalHome;\n166\t      await fs.rm(fakeHome, { recursive: true, force: true });\n167\t    }\n168\t  });\n169\t\n170\t  await asyncTest('buildFilteredMcpConfig with excludePlaywright also drops Playwright', async () => {\n171\t    const fakeHome = await fs.mkdtemp(path.join(os.tmpdir(), 'useless-tools-test-'));\n172\t    const claudeJsonPath = path.join(fakeHome, '.claude.json');\n173\t    const input = {\n174\t      mcpServers: {\n175\t        'claude.ai Gmail': { url: 'https://gmail.mcp.claude.com/mcp' },\n176\t        playwright: { command: 'npx', args: ['-y', '@playwright/mcp@latest'] },\n177\t        'other-server': { url: 'https://example.com/mcp' },\n178\t      },\n179\t    };\n180\t    await fs.writeFile(claudeJsonPath, JSON.stringify(input));\n181\t    const originalHome = process.env.HOME;\n182\t    process.env.HOME = fakeHome;\n183\t    try {\n184\t      const configPath = await buildFilteredMcpConfig({ excludePlaywright: true, log: null });\n185\t      assert.ok(configPath, 'should return a path');\n186\t      const written = JSON.parse(await fs.readFile(configPath, 'utf-8'));\n187\t      assert.deepEqual(Object.keys(written.mcpServers), ['other-server']);\n188\t      await fs.rm(configPath, { force: true });\n189\t    } finally {\n190\t      process.env.HOME = originalHome;\n191\t      await fs.rm(fakeHome, { recursive: true, force: true });\n192\t    }\n193\t  });\n194\t\n195\t  await asyncTest('buildFilteredMcpConfig returns null if claude.json is missing', async () => {\n196\t    const fakeHome = await fs.mkdtemp(path.join(os.tmpdir(), 'useless-tools-test-'));\n197\t    const originalHome = process.env.HOME;\n198\t    process.env.HOME = fakeHome;\n199\t    try {\n200\t      const configPath = await buildFilteredMcpConfig({ log: null });\n201\t      assert.equal(configPath, null, 'should return null when claude.json is missing');\n202\t    } finally {\n203\t      process.env.HOME = originalHome;\n204\t      await fs.rm(fakeHome, { recursive: true, force: true });\n205\t    }\n206\t  });\n207\t\n208\t  // ============================================================================\n209\t  // ensureDisallowedToolsInSettings\n210\t  // ============================================================================\n211\t\n212\t  await asyncTest('ensureDisallowedToolsInSettings creates a new settings file if missing', async () => {\n213\t    const tmp = await fs.mkdtemp(path.join(os.tmpdir(), 'useless-tools-settings-'));\n214\t    const settingsPath = path.join(tmp, 'settings.json');\n215\t    const result = await ensureDisallowedToolsInSettings({ settingsPath, log: null });\n216\t    assert.equal(result.added.length, buildDisallowedToolsList().length, 'should add the full block-list');\n217\t    const written = JSON.parse(await fs.readFile(settingsPath, 'utf-8'));\n218\t    assert.deepEqual(written.disallowedTools.sort(), buildDisallowedToolsList().sort());\n219\t    await fs.rm(tmp, { recursive: true, force: true });\n220\t  });\n221\t\n222\t  await asyncTest('ensureDisallowedToolsInSettings preserves unrelated settings and existing disallowedTools', async () => {\n223\t    const tmp = await fs.mkdtemp(path.join(os.tmpdir(), 'useless-tools-settings-'));\n224\t    const settingsPath = path.join(tmp, 'settings.json');\n225\t    await fs.writeFile(settingsPath, JSON.stringify({ theme: 'dark', disallowedTools: ['AskUserQuestion', 'CustomTool'] }));\n226\t    const result = await ensureDisallowedToolsInSettings({ settingsPath, log: null });\n227\t    const written = JSON.parse(await fs.readFile(settingsPath, 'utf-8'));\n228\t    assert.equal(written.theme, 'dark', 'unrelated settings preserved');\n229\t    assert.ok(written.disallowedTools.includes('CustomTool'), 'existing custom entry preserved');\n230\t    assert.ok(written.disallowedTools.includes('AskUserQuestion'), 'existing block-list entry preserved');\n231\t    assert.ok(written.disallowedTools.includes('CronCreate'), 'new block-list entry added');\n232\t    // AskUserQuestion was already present; it must not have been added.\n233\t    assert.ok(!result.added.includes('AskUserQuestion'), 'already-present entries are not in .added');\n234\t    await fs.rm(tmp, { recursive: true, force: true });\n235\t  });\n236\t\n237\t  // ============================================================================\n238\t  // Integration checks with the rest of the project\n239\t  // ============================================================================\n240\t\n241\t  await asyncTest('solve.config.lib.mjs exposes --useless-tools-disabled option', async () => {\n242\t    const content = await fs.readFile(path.join(process.cwd(), 'src/solve.config.lib.mjs'), 'utf-8');\n243\t    assert.ok(content.includes(\"'useless-tools-disabled'\"), 'solve.config should define useless-tools-disabled');\n244\t    assert.ok(content.includes('default: true'), 'option should default to true');\n245\t  });\n246\t\n247\t  await asyncTest('claude.lib.mjs wires up --disallowedTools via useless-tools helpers', async () => {\n248\t    const content = await fs.readFile(path.join(process.cwd(), 'src/claude.lib.mjs'), 'utf-8');\n249\t    assert.ok(content.includes('resolveClaudeSessionToolFlags'), 'claude.lib should call resolveClaudeSessionToolFlags');\n250\t    assert.ok(content.includes('--disallowedTools'), 'claude.lib should inject --disallowedTools');\n251\t    assert.ok(content.includes('--strict-mcp-config'), 'claude.lib should inject --strict-mcp-config');\n252\t    assert.ok(content.includes(\"from './useless-tools.lib.mjs'\") || content.includes('from \"./useless-tools.lib.mjs\"'), 'claude.lib should import from useless-tools.lib.mjs');\n253\t  });\n254\t\n255\t  await asyncTest('resolveClaudeSessionToolFlags returns disallowed list by default', async () => {\n256\t    const { resolveClaudeSessionToolFlags } = await import('../src/useless-tools.lib.mjs');\n257\t    const fakeHome = await fs.mkdtemp(path.join(os.tmpdir(), 'useless-tools-resolve-'));\n258\t    await fs.writeFile(path.join(fakeHome, '.claude.json'), JSON.stringify({ mcpServers: { playwright: { command: 'npx' } } }));\n259\t    const originalHome = process.env.HOME;\n260\t    process.env.HOME = fakeHome;\n261\t    try {\n262\t      const { mcpConfigPath, disallowedToolsList } = await resolveClaudeSessionToolFlags({ argv: {}, log: null });\n263\t      assert.ok(mcpConfigPath, 'default path returns a temp mcp config path');\n264\t      assert.equal(disallowedToolsList.length, buildDisallowedToolsList().length, 'default returns full disallowed list');\n265\t      await fs.rm(mcpConfigPath, { force: true });\n266\t    } finally {\n267\t      process.env.HOME = originalHome;\n268\t      await fs.rm(fakeHome, { recursive: true, force: true });\n269\t    }\n270\t  });\n271\t\n272\t  await asyncTest('resolveClaudeSessionToolFlags returns empty list when disabled', async () => {\n273\t    const { resolveClaudeSessionToolFlags } = await import('../src/useless-tools.lib.mjs');\n274\t    const { mcpConfigPath, disallowedToolsList } = await resolveClaudeSessionToolFlags({ argv: { uselessToolsDisabled: false }, log: null });\n275\t    assert.equal(mcpConfigPath, null, 'when fully disabled, no mcp config is produced');\n276\t    assert.deepEqual(disallowedToolsList, [], 'no disallowed tools when opted out');\n277\t  });\n278\t\n279\t  await asyncTest('Dockerfile bakes disallowedTools into baseline ~/.claude/settings.json', async () => {\n280\t    const content = await fs.readFile(path.join(process.cwd(), 'Dockerfile'), 'utf-8');\n281\t    assert.ok(content.includes('disallowedTools'), 'Dockerfile should configure disallowedTools');\n282\t    assert.ok(content.includes('AskUserQuestion'), 'Dockerfile disallowedTools should include AskUserQuestion');\n283\t    assert.ok(content.includes('CronCreate'), 'Dockerfile disallowedTools should include CronCreate');\n284\t    assert.ok(content.includes('issue #1627'), 'Dockerfile should reference issue #1627');\n285\t  });\n286\t\n287\t  await asyncTest('coolify/Dockerfile bakes disallowedTools into baseline ~/.claude/settings.json', async () => {\n288\t    const content = await fs.readFile(path.join(process.cwd(), 'coolify/Dockerfile'), 'utf-8');\n289\t    assert.ok(content.includes('disallowedTools'), 'coolify/Dockerfile should configure disallowedTools');\n290\t    assert.ok(content.includes('AskUserQuestion'), 'coolify/Dockerfile disallowedTools should include AskUserQuestion');\n291\t    assert.ok(content.includes('issue #1627'), 'coolify/Dockerfile should reference issue #1627');\n292\t  });\n293\t\n294\t  // ============================================================================\n295\t  // Summary\n296\t  // ============================================================================\n297\t\n298\t  console.log(`\\n📊 Results: ${testsPassed} passed, ${testsFailed} failed\\n`);\n299\t  if (testsFailed > 0) process.exit(1);\n300\t}\n301\t\n302\trunTests().catch(err => {\n303\t  console.error('Test runner error:', err);\n304\t  process.exit(1);\n305\t});\n306\t"
