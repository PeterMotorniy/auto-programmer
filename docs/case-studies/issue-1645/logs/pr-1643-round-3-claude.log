[2026-04-18T17:05:18.275Z] [INFO]         "content": "1\t#!/usr/bin/env node\n2\t\n3\t/**\n4\t * Wait for NPM package availability\n5\t * Usage: node scripts/wait-for-npm.mjs --release-version <version>\n6\t *   release-version: Version number to wait for (e.g., 1.0.0)\n7\t *\n8\t * This script waits for a specific version of @link-assistant/hive-mind\n9\t * to become available on the npm registry. This is necessary because there\n10\t * can be a delay between publishing and availability.\n11\t *\n12\t * Uses link-foundation libraries:\n13\t * - use-m: Dynamic package loading without package.json dependencies\n14\t * - command-stream: Modern shell command execution with streaming support\n15\t * - lino-arguments: Unified configuration from CLI args, env vars, and .lenv files\n16\t */\n17\t\n18\tconst PACKAGE_NAME = '@link-assistant/hive-mind';\n19\t\n20\t// Load use-m dynamically\n21\tconst { use } = eval(await (await fetch('https://unpkg.com/use-m/use.js')).text());\n22\t\n23\t// Import link-foundation libraries\n24\tconst { $ } = await use('command-stream');\n25\tconst { makeConfig } = await use('lino-arguments');\n26\t\n27\t// Parse CLI arguments using lino-arguments\n28\t// Note: Using --release-version instead of --version to avoid conflict with yargs' built-in --version flag\n29\tconst config = makeConfig({\n30\t  yargs: ({ yargs, getenv }) =>\n31\t    yargs\n32\t      .option('release-version', {\n33\t        type: 'string',\n34\t        default: getenv('VERSION', ''),\n35\t        describe: 'Version number to wait for (e.g., 1.0.0)',\n36\t      })\n37\t      .option('max-attempts', {\n38\t        type: 'number',\n39\t        default: getenv('MAX_ATTEMPTS', 30),\n40\t        describe: 'Maximum number of attempts to check npm',\n41\t      })\n42\t      .option('sleep-time', {\n43\t        type: 'number',\n44\t        default: getenv('SLEEP_TIME', 10),\n45\t        describe: 'Seconds to wait between attempts',\n46\t      }),\n47\t});\n48\t\n49\tconst { releaseVersion: version, maxAttempts, sleepTime } = config;\n50\t\n51\tif (!version) {\n52\t  console.error('Error: Version is required');\n53\t  console.error('Usage: node scripts/wait-for-npm.mjs --release-version <version>');\n54\t  process.exit(1);\n55\t}\n56\t\n57\t/**\n58\t * Sleep for specified seconds\n59\t * @param {number} seconds\n60\t */\n61\tfunction sleep(seconds) {\n62\t  return new Promise(resolve => globalThis.setTimeout(resolve, seconds * 1000));\n63\t}\n64\t\n65\tconsole.log(`Waiting for NPM package ${PACKAGE_NAME}@${version} to become available...`);\n66\t\n67\tfor (let i = 1; i <= maxAttempts; i++) {\n68\t  console.log(`Attempt ${i}/${maxAttempts}: Checking NPM registry...`);\n69\t\n70\t  try {\n71\t    const result = await $`npm view \"${PACKAGE_NAME}@${version}\" version`.run({ capture: true });\n72\t\n73\t    if (result.code === 0) {\n74\t      console.log(`Package ${PACKAGE_NAME}@${version} is now available on NPM!`);\n75\t      process.exit(0);\n76\t    }\n77\t  } catch (_error) {\n78\t    // Package not found yet, continue waiting\n79\t  }\n80\t\n81\t  if (i < maxAttempts) {\n82\t    console.log(`Package not yet available, waiting ${sleepTime} seconds...`);\n83\t    await sleep(sleepTime);\n84\t  }\n85\t}\n86\t\n87\tconsole.error(`Package ${PACKAGE_NAME}@${version} did not become available after ${maxAttempts * sleepTime} seconds`);\n88\tprocess.exit(1);\n89\t"
