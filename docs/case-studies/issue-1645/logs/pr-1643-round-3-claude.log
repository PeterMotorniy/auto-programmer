[2026-04-18T17:04:50.452Z] [INFO]         "content": "1\t# Hive Mind Docker image\n2\t# Inherits from konard/sandbox which provides all general-purpose development tools\n3\t# This image adds AI-specific tools (Claude CLI, OpenAI Codex, Playwright MCP, etc.)\n4\t#\n5\t# Architecture (see issue #1394, #1499, #1505 and sandbox#73, sandbox#74):\n6\t#   konard/sandbox (pinned version)\n7\t#     └── All general dev tools: Node.js, Bun, Deno, Python, Go, Rust, Java, PHP, etc.\n8\t#     └── Playwright browsers pre-installed (chromium, firefox, webkit, msedge, chrome)\n9\t#     └── /workspace directory owned by sandbox user\n10\t#   hive-mind (konard/hive-mind)\n11\t#     └── Inherits sandbox, adds AI coding assistants and Playwright MCP\n12\t#     └── Runs entirely as sandbox user (no USER root needed)\n13\t#\n14\t# Sandbox image version: pinned to a specific release for stable, reproducible builds.\n15\t# To upgrade: update the version tag below and in coolify/Dockerfile.\n16\t# Latest sandbox releases: https://hub.docker.com/r/konard/sandbox/tags\n17\t#\n18\t# Build: docker build -t konard/hive-mind .\n19\t\n20\tFROM konard/sandbox:1.6.0\n21\t\n22\t# --- Environment variables ---\n23\t# Set environment variables EARLY so they're available in subsequent RUN commands\n24\t# All paths use /workspace (shared directory owned by sandbox:sandbox)\n25\tENV HOME=/workspace\n26\tENV NVM_DIR=\"/workspace/.nvm\"\n27\tENV PYENV_ROOT=\"/workspace/.pyenv\"\n28\tENV BUN_INSTALL=\"/workspace/.bun\"\n29\tENV DENO_INSTALL=\"/workspace/.deno\"\n30\tENV CARGO_HOME=\"/workspace/.cargo\"\n31\tENV GOROOT=\"/workspace/.go\"\n32\tENV GOPATH=\"/workspace/.go/path\"\n33\tENV SDKMAN_DIR=\"/workspace/.sdkman\"\n34\tENV PERLBREW_ROOT=\"/workspace/.perl5\"\n35\tENV RBENV_ROOT=\"/workspace/.rbenv\"\n36\t\n37\t# Quiet, deterministic Claude Code defaults for autonomous solve runs (issue #1642)\n38\tENV CLAUDE_CODE_DISABLE_AUTO_MEMORY=1 \\\n39\t    CLAUDE_CODE_DISABLE_CRON=1 \\\n40\t    CLAUDE_CODE_DISABLE_TERMINAL_TITLE=1 \\\n41\t    CLAUDE_CODE_DISABLE_CLAUDE_MDS=1 \\\n42\t    CLAUDE_CODE_DISABLE_FAST_MODE=1 \\\n43\t    CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY=1 \\\n44\t    CLAUDE_CODE_DISABLE_MOUSE=1 \\\n45\t    CLAUDE_CODE_ENABLE_AWAY_SUMMARY=0 \\\n46\t    CLAUDE_CODE_ENABLE_TASKS=1 \\\n47\t    CLAUDE_CODE_MAX_TOOL_USE_CONCURRENCY=4 \\\n48\t    CLAUDE_CODE_RESUME_INTERRUPTED_TURN=1 \\\n49\t    DISABLE_FEEDBACK_COMMAND=1\n50\t\n51\t# Opam environment variables for Rocq/Coq theorem prover\n52\tENV OPAM_SWITCH_PREFIX=\"/workspace/.opam/default\"\n53\tENV CAML_LD_LIBRARY_PATH=\"/workspace/.opam/default/lib/stublibs:/workspace/.opam/default/lib/ocaml/stublibs:/workspace/.opam/default/lib/ocaml\"\n54\tENV OCAML_TOPLEVEL_PATH=\"/workspace/.opam/default/lib/toplevel\"\n55\t\n56\t# Comprehensive PATH including all tools\n57\t# Note: Node.js path is added dynamically since NVM version may vary\n58\t# Note: ~/.local/bin is included for user-installed binaries (e.g., opam binary from sandbox rocq image)\n59\tENV PATH=\"/home/linuxbrew/.linuxbrew/opt/php@8.3/bin:/home/linuxbrew/.linuxbrew/opt/php@8.3/sbin:/home/linuxbrew/.linuxbrew/bin:/workspace/.pyenv/bin:/workspace/.pyenv/shims:/workspace/.rbenv/bin:/workspace/.rbenv/shims:/workspace/.swift/usr/bin:/workspace/.elan/bin:/workspace/.opam/default/bin:/workspace/.local/bin:/workspace/.cargo/bin:/workspace/.deno/bin:/workspace/.bun/bin:/workspace/.go/bin:/workspace/.go/path/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin\"\n60\t\n61\t# Run entirely as sandbox user — no USER root needed (see issue #1505)\n62\tUSER sandbox\n63\tWORKDIR /workspace\n64\t\n65\t# Create a stable symlink to the active Node.js version's bin directory\n66\t# This allows us to add it to PATH without knowing the specific version\n67\tRUN NODE_VERSION_DIR=$(ls -d /workspace/.nvm/versions/node/v* 2>/dev/null | head -1) && \\\n68\t    if [ -n \"$NODE_VERSION_DIR\" ] && [ -d \"$NODE_VERSION_DIR/bin\" ]; then \\\n69\t      ln -sf \"$NODE_VERSION_DIR/bin\" /workspace/.node-bin; \\\n70\t    fi\n71\t\n72\tENV PATH=\"/workspace/.node-bin:${PATH}\"\n73\t\n74\t# --- Install opam binary ---\n75\t# The sandbox full image copies ~/.opam (opam switch data) from the rocq stage"
