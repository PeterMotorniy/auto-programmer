[2026-04-18T17:04:23.231Z] [INFO]         "content": "110\t    bun install -g start-command && \\\n111\t    bun install -g gh-setup-git-identity && \\\n112\t    bun install -g gh-pull-all && \\\n113\t    bun install -g gh-load-issue && \\\n114\t    bun install -g gh-load-pull-request && \\\n115\t    bun install -g gh-upload-log\n116\t\n117\t# --- Playwright MCP Setup ---\n118\t# Sandbox 1.6.0 pre-installs Playwright browsers and @playwright/test (sandbox#74).\n119\t# We only add @playwright/mcp (AI-specific MCP server for Claude/Codex).\n120\t# --force handles the shared 'playwright' binary conflict between packages.\n121\tRUN npm install -g @playwright/mcp@latest --no-fund --force\n122\t\n123\t# Configure Playwright MCP for Claude CLI — fail the build if registration fails (issue #1514)\n124\tRUN if command -v claude &>/dev/null; then \\\n125\t      claude mcp add playwright -s user -- npx -y @playwright/mcp@latest --isolated --headless --no-sandbox --timeout-action=600000 --viewport-size 1920x1080; \\\n126\t    fi\n127\t\n128\t# Configure Playwright MCP for Codex CLI with the same server settings\n129\tRUN if command -v codex &>/dev/null; then \\\n130\t      codex mcp add playwright -- npx -y @playwright/mcp@latest --isolated --headless --no-sandbox --timeout-action=600000 --viewport-size 1920x1080; \\\n131\t    fi\n132\t\n133\t# --- Disable noisy/unused Claude Code features and tools (issue #1627, issue #1642) ---\n134\t# Autonomous headless hive-mind runs never benefit from tools that wait for\n135\t# human interaction or leave persistent side effects. Pre-seed the\n136\t# user-scope ~/.claude/settings.json disallowedTools list so that even\n137\t# interactive claude sessions in this image do not surface them. The three\n138\t# claude.ai OAuth connectors (Gmail/Google Drive/Google Calendar) cannot be\n139\t# removed via `claude mcp remove` because they are not registered under\n140\t# user/local/project scope; solve.mjs filters them at run time using\n141\t# --strict-mcp-config --mcp-config <temp-file>.\n142\tRUN mkdir -p /workspace/.claude && \\\n143\t    node -e \" \\\n144\tconst fs = require('fs'); \\\n145\tconst p = '/workspace/.claude/settings.json'; \\\n146\tconst blocked = ['AskUserQuestion','CronCreate','CronDelete','CronList','EnterPlanMode','EnterWorktree','ExitPlanMode','ExitWorktree','Monitor','NotebookEdit','PushNotification','RemoteTrigger','ScheduleWakeup','mcp__claude_ai_Gmail__*','mcp__claude_ai_Google_Drive__*','mcp__claude_ai_Google_Calendar__*']; \\\n147\tconst quietEnv = { CLAUDE_CODE_DISABLE_AUTO_MEMORY: '1', CLAUDE_CODE_DISABLE_CRON: '1', CLAUDE_CODE_DISABLE_TERMINAL_TITLE: '1', CLAUDE_CODE_DISABLE_CLAUDE_MDS: '1', CLAUDE_CODE_DISABLE_FAST_MODE: '1', CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY: '1', CLAUDE_CODE_DISABLE_MOUSE: '1', CLAUDE_CODE_ENABLE_AWAY_SUMMARY: '0', CLAUDE_CODE_ENABLE_TASKS: '1', CLAUDE_CODE_MAX_TOOL_USE_CONCURRENCY: '4', CLAUDE_CODE_RESUME_INTERRUPTED_TURN: '1', DISABLE_FEEDBACK_COMMAND: '1' }; \\\n148\tconst quietSettings = { autoMemoryEnabled: false, spinnerTipsEnabled: false, awaySummaryEnabled: false, feedbackSurveyRate: 0, includeCoAuthoredBy: false, includeGitInstructions: true, prefersReducedMotion: true, showThinkingSummaries: false, skipDangerousModePermissionPrompt: true, viewMode: 'verbose' }; \\\n149\tconst quietAttribution = { commit: '', pr: '' }; \\\n150\tconst quietPermissions = { defaultMode: 'bypassPermissions' }; \\\n151\tlet s = {}; \\\n152\ttry { s = JSON.parse(fs.readFileSync(p, 'utf-8')); } catch (e) {} \\\n153\tif (!s || typeof s !== 'object' || Array.isArray(s)) s = {}; \\\n154\tfor (const [key, value] of Object.entries(quietSettings)) s[key] = value; \\\n155\ts.attribution = s.attribution && typeof s.attribution === 'object' && !Array.isArray(s.attribution) ? s.attribution : {}; \\\n156\tfor (const [key, value] of Object.entries(quietAttribution)) s.attribution[key] = value; \\\n157\ts.permissions = s.permissions && typeof s.permissions === 'object' && !Array.isArray(s.permissions) ? s.permissions : {}; \\\n158\tfor (const [key, value] of Object.entries(quietPermissions)) s.permissions[key] = value; \\\n159\ts.env = s.env && typeof s.env === 'object' && !Array.isArray(s.env) ? s.env : {}; \\\n160\tfor (const [key, value] of Object.entries(quietEnv)) s.env[key] = value; \\\n161\tconst existing = Array.isArray(s.disallowedTools) ? s.disallowedTools : []; \\\n162\tconst merged = [...existing]; \\\n163\tfor (const t of blocked) if (!merged.includes(t)) merged.push(t); \\\n164\ts.disallowedTools = merged; \\\n165\tfs.writeFileSync(p, JSON.stringify(s, null, 2)); \\\n166\tconsole.log('Configured quiet Claude Code defaults and', merged.length, 'disallowedTools in', p); \\\n167\t\"\n168\t\n169\t# --- Application Setup ---"
