[2026-04-18T17:04:17.561Z] [INFO]         "content": "120\t    bun install -g gh-upload-log\n121\t\n122\t# --- Playwright MCP Setup ---\n123\t# Sandbox 1.6.0 pre-installs Playwright browsers and @playwright/test (sandbox#74).\n124\t# We only add @playwright/mcp (AI-specific MCP server for Claude/Codex).\n125\t# --force handles the shared 'playwright' binary conflict between packages.\n126\tRUN npm install -g @playwright/mcp@latest --no-fund --force\n127\t\n128\t# Configure Playwright MCP for Claude CLI — fail the build if registration fails (issue #1514)\n129\tRUN if command -v claude &>/dev/null; then \\\n130\t      claude mcp add playwright -s user -- npx -y @playwright/mcp@latest --isolated --headless --no-sandbox --timeout-action=600000 --viewport-size 1920x1080; \\\n131\t    fi\n132\t\n133\t# Configure Playwright MCP for Codex CLI with the same server settings\n134\tRUN if command -v codex &>/dev/null; then \\\n135\t      codex mcp add playwright -- npx -y @playwright/mcp@latest --isolated --headless --no-sandbox --timeout-action=600000 --viewport-size 1920x1080; \\\n136\t    fi\n137\t\n138\t# --- Disable noisy/unused Claude Code features and tools (issue #1627, issue #1642) ---\n139\t# Autonomous headless hive-mind runs never benefit from tools that wait for\n140\t# human interaction (AskUserQuestion, EnterPlanMode) or that register local\n141\t# session cron jobs (CronCreate/List/Delete) or create worktrees\n142\t# (EnterWorktree/ExitWorktree) or fire mobile notifications\n143\t# (PushNotification) or kick off remote agent triggers (RemoteTrigger)\n144\t# or create notebook cells (NotebookEdit) or monitor processes (Monitor) or\n145\t# self-schedule wakeups (ScheduleWakeup). Pre-seed the user-scope\n146\t# ~/.claude/settings.json disallowedTools list so that even interactive\n147\t# claude sessions in this image do not surface them.\n148\t# The three claude.ai OAuth connectors (Gmail/Google Drive/Google Calendar)\n149\t# cannot be removed via `claude mcp remove` because they are not registered\n150\t# under user/local/project scope; solve.mjs filters them at run time using\n151\t# --strict-mcp-config --mcp-config <temp-file>.\n152\tRUN mkdir -p /workspace/.claude && \\\n153\t    node -e \" \\\n154\tconst fs = require('fs'); \\\n155\tconst p = '/workspace/.claude/settings.json'; \\\n156\tconst blocked = ['AskUserQuestion','CronCreate','CronDelete','CronList','EnterPlanMode','EnterWorktree','ExitPlanMode','ExitWorktree','Monitor','NotebookEdit','PushNotification','RemoteTrigger','ScheduleWakeup','mcp__claude_ai_Gmail__*','mcp__claude_ai_Google_Drive__*','mcp__claude_ai_Google_Calendar__*']; \\\n157\tconst quietEnv = { CLAUDE_CODE_DISABLE_AUTO_MEMORY: '1', CLAUDE_CODE_DISABLE_CRON: '1', CLAUDE_CODE_DISABLE_TERMINAL_TITLE: '1', CLAUDE_CODE_DISABLE_CLAUDE_MDS: '1', CLAUDE_CODE_DISABLE_FAST_MODE: '1', CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY: '1', CLAUDE_CODE_DISABLE_MOUSE: '1', CLAUDE_CODE_ENABLE_AWAY_SUMMARY: '0', CLAUDE_CODE_ENABLE_TASKS: '1', CLAUDE_CODE_MAX_TOOL_USE_CONCURRENCY: '4', CLAUDE_CODE_RESUME_INTERRUPTED_TURN: '1', DISABLE_FEEDBACK_COMMAND: '1' }; \\\n158\tconst quietSettings = { autoMemoryEnabled: false, spinnerTipsEnabled: false, awaySummaryEnabled: false, feedbackSurveyRate: 0, includeCoAuthoredBy: false, includeGitInstructions: true, prefersReducedMotion: true, showThinkingSummaries: false, skipDangerousModePermissionPrompt: true, viewMode: 'verbose' }; \\\n159\tconst quietAttribution = { commit: '', pr: '' }; \\\n160\tconst quietPermissions = { defaultMode: 'bypassPermissions' }; \\\n161\tlet s = {}; \\\n162\ttry { s = JSON.parse(fs.readFileSync(p, 'utf-8')); } catch (e) {} \\\n163\tif (!s || typeof s !== 'object' || Array.isArray(s)) s = {}; \\\n164\tfor (const [key, value] of Object.entries(quietSettings)) s[key] = value; \\\n165\ts.attribution = s.attribution && typeof s.attribution === 'object' && !Array.isArray(s.attribution) ? s.attribution : {}; \\\n166\tfor (const [key, value] of Object.entries(quietAttribution)) s.attribution[key] = value; \\\n167\ts.permissions = s.permissions && typeof s.permissions === 'object' && !Array.isArray(s.permissions) ? s.permissions : {}; \\\n168\tfor (const [key, value] of Object.entries(quietPermissions)) s.permissions[key] = value; \\\n169\ts.env = s.env && typeof s.env === 'object' && !Array.isArray(s.env) ? s.env : {}; \\\n170\tfor (const [key, value] of Object.entries(quietEnv)) s.env[key] = value; \\\n171\tconst existing = Array.isArray(s.disallowedTools) ? s.disallowedTools : []; \\\n172\tconst merged = [...existing]; \\\n173\tfor (const t of blocked) if (!merged.includes(t)) merged.push(t); \\\n174\ts.disallowedTools = merged; \\\n175\tfs.writeFileSync(p, JSON.stringify(s, null, 2)); \\\n176\tconsole.log('Configured quiet Claude Code defaults and', merged.length, 'disallowedTools in', p); \\\n177\t\"\n178\t\n179\tSHELL [\"/bin/bash\", \"-c\"]\n180\tCMD [\"/bin/bash\"]\n181\t"
