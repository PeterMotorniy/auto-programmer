[2026-04-18T17:04:37.228Z] [INFO]         "content": "1\t#!/usr/bin/env node\n2\t\n3\timport assert from 'node:assert/strict';\n4\timport fs from 'node:fs/promises';\n5\timport os from 'node:os';\n6\timport path from 'node:path';\n7\t\n8\timport { ensureClaudeQuietConfig, REQUIRED_CLAUDE_QUIET_ENV, REQUIRED_CLAUDE_QUIET_SETTINGS, REQUIRED_CLAUDE_QUIET_ATTRIBUTION, REQUIRED_CLAUDE_QUIET_PERMISSIONS } from '../src/claude-quiet-config.lib.mjs';\n9\timport { getClaudeEnv } from '../src/config.lib.mjs';\n10\t\n11\tconst claudeEnv = getClaudeEnv();\n12\tfor (const [name, value] of Object.entries(REQUIRED_CLAUDE_QUIET_ENV)) {\n13\t  assert.equal(claudeEnv[name], value, `getClaudeEnv should force ${name}=${value}`);\n14\t}\n15\t\n16\t// CLAUDE_CODE_DISABLE_GIT_INSTRUCTIONS must NOT be forced — built-in git/PR\n17\t// guidance is useful for our solve runs (per maintainer feedback on PR #1643).\n18\t// The includeGitInstructions setting is what turns it on.\n19\tassert.ok(!Object.prototype.hasOwnProperty.call(REQUIRED_CLAUDE_QUIET_ENV, 'CLAUDE_CODE_DISABLE_GIT_INSTRUCTIONS'), 'REQUIRED_CLAUDE_QUIET_ENV must not disable git instructions — includeGitInstructions keeps them on');\n20\t\n21\tconst claudeLibContent = await fs.readFile(path.join(process.cwd(), 'src/claude.lib.mjs'), 'utf-8');\n22\tassert.ok(claudeLibContent.includes('ensureClaudeQuietConfig({ log })'), 'claude.lib should verify global Claude quiet config before launching Claude');\n23\tassert.ok(claudeLibContent.includes('--dangerously-skip-permissions'), 'claude.lib should still pass --dangerously-skip-permissions as belt-and-suspenders for the bypassPermissions defaultMode');\n24\t\n25\tconst tmp = await fs.mkdtemp(path.join(os.tmpdir(), 'claude-quiet-config-'));\n26\ttry {\n27\t  const settingsPath = path.join(tmp, 'settings.json');\n28\t  await fs.writeFile(\n29\t    settingsPath,\n30\t    JSON.stringify({\n31\t      theme: 'dark',\n32\t      disallowedTools: ['CustomTool'],\n33\t      attribution: {\n34\t        commit: 'custom-commit-trailer',\n35\t      },\n36\t      permissions: {\n37\t        additionalDirectories: ['/tmp/preserved'],\n38\t      },\n39\t      env: {\n40\t        CUSTOM_SETTING: 'preserved',\n41\t        CLAUDE_CODE_DISABLE_AUTO_MEMORY: '0',\n42\t      },\n43\t    })\n44\t  );\n45\t\n46\t  const logs = [];\n47\t  const result = await ensureClaudeQuietConfig({ settingsPath, log: async line => logs.push(line) });\n48\t  const written = JSON.parse(await fs.readFile(settingsPath, 'utf-8'));\n49\t\n50\t  assert.equal(result.changed, true, 'first merge should update missing or incorrect target keys');\n51\t  assert.ok(\n52\t    logs.some(line => line.includes('Claude Code quiet config updated')),\n53\t    'merge should log the effective quiet configuration'\n54\t  );\n55\t  assert.equal(written.theme, 'dark', 'unrelated settings should be preserved');\n56\t  assert.deepEqual(written.disallowedTools, ['CustomTool'], 'existing unrelated arrays should be preserved');\n57\t  assert.deepEqual(written.permissions.additionalDirectories, ['/tmp/preserved'], 'unrelated permissions subkeys should be preserved');\n58\t  assert.equal(written.env.CUSTOM_SETTING, 'preserved', 'unrelated env values should be preserved');\n59\t  for (const [name, value] of Object.entries(REQUIRED_CLAUDE_QUIET_ENV)) {\n60\t    assert.equal(written.env[name], value, `settings env should force ${name}=${value}`);\n61\t  }\n62\t  for (const [name, value] of Object.entries(REQUIRED_CLAUDE_QUIET_SETTINGS)) {\n63\t    assert.deepEqual(written[name], value, `settings should force ${name}=${JSON.stringify(value)}`);\n64\t  }\n65\t  for (const [name, value] of Object.entries(REQUIRED_CLAUDE_QUIET_ATTRIBUTION)) {\n66\t    assert.equal(written.attribution[name], value, `attribution should force ${name}=${JSON.stringify(value)}`);\n67\t  }\n68\t  for (const [name, value] of Object.entries(REQUIRED_CLAUDE_QUIET_PERMISSIONS)) {\n69\t    assert.equal(written.permissions[name], value, `permissions should force ${name}=${JSON.stringify(value)}`);\n70\t  }\n71\t  assert.equal(Object.prototype.hasOwnProperty.call(written.env, 'CLAUDE_CODE_DISABLE_GIT_INSTRUCTIONS'), false, 'settings env should NOT set CLAUDE_CODE_DISABLE_GIT_INSTRUCTIONS — git instructions are kept on via includeGitInstructions');\n72\t\n73\t  const secondResult = await ensureClaudeQuietConfig({ settingsPath, log: async () => {} });\n74\t  assert.equal(secondResult.changed, false, 'second merge should verify without rewriting already-correct config');\n75\t} finally {\n76\t  await fs.rm(tmp, { recursive: true, force: true });\n77\t}\n78\t\n79\tfor (const file of ['Dockerfile', 'coolify/Dockerfile']) {\n80\t  const content = await fs.readFile(path.join(process.cwd(), file), 'utf-8');\n81\t  for (const [name, value] of Object.entries(REQUIRED_CLAUDE_QUIET_ENV)) {\n82\t    assert.ok(content.includes(`${name}=${value}`) || content.includes(`${name}: '${value}'`), `${file} should configure ${name}=${value}`);\n83\t  }\n84\t  assert.ok(!content.includes('CLAUDE_CODE_DISABLE_GIT_INSTRUCTIONS'), `${file} should not set CLAUDE_CODE_DISABLE_GIT_INSTRUCTIONS — built-in git instructions are kept on`);\n85\t  for (const [name, value] of Object.entries(REQUIRED_CLAUDE_QUIET_SETTINGS)) {\n86\t    const serialized = JSON.stringify(value);\n87\t    const singleQuoted = typeof value === 'string' ? `${name}: '${value}'` : null;\n88\t    assert.ok(content.includes(`${name}: ${value}`) || content.includes(`${name}: ${serialized}`) || content.includes(`\"${name}\": ${serialized}`) || (singleQuoted && content.includes(singleQuoted)), `${file} should configure ${name}: ${serialized}`);\n89\t  }\n90\t  assert.ok(content.includes(\"commit: ''\") && content.includes(\"pr: ''\"), `${file} should configure attribution commit/pr overrides`);\n91\t  for (const [name, value] of Object.entries(REQUIRED_CLAUDE_QUIET_PERMISSIONS)) {\n92\t    const singleQuoted = typeof value === 'string' ? `${name}: '${value}'` : null;\n93\t    assert.ok((singleQuoted && content.includes(singleQuoted)) || content.includes(`${name}: ${JSON.stringify(value)}`) || content.includes(`\"${name}\": ${JSON.stringify(value)}`), `${file} should configure permissions.${name}=${JSON.stringify(value)}`);\n94\t  }\n95\t  assert.ok(content.includes('issue #1642'), `${file} should reference issue #1642`);\n96\t}\n97\t\n98\tconsole.log('Claude quiet configuration tests passed');\n99\t"
