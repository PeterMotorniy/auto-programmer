gurations (in milliseconds)\n47\texport const timeouts = {\n48\t  claudeCli: parseIntWithDefault('HIVE_MIND_CLAUDE_TIMEOUT_SECONDS', 60) * 1000,\n49\t  opencodeCli: parseIntWithDefault('HIVE_MIND_OPENCODE_TIMEOUT_SECONDS', 60) * 1000,\n50\t  codexCli: parseIntWithDefault('HIVE_MIND_CODEX_TIMEOUT_SECONDS', 60) * 1000,\n51\t  githubApiDelay: parseIntWithDefault('HIVE_MIND_GITHUB_API_DELAY_MS', 5000),\n52\t  githubRepoDelay: parseIntWithDefault('HIVE_MIND_GITHUB_REPO_DELAY_MS', 2000),\n53\t  retryBaseDelay: parseIntWithDefault('HIVE_MIND_RETRY_BASE_DELAY_MS', 5000),\n54\t  retryBackoffDelay: parseIntWithDefault('HIVE_MIND_RETRY_BACKOFF_DELAY_MS', 1000),\n55\t  // Issue #1280: Timeout (ms) to wait for stream close after result event before force-killing\n56\t  // command-stream's stream() waits for process exit + pipe close; if stdout stays open, it hangs\n57\t  resultStreamCloseMs: parseIntWithDefault('HIVE_MIND_RESULT_STREAM_CLOSE_MS', 30000),\n58\t  // Issue #1472/#1475: Timeout (ms) to wait for first stream output from Claude CLI after startup.\n59\t  // If no stdout/stderr output is received within this period, the process is considered stuck\n60\t  // and will be force-killed. Both affected sessions showed ~4.5h with zero output from Claude CLI.\n61\t  // Default: 120000ms (2 minutes) — Claude CLI normally emits system.init within 1-3 seconds.\n62\t  streamStartupMs: parseIntWithDefault('HIVE_MIND_STREAM_STARTUP_MS', 120000),\n63\t  // Issue #1472: Activity timeout (ms) — if no new stream output is received for this duration\n64\t  // after at least one event was received, the process is considered hung mid-session.\n65\t  // This catches the case where Claude CLI starts producing output but then stops (e.g., the\n66\t  // original Issue #1472 where CLI was stuck for 4.5h with all output arriving only at CTRL+C).\n67\t  // Issue #1510: Increased from 300000ms (5 min) to 3600000ms (1 hour) because Claude Code can\n68\t  // legitimately wait for long-running operations (docker builds, CI polls, large compilations).\n69\t  // The 5-minute timeout was force-killing sessions during `sleep 300 && gh run view ...` commands.\n70\t  // Default: 3600000ms (1 hour). Set to 0 to disable. Configurable via environment variable.\n71\t  streamActivityMs: parseIntWithDefault('HIVE_MIND_STREAM_ACTIVITY_MS', 3600000),\n72\t};\n73\t\n74\t// Auto-continue configurations\n75\texport const autoContinue = {\n76\t  ageThresholdHours: parseIntWithDefault('HIVE_MIND_AUTO_CONTINUE_AGE_HOURS', 24),\n77\t};\n78\t\n79\t// Auto-resume on limit reset configurations\n80\t// See: https://github.com/link-assistant/hive-mind/issues/1152\n81\t// See: https://github.com/link-assistant/hive-mind/issues/1236\n82\texport const limitReset = {\n83\t  // Buffer time to wait after limit reset (in milliseconds)\n84\t  // Default: 10 minutes - accounts for server time differences and API propagation delays\n85\t  // Increased from 5 to 10 minutes to reduce risk of hitting limits again immediately\n86\t  // See: https://github.com/link-assistant/hive-mind/issues/1236\n87\t  bufferMs: parseIntWithDefault('HIVE_MIND_LIMIT_RESET_BUFFER_MS', 10 * 60 * 1000),\n88\t  // Random jitter added to buffer to avoid thundering herd problem (in milliseconds)\n89\t  // When multiple instances wait for the same limit reset, jitter distributes their\n90\t  // resume times to reduce simultaneous API load\n91\t  // Default: 5 minutes (0 to 5 minutes random) - total wait after reset: 10-15 minutes\n92\t  // See: https://github.com/link-assistant/hive-mind/issues/1236\n93\t  jitterMs: parseIntWithDefault('HIVE_MIND_LIMIT_RESET_JITTER_MS', 5 * 60 * 1000),\n94\t};\n95\t\n96\t// GitHub API limits\n97\texport const githubLimits = {\n98\t  commentMaxSize: parseIntWithDefault('HIVE_MIND_GITHUB_COMMENT_MAX_SIZE', 65536),\n99\t  fileMaxSize: parseIntWithDefault('HIVE_MIND_GITHUB_FILE_MAX_SIZE', 25 * 1024 * 1024),\n100\t  issueBodyMaxSize: parseIntWithDefault('HIVE_MIND_GITHUB_ISSUE_BODY_MAX_SIZE', 60000),\n101\t  attachmentMaxSize: parseIntWithDefault('HIVE_MIND_GITHUB_ATTACHMENT_MAX_SIZE', 10 * 1024 * 1024),\n102\t  bufferMaxSize: parseIntWithDefault('HIVE_MIND_GITHUB_BUFFER_MAX_SIZE', 10 * 1024 * 1024),\n103\t};\n104\t\n105\t// Memory and disk configurations\n106\texport const systemLimits = {\n107\t  minDiskSpaceMb: parseIntWithDefault('HIVE_MIND_MIN_DISK_SPACE_MB', 2048),\n108\t  defaultPageSizeKb: parseIntWithDefault('HIVE_MIND_DEFAULT_PAGE_SIZE_KB', 16),\n109\t};\n110\t\n111\t// Retry configurations\n112\t// Issue #1331: All API error types use unified retry parameters:\n113\t// 10 max retries, 2 minute initial delay, 30 minute max delay (exponential backoff), session preserved\n114\texport const retryLimits = {\n115\t  maxForkRetries: parseIntWithDefault('HIVE_MIND_MAX_FORK_RETRIES', 5),\n116\t  maxVerifyRetries: parseIntWithDefault('HIVE_MIND_MAX_VERIFY_RETRIES', 5),\n117\t  maxApiRetries: parseIntWithDefault('HIVE_MIND_MAX_API_RETRIES', 3),\n118\t  retryBackoffMultiplier: parseFloatWithDefault('HIVE_MIND_RETRY_BACKOFF_MULTIPLIER', 2),\n119\t  // Unified retry config for all transient API errors (Overloaded, 503, Internal Server Error)\n120\t  maxTransientErrorRetries: parseIntWithDefault('HIVE_MIND_MAX_TRANSIENT_ERROR_RETRIES', 10),\n121\t  initialTransientErrorDelayMs: parseIntWithDefault('HIVE_MIND_INITIAL_TRANSIENT_ERROR_DELAY_MS', 2 * 60 * 1000), // 2 minutes\n122\t  maxTransientErrorDelayMs: parseIntWithDefault('HIVE_MIND_MAX_TRANSIENT_ERROR_DELAY_MS', 30 * 60 * 1000), // 30 minutes\n123\t  // Request timeout retry configuration (Issue #1353)\n124\t  // Network timeouts need longer waits than API errors — Claude CLI already exhausted its own retries\n125\t  maxRequestTimeoutRetries: parseIntWithDefault('HIVE_MIND_MAX_REQUEST_TIMEOUT_RETRIES', 10),\n126\t  initialRequestTimeoutDelayMs: parseIntWithDefault('HIVE_MIND_INITIAL_REQUEST_TIMEOUT_DELAY_MS', 5 * 60 * 1000), // 5 minutes\n127\t  maxRequestTimeoutDelayMs: parseIntWithDefault('HIVE_MIND_MAX_REQUEST_TIMEOUT_DELAY_MS', 60 * 60 * 1000), // 1 hour\n128\t  // Not-retryable error fail-fast configuration (Issue #1437)\n129\t  // When the API sends x-should-retry: false AND retries make no progress (num_turns <= 1),\n130\t  // stop retrying after this many attempts to avoid a stuck loop with no recovery prospects.\n131\t  // Default: 5 — retry generously even when API signals not retryable, since the signal can be wrong\n132\t  // for transient backend glitches (e.g. overloaded errors observed as non-retryable 500s).\n133\t  maxNotRetryableAttempts: parseIntWithDefault('HIVE_MIND_MAX_NOT_RETRYABLE_ATTEMPTS', 5),\n134\t};\n135\t\n136\t// Claude Code CLI configurations\n137\t// See: https://github.com/link-assistant/hive-mind/issues/1076\n138\t// Claude models support different max output tokens:\n139\t// - Opus 4.6 (default 'opus' alias): 128K tokens (Issue #1221, Issue #1433)\n140\t// - Sonnet 4.5, Opus 4.5, Haiku 4.5: 64K tokens\n141\t// Setting a higher limit allows Claude to generate longer responses without hitting the limit\n142\texport const claudeCode = {\n143\t  // Maximum output tokens for Claude Code CLI responses\n144\t  // Default: 64000 (matches Claude Sonnet/Opus/Haiku 4.5 model capabilities)\n145\t  // Set via CLAUDE_CODE_MAX_OUTPUT_TOKENS or HIVE_MIND_CLAUDE_CODE_MAX_OUTPUT_TOKENS\n146\t  maxOutputTokens: parseIntWithDefault('CLAUDE_CODE_MAX_OUTPUT_TOKENS', parseIntWithDefault('HIVE_MIND_CLAUDE_CODE_MAX_OUTPUT_TOKENS', 64000)),\n147\t  // Maximum output tokens for Opus 4.6 (Issue #1221)\n148\t  // See: https://platform.claude.com/docs/en/about-claude/models/overview\n149\t  maxOutputTokensOpus46: parseIntWithDefault('CLAUDE_CODE_MAX_OUTPUT_TOKENS_OPUS_46', parseIntWithDefault('HIVE_MIND_CLAUDE_CODE_MAX_OUTPUT_TOKENS_OPUS_46', 128000)),\n150\t  // MCP (Model Context Protocol) timeout configurations\n151\t  // See: https://github.com/link-assistant/hive-mind/issues/1066\n152\t  // See: https://code.claude.com/docs/en/settings#environment-variables\n153\t  // MCP_TIMEOUT: Timeout in milliseconds for MCP server startup\n154\t  // MCP_TOOL_TIMEOUT: Timeout in milliseconds for MCP tool execution\n155\t  // Default: 900000ms (15 minutes) to accommodate long-running Playwright operations\n156\t  // Set via MCP_TIMEOUT/MCP_TOOL_TIMEOUT or HIVE_MIND_MCP_TIMEOUT/HIVE_MIND_MCP_TOOL_TIMEOUT\n157\t  mcpTimeout: parseIntWithDefault('MCP_TIMEOUT', parseIntWithDefault('HIVE_MIND_MCP_TIMEOUT', 900000)),\n158\t  mcpToolTimeout: parseIntWithDefault('MCP_TOOL_TIMEOUT', parseIntWithDefault('HIVE_MIND_MCP_TOOL_TIMEOUT', 900000)),\n159\t};\n160\t\n161\t// Default max thinking budget for Claude Code (see issue #1146)\n162\t// This is the default value used by Claude Code when extended thinking is enabled\n163\t// Can be overridden via --max-thinking-budget option\n164\texport const DEFAULT_MAX_THINKING_BUDGET = 31999;\n165\t\n166\t// Default max thinking budget for Opus 4.6 (Issue #1221, updated in Issue #1238)\n167\t// Aligned with standard models (31999) for consistency.\n168\t// Opus 4.6 uses CLAUDE_CODE_EFFORT_LEVEL for thinking depth instead of MAX_THINKING_TOKENS\n169\t// (MAX_THINKING_TOKENS is ignored for Opus 4.6 unless set to 0 to disable thinking).\n170\t// Can be overridden via --max-thinking-budget option or HIVE_MIND_MAX_THINKING_BUDGET_OPUS_46\n171\texport const DEFAULT_MAX_THINKING_BUDGET_OPUS_46 = parseIntWithDefault('HIVE_MIND_MAX_THINKING_BUDGET_OPUS_46', 31999);\n172\t\n173\t/**\n174\t * Check if a model is Opus 4.6 or later (Issue #1221, updated in Issue #1238)\n175\t * @param {string} model - The model name or ID\n176\t * @returns {boolean} True if the model is Opus 4.6 or later\n177\t */\n178\texport const isOpus46OrLater = model => {\n179\t  if (!model) return false;\n180\t  const normalizedModel = model.toLowerCase();\n181\t  // Check for explicit opus-4-6 or later versions, or opusplan (Issue #1223)\n182\t  // Note: The 'opus' alias now maps to Opus 4.7 (Issue #1620), so we also check for the alias directly\n183\t  // opusplan uses Opus for planning, so it should get Opus-level settings\n184\t  return normalizedModel === 'opus' || normalizedModel === 'opusplan' || normalizedModel.includes('opus-4-6') || normalizedModel.includes('opus-4-7') || normalizedModel.includes('opus-5');\n185\t};\n186\t\n187\tconst isOpus47 = model => {\n188\t  if (!model) return false;\n189\t  const normalizedModel = model.toLowerCase();\n190\t  // 'opus' alias now maps to Opus 4.7 (Issue #1620)\n191\t  // opusplan uses Opus for planning, so it gets Opus-level settings\n192\t  return normalizedModel === 'opus' || normalizedModel === 'opusplan' || normalizedModel.includes('opus-4-7');\n193\t};\n194\t\n195\t/**\n196\t * Check if a model is Opus 4.7 or later (Issue #1620)\n197\t * These models use Opus 4.7+ adaptive thinking behavior.\n198\t * @param {string} model - The model name or ID\n199\t * @returns {boolean} True if the model is Opus 4.7 or later\n200\t */\n201\texport const isOpus47OrLater = model => {\n202\t  if (!model) return false;\n203\t  const normalizedModel = model.toLowerCase();\n204\t  return isOpus47(model) || normalizedModel.includes('opus-5');\n205\t};\n206\t\n207\tconst isOpus45 = model => {\n208\t  if (!model) return false;\n209\t  const m = model.toLowerCase();\n210\t  return m === 'opus-4-5' || m.includes('opus-4-5');\n211\t};\n212\t\n213\tconst isOpus46 = model => {\n214\t  if (!model) return false;\n215\t  const m = model.toLowerCase();\n216\t  return m === 'opus-4-6' || m.includes('opus-4-6');\n217\t};\n218\t\n219\tconst isSonnet46OrLater = model => {\n220\t  if (!model) return false;\n221\t  const m = model.toLowerCase();\n222\t  return m === 'sonnet' || m === 'sonnet-4-6' || m.includes('sonnet-4-6') || m.includes('sonnet-5');\n223\t};\n224\t\n225\tconst isMythosPreview = model => {\n226\t  if (!model) return false;\n227\t  return model.toLowerCase().includes('mythos');\n228\t};\n229\t\n230\t/**\n231\t * Check if a model supports CLAUDE_CODE_EFFORT_LEVEL (Issue #1238, Issue #1620)\n232\t * Official effort support: Claude Mythos Preview, Opus 4.7, Opus 4.6, Sonnet 4.6, and Opus 4.5.\n233\t * Haiku 4.5 and older models use MAX_THINKING_TOKENS only.\n234\t * @param {string} model - The model name or ID\n235\t * @returns {boolean} True if the model supports effort levels\n236\t */\n237\texport const supportsEffortLevel = model => {\n238\t  if (!model) return false;\n239\t  return isMythosPreview(model) || isOpus47OrLater(model) || isOpus46(model) || isSonnet46OrLater(model) || isOpus45(model);\n240\t};\n241\t\n242\t/**\n243\t * Check if a model supports the xhigh effort level.\n244\t * Official docs list xhigh only for Claude Opus 4.7.\n245\t * @param {string} model - The model name or ID\n246\t * @returns {boolean} True if the model supports xhigh effort\n247\t */\n248\texport const supportsXHighEffortLevel = model => isOpus47(model);\n249\t\n250\t/**\n251\t * Check if a model supports the max effort level.\n252\t * Official docs list max for Claude Mythos Preview, Opus 4.7, Opus 4.6, and Sonnet 4.6.\n253\t * @param {string} model - The model name or ID\n254\t * @returns {boolean} True if the model supports max effort\n255\t */\n256\texport const supportsMaxEffortLevel = model => isMythosPreview(model) || isOpus47OrLater(model) || isOpus46(model) || isSonnet46OrLater(model);\n257\t\n258\t/**\n259\t * Get the max output tokens for a specific model (Issue #1221)\n260\t * @param {string} model - The model name or ID\n261\t * @returns {number} The max output tokens for the model\n262\t */\n263\texport const getMaxOutputTokensForModel = model => {\n264\t  if (isOpus46OrLater(model)) {\n265\t    return claudeCode.maxOutputTokensOpus46;\n266\t  }\n267\t  return claudeCode.maxOutputTokens;\n268\t};\n269\t\n270\t/**\n271\t * Get the default max thinking budget for a specific model (Issue #1221)\n272\t * @param {string} model - The model name or ID\n273\t * @returns {number} The default max thinking budget for the model\n274\t */\n275\texport const getDefaultMaxThinkingBudgetForModel = model => {\n276\t  if (isOpus46OrLater(model)) {\n277\t    return DEFAULT_MAX_THINKING_BUDGET_OPUS_46;\n278\t  }\n279\t  return DEFAULT_MAX_THINKING_BUDGET;\n280\t};\n281\t\n282\t/**\n283\t * Get thinking level token values calculated from max budget\n284\t * Values are evenly distributed: off=0, low=max/4, medium=max/2, high=max*3/4, max=max\n285\t * @param {number} maxBudget - Maximum thinking budget (default: 31999)\n286\t * @returns {Object} Mapping of thinking levels to token values\n287\t */\n288\texport const getThinkingLevelToTokens = (maxBudget = DEFAULT_MAX_THINKING_BUDGET) => ({\n289\t  off: 0,\n290\t  low: Math.floor(maxBudget / 4), // ~8000 for default 31999\n291\t  medium: Math.floor(maxBudget / 2), // ~16000 for default 31999\n292\t  high: Math.floor((maxBudget * 3) / 4), // ~24000 for default 31999\n293\t  xhigh: maxBudget, // same as max when represented as MAX_THINKING_TOKENS\n294\t  max: maxBudget, // 31999 by default\n295\t});\n296\t\n297\t// Default thinking level to tokens mapping (using default max budget)\n298\texport const thinkingLevelToTokens = getThinkingLevelToTokens(DEFAULT_MAX_THINKING_BUDGET);\n299\t\n300\t/**\n301\t * Get tokens to thinking level mapping function with configurable max budget\n302\t * Uses midpoint ranges to determine the level\n303\t * @param {number} maxBudget - Maximum thinking budget (default: 31999)\n304\t * @returns {Function} Function that converts tokens to thinking level\n305\t */\n306\texport const getTokensToThinkingLevel = (maxBudget = DEFAULT_MAX_THINKING_BUDGET) => {\n307\t  const levels = getThinkingLevelToTokens(maxBudget);\n308\t  // Calculate midpoints between levels for range determination\n309\t  const lowMediumMidpoint = Math.floor((levels.low + levels.medium) / 2);\n310\t  const mediumHighMidpoint = Math.floor((levels.medium + levels.high) / 2);\n311\t  const highMaxMidpoint = Math.floor((levels.high + levels.max) / 2);\n312\t\n313\t  return tokens => {\n314\t    if (tokens === 0) return 'off';\n315\t    if (tokens <= lowMediumMidpoint) return 'low';\n316\t    if (tokens <= mediumHighMidpoint) return 'medium';\n317\t    if (tokens <= highMaxMidpoint) return 'high';\n318\t    return 'max';\n319\t  };\n320\t};\n321\t\n322\t// Default tokens to thinking level function (using default max budget)\n323\texport const tokensToThinkingLevel = getTokensToThinkingLevel(DEFAULT_MAX_THINKING_BUDGET);\n324\t\n325\t/**\n326\t * Valid effort levels for Opus 4.6 and Sonnet 4.6 (Issue #1238, Issue #1620)\n327\t * These models use CLAUDE_CODE_EFFORT_LEVEL for thinking depth control\n328\t * @type {string[]}\n329\t */\n330\texport const OPUS_46_EFFORT_LEVELS = ['low', 'medium', 'high', 'max'];\n331\t\n332\t/**\n333\t * Valid effort levels for Opus 4.7 (Issue #1620)\n334\t * Opus 4.7 supports the additional 'xhigh' level.\n335\t * See: https://platform.claude.com/docs/en/build-with-claude/effort\n336\t * @type {string[]}\n337\t */\n338\texport const OPUS_47_EFFORT_LEVELS = ['low', 'medium', 'high', 'xhigh', 'max'];\n339\t\n340\t/**\n341\t * Convert thinking level to effort level (Issue #1238, Issue #1620)\n342\t * Models with max support keep max as max. Opus 4.7 keeps xhigh as xhigh.\n343\t * Models with effort but without max support use high for max/xhigh.\n344\t * @param {string|undefined} thinkLevel - The thinking level (off/low/medium/high/xhigh/max)\n345\t * @param {Object} [options] - Options\n346\t * @param {boolean} [options.isOpus47] - Backward-compatible shorthand for supportsXHigh\n347\t * @param {boolean} [options.supportsXHigh] - Whether the model supports xhigh effort\n348\t * @param {boolean} [options.supportsMax] - Whether the model supports max effort\n349\t * @returns {string|undefined} The effort level or undefined if thinking is off\n350\t */\n351\texport const thinkLevelToEffortLevel = (thinkLevel, options = {}) => {\n352\t  if (!thinkLevel || thinkLevel === 'off') {\n353\t    return undefined;\n354\t  }\n355\t\n356\t  const supportsXHigh = options.supportsXHigh ?? options.isOpus47 ?? false;\n357\t  const supportsMax = options.supportsMax ?? true;\n358\t\n359\t  switch (thinkLevel) {\n360\t    case 'low':\n361\t      return 'low';\n362\t    case 'medium':\n363\t      return 'medium';\n364\t    case 'high':\n365\t      return 'high';\n366\t    case 'xhigh':\n367\t      return supportsXHigh ? 'xhigh' : supportsMax ? 'max' : 'high';\n368\t    case 'max':\n369\t      return supportsMax ? 'max' : 'high';\n370\t    default:\n371\t      return undefined;\n372\t  }\n373\t};\n374\t\n375\t/**\n376\t * Convert thinking budget (tokens) to effort level (Issue #1238, Issue #1620)\n377\t * Uses token thresholds to determine the appropriate effort level\n378\t * @param {number|undefined} thinkingBudget - The thinking budget in tokens\n379\t * @param {number} maxBudget - Maximum thinking budget (default: 31999)\n380\t * @param {Object} [options] - Options\n381\t * @param {boolean} [options.isOpus47] - Backward-compatible shorthand for supportsXHigh\n382\t * @param {boolean} [options.supportsXHigh] - Whether the model supports xhigh effort\n383\t * @param {boolean} [options.supportsMax] - Whether the model supports max effort\n384\t * @returns {string|undefined} The effort level or undefined if thinking is off\n385\t */\n386\texport const thinkingBudgetToEffortLevel = (thinkingBudget, maxBudget = DEFAULT_MAX_THINKING_BUDGET, options = {}) => {\n387\t  if (thinkingBudget === undefined || thinkingBudget === 0) {\n388\t    return undefined;\n389\t  }\n390\t\n391\t  const thinkLevel = getTokensToThinkingLevel(maxBudget)(thinkingBudget);\n392\t  return thinkLevelToEffortLevel(thinkLevel, options);\n393\t};\n394\t\n395\t// Check if a version supports thinking budget (>= minimum version)\n396\t// Uses semver npm package for reliable version comparison (see issue #1146)\n397\texport const supportsThinkingBudget = (version, minVersion = '2.1.12') => {\n398\t  // Clean the version string (remove any leading 'v' and extra text)\n399\t  const cleanVersion = semver.clean(version) || semver.coerce(version)?.version;\n400\t  const cleanMinVersion = semver.clean(minVersion) || semver.coerce(minVersion)?.version;\n401\t\n402\t  if (!cleanVersion || !cleanMinVersion) {\n403\t    // If versions can't be parsed, assume old version (doesn't support budget)\n404\t    return false;\n405\t  }\n406\t\n407\t  return semver.gte(cleanVersion, cleanMinVersion);\n408\t};\n409\t\n410\t// Helper function to get Claude CLI environment with CLAUDE_CODE_MAX_OUTPUT_TOKENS set\n411\t// Optionally sets MAX_THINKING_TOKENS when thinkingBudget is provided (see issue #1146)\n412\t// Also sets MCP_TIMEOUT and MCP_TOOL_TIMEOUT for MCP tool execution (see issue #1066)\n413\t// Supports model-specific max output tokens for Opus 4.6 (Issue #1221)\n414\t// Sets CLAUDE_CODE_EFFORT_LEVEL for Opus 4.6 models (Issue #1238)\n415\t// Supports planModel/executionModel for opusplan mode (Issue #1223)\n416\t// See: https://code.claude.com/docs/en/model-config\n417\t//   ANTHROPIC_DEFAULT_OPUS_MODEL  → model used in plan mode (and for 'opus' alias)\n418\t//   ANTHROPIC_DEFAULT_SONNET_MODEL → model used in execution mode (and for 'sonnet' alias)\n419\texport const getClaudeEnv = (options = {}) => {\n420\t  // Get max output tokens based on model (Issue #1221)\n421\t  const maxOutputTokens = options.model ? getMaxOutputTokensForModel(options.model) : claudeCode.maxOutputTokens;\n422\t\n423\t  const env = buildClaudeQuietEnv({\n424\t    ...process.env,\n425\t    CLAUDE_CODE_MAX_OUTPUT_TOKENS: String(maxOutputTokens),\n426\t    // MCP timeout configurations to prevent tool calls from hanging indefinitely\n427\t    // See: https://github.com/link-assistant/hive-mind/issues/1066\n428\t    MCP_TIMEOUT: String(claudeCode.mcpTimeout),\n429\t    MCP_TOOL_TIMEOUT: String(claudeCode.mcpToolTimeout),\n430\t  });\n431\t\n432\t  // Opus 4.7+ always uses adaptive thinking — MAX_THINKING_TOKENS has no effect (Issue #1620)\n433\t  // For Opus 4.6 and earlier, MAX_THINKING_TOKENS controls extended thinking (Claude Code >= 2.1.12)\n434\t  // Default is 0 (thinking disabled) per Issue #1238.\n435\t  const opus47 = options.model && isOpus47OrLater(options.model);\n436\t  if (opus47) {\n437\t    // Remove any inherited MAX_THINKING_TOKENS from process.env — Opus 4.7 ignores it\n438\t    delete env.MAX_THINKING_TOKENS;\n439\t  } else {\n440\t    env.MAX_THINKING_TOKENS = String(options.thinkingBudget ?? 0);\n441\t  }\n442\t\n443\t  // Set CLAUDE_CODE_EFFORT_LEVEL for models that support it (Issue #1238, Issue #1620)\n444\t  if (options.model && supportsEffortLevel(options.model)) {\n445\t    const effortOptions = {\n446\t      supportsXHigh: supportsXHighEffortLevel(options.model),\n447\t      supportsMax: supportsMaxEffortLevel(options.model),\n448\t    };\n449\t    let effortLevel;\n450\t    if (options.thinkLevel) {\n451\t      effortLevel = thinkLevelToEffortLevel(options.thinkLevel, effortOptions);\n452\t    } else if (options.thinkingBudget !== undefined && options.thinkingBudget > 0) {\n453\t      effortLevel = thinkingBudgetToEffortLevel(options.thinkingBudget, options.maxBudget, effortOptions);\n454\t    }\n455\t\n456\t    if (effortLevel) {\n457\t      env.CLAUDE_CODE_EFFORT_LEVEL = effortLevel;\n458\t    }\n459\t  }\n460\t\n461\t  // Opus 4.7 omits thinking content by default; opt in with --show-thinking-content (Issue #1620)\n462\t  // Sets CLAUDE_CODE_SHOW_THINKING=1 which Claude Code uses to request display: \"summarized\"\n463\t  if (options.showThinkingContent) {\n464\t    env.CLAUDE_CODE_SHOW_THINKING = '1';\n465\t  }\n466\t  // Set ANTHROPIC_DEFAULT_OPUS_MODEL when planModel is specified (Issue #1223)\n467\t  // This tells Claude Code which model to use during plan mode in opusplan\n468\t  if (options.planModel) {\n469\t    env.ANTHROPIC_DEFAULT_OPUS_MODEL = String(options.planModel);\n470\t  }\n471\t  // Set ANTHROPIC_DEFAULT_SONNET_MODEL when executionModel is specified (Issue #1223)\n472\t  // This tells Claude Code which model to use during execution mode in opusplan\n473\t  // Enables combinations like --plan-model opus --model haiku\n474\t  if (options.executionModel) {\n475\t    env.ANTHROPIC_DEFAULT_SONNET_MODEL = String(options.executionModel);\n476\t  }\n477\t\n478\t  return env;\n479\t};\n480\t\n481\t// Cache TTL configurations (in milliseconds)\n482\t// The Usage API (Claude limits) has stricter rate limiting than regular APIs\n483\t// See: https://github.com/link-assistant/hive-mind/issues/1074\n484\texport const cacheTtl = {\n485\t  // General API cache TTL (GitHub API, etc.)\n486\t  api: parseIntWithDefault('HIVE_MIND_API_CACHE_TTL_MS', 3 * 60 * 1000), // 3 minutes\n487\t  // Claude Usage API cache TTL - must be at least 20 minutes to avoid rate limiting\n488\t  // The API returns null values when called too frequently\n489\t  usageApi: parseIntWithDefault('HIVE_MIND_USAGE_API_CACHE_TTL_MS', 10 * 60 * 1000), // 10 minutes\n490\t  // System metrics cache TTL (RAM, CPU, disk)\n491\t  system: parseIntWithDefault('HIVE_MIND_SYSTEM_CACHE_TTL_MS', 2 * 60 * 1000), // 2 minutes\n492\t};\n493\t\n494\t// File and path configurations\n495\texport const filePaths = {\n496\t  tempDir: getenv('HIVE_MIND_TEMP_DIR', '/tmp'),\n497\t  taskInfoFilename: getenv('HIVE_MIND_TASK_INFO_FILENAME', 'CLAUDE.md'),\n498\t  procMeminfo: getenv('HIVE_MIND_PROC_MEMINFO', '/proc/meminfo'),\n499\t};\n500\t\n501\t// Text processing configurations\n502\texport const textProcessing = {\n503\t  tokenMaskMinLength: parseIntWithDefault('HIVE_MIND_TOKEN_MASK_MIN_LENGTH', 12),\n504\t  tokenMaskStartChars: parseIntWithDefault('HIVE_MIND_TOKEN_MASK_START_CHARS', 5),\n505\t  tokenMaskEndChars: parseIntWithDefault('HIVE_MIND_TOKEN_MASK_END_CHARS', 5),\n506\t  textPreviewLength: parseIntWithDefault('HIVE_MIND_TEXT_PREVIEW_LENGTH', 100),\n507\t  logTruncationLength: parseIntWithDefault('HIVE_MIND_LOG_TRUNCATION_LENGTH', 5000),\n508\t};\n509\t\n510\t// UI/Display configurations\n511\texport const display = {\n512\t  labelWidth: parseIntWithDefault('HIVE_MIND_LABEL_WIDTH', 25),\n513\t};\n514\t\n515\t// Sentry configurations\n516\texport const sentry = {\n517\t  dsn: getenv('HIVE_MIND_SENTRY_DSN', 'https://77b711f23c84cbf74366df82090dc389@o4510072519983104.ingest.us.sentry.io/4510072523325440'),\n518\t  tracesSampleRateDev: parseFloatWithDefault('HIVE_MIND_SENTRY_TRACES_SAMPLE_RATE_DEV', 1.0),\n519\t  tracesSampleRateProd: parseFloatWithDefault('HIVE_MIND_SENTRY_TRACES_SAMPLE_RATE_PROD', 0.1),\n520\t  profileSessionSampleRateDev: parseFloatWithDefault('HIVE_MIND_SENTRY_PROFILE_SESSION_SAMPLE_RATE_DEV', 1.0),\n521\t  profileSessionSampleRateProd: parseFloatWithDefault('HIVE_MIND_SENTRY_PROFILE_SESSION_SAMPLE_RATE_PROD', 0.1),\n522\t};\n523\t\n524\t// External URLs\n525\texport const externalUrls = {\n526\t  githubBase: getenv('HIVE_MIND_GITHUB_BASE_URL', 'https://github.com'),\n527\t  bunInstall: getenv('HIVE_MIND_BUN_INSTALL_URL', 'https://bun.sh/'),\n528\t};\n529\t\n530\t// Model configurations\n531\t// Default available models in Links Notation format (only aliases)\n532\tconst defaultAvailableModels = `(\n533\t  opus\n534\t  sonnet\n535\t  haiku\n536\t  opusplan\n537\t)`;\n538\t\n539\texport const modelConfig = {\n540\t  availableModels: (() => {\n541\t    const envValue = getenv('HIVE_MIND_AVAILABLE_MODELS', defaultAvailableModels);\n542\t    // Parse Links Notation format\n543\t    const parsed = lino.parse(envValue);\n544\t    // If parsing returns empty array, fall back to the three aliases\n545\t    return parsed.length > 0 ? parsed : ['opus', 'sonnet', 'haiku'];\n546\t  })(),\n547\t  defaultModel: getenv('HIVE_MIND_DEFAULT_MODEL', 'sonnet'),\n548\t  // Allow any model ID - validation is delegated to the tool implementation\n549\t  restrictModels: getenv('HIVE_MIND_RESTRICT_MODELS', 'false').toLowerCase() === 'true',\n550\t};\n551\t\n552\t// Version configurations\n553\texport const version = {\n554\t  fallback: getenv('HIVE_MIND_VERSION_FALLBACK', '0.14.3'),\n555\t  default: getenv('HIVE_MIND_VERSION_DEFAULT', '0.14.3'),\n556\t};\n557\t\n558\t// Merge queue configurations\n559\t// See: https://github.com/link-assistant/hive-mind/issues/1143\n560\t// See: https://github.com/link-assistant/hive-mind/issues/1269\n561\t// See: https://github.com/link-assistant/hive-mind/issues/1307\n562\texport const mergeQueue = {\n563\t  // Maximum PRs to process in one merge session\n564\t  // Default: 10 PRs per session\n565\t  maxPrsPerSession: parseIntWithDefault('HIVE_MIND_MERGE_QUEUE_MAX_PRS', 10),\n566\t  // CI/CD polling interval in milliseconds\n567\t  // Default: 5 minutes (300000ms) - checks CI status every 5 minutes\n568\t  ciPollIntervalMs: parseIntWithDefault('HIVE_MIND_MERGE_QUEUE_CI_POLL_INTERVAL_MS', 5 * 60 * 1000),\n569\t  // CI/CD timeout in milliseconds\n570\t  // Default: 7 hours (25200000ms) - maximum wait time for CI to complete\n571\t  ciTimeoutMs: parseIntWithDefault('HIVE_MIND_MERGE_QUEUE_CI_TIMEOUT_MS', 7 * 60 * 60 * 1000),\n572\t  // Wait time after merge before processing next PR\n573\t  // Default: 1 minute (60000ms) - allows CI to stabilize\n574\t  postMergeWaitMs: parseIntWithDefault('HIVE_MIND_MERGE_QUEUE_POST_MERGE_WAIT_MS', 60 * 1000),\n575\t  // Default merge method: 'merge', 'squash', or 'rebase'\n576\t  // Issue #1269: gh pr merge requires explicit method when running non-interactively\n577\t  // Default: 'merge' - creates a merge commit\n578\t  mergeMethod: getenv('HIVE_MIND_MERGE_QUEUE_MERGE_METHOD', 'merge'),\n579\t  // Issue #1307: Wait for main branch CI to complete before processing merge queue\n580\t  // When enabled, the merge queue will wait for any active CI runs on the target branch\n581\t  // (usually main) to complete before merging the first PR.\n582\t  // Default: true - ensures all post-merge CI workflows complete before next merge\n583\t  waitForTargetBranchCI: getenv('HIVE_MIND_MERGE_QUEUE_WAIT_FOR_TARGET_CI', 'true').toLowerCase() === 'true',\n584\t  // Issue #1307: Timeout for waiting on target branch CI (in milliseconds)\n585\t  // If active runs don't complete within this time, proceed with merge anyway\n586\t  // Default: 45 minutes (2700000ms)\n587\t  targetBranchCITimeoutMs: parseIntWithDefault('HIVE_MIND_MERGE_QUEUE_TARGET_CI_TIMEOUT_MS', 45 * 60 * 1000),\n588\t  // Issue #1307: Polling interval for checking target branch CI status (in milliseconds)\n589\t  // Default: 30 seconds (30000ms) - more frequent than PR CI polling since we're blocking\n590\t  targetBranchCIPollIntervalMs: parseIntWithDefault('HIVE_MIND_MERGE_QUEUE_TARGET_CI_POLL_INTERVAL_MS', 30 * 1000),\n591\t  // Issue #1341: Wait for post-merge CI to complete before merging next PR\n592\t  // When enabled, the merge queue will wait for all CI runs triggered by a merge\n593\t  // to complete before processing the next PR. This ensures each merge gets its own\n594\t  // release/publish cycle.\n595\t  // Default: true - ensures post-merge CI (including release workflows) completes\n596\t  waitForPostMergeCI: getenv('HIVE_MIND_MERGE_QUEUE_WAIT_FOR_POST_MERGE_CI', 'true').toLowerCase() === 'true',\n597\t  // Issue #1341: Stop the queue if post-merge CI fails\n598\t  // When enabled, the merge queue will stop processing if any post-merge CI run fails\n599\t  // This prevents cascading failures and allows humans to investigate\n600\t  // Default: true - stop on failure to prevent problems from multiplying\n601\t  stopOnPostMergeCIFailure: getenv('HIVE_MIND_MERGE_QUEUE_STOP_ON_CI_FAILURE', 'true').toLowerCase() === 'true',\n602\t  // Issue #1341: Check for existing CI failures before starting the queue\n603\t  // When enabled, the merge queue will check if there are any failed CI runs on\n604\t  // the default branch before starting to process PRs. If failures exist, it will\n605\t  // report them and stop.\n606\t  // Default: true - ensure a healthy branch before merging\n607\t  checkBranchCIHealthBeforeStart: getenv('HIVE_MIND_MERGE_QUEUE_CHECK_BRANCH_HEALTH', 'true').toLowerCase() === 'true',\n608\t  // Issue #1341: Timeout for waiting on post-merge CI (in milliseconds)\n609\t  // This is per-merge, not total. If a single merge's CI doesn't complete within\n610\t  // this time, the queue will fail with a timeout error.\n611\t  // Default: 60 minutes (3600000ms) - typical CI/CD pipelines take 15-45 minutes\n612\t  postMergeCITimeoutMs: parseIntWithDefault('HIVE_MIND_MERGE_QUEUE_POST_MERGE_CI_TIMEOUT_MS', 60 * 60 * 1000),\n613\t  // Issue #1341: Polling interval for post-merge CI status (in milliseconds)\n614\t  // Default: 30 seconds (30000ms) - balance between responsiveness and API rate limits\n615\t  postMergeCIPollIntervalMs: parseIntWithDefault('HIVE_MIND_MERGE_QUEUE_POST_MERGE_CI_POLL_INTERVAL_MS', 30 * 1000),\n616\t};\n617\t\n618\t// Helper function to validate configuration values\n619\texport function validateConfig() {\n620\t  // Ensure all numeric values are valid\n621\t  const numericConfigs = [...Object.values(timeouts), ...Object.values(githubLimits), ...Object.values(systemLimits), ...Object.values(retryLimits).filter(v => typeof v === 'number'), ...Object.values(textProcessing), display.labelWidth, autoContinue.ageThresholdHours];\n622\t\n623\t  for (const value of numericConfigs) {\n624\t    if (isNaN(value) || value < 0) {\n625\t      throw new Error(`Invalid numeric configuration value: ${value}`);\n626\t    }\n627\t  }\n628\t\n629\t  // Ensure sample rates are between 0 and 1\n630\t  const sampleRates = [sentry.tracesSampleRateDev, sentry.tracesSampleRateProd, sentry.profileSessionSampleRateDev, sentry.profileSessionSampleRateProd];\n631\t\n632\t  for (const rate of sampleRates) {\n633\t    if (isNaN(rate) || rate < 0 || rate > 1) {\n634\t      throw new Error(`Invalid sample rate configuration: ${rate}. Must be between 0 and 1.`);\n635\t    }\n636\t  }\n637\t\n638\t  // Ensure required paths exist\n639\t  if (!filePaths.tempDir) {\n640\t    throw new Error('tempDir configuration is required');\n641\t  }\n642\t\n643\t  return true;\n644\t}\n645\t\n646\t// Export a function to get all configurations as an object (useful for debugging)\n647\texport function getAllConfigurations() {\n648\t  return {\n649\t    timeouts,\n650\t    autoContinue,\n651\t    githubLimits,\n652\t    systemLimits,\n653\t    retryLimits,\n654\t    claudeCode,\n655\t    cacheTtl,\n656\t    filePaths,\n657\t    textProcessing,\n658\t    display,\n659\t    sentry,\n660\t    externalUrls,\n661\t    modelConfig,\n662\t    version,\n663\t    mergeQueue,\n664\t  };\n665\t}\n666\t\n667\t// Export a function to print current configuration (useful for debugging)\n668\texport function printConfiguration() {\n669\t  console.log('Current Configuration:');\n670\t  console.log(JSON.stringify(getAllConfigurations(), null, 2));\n671\t}\n672\t"
