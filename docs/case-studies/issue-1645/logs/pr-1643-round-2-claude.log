[2026-04-18T16:24:40.049Z] [INFO]         "content": "1\t#!/usr/bin/env node\n2\t\n3\timport fs from 'node:fs/promises';\n4\timport os from 'node:os';\n5\timport path from 'node:path';\n6\t\n7\texport const REQUIRED_CLAUDE_QUIET_ENV = Object.freeze({\n8\t  CLAUDE_CODE_DISABLE_AUTO_MEMORY: '1',\n9\t  CLAUDE_CODE_DISABLE_CRON: '1',\n10\t  CLAUDE_CODE_DISABLE_TERMINAL_TITLE: '1',\n11\t  CLAUDE_CODE_DISABLE_CLAUDE_MDS: '1',\n12\t  CLAUDE_CODE_DISABLE_GIT_INSTRUCTIONS: '1',\n13\t  CLAUDE_CODE_DISABLE_FAST_MODE: '1',\n14\t  CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY: '1',\n15\t  CLAUDE_CODE_DISABLE_MOUSE: '1',\n16\t  CLAUDE_CODE_ENABLE_AWAY_SUMMARY: '0',\n17\t  CLAUDE_CODE_MAX_TOOL_USE_CONCURRENCY: '4',\n18\t  DISABLE_FEEDBACK_COMMAND: '1',\n19\t});\n20\t\n21\texport const REQUIRED_CLAUDE_QUIET_SETTINGS = Object.freeze({\n22\t  autoMemoryEnabled: false,\n23\t  spinnerTipsEnabled: false,\n24\t  awaySummaryEnabled: false,\n25\t  feedbackSurveyRate: 0,\n26\t  includeCoAuthoredBy: false,\n27\t  prefersReducedMotion: true,\n28\t  showThinkingSummaries: false,\n29\t  viewMode: 'verbose',\n30\t});\n31\t\n32\texport const REQUIRED_CLAUDE_QUIET_ATTRIBUTION = Object.freeze({\n33\t  commit: '',\n34\t  pr: '',\n35\t});\n36\t\n37\texport const buildClaudeQuietEnv = (baseEnv = process.env) => ({\n38\t  ...baseEnv,\n39\t  ...REQUIRED_CLAUDE_QUIET_ENV,\n40\t});\n41\t\n42\texport const formatClaudeQuietConfigSummary = () => {\n43\t  const settings = Object.entries(REQUIRED_CLAUDE_QUIET_SETTINGS)\n44\t    .map(([key, value]) => `${key}=${JSON.stringify(value)}`)\n45\t    .join(', ');\n46\t  const attribution = `attribution=${JSON.stringify(REQUIRED_CLAUDE_QUIET_ATTRIBUTION)}`;\n47\t  const env = Object.entries(REQUIRED_CLAUDE_QUIET_ENV)\n48\t    .map(([key, value]) => `${key}=${value}`)\n49\t    .join(', ');\n50\t  return `settings[${settings}, ${attribution}], env[${env}]`;\n51\t};\n52\t\n53\tconst isPlainObject = value => value && typeof value === 'object' && !Array.isArray(value);\n54\t\n55\texport const ensureClaudeQuietConfig = async ({ settingsPath, log } = {}) => {\n56\t  const resolvedPath = settingsPath || path.join(os.homedir(), '.claude', 'settings.json');\n57\t  let settings = {};\n58\t  try {\n59\t    const content = await fs.readFile(resolvedPath, 'utf-8');\n60\t    const parsed = JSON.parse(content);\n61\t    settings = isPlainObject(parsed) ? parsed : {};\n62\t  } catch (err) {\n63\t    if (err.code !== 'ENOENT' && log) {\n64\t      await log(`⚠️  Could not read ${resolvedPath}: ${err.message}`, { verbose: true });\n65\t    }\n66\t    settings = {};\n67\t  }\n68\t\n69\t  const updatedSettingsKeys = [];\n70\t  for (const [key, value] of Object.entries(REQUIRED_CLAUDE_QUIET_SETTINGS)) {\n71\t    if (settings[key] !== value) {\n72\t      settings[key] = value;\n73\t      updatedSettingsKeys.push(key);\n74\t    }\n75\t  }\n76\t\n77\t  const existingAttribution = isPlainObject(settings.attribution) ? settings.attribution : {};\n78\t  const updatedAttributionKeys = [];\n79\t  for (const [key, value] of Object.entries(REQUIRED_CLAUDE_QUIET_ATTRIBUTION)) {\n80\t    if (existingAttribution[key] !== value) {\n81\t      existingAttribution[key] = value;\n82\t      updatedAttributionKeys.push(key);\n83\t    }\n84\t  }\n85\t  settings.attribution = existingAttribution;\n86\t  if (updatedAttributionKeys.length > 0) {\n87\t    updatedSettingsKeys.push('attribution');\n88\t  }\n89\t\n90\t  const existingEnv = isPlainObject(settings.env) ? settings.env : {};\n91\t  const updatedEnvKeys = [];\n92\t  for (const [key, value] of Object.entries(REQUIRED_CLAUDE_QUIET_ENV)) {\n93\t    if (existingEnv[key] !== value) {\n94\t      existingEnv[key] = value;\n95\t      updatedEnvKeys.push(key);\n96\t    }\n97\t  }\n98\t  settings.env = existingEnv;\n99\t\n100\t  const changed = updatedSettingsKeys.length > 0 || updatedEnvKeys.length > 0;\n101\t  try {\n102\t    if (changed) {\n103\t      await fs.mkdir(path.dirname(resolvedPath), { recursive: true });\n104\t      await