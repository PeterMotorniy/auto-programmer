[2026-04-18T16:16:12.195Z] [INFO]         "content": "1\t#!/usr/bin/env node\n2\t\n3\timport fs from 'node:fs/promises';\n4\timport os from 'node:os';\n5\timport path from 'node:path';\n6\t\n7\texport const REQUIRED_CLAUDE_QUIET_ENV = Object.freeze({\n8\t  CLAUDE_CODE_DISABLE_AUTO_MEMORY: '1',\n9\t  CLAUDE_CODE_DISABLE_CRON: '1',\n10\t  CLAUDE_CODE_DISABLE_TERMINAL_TITLE: '1',\n11\t  CLAUDE_CODE_DISABLE_CLAUDE_MDS: '1',\n12\t  CLAUDE_CODE_DISABLE_GIT_INSTRUCTIONS: '1',\n13\t  DISABLE_FEEDBACK_COMMAND: '1',\n14\t});\n15\t\n16\texport const REQUIRED_CLAUDE_QUIET_SETTINGS = Object.freeze({\n17\t  autoMemoryEnabled: false,\n18\t  spinnerTipsEnabled: false,\n19\t  awaySummaryEnabled: false,\n20\t  feedbackSurveyRate: 0,\n21\t});\n22\t\n23\texport const buildClaudeQuietEnv = (baseEnv = process.env) => ({\n24\t  ...baseEnv,\n25\t  ...REQUIRED_CLAUDE_QUIET_ENV,\n26\t});\n27\t\n28\texport const formatClaudeQuietConfigSummary = () => {\n29\t  const settings = Object.entries(REQUIRED_CLAUDE_QUIET_SETTINGS)\n30\t    .map(([key, value]) => `${key}=${JSON.stringify(value)}`)\n31\t    .join(', ');\n32\t  const env = Object.entries(REQUIRED_CLAUDE_QUIET_ENV)\n33\t    .map(([key, value]) => `${key}=${value}`)\n34\t    .join(', ');\n35\t  return `settings[${settings}], env[${env}]`;\n36\t};\n37\t\n38\tconst isPlainObject = value => value && typeof value === 'object' && !Array.isArray(value);\n39\t\n40\texport const ensureClaudeQuietConfig = async ({ settingsPath, log } = {}) => {\n41\t  const resolvedPath = settingsPath || path.join(os.homedir(), '.claude', 'settings.json');\n42\t  let settings = {};\n43\t  try {\n44\t    const content = await fs.readFile(resolvedPath, 'utf-8');\n45\t    const parsed = JSON.parse(content);\n46\t    settings = isPlainObject(parsed) ? parsed : {};\n47\t  } catch (err) {\n48\t    if (err.code !== 'ENOENT' && log) {\n49\t      await log(`⚠️  Could not read ${resolvedPath}: ${err.message}`, { verbose: true });\n50\t    }\n51\t    settings = {};\n52\t  }\n53\t\n54\t  const updatedSettingsKeys = [];\n55\t  for (const [key, value] of Object.entries(REQUIRED_CLAUDE_QUIET_SETTINGS)) {\n56\t    if (settings[key] !== value) {\n57\t      settings[key] = value;\n58\t      updatedSettingsKeys.push(key);\n59\t    }\n60\t  }\n61\t\n62\t  const existingEnv = isPlainObject(settings.env) ? settings.env : {};\n63\t  const updatedEnvKeys = [];\n64\t  for (const [key, value] of Object.entries(REQUIRED_CLAUDE_QUIET_ENV)) {\n65\t    if (existingEnv[key] !== value) {\n66\t      existingEnv[key] = value;\n67\t      updatedEnvKeys.push(key);\n68\t    }\n69\t  }\n70\t  settings.env = existingEnv;\n71\t\n72\t  const changed = updatedSettingsKeys.length > 0 || updatedEnvKeys.length > 0;\n73\t  try {\n74\t    if (changed) {\n75\t      await fs.mkdir(path.dirname(resolvedPath), { recursive: true });\n76\t      await fs.writeFile(resolvedPath, JSON.stringify(settings, null, 2));\n77\t    }\n78\t    if (log) {\n79\t      await log(`🧭 Claude Code quiet config ${changed ? 'updated' : 'verified'} at ${resolvedPath}: ${formatClaudeQuietConfigSummary()}`);\n80\t    }\n81\t  } catch (err) {\n82\t    if (log) await log(`⚠️  Could not write ${resolvedPath}: ${err.message}`, { verbose: true });\n83\t  }\n84\t\n85\t  return {\n86\t    path: resolvedPath,\n87\t    changed,\n88\t    updatedSettingsKeys,\n89\t    updatedEnvKeys,\n90\t    settings: { ...REQUIRED_CLAUDE_QUIET_SETTINGS },\n91\t    env: { ...REQUIRED_CLAUDE_QUIET_ENV },\n92\t  };\n93\t};\n94\t"
