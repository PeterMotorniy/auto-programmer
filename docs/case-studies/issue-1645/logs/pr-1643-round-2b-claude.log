[2026-04-18T16:40:58.428Z] [INFO]         "tool_use_id": "toolu_015YVKhjHu1hih9yry4U4CSb",
[2026-04-18T16:40:58.428Z] [INFO]         "type": "tool_result",
[2026-04-18T16:40:58.428Z] [INFO]         "content": "1\t# Hive Mind Docker image\n2\t# Inherits from konard/sandbox which provides all general-purpose development tools\n3\t# This image adds AI-specific tools (Claude CLI, OpenAI Codex, Playwright MCP, etc.)\n4\t#\n5\t# Architecture (see issue #1394, #1499, #1505 and sandbox#73, sandbox#74):\n6\t#   konard/sandbox (pinned version)\n7\t#     └── All general dev tools: Node.js, Bun, Deno, Python, Go, Rust, Java, PHP, etc.\n8\t#     └── Playwright browsers pre-installed (chromium, firefox, webkit, msedge, chrome)\n9\t#     └── /workspace directory owned by sandbox user\n10\t#   hive-mind (konard/hive-mind)\n11\t#     └── Inherits sandbox, adds AI coding assistants and Playwright MCP\n12\t#     └── Runs entirely as sandbox user (no USER root needed)\n13\t#\n14\t# Sandbox image version: pinned to a specific release for stable, reproducible builds.\n15\t# To upgrade: update the version tag below and in coolify/Dockerfile.\n16\t# Latest sandbox releases: https://hub.docker.com/r/konard/sandbox/tags\n17\t#\n18\t# Build: docker build -t konard/hive-mind .\n19\t\n20\tFROM konard/sandbox:1.6.0\n21\t\n22\t# --- Environment variables ---\n23\t# Set environment variables EARLY so they're available in subsequent RUN commands\n24\t# All paths use /workspace (shared directory owned by sandbox:sandbox)\n25\tENV HOME=/workspace\n26\tENV NVM_DIR=\"/workspace/.nvm\"\n27\tENV PYENV_ROOT=\"/workspace/.pyenv\"\n28\tENV BUN_INSTALL=\"/workspace/.bun\"\n29\tENV DENO_INSTALL=\"/workspace/.deno\"\n30\tENV CARGO_HOME=\"/workspace/.cargo\"\n31\tENV GOROOT=\"/workspace/.go\"\n32\tENV GOPATH=\"/workspace/.go/path\"\n33\tENV SDKMAN_DIR=\"/workspace/.sdkman\"\n34\tENV PERLBREW_ROOT=\"/workspace/.perl5\"\n35\tENV RBENV_ROOT=\"/workspace/.rbenv\"\n36\t\n37\t# Quiet, deterministic Claude Code defaults for autonomous solve runs (issue #1642)\n38\tENV CLAUDE_CODE_DISABLE_AUTO_MEMORY=1 \\\n39\t    CLAUDE_CODE_DISABLE_CRON=1 \\\n40\t    CLAUDE_CODE_DISABLE_TERMINAL_TITLE=1 \\\n41\t    CLAUDE_CODE_DISABLE_CLAUDE_MDS=1 \\\n42\t    CLAUDE_CODE_DISABLE_GIT_INSTRUCTIONS=1 \\\n43\t    CLAUDE_CODE_DISABLE_FAST_MODE=1 \\\n44\t    CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY=1 \\\n45\t    CLAUDE_CODE_DISABLE_MOUSE=1 \\\n46\t    CLAUDE_CODE_ENABLE_AWAY_SUMMARY=0 \\\n47\t    CLAUDE_CODE_MAX_TOOL_USE_CONCURRENCY=4 \\\n48\t    DISABLE_FEEDBACK_COMMAND=1\n49\t\n50\t# Opam environment variables for Rocq/Coq theorem prover\n51\tENV OPAM_SWITCH_PREFIX=\"/workspace/.opam/default\"\n52\tENV CAML_LD_LIBRARY_PATH=\"/workspace/.opam/default/lib/stublibs:/workspace/.opam/default/lib/ocaml/stublibs:/workspace/.opam/default/lib/ocaml\"\n53\tENV OCAML_TOPLEVEL_PATH=\"/workspace/.opam/default/lib/toplevel\"\n54\t\n55\t# Comprehensive PATH including all tools\n56\t# Note: Node.js path is added dynamically since NVM version may vary\n57\t# Note: ~/.local/bin is included for user-installed binaries (e.g., opam binary from sandbox rocq image)\n58\tENV PATH=\"/home/linuxbrew/.linuxbrew/opt/php@8.3/bin:/home/linuxbrew/.linuxbrew/opt/php@8.3/sbin:/home/linuxbrew/.linuxbrew/bin:/workspace/.pyenv/bin:/workspace/.pyenv/shims:/workspace/.rbenv/bin:/workspace/.rbenv/shims:/workspace/.swift/usr/bin:/workspace/.elan/bin:/workspace/.opam/default/bin:/workspace/.local/bin:/workspace/.cargo/bin:/workspace/.deno/bin:/workspace/.bun/bin:/workspace/.go/bin:/workspace/.go/path/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin\"\n59\t\n60\t# Run entirely as sandbox user — no USER root needed (see issue #1505)\n61\tUSER sandbox\n62\tWORKDIR /workspace\n63\t\n64\t# Create a stable symlink to the active Node.js version's bin directory\n65\t# This allows us to add it to PATH without knowing the specific version\n66\tRUN NODE_VERSION_DIR=$(ls -d /workspace/.nvm/versions/node/v* 2>/dev/null | head -1) && \\\n67\t    if [ -n \"$NODE_VERSION_DIR\" ] && [ -d \"$NODE_VERSION_DIR/bin\" ]; then \\\n68\t      ln -sf \"$NODE_VERSION_DIR/bin\" /workspace/.node-bin; \\\n69\t    fi\n70\t\n71\tENV PATH=\"/workspace/.node-bin:${PATH}\"\n72\t\n73\t# --- Install opam binary ---\n74\t# The sandbox full image copies ~/.opam (opam switch data) from the rocq stage\n75\t# but does NOT copy the opam binary from ~/.local/bin. Install it as sandbox user.\n76\t# See: https://github.com/link-foundation/sandbox/issues/74\n77\tRUN mkdir -p /workspace/.local/bin && \\\n78\t    ARCH=\"$(uname -m)\" && \\\n79\t    case \"$ARCH\" in \\\n80\t      x86_64)  OPAM_ARCH=\"x86_64\" ;; \\\n81\t      aarch64) OPAM_ARCH=\"arm64\" ;; \\\n82\t      *)       OPAM_ARCH=\"$ARCH\" ;; \\\n83\t    esac && \\\n84\t    OPAM_TAG=$(curl -fsSIL -o /dev/null -w '%{url_effective}' https://github.com/ocaml/opam/releases/latest | sed 's|.*/||') && \\\n85\t    curl -fsSL \"https://github.com/ocaml/opam/releases/download/${OPAM_TAG}/opam-${OPAM_TAG}-${OPAM_ARCH}-linux\" -o /workspace/.local/bin/opam && \\\n86\t    chmod +x /workspace/.local/bin/opam\n87\t\n88\t# --- AI-specific packages installation ---\n89\t# These are the tools that differentiate hive-mind from the generic sandbox\n90\t# Global bun packages for AI coding assistants and workflow utilities\n91\t# Every install must fail the build on error — no silent fallbacks (see issue #1505)\n92\t\n93\t# Install Claude Code through Anthropic's native installer. Bun blocks the\n94\t# @anthropic-ai/claude-code postinstall that links the native binary (issue #1633).\n95\tRUN curl -fsSL https://claude.ai/install.sh -o /tmp/claude-code-install.sh && \\\n96\t    bash /tmp/claude-code-install.sh && \\\n97\t    rm /tmp/claude-code-install.sh && \\\n98\t    claude --version\n99\t\n100\t# Install AI coding assistant CLIs\n101\tRUN bun install -g @openai/codex && \\\n102\t    bun install -g @qwen-code/qwen-code && \\\n103\t    bun install -g @google/gemini-cli && \\\n104\t    bun install -g @github/copilot && \\\n105\t    bun install -g opencode-ai\n106\t\n107\t# Install hive-mind workflow utilities\n108\t# Note: start-command provides `$` CLI for isolation modes (--isolation screen/tmux/docker)\n109\t# The sandbox base image includes screen. For tmux/docker isolation, ensure they are\n110\t# available in the base image or install them separately.\n111\tRUN bun install -g @link-assistant/hive-mind && \\\n112\t    bun install -g @link-assistant/claude-profiles && \\\n113\t    bun install -g @link-assistant/agent && \\\n114\t    bun install -g start-command && \\\n115\t    bun install -g gh-setup-git-identity && \\\n116\t    bun install -g gh-pull-all && \\\n117\t    bun install -g gh-load-issue && \\\n118\t    bun install -g gh-load-pull-request && \\\n119\t    bun install -g gh-upload-log\n120\t\n121\t# --- Playwright MCP Setup ---\n122\t# Sandbox 1.6.0 pre-installs Playwright browsers and @playwright/test (sandbox#74).\n123\t# We only add @playwright/mcp (AI-specific MCP server for Claude/Codex).\n124\t# --force handles the shared 'playwright' binary conflict between packages.\n125\tRUN npm install -g @playwright/mcp@latest --no-fund --force\n126\t\n127\t# Configure Playwright MCP for Claude CLI — fail the build if registration fails (issue #1514)\n128\tRUN if command -v claude &>/dev/null; then \\\n129\t      claude mcp add playwright -s user -- npx -y @playwright/mcp@latest --isolated --headless --no-sandbox --timeout-action=600000 --viewport-size 1920x1080; \\\n130\t    fi\n131\t\n132\t# Configure Playwright MCP for Codex CLI with the same server settings\n133\tRUN if command -v codex &>/dev/null; then \\\n134\t      codex mcp add playwright -- npx -y @playwright/mcp@latest --isolated --headless --no-sandbox --timeout-action=600000 --viewport-size 1920x1080; \\\n135\t    fi\n136\t\n137\t# --- Disable noisy/unused Claude Code features and tools (issue #1627, issue #1642) ---\n138\t# Autonomous headless hive-mind runs never benefit from tools that wait for\n139\t# human interaction (AskUserQuestion, EnterPlanMode) or that register local\n140\t# session cron jobs (CronCreate/List/Delete) or create worktrees\n141\t# (EnterWorktree/ExitWorktree) or fire mobile notifications\n142\t# (PushNotification) or kick off remote agent triggers (RemoteTrigger)\n143\t# or create notebook cells (NotebookEdit) or monitor processes (Monitor) or\n144\t# self-schedule wakeups (ScheduleWakeup). Pre-seed the user-scope\n145\t# ~/.claude/settings.json disallowedTools list so that even interactive\n146\t# claude sessions in this image do not surface them.\n147\t# The three claude.ai OAuth connectors (Gmail/Google Drive/Google Calendar)\n148\t# cannot be removed via `claude mcp remove` because they are not registered\n149\t# under user/local/project scope; solve.mjs filters them at run time using\n150\t# --strict-mcp-config --mcp-config <temp-file>.\n151\tRUN mkdir -p /workspace/.claude && \\\n152\t    node -e \" \\\n153\tconst fs = require('fs'); \\\n154\tconst p = '/workspace/.claude/settings.json'; \\\n155\tconst blocked = ['AskUserQuestion','CronCreate','CronDelete','CronList','EnterPlanMode','EnterWorktree','ExitPlanMode','ExitWorktree','Monitor','NotebookEdit','PushNotification','RemoteTrigger','ScheduleWakeup','mcp__claude_ai_Gmail__*','mcp__claude_ai_Google_Drive__*','mcp__claude_ai_Google_Calendar__*']; \\\n156\tconst quietEnv = { CLAUDE_CODE_DISABLE_AUTO_MEMORY: '1', CLAUDE_CODE_DISABLE_CRON: '1', CLAUDE_CODE_DISABLE_TERMINAL_TITLE: '1', CLAUDE_CODE_DISABLE_CLAUDE_MDS: '1', CLAUDE_CODE_DISABLE_GIT_INSTRUCTIONS: '1', CLAUDE_CODE_DISABLE_FAST_MODE: '1', CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY: '1', CLAUDE_CODE_DISABLE_MOUSE: '1', CLAUDE_CODE_ENABLE_AWAY_SUMMARY: '0', CLAUDE_CODE_MAX_TOOL_USE_CONCURRENCY: '4', DISABLE_FEEDBACK_COMMAND: '1' }; \\\n157\tconst quietSettings = { autoMemoryEnabled: false, spinnerTipsEnabled: false, awaySummaryEnabled: false, feedbackSurveyRate: 0, includeCoAuthoredBy: false, prefersReducedMotion: true, showThinkingSummaries: false, viewMode: 'verbose' }; \\\n158\tconst quietAttribution = { commit: '', pr: '' }; \\\n159\tlet s = {}; \\\n160\ttry { s = JSON.parse(fs.readFileSync(p, 'utf-8')); } catch (e) {} \\\n161\tif (!s || typeof s !== 'object' || Array.isArray(s)) s = {}; \\\n162\tfor (const [key, value] of Object.entries(quietSettings)) s[key] = value; \\\n163\ts.attribution = s.attribution && typeof s.attribution === 'object' && !Array.isArray(s.attribution) ? s.attribution : {}; \\\n164\tfor (const [key, value] of Object.entries(quietAttribution)) s.attribution[key] = value; \\\n165\ts.env = s.env && typeof s.env === 'object' && !Array.isArray(s.env) ? s.env : {}; \\\n166\tfor (const [key, value] of Object.entries(quietEnv)) s.env[key] = value; \\\n167\tconst existing = Array.isArray(s.disallowedTools) ? s.disallowedTools : []; \\\n168\tconst merged = [...existing]; \\\n169\tfor (const t of blocked) if (!merged.includes(t)) merged.push(t); \\\n170\ts.disallowedTools = merged; \\\n171\tfs.writeFileSync(p, JSON.stringify(s, null, 2)); \\\n172\tconsole.log('Configured quiet Claude Code defaults and', merged.length, 'disallowedTools in', p); \\\n173\t\"\n174\t\n175\tSHELL [\"/bin/bash\", \"-c\"]\n176\tCMD [\"/bin/bash\"]\n177\t"
