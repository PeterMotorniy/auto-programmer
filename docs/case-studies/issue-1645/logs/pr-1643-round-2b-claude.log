[2026-04-18T16:40:55.895Z] [INFO]         "content": "1\t#!/usr/bin/env node\n2\t\n3\timport assert from 'node:assert/strict';\n4\timport fs from 'node:fs/promises';\n5\timport os from 'node:os';\n6\timport path from 'node:path';\n7\t\n8\timport { ensureClaudeQuietConfig, REQUIRED_CLAUDE_QUIET_ENV, REQUIRED_CLAUDE_QUIET_SETTINGS, REQUIRED_CLAUDE_QUIET_ATTRIBUTION } from '../src/claude-quiet-config.lib.mjs';\n9\timport { getClaudeEnv } from '../src/config.lib.mjs';\n10\t\n11\tconst claudeEnv = getClaudeEnv();\n12\tfor (const [name, value] of Object.entries(REQUIRED_CLAUDE_QUIET_ENV)) {\n13\t  assert.equal(claudeEnv[name], value, `getClaudeEnv should force ${name}=${value}`);\n14\t}\n15\t\n16\tconst claudeLibContent = await fs.readFile(path.join(process.cwd(), 'src/claude.lib.mjs'), 'utf-8');\n17\tassert.ok(claudeLibContent.includes('ensureClaudeQuietConfig({ log })'), 'claude.lib should verify global Claude quiet config before launching Claude');\n18\t\n19\tconst tmp = await fs.mkdtemp(path.join(os.tmpdir(), 'claude-quiet-config-'));\n20\ttry {\n21\t  const settingsPath = path.join(tmp, 'settings.json');\n22\t  await fs.writeFile(\n23\t    settingsPath,\n24\t    JSON.stringify({\n25\t      theme: 'dark',\n26\t      disallowedTools: ['CustomTool'],\n27\t      attribution: {\n28\t        commit: 'custom-commit-trailer',\n29\t      },\n30\t      env: {\n31\t        CUSTOM_SETTING: 'preserved',\n32\t        CLAUDE_CODE_DISABLE_AUTO_MEMORY: '0',\n33\t      },\n34\t    })\n35\t  );\n36\t\n37\t  const logs = [];\n38\t  const result = await ensureClaudeQuietConfig({ settingsPath, log: async line => logs.push(line) });\n39\t  const written = JSON.parse(await fs.readFile(settingsPath, 'utf-8'));\n40\t\n41\t  assert.equal(result.changed, true, 'first merge should update missing or incorrect target keys');\n42\t  assert.ok(\n43\t    logs.some(line => line.includes('Claude Code quiet config updated')),\n44\t    'merge should log the effective quiet configuration'\n45\t  );\n46\t 