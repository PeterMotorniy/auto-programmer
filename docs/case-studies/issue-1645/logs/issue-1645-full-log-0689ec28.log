ds AI-specific tools on top of the sandbox base.\"\n          echo \"\"\n\n          # Note: Multi-platform builds (amd64+arm64) are tested in docker-publish job during release\n          # PR checks only validate amd64 using standard docker build (not buildx) to ensure\n          # the image is properly loaded into Docker daemon for container verification\n          docker build --progress=plain -t ${{ env.IMAGE_NAME }}:test . 2>&1 | tee build-output.log\n\n          echo \"\"\n          echo \"Docker image built successfully\"\n          docker images | grep -E \"${{ env.IMAGE_NAME }}|REPOSITORY\"\n\n      - name: Verify build completed without errors\n        run: |\n          echo \"Checking build logs for critical errors...\"\n\n          # Check for unbound variable errors (indicates shell script issues with set -u compatibility)\n          if grep -E 'unbound variable' build-output.log; then\n            echo \"ERROR: Unbound variable error detected in Docker build\"\n            echo \"This typically indicates a shell script issue with set -u compatibility\"\n            grep -E 'unbound variable' build-output.log || true\n            exit 1\n          fi\n\n          echo \"Build log check completed\"\n\n      - name: Verify system & development tools in running container\n        run: |\n          SANDBOX_VERSION=$(grep '^FROM konard/sandbox:' Dockerfile | sed 's/FROM konard\\/sandbox://')\n          echo \"=== Verifying hive-mind Docker image ===\"\n          echo \"Base: konard/sandbox:${SANDBOX_VERSION} (pinned) + AI-specific tools\"\n          echo \"\"\n\n          # Run verification script inside container (mounts script as read-only volume)\n          # Verifies: sandbox user setup (/workspace access), all dev tools, AI-specific tools\n          # See scripts/verify-docker-image.sh for the full list of checks\n          docker run --rm \\\n            -v \"$(pwd)/scripts/verify-docker-image.sh:/verify-docker-image.sh:ro\" \\\n            ${{ env.IMAGE_NAME }}:test \\\n            bash /verify-docker-image.sh\n\n          echo \"\"\n          echo \"All system & development tools verification checks passed!\"\n\n  # === HELM PR CHECK (FAST) ===\n  helm-pr-check:\n    runs-on: ubuntu-latest\n    needs: [detect-changes, changeset-check]\n    # Only runs when helm chart, package.json, or workflow files changed (Issue #1436)\n    if: always() && github.event_name == 'pull_request' && (needs.changeset-check.result == 'success' || needs.changeset-check.result == 'skipped') && (needs.detect-changes.outputs.helm-changed == 'true' || needs.detect-changes.outputs.package-changed == 'true' || needs.detect-changes.outputs.workflow-changed == 'true')\n\n    steps:",
