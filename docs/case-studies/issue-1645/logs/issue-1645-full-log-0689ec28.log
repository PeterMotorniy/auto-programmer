[2026-04-18T22:04:38.160Z] [INFO]         "content": "1\t# Hive Mind Coolify Docker image\n2\t# Inherits from konard/sandbox which provides all general-purpose development tools\n3\t# This image adds AI-specific tools and application code for Coolify deployment\n4\t#\n5\t# Architecture (see issue #1394, #1499, #1505 and sandbox#73, sandbox#74):\n6\t#   konard/sandbox (pinned version)\n7\t#     └── All general dev tools: Node.js, Bun, Deno, Python, Go, Rust, Java, PHP, etc.\n8\t#     └── Playwright browsers pre-installed (chromium, firefox, webkit, msedge, chrome)\n9\t#     └── /workspace directory owned by sandbox user\n10\t#   hive-mind (this Dockerfile)\n11\t#     └── Inherits sandbox, adds AI coding assistants, Playwright MCP, and app code\n12\t#     └── Runs entirely as sandbox user (no USER root needed for tool installs)\n13\t#\n14\t# Sandbox image version: pinned to a specific release for stable, reproducible builds.\n15\t# To upgrade: update the version tag below and in the root Dockerfile.\n16\t# Latest sandbox releases: https://hub.docker.com/r/konard/sandbox/tags\n17\t#\n18\t# Build: docker build -f coolify/Dockerfile -t konard/hive-mind .\n19\t\n20\tFROM konard/sandbox:1.6.0\n21\tARG HIVE_MIND_VERSION=latest\n22\t\n23\t# --- Environment variables ---\n24\t# Set environment variables EARLY so they're available in subsequent RUN commands\n25\t# All paths use /workspace (shared directory owned by sandbox:sandbox)\n26\tENV HOME=/workspace\n27\tENV NVM_DIR=\"/workspace/.nvm\"\n28\tENV PYENV_ROOT=\"/workspace/.pyenv\"\n29\tENV BUN_INSTALL=\"/workspace/.bun\"\n30\tENV DENO_INSTALL=\"/workspace/.deno\"\n31\tENV CARGO_HOME=\"/workspace/.cargo\"\n32\tENV GOROOT=\"/workspace/.go\"\n33\tENV GOPATH=\"/workspace/.go/path\"\n34\tENV SDKMAN_DIR=\"/workspace/.sdkman\"\n35\tENV PERLBREW_ROOT=\"/workspace/.perl5\"\n36\tENV RBENV_ROOT=\"/workspace/.rbenv\"\n37\t\n38\t# Quiet, deterministic Claude Code defaults for autonomous solve runs (issue #1642)\n39\tENV CLAUDE_CODE_DISABLE_AUTO_MEMORY=1 \\\n40\t    CLAUDE_CODE_DISABLE_CRON=1 \\\n41\t    CLAUDE_CODE_DISABLE_TERMINAL_TITLE=1 \\\n42\t    CLAUDE_CODE_DISABLE_CLAUDE_MDS=1 \\\n43\t    CLAUDE_CODE_DISABLE_FAST_MODE=1 \\\n44\t    CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY=1 \\\n45\t    CLAUDE_CODE_DISABLE_MOUSE=1 \\\n46\t    CLAUDE_CODE_ENABLE_AWAY_SUMMARY=0 \\\n47\t    CLAUDE_CODE_ENABLE_TASKS=1 \\\n48\t    CLAUDE_CODE_MAX_TOOL_USE_CONCURRENCY=4 \\\n49\t    CLAUDE_CODE_RESUME_INTERRUPTED_TURN=1 \\\n50\t    DISABLE_FEEDBACK_COMMAND=1\n51\t\n52\tENV OPAM_SWITCH_PREFIX=\"/workspace/.opam/default\"\n53\tENV CAML_LD_LIBRARY_PATH=\"/workspace/.opam/default/lib/stublibs:/workspace/.opam/default/lib/ocaml/stublibs:/workspace/.opam/default/lib/ocaml\"\n54\tENV OCAML_TOPLEVEL_PATH=\"/workspace/.opam/default/lib/toplevel\"\n55\t\n56\t# Comprehensive PATH including all tools\n57\t# Note: ~/.local/bin is included for user-installed binaries (e.g., opam binary from sandbox rocq image)\n58\tENV PATH=\"/home/linuxbrew/.linuxbrew/opt/php@8.3/bin:/home/linuxbrew/.linuxbrew/opt/php@8.3/sbin:/home/linuxbrew/.linuxbrew/bin:/workspace/.pyenv/bin:/workspace/.pyenv/shims:/workspace/.rbenv/bin:/workspace/.rbenv/shims:/workspace/.swift/usr/bin:/workspace/.elan/bin:/workspace/.opam/default/bin:/workspace/.local/bin:/workspace/.cargo/bin:/workspace/.deno/bin:/workspace/.bun/bin:/workspace/.go/bin:/workspace/.go/path/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin\"\n59\t\n60\t# Run entirely as sandbox user — no USER root needed (see issue #1505)\n61\tUSER sandbox\n62\tWORKDIR /workspace\n63\t\n64\t# Create stable symlink to Node.js bin directory\n65\tRUN NODE_VERSION_DIR=$(ls -d /workspace/.nvm/versions/node/v* 2>/dev/null | head -1) && \\\n66\t    if [ -n \"$NODE_VERSION_DIR\" ] && [ -d \"$NODE_VERSION_DIR/bin\" ]; then \\\n67\t      ln -sf \"$NODE_VERSION_DIR/bin\" /workspace/.node-bin; \\\n68\t    fi\n69\t\n70\tENV PATH=\"/workspace/.node-bin:${PATH}\"\n71\t\n72\t# --- Install opam binary ---\n73\t# The sandbox full image copies ~/.opam (opam switch data) from the rocq stage\n74\t# but does NOT copy the opam binary from ~/.local/bin. Install it as sandbox user.\n75\t# See: https://github.com/link-foundation/sandbox/issues/74\n76\tRUN mkdir -p /workspace/.local/bin && \\\n77\t    ARCH=\"$(uname -m)\" && \\\n78\t    case \"$ARCH\" in \\\n79\t      x86_64)  OPAM_ARCH=\"x86_64\" ;; \\\n80\t      aarch64) OPAM_ARCH=\"arm64\" ;; \\\n81\t      *)       OPAM_ARCH=\"$ARCH\" ;; \\\n82\t    esac && \\\n83\t    OPAM_TAG=$(curl -fsSIL -o /dev/null -w '%{url_effective}' https://github.com/ocaml/opam/releases/latest | sed 's|.*/||') && \\\n84\t    curl -fsSL \"https://github.com/ocaml/opam/releases/download/${OPAM_TAG}/opam-${OPAM_TAG}-${OPAM_ARCH}-linux\" -o /workspace/.local/bin/opam && \\\n85\t    chmod +x /workspace/.local/bin/opam\n86\t\n87\t# --- AI-specific packages installation ---\n88\t# Every install must fail the build on error — no silent fallbacks (see issue #1505)\n89\t\n90\t# Install Claude Code through Anthropic's native installer. Bun blocks the\n91\t# @anthropic-ai/claude-code postinstall that links the native binary (issue #1633).\n92\tRUN curl -fsSL https://claude.ai/install.sh -o /tmp/claude-code-install.sh && \\\n93\t    bash /tmp/claude-code-install.sh && \\\n94\t    rm /tmp/claude-code-install.sh && \\\n95\t    claude --version\n96\t\n97\t# Install AI coding assistant CLIs\n98\tRUN bun install -g @openai/codex && \\\n99\t    bun install -g @qwen-code/qwen-code && \\\n100\t    bun install -g @google/gemini-cli && \\\n101\t    bun install -g @github/copilot && \\\n102\t    bun install -g opencode-ai\n103\t\n104\t# Install hive-mind workflow utilities\n105\t# Release builds pass HIVE_MIND_VERSION after npm publish, so Docker installs\n106\t# the exact package version that contains the configure-claude bin.\n107\t# Note: start-command provides `$` CLI for isolation modes (--isolation screen/tmux/docker)\n108\t# The sandbox base image includes screen. For tmux/docker isolation, ensure they are\n109\t# available in the base image or install them separately.\n110\tRUN echo \"Installing @link-assistant/hive-mind@${HIVE_MIND_VERSION}\" && \\\n111\t    bun install -g \"@link-assistant/hive-mind@${HIVE_MIND_VERSION}\" && \\\n112\t    if [ \"${HIVE_MIND_VERSION}\" != \"latest\" ]; then \\\n113\t      test \"$(hive --version)\" = \"${HIVE_MIND_VERSION}\"; \\\n114\t    fi && \\\n115\t    bun install -g @link-assistant/claude-profiles && \\\n116\t    bun install -g @link-assistant/agent && \\\n117\t    bun install -g start-command && \\\n118\t    bun install -g gh-setup-git-identity && \\\n119\t    bun install -g gh-pull-all && \\\n120\t    bun install -g gh-load-issue && \\\n121\t    bun install -g gh-load-pull-request && \\\n122\t    bun install -g gh-upload-log\n123\t\n124\t# --- Playwright MCP Setup ---\n125\t# Sandbox 1.6.0 pre-installs Playwright browsers and @playwright/test (sandbox#74).\n126\t# We only add @playwright/mcp (AI-specific MCP server for Claude/Codex).\n127\t# --force handles the shared 'playwright' binary conflict between packages.\n128\tRUN npm install -g @playwright/mcp@latest --no-fund --force\n129\t\n130\t# Configure Playwright MCP for Claude CLI — fail the build if registration fails (issue #1514)\n131\tRUN if command -v claude &>/dev/null; then \\\n132\t      claude mcp add playwright -s user -- npx -y @playwright/mcp@latest --isolated --headless --no-sandbox --timeout-action=600000 --viewport-size 1920x1080; \\\n133\t    fi\n134\t\n135\t# Configure Playwright MCP for Codex CLI with the same server settings\n136\tRUN if command -v codex &>/dev/null; then \\\n137\t      codex mcp add playwright -- npx -y @playwright/mcp@latest --isolated --headless --no-sandbox --timeout-action=600000 --viewport-size 1920x1080; \\\n138\t    fi\n139\t\n140\t# --- Disable noisy/unused Claude Code features and tools (issue #1627, issue #1642) ---\n141\t# Autonomous headless hive-mind runs never benefit from tools that wait for\n142\t# human interaction or leave persistent side effects. Pre-seed the\n143\t# user-scope ~/.claude/settings.json disallowedTools list so that even\n144\t# interactive claude sessions in this image do not surface them. The three\n145\t# claude.ai OAuth connectors (Gmail/Google Drive/Google Calendar) cannot be\n146\t# removed via `claude mcp remove` because they are not registered under\n147\t# user/local/project scope; solve.mjs filters them at run time using\n148\t# --strict-mcp-config --mcp-config <temp-file>.\n149\t#\n150\t# The release workflow builds this image only after npm publishes the Hive-Mind\n151\t# version and waits until that version is visible in the registry. The image can\n152\t# therefore use the published `configure-claude` bin directly instead of copying\n153\t# repository source into the Docker build context.\n154\tRUN mkdir -p /workspace/.claude && \\\n155\t    configure-claude --settings-path /workspace/.claude/settings.json && \\\n156\t    configure-claude --settings-path /workspace/.claude/settings.json --verify\n157\t\n158\t# --- Application Setup ---\n159\t# Minimal USER root: only for creating /app directory and copying files.\n160\t# All /workspace operations run as sandbox user to prevent permission issues (issue #1505).\n161\tUSER root\n162\tWORKDIR /app\n163\t\n164\t# Copy application files from repo root\n165\tCOPY --chown=sandbox:sandbox . .\n166\t\n167\t# Ensure scripts are executable\n168\tRUN chmod +x *.mjs 2>/dev/null || true && \\\n169\t    chmod +x src/*.mjs 2>/dev/null || true\n170\t\n171\t# Create /app subdirectories (root-owned parent)\n172\tRUN mkdir -p /app/claude-logs /app/claude-sessions /app/output && \\\n173\t    chown -R sandbox:sandbox /app\n174\t\n175\t# Copy and configure startup script\n176\tCOPY --chown=root:root coolify/start.sh /app/start.sh\n177\tRUN chmod +x /app/start.sh\n178\t\n179\t# Switch to sandbox user for /workspace operations and runtime\n180\tUSER sandbox\n181\t\n182\t# Create necessary /workspace directories\n183\tRUN mkdir -p /workspace/.claude/plugins /workspace/.config\n184\t\n185\t# Create bash profile for sandbox user\n186\t# Note: .node-bin is a symlink to the active Node.js version's bin directory\n187\tRUN echo 'export PATH=\"/workspace/.node-bin:/workspace/.bun/bin:/workspace/.cargo/bin:/workspace/.elan/bin:/workspace/.opam/default/bin:/home/linuxbrew/.linuxbrew/bin:$PATH\"' >> /workspace/.bashrc && \\\n188\t    echo 'export BUN_INSTALL=\"/workspace/.bun\"' >> /workspace/.bashrc\n189\t\n190\t# Create git config file for sandbox user\n191\tRUN echo \"[user]\" > /workspace/.gitconfig && \\\n192\t    echo \"  name = Hive-Mind Bot\" >> /workspace/.gitconfig && \\\n193\t    echo \"  email = hive-mind@localhost\" >> /workspace/.gitconfig && \\\n194\t    echo \"[init]\" >> /workspace/.gitconfig && \\\n195\t    echo \"  defaultBranch = main\" >> /workspace/.gitconfig && \\\n196\t    echo \"[safe]\" >> /workspace/.gitconfig && \\\n197\t    echo \"  directory = *\" >> /workspace/.gitconfig\n198\t\n199\t# Runtime configuration\n200\tENV NODE_ENV=production\n201\tENV PORT=3000\n202\tENV MONITOR_TAG=\"help wanted\"\n203\tENV CONCURRENCY=2\n204\tENV INTERVAL=300\n205\tENV MODEL=sonnet\n206\t\n207\t# Health check\n208\tHEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \\\n209\t    CMD pgrep -f \"hive.mjs\\|tail\" > /dev/null || exit 1\n210\t\n211\tSHELL [\"/bin/bash\", \"-c\"]\n212\tENTRYPOINT [\"/app/start.sh\"]\n213\t"
