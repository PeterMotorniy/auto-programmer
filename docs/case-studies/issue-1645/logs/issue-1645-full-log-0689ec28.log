st dockerPrSection = releaseYml.slice(dockerPrStart, helmPrStart);\n30\t\n31\tassert.ok(dockerPrSection.includes('node tests/test-docker-release-order.mjs'), 'docker-pr-check should run this static release-order contract test');\n32\tassert.ok(!dockerPrSection.includes('docker build --progress=plain'), 'docker-pr-check should not build Docker images before npm publish');\n33\t\n34\tassert.ok(releaseYml.includes('docker-publish:\\n    name: Docker Publish'), 'release workflow should keep the normal Docker publish job');\n35\tassert.ok(releaseYml.includes('needs: [release]'), 'docker-publish should depend on the npm release job');\n36\tassert.ok(releaseYml.includes('needs: [instant-release]'), 'instant Docker publish should depend on the instant npm release job');\n37\tassert.ok(releaseYml.includes('node scripts/wait-for-npm.mjs --release-version \"${{ needs.release.outputs.published_version }}\"'), 'release Docker job should wait for the published npm version');\n38\tassert.ok(releaseYml.includes('node scripts/wait-for-npm.mjs --release-version \"${{ needs.instant-release.outputs.published_version }}\"'), 'instant Docker job should wait for the published npm version');\n39\tassert.ok(!/Wait for NPM package availability[\\s\\S]{0,160}\\n\\s+if: matrix\\.platform == 'linux\\/amd64'/.test(releaseYml), 'every Docker matrix build should wait for npm availability');\n40\tassert.ok(releaseYml.includes('HIVE_MIND_VERSION=${{ needs.release.outputs.published_version }}'), 'release Docker build should pass the exact npm version into Docker');\n41\tassert.ok(releaseYml.includes('HIVE_MIND_VERSION=${{ needs.instant-release.outputs.published_version }}'), 'instant Docker build should pass the exact npm version into Docker');\n42\t\n43\tconsole.log('Docker release-order contract tests passed');\n44\t"
