        "content": "   900→                                let l = eval_arith(&children[0], env);\n   901→                                let r = eval_arith(&children[2], env);\n   902→                                let num_eq = if dec_round(l) == dec_round(r) {\n   903→                                    env.hi\n   904→                                } else {\n   905→                                    env.lo\n   906→                                };\n   907→                                let neq = env.apply_op(\"not\", &[num_eq]);\n   908→                                return EvalResult::Value(env.clamp(neq));\n   909→                            }\n   910→                        }\n   911→                    }\n   912→                }\n   913→            }\n   914→\n   915→            // ---------- Type System: \"everything is a link\" ----------\n   916→\n   917→            // Type universe: (Type N)\n   918→            if children.len() == 2 {\n   919→                if let Node::Leaf(ref first) = children[0] {\n   920→                    if first == \"Type\" {\n   921→                        if let Node::Leaf(ref level_s) = children[1] {\n   922→                            let level: i64 = level_s.parse().unwrap_or(0);\n   923→                            let key = key_of(&Node::List(children.clone()));\n   924→                            env.set_type(&key, &format!(\"(Type {})\", level + 1));\n   925→                            return EvalResult::Value(1.0);\n   926→                        }\n   927→                    }\n   928→                }\n   929→            }\n   930→\n   931→            // Prop: (Prop) sugar for (Type 0)\n   932→            if children.len() == 1 {\n   933→                if let Node::Leaf(ref first) = children[0] {\n   934→                    if first == \"Prop\" {\n   935→                        env.set_type(\"(Prop)\", \"(Type 1)\");\n   936→                        return EvalResult::Value(1.0);\n   937→                    }\n