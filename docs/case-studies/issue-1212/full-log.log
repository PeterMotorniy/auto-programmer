        "content": "   200→}\n   201→\n   202→/// Check structural equality of two nodes.\n   203→pub fn is_structurally_same(a: &Node, b: &Node) -> bool {\n   204→    match (a, b) {\n   205→        (Node::Leaf(sa), Node::Leaf(sb)) => sa == sb,\n   206→        (Node::List(la), Node::List(lb)) => {\n   207→            la.len() == lb.len()\n   208→                && la\n   209→                    .iter()\n   210→                    .zip(lb.iter())\n   211→                    .all(|(x, y)| is_structurally_same(x, y))\n   212→        }\n   213→        _ => false,\n   214→    }\n   215→}\n   216→\n   217→// ========== Decimal-precision arithmetic ==========\n   218→// Round to at most DECIMAL_PRECISION significant decimal places to eliminate\n   219→// IEEE-754 floating-point artefacts (e.g. 0.1+0.2 → 0.3, not 0.30000000000000004).\n   220→const DECIMAL_PRECISION: i32 = 12;\n   221→\n   222→pub fn dec_round(x: f64) -> f64 {\n   223→    if !x.is_finite() {\n   224→        return x;\n   225→    }\n   226→    let factor = 10f64.powi(DECIMAL_PRECISION);\n   227→    (x * factor).round() / factor\n   228→}\n   229→\n   230→// ========== Quantization ==========\n   231→\n   232→/// Quantize a value to N discrete levels in range [lo, hi].\n   233→/// For N=2 (Boolean): levels are {lo, hi}\n   234→/// For N=3 (ternary): levels are {lo, mid, hi}\n   235→/// For N<2 (continuous/unary): no quantization\n   236→/// See: https://en.wikipedia.org/wiki/Many-valued_logic\n   237→pub fn quantize(x: f64, valence: u32, lo: f64, hi: f64) -> f64 {\n   238→    if valence < 2 {\n   239→        return x; // unary or continuous — no quantization\n   240→    }\n   241→    let step = (hi - lo) / (valence as f64 - 1.0);\n   242→    let level = ((x - lo) / step).round();\n   243→    let level = level.max(0.0).min(valence as f64 - 1.0);\n   244→    lo + level * step\n   245→}\n   246→\n   247→// ========== Aggregator Types ==========\n   248→\n   249→/// Supported aggregator types for AND/OR operators.\n   250→#[derive(Debug, Clone, Copy, PartialEq)]\n   251→pub enum Aggregator {\n   252→    Avg,\n   253→    Min,\n   254→    Max,\n   255→    Prod,\n   256→    Ps, // Probabilistic sum: 1 - ∏(1-xi)\n   257→}\n   258→\n   259→impl Aggregator {\n   260→    fn apply(&self, xs: &[f64], lo: f64) -> f64 {\n   261→        if xs.is_empty() {\n   262→            return lo;\n   263→        }\n   264→        match self {\n   265→            Aggregator::Avg => xs.iter().sum::<f64>() / xs.len() as f64,\n   266→            Aggregator::Min => xs.iter().copied().fold(f64::INFINITY, f64::min),\n   267→            Aggregator::Max => xs.iter().copied().fold(f64::NEG_INFINITY, f64::max),\n   268→            Aggregator::Prod => xs.iter().copied().fold(1.0, |a, b| a * b),\n   269→            Aggregator::Ps => 1.0 - xs.iter().copied().fold(1.0, |a, b| a * (1.0 - b)),\n   270→        }\n   271→    }\n   272→\n   273→    fn from_name(name: &str) -> Option<Self> {\n   274→        match name {\n   275→            \"avg\" => Some(Aggregator::Avg),\n   276→            \"min\" => Some(Aggregator::Min),\n   277→            \"max\" => Some(Aggregator::Max),\n   278→            \"prod\" => Some(Aggregator::Prod),\n   279→            \"ps\" => Some(Aggregator::Ps),\n   280→            _ => None,\n   281→        }\n   282→    }\n   283→}\n   284→\n   285→// ========== Operator ==========\n   286→\n   287→/// Operator types supported by the environment.\n   288→#[derive(Debug, Clone)]\n   289→pub enum Op {\n   290→    /// Negation: mirrors around midpoint. not(x) = hi - (x - lo)\n   291→    Not,\n   292→    /// Aggregator-based operator (for and/or).\n   293→    Agg(Aggregator),\n   294→    /// Equality operator: checks assigned probability or structural equality.\n   295→    Eq,\n   296→    /// Inequality: not(eq(...))\n   297→    Neq,\n   298→    /// Composition: outer(inner(...))\n   299→    Compose { outer: String, inner: String },\n   300→    /// Arithmetic: +, -, *, / (decimal-precision)\n   301→    Add,\n   302→    Sub,\n   303→    Mul,\n   304→    Div,\n   305→}\n   306→\n   307→// ========== Environment ==========\n   308→\n   309→/// Options for creating an Env.\n   310→#[derive(Debug, Clone)]\n   311→pub struct EnvOptions {\n   312→    pub lo: f64,\n   313→    pub hi: f64,\n   314→    pub valence: u32,\n   315→}\n   316→\n   317→impl Default for EnvOptions {\n   318→    fn default() -> Self {\n   319→        Self {\n   320→            lo: 0.0,\n   321→            hi: 1.0,\n   322→            valence: 0,\n   323→        }\n   324→    }\n   325→}\n   326→\n   327→/// A stored lambda definition (param name, param type, body).\n   328→#[derive(Debug, Clone)]\n   329→pub struct Lambda {\n   330→    pub param: String,\n   331→    pub param_type: String,\n   332→    pub body: Node,\n   333→}\n   334→\n   335→/// The evaluation environment: holds terms, assignments, operators, and range/valence config.\n   336→pub struct Env {\n   337→    pub terms: HashSet<String>,\n   338→    pub assign: HashMap<String, f64>,\n   339→    pub symbol_prob: HashMap<String, f64>,\n   340→    pub lo: f64,\n   341→    pub hi: f64,\n   342→    pub valence: u32,\n   343→    pub ops: HashMap<String, Op>,\n   344→    pub types: HashMap<String, String>,\n   345→    pub lambdas: HashMap<String, Lambda>,\n   346→}\n   347→\n   348→impl Env {\n   349→    pub fn new(options: Option<EnvOptions>) -> Self {\n   350→        let opts = options.unwrap_or_default();\n   351→        let mut ops = HashMap::new();\n   352→        ops.insert(\"not\".to_string(), Op::Not);\n   353→        ops.insert(\"and\".to_string(), Op::Agg(Aggregator::Avg));\n   354→        ops.insert(\"or\".to_string(), Op::Agg(Aggregator::Max));\n   355→        ops.insert(\"=\".to_string(), Op::Eq);\n   356→        ops.insert(\"!=\".to_string(), Op::Neq);\n   357→        ops.insert(\"+\".to_string(), Op::Add);\n   358→        ops.insert(\"-\".to_string(), Op::Sub);\n   359→        ops.insert(\"*\".to_string(), Op::Mul);\n   360→        ops.insert(\"/\".to_string(), Op::Div);\n   361→\n   362→        let mut env = Self {\n   363→            terms: HashSet::new(),\n   364→            assign: HashMap::new(),\n   365→            symbol_prob: HashMap::new(),\n   366→            lo: opts.lo,\n   367→            hi: opts.hi,\n   368→            valence: opts.valence,\n   369→            ops,\n   370→            types: HashMap::new(),\n   371→            lambdas: HashMap::new(),\n   372→        };\n   373→\n   374→        // Initialize truth constants: true, false, unknown, undefined\n   375→        // These are predefined symbol probabilities based on the current range.\n   376→        // By default: (false: min(range)), (true: max(range)),\n   377→        //             (unknown: mid(range)), (undefined: mid(range))\n   378→        // They can be redefined by the user via (true: <value>), (false: <value>), etc.\n   379→        env.init_truth_constants();\n   380→        env\n   381→    }\n   382→\n   383→    /// Midpoint of the range.\n   384→    pub fn mid(&self) -> f64 {\n   385→        (self.lo + self.hi) / 2.0\n   386→    }\n   387→\n   388→    /// Initialize truth constants based on current range.\n   389→    /// (false: min(range)), (true: max(range)),\n   390→    /// (unknown: mid(range)), (undefined: mid(range))\n   391→    pub fn init_truth_constants(&mut self) {\n   392→        self.symbol_prob.insert(\"true\".to_string(), self.hi);\n   393→        self.symbol_prob.insert(\"false\".to_string(), self.lo);\n   394→        let mid = self.mid();\n   395→        self.symbol_prob.insert(\"unknown\".to_string(), mid);\n   396→        self.symbol_prob.insert(\"undefined\".to_string(), mid);\n   397→    }\n   398→\n   399→    /// Clamp and optionally quantize a value to the valid range.\n   400→    pub fn clamp(&self, x: f64) -> f64 {\n   401→        let clamped = x.max(self.lo).min(self.hi);\n   402→        if self.valence >= 2 {\n   403→            quantize(clamped, self.valence, self.lo, self.hi)\n   404→        } else {\n   405→            clamped\n   406→        }\n   407→    }\n   408→\n   409→    /// Parse a numeric string respecting current range.\n   410→    pub fn to_num(&self, s: &str) -> f64 {\n   411→        self.clamp(s.parse::<f64>().unwrap_or(0.0))\n   412→    }\n   413→\n   414→    pub fn define_op(&mut self, name: &str, op: Op) {\n   415→        self.ops.insert(name.to_string(), op);\n   416→    }\n   417→\n   418→    pub fn get_op(&self, name: &str) -> Option<&Op> {\n   419→        self.ops.get(name)\n   420→    }\n   421→\n   422→    pub fn set_expr_prob(&mut self, expr_node: &Node, p: f64) {\n   423→        self.assign.insert(key_of(expr_node), self.clamp(p));\n   424→    }\n   425→\n   426→    pub fn set_symbol_prob(&mut self, sym: &str, p: f64) {\n   427→        self.symbol_prob.insert(sym.to_string(), self.clamp(p));\n   428→    }\n   429→\n   430→    pub fn get_symbol_prob(&self, sym: &str) -> f64 {\n   431→        self.symbol_prob\n   432→            .get(sym)\n   433→            .copied()\n   434→            .unwrap_or_else(|| self.mid())\n   435→    }\n   436→\n   437→    pub fn set_type(&mut self, expr: &str, type_expr: &str) {\n   438→        self.types.insert(expr.to_string(), type_expr.to_string());\n   439→    }\n   440→\n   441→    pub fn get_type(&self, expr: &str) -> Option<&String> {\n   442→        self.types.get(expr)\n   443→    }\n   444→\n   445→    pub fn set_lambda(&mut self, name: &str, lambda: Lambda) {\n   446→        self.lambdas.insert(name.to_string(), lambda);\n   447→    }\n   448→\n   449→    pub fn get_lambda(&self, name: &str) -> Option<&Lambda> {\n   450→        self.lambdas.get(name)\n   451→    }\n   452→\n   453→    /// Apply an operator by name to the given values.\n   454→    pub fn apply_op(&self, name: &str, vals: &[f64]) -> f64 {\n   455→        let op = match self.ops.get(name) {\n   456→            Some(op) => op.clone(),\n   457→            None => panic!(\"Unknown op: {}\", name),\n   458→        };\n   459→        match op {\n   460→            Op::Not => {\n   461→                if vals.is_empty() {\n   462→                    self.lo\n   463→                } else {\n   464→                    self.hi - (vals[0] - self.lo)\n   465→                }\n   466→            }\n   467→            Op::Agg(agg) => agg.apply(vals, self.lo),\n   468→            Op::Eq | Op::Neq => self.lo,\n   469→            Op::Compose {\n   470→                ref outer,\n   471→                ref inner,\n   472→            } => {\n   473→                let inner_result = self.apply_op(inner, vals);\n   474→                self.apply_op(outer, &[inner_result])\n   475→            }\n   476→            Op::Add => {\n   477→                if vals.len() >= 2 {\n   478→                    dec_round(vals[0] + vals[1])\n   479→                } else {\n   480→                    0.0\n   481→                }\n   482→            }\n   483→            Op::Sub => {\n   484→                if vals.len() >= 2 {\n   485→                    dec_round(vals[0] - vals[1])\n   486→                } else {\n   487→                    0.0\n   488→                }\n   489→            }\n   490→            Op::Mul => {\n   491→                if vals.len() >= 2 {\n   492→                    dec_round(vals[0] * vals[1])\n   493→                } else {\n   494→                    0.0\n   495→                }\n   496→            }\n   497→            Op::Div => {\n   498→                if vals.len() >= 2 && vals[1] != 0.0 {\n   499→                    dec_round(vals[0] / vals[1])\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"
