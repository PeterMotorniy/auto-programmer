        "content": "     1→import { describe, it } from 'node:test';\n     2→import assert from 'node:assert';\n     3→import { run, tokenizeOne, parseOne, Env, evalNode, quantize, decRound, substitute } from '../src/adl-links.mjs';\n     4→\n     5→const approx = (actual, expected, epsilon = 1e-9) =>\n     6→  assert.ok(Math.abs(actual - expected) < epsilon,\n     7→    `Expected ${expected}, got ${actual} (diff: ${Math.abs(actual - expected)})`);\n     8→\n     9→describe('tokenizeOne', () => {\n    10→  it('should tokenize simple link', () => {\n    11→    const tokens = tokenizeOne('(a: a is a)');\n    12→    assert.deepStrictEqual(tokens, ['(', 'a:', 'a', 'is', 'a', ')']);\n    13→  });\n    14→\n    15→  it('should tokenize nested link', () => {\n    16→    const tokens = tokenizeOne('((a = a) has probability 1)');\n    17→    assert.deepStrictEqual(tokens, ['(', '(', 'a', '=', 'a', ')', 'has', 'probability', '1', ')']);\n    18→  });\n    19→\n    20→  it('should strip inline comments', () => {\n    21→    const tokens = tokenizeOne('(and: avg) # this is a comment');\n    22→    assert.deepStrictEqual(tokens, ['(', 'and:', 'avg', ')']);\n    23→  });\n    24→\n    25→  it('should balance parens after stripping comments', () => {\n    26→    const tokens = tokenizeOne('((and: avg) # comment)');\n    27→    assert.deepStrictEqual(tokens, ['(', '(', 'and:', 'avg', ')', ')']);\n    28→  });\n    29→});\n    30→\n    31→describe('parseOne', () => {\n    32→  it('should parse simple link', () => {\n    33→    const tokens = ['(', 'a:', 'a', 'is', 'a', ')'];\n    34→    const ast = parseOne(tokens);\n    35→    assert.deepStrictEqual(ast, ['a:', 'a', 'is', 'a']);\n    36→  });\n    37→\n    38→  it('should parse nested link', () => {\n    39→    const tokens = ['(', '(', 'a', '=', 'a', ')', 'has', 'probability', '1', ')'];\n    40→    const ast = parseOne(tokens);\n    41→    assert.deepStrictEqual(ast, [['a', '=', 'a'], 'has', 'probability', '1']);\n    42→  });\n    43→\n    44→  it('should parse deeply nested link', () => {\n    45→    const tokens = ['(', '?', '(', '(', 'a', '=', 'a', ')', 'and', '(', 'a', '!=', 'a', ')', ')', ')'];\n    46→    const ast = parseOne(tokens);\n    47→    assert.deepStrictEqual(ast, ['?', [['a', '=', 'a'], 'and', ['a', '!=', 'a']]]);\n    48→  });\n    49→});\n    50→\n    51→describe('Env', () => {\n    52→  it('should initialize with default operators', () => {\n    53→    const env = new Env();\n    54→    assert.ok(env.ops.has('not'));\n    55→    assert.ok(env.ops.has('and'));\n    56→    assert.ok(env.ops.has('or'));\n    57→    assert.ok(env.ops.has('='));\n    58→    assert.ok(env.ops.has('!='));\n    59→  });\n    60→\n    61→  it('should allow defining new operators', () => {\n    62→    const env = new Env();\n    63→    env.defineOp('test', (x) => x * 2);\n    64→    assert.ok(env.ops.has('test'));\n    65→    assert.strictEqual(env.getOp('test')(0.5), 1);\n    66→  });\n    67→\n    68→  it('should store expression probabilities', () => {\n    69→    const env = new Env();\n    70→    env.setExprProb(['a', '=', 'a'], 1);\n    71→    assert.strictEqual(env.assign.get('(a = a)'), 1);\n    72→  });\n    73→});\n    74→\n    75→describe('evalNode', () => {\n    76→  it('should evaluate numeric literals', () => {\n    77→    const env = new Env();\n    78→    assert.strictEqual(evalNode('1', env), 1);\n    79→    assert.strictEqual(evalNode('0.5', env), 0.5);\n    80→    assert.strictEqual(evalNode('0', env), 0);\n    81→  });\n    82→\n    83→  it('should evaluate term definitions', () => {\n    84→    const env = new Env();\n    85→    evalNode(['a:', 'a', 'is', 'a'], env);\n    86→    assert.ok(env.terms.has('a'));\n    87→  });\n    88→\n    89→  it('should evaluate operator redefinitions', () => {\n    90→    const env = new Env();\n    91→    evalNode(['!=:', 'not', '='], env);\n    92→    assert.ok(env.ops.has('!='));\n    93→  });\n    94→\n    95→  it('should evaluate aggregator selection', () => {\n    96→    const env = new Env();\n    97→    evalNode(['and:', 'min'], env);\n    98→    const andOp = env.getOp('and');\n    99→    assert.strictEqual(andOp(0.3, 0.7), 0.3);\n   100→  });\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"
