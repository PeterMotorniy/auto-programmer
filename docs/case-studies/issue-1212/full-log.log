if (lambda) {\n   510→      // Apply first argument, then recursively apply rest\n   511→      let result = substitute(lambda.body, lambda.param, args[0]);\n   512→      if (args.length === 1) {\n   513→        return evalNode(result, env);\n   514→      }\n   515→      // Curry: apply remaining args\n   516→      let current = evalNode(result, env);\n   517→      for (let i = 1; i < args.length; i++) {\n   518→        // If current result is a lambda, apply next arg\n   519→        current = evalNode(args[i], env);\n   520→      }\n   521→      return current;\n   522→    }\n   523→  }\n   524→\n   525→  return 0;\n   526→}\n   527→\n   528→// Re-initialize default ops when range changes\n   529→function _reinitOps(env) {\n   530→  env.ops.set('not', (x) => env.hi - (x - env.lo));\n   531→  env.ops.set('and', (...xs) => xs.length ? xs.reduce((a,b)=>a+b,0)/xs.length : env.lo);\n   532→  env.ops.set('or', (...xs) => xs.length ? Math.max(...xs) : env.lo);\n   533→  env.ops.set('=', (L,R,ctx) => {\n   534→    const kPrefix = keyOf(['=',L,R]);\n   535→    if (env.assign.has(kPrefix)) return env.assign.get(kPrefix);\n   536→    const kInfix = keyOf([L,'=',R]);\n   537→    if (env.assign.has(kInfix)) return env.assign.get(kInfix);\n   538→    return isStructurallySame(L,R) ? env.hi : env.lo;\n   539→  });\n   540→  env.ops.set('!=', (...args) => env.getOp('not')( env.getOp('=')(...args) ));\n   541→  env.ops.set('+', (a,b) => decRound(a + b));\n   542→  env.ops.set('-', (a,b) => decRound(a - b));\n   543→  env.ops.set('*', (a,b) => decRound(a * b));\n   544→  env.ops.set('/', (a,b) => b === 0 ? 0 : decRound(a / b));\n   545→  // Re-initialize truth constants for new range\n   546→  env._initTruthConstants();\n   547→}\n   548→\n   549→function defineForm(head, rhs, env){\n   550→  // Term definition: (a: a is a)  → declare 'a' as a term (no probability assignment)\n   551→  if (rhs.length === 3 && typeof rhs[0]==='string' && rhs[1]==='is' && typeof rhs[2]==='string' && rh