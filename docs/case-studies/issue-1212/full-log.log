        "content": "     1→#!/usr/bin/env node\n     2→// ADL — minimal associative-dependent logic over LiNo (Links Notation)\n     3→// Supports many-valued logics from unary (1-valued) through continuous probabilistic (∞-valued).\n     4→// See: https://en.wikipedia.org/wiki/Many-valued_logic\n     5→//\n     6→// - Uses official links-notation parser to parse links\n     7→// - Terms are defined via (x: x is x)\n     8→// - Probabilities are assigned ONLY via: ((<expr>) has probability <p>)\n     9→// - Redefinable ops: (=: ...), (!=: not =), (and: avg|min|max|prod|ps), (or: ...), (not: ...)\n    10→// - Range: (range: 0 1) for [0,1] or (range: -1 1) for [-1,1] (balanced/symmetric)\n    11→// - Valence: (valence: N) to restrict truth values to N discrete levels (N=2 → Boolean, N=3 → ternary, etc.)\n    12→// - Query: (? <expr>)\n    13→\n    14→import fs from 'node:fs';\n    15→import { Parser } from 'links-notation';\n    16→\n    17→// ---------- helpers: canonical keys & tokenization of a single link string ----------\n    18→function tokenizeOne(s) {\n    19→  // s is a single-link string like \"( (a = a) has probability 1 )\"\n    20→  // Strip inline comments (everything after #) but balance parens\n    21→  const commentIdx = s.indexOf('#');\n    22→  if (commentIdx !== -1) {\n    23→    s = s.substring(0, commentIdx);\n    24→    // Count unmatched opening parens and add closing parens to balance\n    25→    let depth = 0;\n    26→    for (let i = 0; i < s.length; i++) {\n    27→      if (s[i] === '(') depth++;\n    28→      else if (s[i] === ')') depth--;\n    29→    }\n    30→    // Add missing closing parens\n    31→    while (depth > 0) {\n    32→      s += ')';\n    33→      depth--;\n    34→    }\n    35→  }\n    36→\n    37→  const out = [];\n    38→  let i = 0;\n    39→  const isWS = c => /\\s/.test(c);\n    40→  while (i < s.length) {\n    41→    const c = s[i];\n    42→    if (isWS(c)) { i++; continue; }\n    43→    if (c === '(' || c === ')') { out.push(c); i++; continue; }\n    44→    let j = i;\n    45→    while (j < s.length && !isWS(s[j]) && s[j] !== '(' && s[j] !== ')') j++;\n    46→    out.push(s.slice(i, j));\n    47→    i = j;\n    48→  }\n    49→  return out;\n    50→}\n    51→function parseOne(tokens) {\n    52→  let i = 0;\n    53→  function read() {\n    54→    if (tokens[i] !== '(') throw new Error('expected \"(\"');\n    55→    i++;\n    56→    const arr = [];\n    57→    while (i < tokens.length && tokens[i] !== ')') {\n    58→      if (tokens[i] === '(') arr.push(read());\n    59→      else { arr.push(tokens[i]); i++; }\n    60→    }\n    61→    if (tokens[i] !== ')') throw new Error('expected \")\"');\n    62→    i++;\n    63→    return arr;\n    64→  }\n    65→  const ast = read();\n    66→  if (i !== tokens.length) throw new Error('extra tokens after link');\n    67→  return ast;\n    68→}\n    69→const isNum = s => /^-?(\\d+(\\.\\d+)?|\\.\\d+)$/.test(s);\n    70→const clamp01 = x => Math.max(0, Math.min(1, x));\n    71→\n    72→// ---------- Decimal-precision arithmetic ----------\n    73→// Round to at most `digits` significant decimal places to eliminate\n    74→// IEEE-754 floating-point artefacts (e.g. 0.1+0.2 → 0.3, not 0.30000000000000004).\n    75→const DECIMAL_PRECISION = 12;\n    76→function decRound(x) {\n    77→  if (!Number.isFinite(x)) return x;\n    78→  return +(Math.round(x + 'e' + DECIMAL_PRECISION) + 'e-' + DECIMAL_PRECISION);\n    79→}\n    80→function keyOf(node) {\n    81→  if (Array.isArray(node)) return '(' + node.map(keyOf).join(' ') + ')';\n    82→  return String(node);\n    83→}\n    84→function isStructurallySame(a,b){\n    85→  if (Array.isArray(a) && Array.isArray(b)){\n    86→    if (a.length !== b.length) return false;\n    87→    for (let i=0;i<a.length;i++) if (!isStructurallySame(a[i],b[i])) return false;\n    88→    return true;\n    89→  }\n    90→  return String(a) === String(b);\n    91→}\n    92→\n    93→// ---------- Quantization for N-valued logics ----------\n    94→// Given N discrete levels and a range [lo, hi], quantize a value to the nearest level.\n    95→// For N=2 (Boolean): levels are {lo, hi} (e.g. {0, 1} or {-1, 1})\n    96→// For N=3 (ternary): levels are {lo, mid, hi} (e.g. {0, 0.5, 1} or {-1, 0, 1})\n    97→// For N=0 or Infinity (continuous): no quantization\n    98→// See: https://en.wikipedia.org/wiki/Many-valued_logic\n    99→function quantize(x, valence, lo, hi) {\n   100→  if (valence < 2) return x; // unary or continuous — no quantization\n   101→  const step = (hi - lo) / (valence - 1);\n   102→  const level = Math.round((x - lo) / step);\n   103→  return lo + Math.max(0, Math.min(valence - 1, level)) * step;\n   104→}\n   105→\n   106→// ---------- Environment ----------\n   107→class Env {\n   108→  constructor(options){\n   109→    const opts = options || {};\n   110→    this.terms = new Set();                     // declared terms (via (x: x is x))\n   111→    this.assign = new Map();                    // key(expr) -> truth value\n   112→    this.symbolProb = new Map();                // optional symbol priors if you want (x: 0.7)\n   113→    this.types = new Map();                     // key(expr) -> type expression (as string)\n   114→    this.lambdas = new Map();                   // name -> { param, paramType, body } for named lambdas\n   115→\n   116→    // Range: [lo, hi] — default [0, 1] (standard probabilistic)\n   117→    // Use [-1, 1] for balanced/symmetric range\n   118→    // See: https://en.wikipedia.org/wiki/Balanced_ternary\n   119→    this.lo = opts.lo !== undefined ? opts.lo : 0;\n   120→    this.hi = opts.hi !== undefined ? opts.hi : 1;\n   121→\n   122→    // Valence: number of discrete truth values (0 or Infinity = continuous)\n   123→    // N=1: unary logic (trivial, only one truth value)\n   124→    // N=2: binary/Boolean logic — https://en.wikipedia.org/wiki/Boolean_algebra\n   125→    // N=3: ternary logic — https://en.wikipedia.org/wiki/Three-valued_logic\n   126→    // N=4+: N-valued logic — https://en.wikipedia.org/wiki/Many-valued_logic\n   127→    // N=0/Infinity: continuous probabilistic / fuzzy logic — https://en.wikipedia.org/wiki/Fuzzy_logic\n   128→    this.valence = opts.valence !== undefined ? opts.valence : 0;\n   129→\n   130→    // ops (redefinable)\n   131→    this.ops = new Map(Object.entries({\n   132→      'not': (x)=> this.hi - (x - this.lo),  // negation: mirrors around midpoint\n   133→      'and': (...xs)=> xs.length ? xs.reduce((a,b)=>a+b,0)/xs.length : this.lo, // avg\n   134→      'or' : (...xs)=> xs.length ? Math.max(...xs) : this.lo,\n   135→      '='  : (L,R,ctx)=> {\n   136→        // If assigned explicitly, use that (check both prefix and infix key forms)\n   137→        const kPrefix = keyOf(['=',L,R]);\n   138→        if (this.assign.has(kPrefix)) return this.assign.get(kPrefix);\n   139→        const kInfix = keyOf([L,'=',R]);\n   140→        if (this.assign.has(kInfix)) return this.assign.get(kInfix);\n   141→        // Default: syntactic equality of terms/trees\n   142→        return isStructurallySame(L,R) ? this.hi : this.lo;\n   143→      },\n   144→    }));\n   145→    // sugar: \"!=\" as not of \"=\" (can be redefined)\n   146→    this.defineOp('!=', (...args)=> this.getOp('not')( this.getOp('=')(...args) ));\n   147→\n   148→    // Arithmetic operators (decimal-precision by default)\n   149→    this.defineOp('+', (a,b)=> decRound(a + b));\n   150→    this.defineOp('-', (a,b)=> decRound(a - b));\n   151→    this.defineOp('*', (a,b)=> decRound(a * b));\n   152→    this.defineOp('/', (a,b)=> b === 0 ? 0 : decRound(a / b));\n   153→\n   154→    // Initialize truth constants: true, false, unknown, undefined\n   155→    // These are predefined symbol probabilities based on the current range.\n   156→    // By default: (false: min(range)), (true: max(range)),\n   157→    //             (unknown: mid(range)), (undefined: mid(range))\n   158→    // They can be redefined by the user via (true: <value>), (false: <value>), etc.\n   159→    this._initTruthConstants();\n   160→  }\n   161→\n   162→  // Clamp and optionally quantize a value to the valid range\n   163→  clamp(x) {\n   164→    const clamped = Math.max(this.lo, Math.min(this.hi, x));\n   165→    if (this.valence >= 2) return quantize(clamped, this.valence, this.lo, this.hi);\n   166→    return clamped;\n   167→  }\n   168→\n   169→  // Parse a numeric string respecting current range\n   170→  toNum(s) {\n   171→    return this.clamp(parseFloat(s));\n   172→  }\n   173→\n   174→  // Midpoint of the range (useful for paradox resolution, default symbol prob, etc.)\n   175→  get mid() { return (this.lo + this.hi) / 2; }\n   176→\n   177→  // Initialize truth constants based on current range.\n   178→  // (false: min(range)), (true: max(range)),\n   179→  // (unknown: mid(range)), (undefined: mid(range))\n   180→  _initTruthConstants() {\n   181→    this.symbolProb.set('true', this.hi);\n   182→    this.symbolProb.set('false', this.lo);\n   183→    this.symbolProb.set('unknown', this.mid);\n   184→    this.symbolProb.set('undefined', this.mid);\n   185→  }\n   186→\n   187→  getOp(name){\n   188→    if (!this.ops.has(name)) throw new Error(`Unknown op: ${name}`);\n   189→    return this.ops.get(name);\n   190→  }\n   191→  defineOp(name, fn){ this.ops.set(name, fn); }\n   192→\n   193→  setExprProb(exprNode, p){\n   194→    this.assign.set(keyOf(exprNode), this.clamp(p));\n   195→  }\n   196→  setType(exprNode, typeExpr){\n   197→    const key = typeof exprNode === 'string' ? exprNode : keyOf(exprNode);\n   198→    this.types.set(key, typeof typeExpr === 'string' ? typeExpr : keyOf(typeExpr));\n   199→  }\n   200→  getType(exprNode){\n   201→    const key = typeof exprNode === 'string' ? exprNode : keyOf(exprNode);\n   202→    return this.types.get(key) || null;\n   203→  }\n   204→  setLambda(name, param, paramType, body){\n   205→    this.lambdas.set(name, { param, paramType, body });\n   206→  }\n   207→  getLambda(name){\n   208→    return this.lambdas.get(name) || null;\n   209→  }\n   210→  setSymbolProb(sym, p){ this.symbolProb.set(sym, this.clamp(p)); }\n   211→  getSymbolProb(sym){ return this.symbolProb.has(sym) ? this.symbolProb.get(sym) : this.mid; }\n   212→}\n   213→\n   214→// ---------- Binding parser ----------\n   215→// Parse a binding form in two supported syntaxes:\n   216→// 1. Colon form: (x: A) as ['x:', A] — standard LiNo link definition syntax\n   217→// 2. Prefix type form: (A x) as ['A', 'x'] — type-first notation for lambda/Pi bindings\n   218→//    e.g. (Natural x), used in (lambda (Natural x) body)\n   219→// Returns { paramName, paramType } or null if not a valid binding.\n   220→function parseBinding(binding) {\n   221→  if (!Array.isArray(binding)) return null;\n   222→  // ['x:', A] — two elements where first ends with colon (standard LiNo link definition)\n   223→  if (binding.length === 2 && typeof binding[0] === 'string' && binding[0].endsWith(':')) {\n   224→    return { paramName: binding[0].slice(0, -1), paramType: binding[1] };\n   225→  }\n   226→  // ['A', 'x'] — prefix type form: type name first, then variable name\n   227→  // Type names must start with uppercase (convention from Lean/Rocq)\n   228→  if (binding.length === 2 && typeof binding[0] === 'string' && typeof binding[1] === 'string'\n   229→      && /^[A-Z]/.test(binding[0]) && !binding[1].endsWith(':')) {\n   230→    return { paramName: binding[1], paramType: binding[0] };\n   231→  }\n   232→  return null;\n   233→}\n   234→\n   235→// ---------- Multi-binding parser ----------\n   236→// Parse comma-separated bindings: (Natural x, Natural y) → [{paramName:'x', paramType:'Natural'}, ...]\n   237→// Tokens arrive as ['Natural', 'x,', 'Natural', 'y'] or ['Natural', 'x'] (single binding)\n   238→function parseBindings(binding) {\n   239→  if (!Array.isArray(binding)) return null;\n   240→  // Try single binding first\n   241→  const single = parseBinding(binding);\n   242→  if (single) return [single];\n   243→  // Try comma-separated: flatten tokens, split by commas\n   244→  const tokens = [];\n   245→  for (const tok of binding) {\n   246→    if (typeof tok === 'string') {\n   247→      // Split tokens that end with comma: 'x,' → 'x', separator\n   248→      if (tok.endsWith(',')) {\n   249→        tokens.push(tok.slice(0, -1));\n   250→        tokens.push(',');\n   251→      } else {\n   252→        tokens.push(tok);\n   253→      }\n   254→    } else {\n   255→      tokens.push(tok);\n   256→    }\n   257→  }\n   258→  // Group into pairs separated by commas\n   259→  const bindings = [];\n   260→  let i = 0;\n   261→  while (i < tokens.length) {\n   262→    if (tokens[i] === ',') { i++; continue; }\n   263→    if (i + 1 < tokens.length && typeof tokens[i] === 'string' && typeof tokens[i+1] === 'string' && tokens[i+1] !== ',') {\n   264→      const pair = parseBinding([tokens[i], tokens[i+1]]);\n   265→      if (pair) {\n   266→        bindings.push(pair);\n   267→        i += 2;\n   268→        continue;\n   269→      }\n   270→    }\n   271→    return null; // invalid binding format\n   272→  }\n   273→  return bindings.length > 0 ? bindings : null;\n   274→}\n   275→\n   276→// ---------- Substitution (for beta-reduction) ----------\n   277→// Substitute all occurrences of variable `name` with `replacement` in `expr`.\n   278→// Both expr and replacement can be strings or arrays (AST nodes).\n   279→function substitute(expr, name, replacement) {\n   280→  if (typeof expr === 'string') {\n   281→    return expr === name ? replacement : expr;\n   282→  }\n   283→  if (Array.isArray(expr)) {\n   284→    // Don't substitute inside a binding that shadows the variable\n   285→    if (expr.length === 3 && (expr[0] === 'lambda' || expr[0] === 'Pi') && Array.isArray(expr[1])) {\n   286→      const parsed = parseBinding(expr[1]);\n   287→      if (parsed && parsed.paramName === name) {\n   288→        return expr; // shadowed\n   289→      }\n   290→    }\n   291→    return expr.map(child => substitute(child, name, replacement));\n   292→  }\n   293→  return expr;\n   294→}\n   295→\n   296→// ---------- Eval ----------\n   297→// Evaluate a node in arithmetic context — numeric literals are NOT clamped to the logic range.\n   298→function evalArith(node, env){\n   299→  if (typeof node === 'string' && isNum(node)) return parseFloat(node);\n   300→  return evalNode(node, env);\n   301→}\n   302→\n   303→function evalNode(node, env){\n   304→  if (typeof node === 'string') {\n   305→    if (isNum(node)) return env.toNum(node);\n   306→    // bare symbol → optional prior probability if set; otherwise irrelevant in calc\n   307→    return env.getSymbolProb(node);\n   308→  }\n   309→\n   310→  // Definitions & operator redefs:  (head: ...)\n   311→  if (typeof node[0] === 'string' && node[0].endsWith(':')) {\n   312→    const head = node[0].slice(0,-1);\n   313→    return defineForm(head, node.slice(1), env);\n   314→  }\n   315→  // Note: (x : A) with spaces as a standalone colon separator is NOT supported.\n   316→  // Use (x: A) instead — the colon must be part of the link name.\n   317→\n   318→  // Assignment: ((expr) has probability p)\n   319→  if (node.length === 4 && node[1] === 'has' && node[2] === 'probability' && isNum(node[3])) {\n   320→    env.setExprProb(node[0], parseFloat(node[3]));\n   321→    return env.toNum(node[3]);\n   322→  }\n   323→\n   324→  // Range configuration: (range: lo hi) — sets the truth value range\n   325→  // (range: 0 1) for standard [0,1] or (range: -1 1) for balanced [-1,1]\n   326→  // See: https://en.wikipedia.org/wiki/Balanced_ternary\n   327→  // Must be checked in evalNode for (range lo hi) prefix form\n   328→  if (node.length === 3 && node[0] === 'range' && isNum(node[1]) && isNum(node[2])) {\n   329→    env.lo = parseFloat(node[1]);\n   330→    env.hi = parseFloat(node[2]);\n   331→    // Re-initialize ops for new range\n   332→    _reinitOps(env);\n   333→    return 1;\n   334→  }\n   335→\n   336→  // Valence configuration: (valence N) prefix form\n   337→  if (node.length === 2 && node[0] === 'valence' && isNum(node[1])) {\n   338→    env.valence = parseInt(node[1], 10);\n   339→    return 1;\n   340→  }\n   341→\n   342→  // Query: (? expr)\n   343→  if (node[0] === '?') {\n   344→    const v = evalNode(node[1], env);\n   345→    // If inner result is already a query (e.g. from (type of x)), pass it through\n   346→    if (v && typeof v === 'object' && v.query) return v;\n   347→    return { query:true, value: env.clamp(v) };\n   348→  }\n   349→\n   350→  // Infix arithmetic: (A + B), (A - B), (A * B), (A / B)\n   351→  // Arithmetic uses raw numeric values (not clamped to the logic range)\n   352→  if (node.length === 3 && typeof node[1] === 'string' && ['+','-','*','/'].includes(node[1])) {\n   353→    const op = env.getOp(node[1]);\n   354→    const L = evalArith(node[0], env);\n   355→    const R = evalArith(node[2], env);\n   356→    return op(L,R);\n   357→  }\n   358→\n   359→  // Infix AND/OR: ((A) and (B))  /  ((A) or (B))\n   360→  if (node.length === 3 && typeof node[1] === 'string' && (node[1]==='and' || node[1]==='or')) {\n   361→    const op = env.getOp(node[1]);\n   362→    const L = evalNode(node[0], env);\n   363→    const R = evalNode(node[2], env);\n   364→    return env.clamp(op(L,R));\n   365→  }\n   366→\n   367→  // Infix equality/inequality: (L = R), (L != R)\n   368→  if (node.length === 3 && typeof node[1] === 'string' && (node[1]==='=' || node[1]==='!=')) {\n   369→    const op = env.getOp(node[1]);\n   370→    // Equality checks assigned probability first, then structural equality,\n   371→    // then falls back to numeric comparison of evaluated values (decimal-precision)\n   372→    const raw = op(node[0], node[2], keyOf);\n   373→    // If structural/assigned equality already gave a definitive answer, use it\n   374→    if (raw === env.hi || raw === env.lo) {\n   375→      // Check if there's an explicit assignment — if so, trust it\n   376→      const kPrefix = keyOf(['=',node[0],node[2]]);\n   377→      const kInfix = keyOf([node[0],'=',node[2]]);\n   378→      if (env.assign.has(kPrefix) || env.assign.has(kInfix) || isStructurallySame(node[0], node[2])) {\n   379→        return env.clamp(raw);\n   380→      }\n   381→      // No explicit assignment and not structurally same — try numeric comparison\n   382→      const L = evalNode(node[0], env);\n   383→      const R = evalNode(node[2], env);\n   384→      const numEq = decRound(L) === decRound(R) ? env.hi : env.lo;\n   385→      if (node[1] === '!=') return env.clamp(env.getOp('not')(numEq));\n   386→      return env.clamp(numEq);\n   387→    }\n   388→    return env.clamp(raw);\n   389→  }\n   390→\n   391→  // ---------- Type System: \"everything is a link\" ----------\n   392→\n   393→  // Type universe: (Type N) — the sort at universe level N\n   394→  if (node.length === 2 && node[0] === 'Type') {\n   395→    const level = isNum(node[1]) ? parseInt(node[1], 10) : 0;\n   396→    // (Type N) has type (Type N+1)\n   397→    env.setType(node, ['Type', String(level + 1)]);\n   398→    return 1; // valid expression\n   399→  }\n   400→\n   401→  // Prop: (Prop) is sugar for (Type 0) in the propositions-as-types interpretation\n   402→  if (node.length === 1 && node[0] === 'Prop') {\n   403→    env.setType(['Prop'], ['Type', '1']);\n   404→    return 1;\n   405→  }\n   406→\n   407→  // Dependent product (Pi-type): (Pi (A x) B) or (Pi (x: A) B)\n   408→  if (node.length === 3 && node[0] === 'Pi') {\n   409→    const binding = node[1];\n   410→    const parsed = parseBinding(binding);\n   411→    if (parsed) {\n   412→      const { paramName, paramType } = parsed;\n   413→      env.terms.add(paramName);\n   414→      env.setType(paramName, paramType);\n   415→      env.setType(node, ['Type', '0']);\n   416→    }\n   417→    return 1;\n   418→  }\n   419→\n   420→  // Lambda abstraction: (lambda (A x) body) or (lambda (x: A) body)\n   421→  // Also supports multi-param: (lambda (A x, B y) body)\n   422→  if (node.length === 3 && node[0] === 'lambda') {\n   423→    const binding = node[1];\n   424→    const bindings = parseBindings(binding);\n   425→    if (bindings && bindings.length > 0) {\n   426→      // For single binding — standard case\n   427→      const { paramName, paramType } = bindings[0];\n   428→      const body = node[2];\n   429→      env.terms.add(paramName);\n   430→      env.setType(paramName, paramType);\n   431→      // Register additional bindings\n   432→      for (let i = 1; i < bindings.length; i++) {\n   433→        env.terms.add(bindings[i].paramName);\n   434→        env.setType(bindings[i].paramName, bindings[i].paramType);\n   435→      }\n   436→      const bodyType = env.getType(body);\n   437→      const paramTypeKey = typeof paramType === 'string' ? paramType : keyOf(paramType);\n   438→      const bodyTypeKey = bodyType || 'unknown';\n   439→      env.setType(node, '(Pi (' + paramTypeKey + ' ' + paramName + ') ' + bodyTypeKey + ')');\n   440→    }\n   441→    return 1;\n   442→  }\n   443→\n   444→  // Application: (apply f x) — explicit application with beta-reduction\n   445→  if (node.length === 3 && node[0] === 'apply') {\n   446→    const fn = node[1];\n   447→    const arg = node[2];\n   448→\n   449→    // Check if fn is a lambda: (lambda (A x) body)\n   450→    if (Array.isArray(fn) && fn.length === 3 && fn[0] === 'lambda') {\n   451→      const parsed = parseBinding(fn[1]);\n   452→      if (parsed) {\n   453→        const body = fn[2];\n   454→        const result = substitute(body, parsed.paramName, arg);\n   455→        return evalNode(result, env);\n   456→      }\n   457→    }\n   458→\n   459→    // Check if fn is a named lambda\n   460→    if (typeof fn === 'string') {\n   461→      const lambda = env.getLambda(fn);\n   462→      if (lambda) {\n   463→        const result =