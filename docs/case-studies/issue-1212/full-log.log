th #)\n   680→  const forms = links\n   681→    .filter(linkStr => {\n   682→      const s = String(linkStr).trim();\n   683→      // Skip if it's just a comment link like \"(# ...)\"\n   684→      return !s.match(/^\\(#\\s/);\n   685→    })\n   686→    .map(linkStr => {\n   687→      const s = String(linkStr);                // link's own LiNo string\n   688→      const toks = tokenizeOne(s);\n   689→      return parseOne(toks);\n   690→    });\n   691→\n   692→  const env = new Env(options);\n   693→  const outs = [];\n   694→  for (let form of forms) {\n   695→    // Unwrap single-element arrays (LiNo wraps everything in outer parens)\n   696→    while (Array.isArray(form) && form.length === 1 && Array.isArray(form[0])) {\n   697→      form = form[0];\n   698→    }\n   699→    const res = evalNode(form, env);\n   700→    if (res && res.query) {\n   701→      if (res.typeQuery) {\n   702→        // Type queries return string results\n   703→        outs.push(res.value);\n   704→      } else {\n   705→        outs.push(res.value);\n   706→      }\n   707→    }\n   708→  }\n   709→  return outs;\n   710→}\n   711→\n   712→// CLI\n   713→if (import.meta.url === `file://${process.argv[1]}`) {\n   714→  const file = process.argv[2];\n   715→  if (!file) {\n   716→    console.error('Usage: node src/adl-links.mjs <kb.lino>');\n   717→    process.exit(1);\n   718→  }\n   719→  const text = fs.readFileSync(file, 'utf8');\n   720→  const outs = run(text);\n   721→  for (const v of outs) {\n   722→    if (typeof v === 'string') {\n   723→      console.log(v);\n   724→    } else {\n   725→      console.log(String(+v.toFixed(6)).replace(/\\.0+$/,''));\n   726→    }\n   727→  }\n   728→}\n   729→\n   730→export { run, tokenizeOne, parseOne, Env, evalNode, quantize, decRound, substitute, parseBindings };\n   731→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is d