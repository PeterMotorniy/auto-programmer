[2026-04-14T11:08:11.855Z] [INFO]         "content": "1\t#!/usr/bin/env node\n2\t\n3\t/**\n4\t * Update npm for OIDC trusted publishing\n5\t * npm trusted publishing requires npm >= 11.5.1\n6\t * Node.js 20.x ships with npm 10.x, so we need to update\n7\t *\n8\t * Uses link-foundation libraries:\n9\t * - use-m: Dynamic package loading without package.json dependencies\n10\t * - command-stream: Modern shell command execution with streaming support\n11\t */\n12\t\n13\t// Load use-m dynamically\n14\tconst { use } = eval(\n15\t  await (await fetch(\"https://unpkg.com/use-m/use.js\")).text(),\n16\t);\n17\t\n18\t// Import command-stream for shell command execution\n19\tconst { $ } = await use(\"command-stream\");\n20\t\n21\ttry {\n22\t  // Get current npm version\n23\t  const currentResult = await $`npm --version`.run({ capture: true });\n24\t  const currentVersion = currentResult.stdout.trim();\n25\t  console.log(`Current npm version: ${currentVersion}`);\n26\t\n27\t  // Update npm for OIDC trusted publishing (requires >= 11.5.1)\n28\t  // Pin to npm@11 to avoid breaking changes from future major versions\n29\t  //\n30\t  // Known issue: Node.js 22.22.2 on GitHub Actions (ubuntu-24.04 image >= 20260329.72.1)\n31\t  // ships with a broken npm 10.9.7 that is missing the 'promise-retry' module,\n32\t  // causing `npm install -g` to fail with MODULE_NOT_FOUND.\n33\t  // See: https://github.com/actions/runner-images/issues/13883\n34\t  // See: https://github.com/nodejs/node/issues/62430\n35\t  // See: https://github.com/npm/cli/issues/9151\n36\t  //\n37\t  // Workaround strategies in order of preference:\n38\t  // 1. npm install -g npm@11 (standard approach)\n39\t  // 2. npx npm@11 --version to verify npx can run npm@11 as fallback\n40\t  // 3. corepack as last resort\n41\t  let updated = false;\n42\t  try {\n43\t    await $`npm install -g npm@11`;\n44\t    updated = true;\n45\t  } catch (updateError) {\n46\t    console.warn(`Warning: npm install -g failed: ${updateError.message}`);\n47\t    console.warn(\n48\t      \"This is likely the Node.js 22.22.2 broken npm issue (actions/runner-images#13883).\",\n49\t    );\n50\t\n51\t    // Fallback 1: Use npx to download and install npm@11 via a fresh copy\n52\t    // npx downloads packages to a cache and runs them, bypassing the broken\n53\t    // global npm's rebuild/arborist code path.\n54\t    console.warn(\"Trying npx-based install as fallback...\");\n55\t    try {\n56\t      await $`npx --yes npm@11 install -g npm@11`;\n57\t      updated = true;\n58\t    } catch (npxError) {\n59\t      console.warn(`Warning: npx-based install failed: ${npxError.message}`);\n60\t\n61\t      // Fallback 2: Try corepack\n62\t      console.warn(\"Trying corepack as fallback...\");\n63\t      try {\n64\t        await $`corepack enable`;\n65\t        await $`corepack prepare npm@11 --activate`;\n66\t        updated = true;\n67\t      } catch (corepackError) {\n68\t        console.warn(\n69\t          `Warning: corepack fallback also failed: ${corepackError.message}`,\n70\t        );\n71\t        // Check if current npm version already supports OIDC (>= 11.5.1)\n72\t        const majorVersion = parseInt(currentVersion.split(\".\")[0], 10);\n73\t        if (majorVersion >= 11) {\n74\t          console.log(\n75\t            \"Current npm version already supports OIDC trusted publishing\",\n76\t          );\n77\t          updated = true;\n78\t        } else {\n79\t          console.error(\n80\t            `ERROR: Could not update npm to >= 11.5.1 for OIDC trusted publishing.`,\n81\t          );\n82\t          console.error(\n83\t            `Current npm version ${currentVersion} does not support OIDC.`,\n84\t          );\n85\t          console.error(\n86\t            \"npm publish will likely fail. See: https://github.com/actions/runner-images/issues/13883\",\n87\t          );\n88\t          // Do not exit — let the publish step fail with a clear error instead\n89\t          // This allows the version bump to complete even if publish fails\n90\t        }\n91\t      }\n92\t    }\n93\t  }\n94\t\n95\t  // Get updated npm version\n96\t  const updatedResult = await $`npm --version`.run({ capture: true });\n97\t  const updatedVersion = updatedResult.stdout.trim();\n98\t  console.log(`Updated npm version: ${updatedVersion}`);\n99\t} catch (error) {\n100\t  console.error(\"Error updating npm:\", error.message);\n101\t  process.exit(1);\n102\t}\n103\t"
