[2026-04-14T11:08:45.751Z] [INFO]         "content": "1\t#!/usr/bin/env node\n2\t\n3\t/**\n4\t * Version packages and commit to main\n5\t * Usage: node scripts/version-and-commit.mjs --mode <changeset|instant> [--bump-type <type>] [--description <desc>]\n6\t *   changeset: Run changeset version\n7\t *   instant: Run instant version bump with bump_type (patch|minor|major) and optional description\n8\t *\n9\t * Uses link-foundation libraries:\n10\t * - use-m: Dynamic package loading without package.json dependencies\n11\t * - command-stream: Modern shell command execution with streaming support\n12\t * - lino-arguments: Unified configuration from CLI args, env vars, and .lenv files\n13\t */\n14\t\n15\timport { readFileSync, appendFileSync, readdirSync } from \"fs\";\n16\t\n17\t// Load use-m dynamically\n18\tconst { use } = eval(\n19\t  await (await fetch(\"https://unpkg.com/use-m/use.js\")).text(),\n20\t);\n21\t\n22\t// Import link-foundation libraries\n23\tconst { $ } = await use(\"command-stream\");\n24\tconst { makeConfig } = await use(\"lino-arguments\");\n25\t\n26\t// Parse CLI arguments using lino-arguments\n27\tconst config = makeConfig({\n28\t  yargs: ({ yargs, getenv }) =>\n29\t    yargs\n30\t      .option(\"mode\", {\n31\t        type: \"string\",\n32\t        default: getenv(\"MODE\", \"changeset\"),\n33\t        describe: \"Version mode: changeset or instant\",\n34\t        choices: [\"changeset\", \"instant\"],\n35\t      })\n36\t      .option(\"bump-type\", {\n37\t        type: \"string\",\n38\t        default: getenv(\"BUMP_TYPE\", \"\"),\n39\t        describe: \"Version bump type for instant mode: major, minor, or patch\",\n40\t      })\n41\t      .option(\"description\", {\n42\t        type: \"string\",\n43\t        default: getenv(\"DESCRIPTION\", \"\"),\n44\t        describe: \"Description for instant version bump\",\n45\t      }),\n46\t});\n47\t\n48\tconst { mode, bumpType, description } = config;\n49\t\n50\t// Debug: Log parsed configuration\n51\tconsole.log(\"Parsed configuration:\", {\n52\t  mode,\n53\t  bumpType,\n54\t  description: description || \"(none)\",\n55\t});\n56\t\n57\t// Detect if positional arguments were used (common mistake)\n58\tconst args = process.argv.slice(2);\n59\tif (args.length > 0 && !args[0].startsWith(\"--\")) {\n60\t  console.error(\"Error: Positional arguments detected!\");\n61\t  console.error(\"Command line arguments:\", args);\n62\t  console.error(\"\");\n63\t  console.error(\n64\t    \"This script requires named arguments (--mode, --bump-type, --description).\",\n65\t  );\n66\t  console.error(\"Usage:\");\n67\t  console.error(\"  Changeset mode:\");\n68\t  console.error(\"    node scripts/version-and-commit.mjs --mode changeset\");\n69\t  console.error(\"  Instant mode:\");\n70\t  console.error(\n71\t    \"    node scripts/version-and-commit.mjs --mode instant --bump-type <major|minor|patch> [--description <desc>]\",\n72\t  );\n73\t  console.error(\"\");\n74\t  console.error(\"Examples:\");\n75\t  console.error(\n76\t    '  node scripts/version-and-commit.mjs --mode instant --bump-type patch --description \"Fix bug\"',\n77\t  );\n78\t  console.error(\"  node scripts/version-and-commit.mjs --mode changeset\");\n79\t  process.exit(1);\n80\t}\n81\t\n82\t// Validation: Ensure mode is set correctly\n83\tif (mode !== \"changeset\" && mode !== \"instant\") {\n84\t  console.error(`Invalid mode: \"${mode}\". Expected \"changeset\" or \"instant\".`);\n85\t  console.error(\"Command line arguments:\", process.argv.slice(2));\n86\t  process.exit(1);\n87\t}\n88\t\n89\t// Validation: Ensure bump type is provided for instant mode\n90\tif (mode === \"instant\" && !bumpType) {\n91\t  console.error(\"Error: --bump-type is required for instant mode\");\n92\t  console.error(\n93\t    \"Usage: node scripts/version-and-commit.mjs --mode instant --bump-type <major|minor|patch> [--description <desc>]\",\n94\t  );\n95\t  process.exit(1);\n96\t}\n97\t\n98\t/**\n99\t * Append to GitHub Actions output file\n100\t * @param {string} key\n101\t * @param {string} value\n102\t */\n103\tfunction setOutput(key, value) {\n104\t  const outputFile = process.env.GITHUB_OUTPUT;\n105\t  if (outputFile) {\n106\t    appendFileSync(outputFile, `${key}=${value}\\n`);\n107\t  }\n108\t}\n109\t\n110\t/**\n111\t * Count changeset files (excluding README.md)\n112\t */\n113\tfunction countChangesets() {\n114\t  try {\n115\t    const changesetDir = \".changeset\";\n116\t    const files = readdirSync(changesetDir);\n117\t    return files.filter((f) => f.endsWith(\".md\") && f !== \"README.md\").length;\n118\t  } catch {\n119\t    return 0;\n120\t  }\n121\t}\n122\t\n123\t/**\n124\t * Get package version\n125\t * @param {string} source - 'local' or 'remote'\n126\t */\n127\tasync function getVersion(source = \"local\") {\n128\t  if (source === \"remote\") {\n129\t    // git show uses repo-root-relative paths, but this script runs from\n130\t    // a subdirectory (e.g., js/). Use git rev-parse --show-prefix to get\n131\t    // the current directory relative to the repo root.\n132\t    const prefixResult = await $`git rev-parse --show-prefix`.run({\n133\t      capture: true,\n134\t    });\n135\t    const prefix = prefixResult.stdout.trim();\n136\t    const gitPath = `${prefix}package.json`;\n137\t    const result = await $`git show origin/main:${gitPath}`.run({\n138\t      capture: true,\n139\t    });\n140\t    return JSON.parse(result.stdout).version;\n141\t  }\n142\t  return JSON.parse(readFileSync(\"./package.json\", \"utf8\")).version;\n143\t}\n144\t\n145\tasync function main() {\n146\t  try {\n147\t    // Configure git\n148\t    await $`git config user.name \"github-actions[bot]\"`;\n149\t    await $`git config user.email \"github-actions[bot]@users.noreply.github.com\"`;\n150\t\n151\t    // Check if remote main has advanced (handles re-runs after partial success)\n152\t    console.log(\"Checking for remote changes...\");\n153\t    await $`git fetch origin main`;\n154\t\n155\t    const localHeadResult = await $`git rev-parse HEAD`.run({ capture: true });\n156\t    const localHead = localHeadResult.stdout.trim();\n157\t\n158\t    const remoteHeadResult = await $`git rev-parse origin/main`.run({\n159\t      capture: true,\n160\t    });\n161\t    const remoteHead = remoteHeadResult.stdout.trim();\n162\t\n163\t    if (localHead !== remoteHead) {\n164\t      console.log(\n165\t        `Remote main has advanced (local: ${localHead}, remote: ${remoteHead})`,\n166\t      );\n167\t      console.log(\"This may indicate a previous attempt partially succeeded.\");\n168\t\n169\t      // Check if the remote version is already the expected bump\n170\t      const remoteVersion = await getVersion(\"remote\");\n171\t      console.log(`Remote version: ${remoteVersion}`);\n172\t\n173\t      // Check if there are changesets to process\n174\t      const changesetCount = countChangesets();\n175\t\n176\t      if (changesetCount === 0) {\n177\t        console.log(\"No changesets to process and remote has advanced.\");\n178\t        console.log(\n179\t          \"Assuming version bump was already completed in a previous attempt.\",\n180\t        );\n181\t        setOutput(\"version_committed\", \"false\");\n182\t        setOutput(\"already_released\", \"true\");\n183\t        setOutput(\"new_version\", remoteVersion);\n184\t        return;\n185\t      } else {\n186\t        console.log(\"Rebasing on remote main to incorporate changes...\");\n187\t        await $`git rebase origin/main`;\n188\t      }\n189\t    }\n190\t\n191\t    // Get current version before bump\n192\t    const oldVersion = await getVersion();\n193\t    console.log(`Current version: ${oldVersion}`);\n194\t\n195\t    if (mode === \"instant\") {\n196\t      console.log(\"Running instant version bump...\");\n197\t      // Run instant version bump script\n198\t      // Rely on command-stream's auto-quoting for proper argument handling\n199\t      if (description) {\n200\t        await $`node ../scripts/instant-version-bump.mjs --bump-type ${bumpType} --description ${description}`;\n201\t      } else {\n202\t        await $`node ../scripts/instant-version-bump.mjs --bump-type ${bumpType}`;\n203\t      }\n204\t    } else {\n205\t      console.log(\"Running changeset version...\");\n206\t      // Run changeset version to bump versions and update CHANGELOG\n207\t      await $`npm run changeset:version`;\n208\t    }\n209\t\n210\t    // Get new version after bump\n211\t    const newVersion = await getVersion();\n212\t    console.log(`New version: ${newVersion}`);\n213\t    setOutput(\"new_version\", newVersion);\n214\t\n215\t    // Check if there are changes to commit\n216\t    const statusResult = await $`git status --porcelain`.run({ capture: true });\n217\t    const status = statusResult.stdout.trim();\n218\t\n219\t    if (status) {\n220\t      console.log(\"Changes detected, committing...\");\n221\t\n222\t      // Stage all changes (package.json, package-lock.json, CHANGELOG.md, deleted changesets)\n223\t      await $`git add -A`;\n224\t\n225\t      // Commit with version number as message\n226\t      const commitMessage = newVersion;\n227\t      const escapedMessage = commitMessage.replace(/\"/g, '\\\\\"');\n228\t      await $`git commit -m \"${escapedMessage}\"`;\n229\t\n230\t      // Push directly to main\n231\t      await $`git push origin main`;\n232\t\n233\t      console.log(\"\\u2705 Version bump committed and pushed to main\");\n234\t      setOutput(\"version_committed\", \"true\");\n235\t    } else {\n236\t      console.log(\"No changes to commit\");\n237\t      setOutput(\"version_committed\", \"false\");\n238\t    }\n239\t  } catch (error) {\n240\t    console.error(\"Error:\", error.message);\n241\t    process.exit(1);\n242\t  }\n243\t}\n244\t\n245\tmain();\n246\t"
