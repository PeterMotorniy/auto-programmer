[2026-04-14T11:08:04.887Z] [INFO]         "type": "tool_result",
[2026-04-14T11:08:04.887Z] [INFO]         "content": "1\tname: JavaScript Checks and Release\n2\t\n3\ton:\n4\t  push:\n5\t    branches:\n6\t      - main\n7\t  pull_request:\n8\t    types: [opened, synchronize, reopened]\n9\t  # Manual release support - consolidated here to work with npm trusted publishing\n10\t  # npm only allows ONE workflow file as trusted publisher, so all publishing\n11\t  # must go through this workflow (js.yml)\n12\t  workflow_dispatch:\n13\t    inputs:\n14\t      release_mode:\n15\t        description: 'Manual release mode'\n16\t        required: true\n17\t        type: choice\n18\t        default: 'instant'\n19\t        options:\n20\t          - instant\n21\t          - changeset-pr\n22\t      bump_type:\n23\t        description: 'Manual release type'\n24\t        required: true\n25\t        type: choice\n26\t        options:\n27\t          - patch\n28\t          - minor\n29\t          - major\n30\t      description:\n31\t        description: 'Manual release description (optional)'\n32\t        required: false\n33\t        type: string\n34\t\n35\tconcurrency:\n36\t  group: ${{ github.workflow }}-${{ github.ref }}\n37\t  cancel-in-progress: true\n38\t\n39\tdefaults:\n40\t  run:\n41\t    working-directory: js\n42\t\n43\tjobs:\n44\t  # === DETECT CHANGES - determines which jobs should run ===\n45\t  detect-changes:\n46\t    name: JS - Detect Changes\n47\t    runs-on: ubuntu-latest\n48\t    if: github.event_name != 'workflow_dispatch'\n49\t    outputs:\n50\t      js-code-changed: ${{ steps.changes.outputs.js-code-changed }}\n51\t      js-changed: ${{ steps.changes.outputs.js-changed }}\n52\t      scripts-changed: ${{ steps.changes.outputs.scripts-changed }}\n53\t      js-workflow-changed: ${{ steps.changes.outputs.js-workflow-changed }}\n54\t      any-js-code-changed: ${{ steps.changes.outputs.any-js-code-changed }}\n55\t      any-code-changed: ${{ steps.changes.outputs.any-code-changed }}\n56\t      docs-changed: ${{ steps.changes.outputs.docs-changed }}\n57\t    steps:\n58\t      - uses: actions/checkout@v4\n59\t        with:\n60\t          fetch-depth: 0\n61\t\n62\t      - name: Detect changes\n63\t        id: changes\n64\t        working-directory: .\n65\t        env:\n66\t          GITHUB_EVENT_NAME: ${{ github.event_name }}\n67\t          GITHUB_BASE_SHA: ${{ github.event.pull_request.base.sha }}\n68\t          GITHUB_HEAD_SHA: ${{ github.event.pull_request.head.sha }}\n69\t        run: node scripts/detect-code-changes.mjs\n70\t\n71\t  # Changeset check - only runs on PRs with JS package source changes\n72\t  changeset-check:\n73\t    name: JS - Check for Changesets\n74\t    runs-on: ubuntu-latest\n75\t    needs: [detect-changes]\n76\t    if: github.event_name == 'pull_request' && needs.detect-changes.outputs.js-code-changed == 'true'\n77\t    steps:\n78\t      - uses: actions/checkout@v4\n79\t        with:\n80\t          fetch-depth: 0\n81\t\n82\t      - name: Setup Node.js\n83\t        uses: actions/setup-node@v4\n84\t        with:\n85\t          node-version: '22.x'\n86\t\n87\t      - name: Install dependencies\n88\t        run: npm install\n89\t\n90\t      - name: Check for changesets\n91\t        run: |\n92\t          # Skip changeset check for automated version PRs\n93\t          if [[ \"${{ github.head_ref }}\" == \"changeset-release/\"* ]]; then\n94\t            echo \"Skipping changeset check for automated release PR\"\n95\t            exit 0\n96\t          fi\n97\t\n98\t          # Run changeset validation script\n99\t          node ../scripts/validate-changeset.mjs\n100\t\n101\t  # Linting and formatting - runs when JS-relevant files change\n102\t  lint:\n103\t    name: JS - Lint and Format Check\n104\t    runs-on: ubuntu-latest\n105\t    needs: [detect-changes]\n106\t    if: |\n107\t      always() && !cancelled() && (\n108\t        github.event_name == 'push' ||\n109\t        github.event_name == 'workflow_dispatch' ||\n110\t        needs.detect-changes.outputs.any-js-code-changed == 'true' ||\n111\t        needs.detect-changes.outputs.docs-changed == 'true'\n112\t      )\n113\t    steps:\n114\t      - uses: actions/checkout@v4\n115\t\n116\t      - name: Setup Node.js\n117\t        uses: actions/setup-node@v4\n118\t        with:\n119\t          node-version: '22.x'\n120\t\n121\t      - name: Install dependencies\n122\t        run: npm install\n123\t\n124\t      - name: Run ESLint\n125\t        run: npm run lint\n126\t\n127\t      - name: Check formatting\n128\t        run: npm run format:check\n129\t\n130\t      - name: Check code duplication\n131\t        run: npm run check:duplication\n132\t\n133\t  # Test matrix: Node.js on Ubuntu with unit tests and e2e tests\n134\t  test:\n135\t    name: JS - Test (Node.js on ${{ matrix.os }})\n136\t    runs-on: ${{ matrix.os }}\n137\t    timeout-minutes: 30\n138\t    needs: [detect-changes, changeset-check]\n139\t    # Run if: push/dispatch event, OR (changeset check passed/skipped AND JS code actually changed)\n140\t    if: |\n141\t      always() && !cancelled() && (\n142\t        github.event_name == 'push' ||\n143\t        github.event_name == 'workflow_dispatch' ||\n144\t        (\n145\t          (needs.changeset-check.result == 'success' || needs.changeset-check.result == 'skipped') &&\n146\t          needs.detect-changes.outputs.any-js-code-changed == 'true'\n147\t        )\n148\t      )\n149\t    strategy:\n150\t      fail-fast: false\n151\t      matrix:\n152\t        os: [ubuntu-latest]\n153\t    steps:\n154\t      - uses: actions/checkout@v4\n155\t\n156\t      - name: Setup Node.js\n157\t        uses: actions/setup-node@v4\n158\t        with:\n159\t          node-version: '22.x'\n160\t\n161\t      - name: Install dependencies\n162\t        run: npm install\n163\t\n164\t      - name: Install Playwright browsers\n165\t        run: npx playwright install --with-deps chromium\n166\t\n167\t      - name: Install Puppeteer browsers\n168\t        run: npx puppeteer browsers install chrome\n169\t\n170\t      - name: Run unit, integration, and e2e process tests\n171\t        run: npm test -- --testPathIgnorePatterns=\"docker.test.js\"\n172\t\n173\t      - name: Run Habr article live integration tests\n174\t        env:\n175\t          HABR_INTEGRATION: 'true'\n176\t        run: npm test -- --testPathPattern=\"habr-article\" --testTimeout=120000\n177\t        timeout-minutes: 15\n178\t\n179\t      - name: Build Docker image for e2e tests\n180\t        run: docker compose build\n181\t        timeout-minutes: 10\n182\t\n183\t      - name: Run e2e Docker tests\n184\t        run: npm test -- tests/e2e/docker.test.js\n185\t        timeout-minutes: 5\n186\t\n187\t  # Release - only runs on main after tests pass (for push events)\n188\t  release:\n189\t    name: JS - Release\n190\t    needs: [lint, test]\n191\t    if: |\n192\t      !cancelled() &&\n193\t      github.ref == 'refs/heads/main' &&\n194\t      github.event_name == 'push' &&\n195\t      needs.lint.result == 'success' &&\n196\t      needs.test.result == 'success'\n197\t    runs-on: ubuntu-latest\n198\t    # Permissions required for npm OIDC trusted publishing\n199\t    permissions:\n200\t      contents: write\n201\t      pull-requests: write\n202\t      id-token: write\n203\t    steps:\n204\t      - uses: actions/checkout@v4\n205\t        with:\n206\t          fetch-depth: 0\n207\t\n208\t      - name: Setup Node.js\n209\t        uses: actions/setup-node@v4\n210\t        with:\n211\t          node-version: '22.x'\n212\t          registry-url: 'https://registry.npmjs.org'\n213\t\n214\t      - name: Install dependencies\n215\t        run: npm install\n216\t\n217\t      - name: Update npm for OIDC trusted publishing\n218\t        run: node ../scripts/setup-npm.mjs\n219\t\n220\t      - name: Check for changesets\n221\t        id: check_changesets\n222\t        run: |\n223\t          # Count changeset files (excluding README.md and config.json)\n224\t          CHANGESET_COUNT=$(find .changeset -name \"*.md\" ! -name \"README.md\" | wc -l)\n225\t          echo \"Found $CHANGESET_COUNT changeset file(s)\"\n226\t          echo \"has_changesets=$([[ $CHANGESET_COUNT -gt 0 ]] && echo 'true' || echo 'false')\" >> $GITHUB_OUTPUT\n227\t\n228\t      - name: Version packages and commit to main\n229\t        if: steps.check_changesets.outputs.has_changesets == 'true'\n230\t        id: version\n231\t        run: node ../scripts/version-and-commit.mjs --mode changeset\n232\t\n233\t      - name: Publish to npm\n234\t        # Run if version was committed OR if a previous attempt already committed (for re-runs)\n235\t        if: steps.version.outputs.version_committed == 'true' || steps.version.outputs.already_released == 'true'\n236\t        id: publish\n237\t        run: node ../scripts/publish-to-npm.mjs --should-pull\n238\t\n239\t      - name: Create GitHub Release\n240\t        if: steps.publish.outputs.published == 'true'\n241\t        env:\n242\t          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}\n243\t        run: node ../scripts/create-github-release.mjs --release-version \"${{ steps.publish.outputs.published_version }}\" --repository \"${{ github.repository }}\"\n244\t\n245\t      - name: Format GitHub release notes\n246\t        if: steps.publish.outputs.published == 'true'\n247\t        env:\n248\t          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}\n249\t        run: node ../scripts/format-github-release.mjs --release-version \"${{ steps.publish.outputs.published_version }}\" --repository \"${{ github.repository }}\" --commit-sha \"${{ github.sha }}\"\n250\t\n251\t  # Manual Instant Release - triggered via workflow_dispatch with instant mode\n252\t  # This job is in js.yml because npm trusted publishing\n253\t  # only allows one workflow file to be registered as a trusted publisher\n254\t  instant-release:\n255\t    name: JS - Instant Release\n256\t    if: github.event_name == 'workflow_dispatch' && github.event.inputs.release_mode == 'instant'\n257\t    runs-on: ubuntu-latest\n258\t    # Permissions required for npm OIDC trusted publishing\n259\t    permissions:\n260\t      contents: write\n261\t      pull-requests: write\n262\t      id-token: write\n263\t    steps:\n264\t      - uses: actions/checkout@v4\n265\t        with:\n266\t          fetch-depth: 0\n267\t\n268\t      - name: Setup Node.js\n269\t        uses: actions/setup-node@v4\n270\t        with:\n271\t          node-version: '22.x'\n272\t          registry-url: 'https://registry.npmjs.org'\n273\t\n274\t      - name: Install dependencies\n275\t        run: npm install\n276\t\n277\t      - name: Update npm for OIDC trusted publishing\n278\t        run: node ../scripts/setup-npm.mjs\n279\t\n280\t      - name: Version packages and commit to main\n281\t        id: version\n282\t        run: node ../scripts/version-and-commit.mjs --mode instant --bump-type \"${{ github.event.inputs.bump_type }}\" --description \"${{ github.event.inputs.description }}\"\n283\t\n284\t      - name: Publish to npm\n285\t        # Run if version was committed OR if a previous attempt already committed (for re-runs)\n286\t        if: steps.version.outputs.version_committed == 'true' || steps.version.outputs.already_released == 'true'\n287\t        id: publish\n288\t        run: node ../scripts/publish-to-npm.mjs\n289\t\n290\t      - name: Create GitHub Release\n291\t        if: steps.publish.outputs.published == 'true'\n292\t        env:\n293\t          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}\n294\t        run: node ../scripts/create-github-release.mjs --release-version \"${{ steps.publish.outputs.published_version }}\" --repository \"${{ github.repository }}\"\n295\t\n296\t      - name: Format GitHub release notes\n297\t        if: steps.publish.outputs.published == 'true'\n298\t        env:\n299\t          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}\n300\t        run: node ../scripts/format-github-release.mjs --release-version \"${{ steps.publish.outputs.published_version }}\" --repository \"${{ github.repository }}\" --commit-sha \"${{ github.sha }}\"\n301\t\n302\t  # Manual Changeset PR - creates a pull request with the changeset for review\n303\t  changeset-pr:\n304\t    name: JS - Create Changeset PR\n305\t    if: github.event_name == 'workflow_dispatch' && github.event.inputs.release_mode == 'changeset-pr'\n306\t    runs-on: ubuntu-latest\n307\t    permissions:\n308\t      contents: write\n309\t      pull-requests: write\n310\t    steps:\n311\t      - uses: actions/checkout@v4\n312\t        with:\n313\t          fetch-depth: 0\n314\t\n315\t      - name: Setup Node.js\n316\t        uses: actions/setup-node@v4\n317\t        with:\n318\t          node-version: '22.x'\n319\t\n320\t      - name: Install dependencies\n321\t        run: npm install\n322\t\n323\t      - name: Create changeset file\n324\t        run: node ../scripts/create-manual-changeset.mjs --bump-type \"${{ github.event.inputs.bump_type }}\" --description \"${{ github.event.inputs.description }}\"\n325\t\n326\t      - name: Format changeset with Prettier\n327\t        run: |\n328\t          # Run Prettier on the changeset file to ensure it matches project style\n329\t          npx prettier --write \".changeset/*.md\" || true\n330\t\n331\t          echo \"Formatted changeset files\"\n332\t\n333\t      - name: Create Pull Request\n334\t        uses: peter-evans/create-pull-request@v7\n335\t        with:\n336\t          token: ${{ secrets.GITHUB_TOKEN }}\n337\t          commit-message: 'chore(js): add changeset for manual ${{ github.event.inputs.bump_type }} release'\n338\t          branch: changeset-js-manual-release-${{ github.run_id }}\n339\t          delete-branch: true\n340\t          title: 'chore(js): manual ${{ github.event.inputs.bump_type }} release'\n341\t          body: |\n342\t            ## Manual Release Request (JavaScript)\n343\t\n344\t            This PR was created by a manual workflow trigger to prepare a **${{ github.event.inputs.bump_type }}** release.\n345\t\n346\t            ### Release Details\n347\t            - **Type:** ${{ github.event.inputs.bump_type }}\n348\t            - **Description:** ${{ github.event.inputs.description || 'Manual release' }}\n349\t            - **Triggered by:** @${{ github.actor }}\n350\t\n351\t            ### Next Steps\n352\t            1. Review the changeset in this PR\n353\t            2. Merge this PR to main\n354\t            3. The automated release workflow will create a version PR\n355\t            4. Merge the version PR to publish to npm and create a GitHub release\n356\t"
