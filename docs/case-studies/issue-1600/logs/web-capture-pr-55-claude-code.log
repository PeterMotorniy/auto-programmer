[2026-04-14T11:08:04.916Z] [INFO]         "content": "1\t#!/usr/bin/env node\n2\t\n3\t/**\n4\t * Publish to npm using OIDC trusted publishing\n5\t * Usage: node scripts/publish-to-npm.mjs [--should-pull]\n6\t *   should_pull: Optional flag to pull latest changes before publishing (for release job)\n7\t *\n8\t * IMPORTANT: Update the PACKAGE_NAME constant below to match your package.json\n9\t *\n10\t * Uses link-foundation libraries:\n11\t * - use-m: Dynamic package loading without package.json dependencies\n12\t * - command-stream: Modern shell command execution with streaming support\n13\t * - lino-arguments: Unified configuration from CLI args, env vars, and .lenv files\n14\t */\n15\t\n16\timport { readFileSync, appendFileSync } from 'fs';\n17\t\n18\tconst PACKAGE_NAME = '@link-assistant/web-capture';\n19\t\n20\t// Load use-m dynamically\n21\tconst { use } = eval(\n22\t  await (await fetch('https://unpkg.com/use-m/use.js')).text()\n23\t);\n24\t\n25\t// Import link-foundation libraries\n26\tconst { $ } = await use('command-stream');\n27\tconst { makeConfig } = await use('lino-arguments');\n28\t\n29\t// Parse CLI arguments using lino-arguments\n30\tconst config = makeConfig({\n31\t  yargs: ({ yargs, getenv }) =>\n32\t    yargs.option('should-pull', {\n33\t      type: 'boolean',\n34\t      default: getenv('SHOULD_PULL', false),\n35\t      describe: 'Pull latest changes before publishing',\n36\t    }),\n37\t});\n38\t\n39\tconst { shouldPull } = config;\n40\tconst MAX_RETRIES = 3;\n41\tconst RETRY_DELAY = 10000; // 10 seconds\n42\t\n43\t/**\n44\t * Sleep for specified milliseconds\n45\t * @param {number} ms\n46\t */\n47\tfunction sleep(ms) {\n48\t  return new Promise((resolve) => globalThis.setTimeout(resolve, ms));\n49\t}\n50\t\n51\t/**\n52\t * Append to GitHub Actions output file\n53\t * @param {string} key\n54\t * @param {string} value\n55\t */\n56\tfunction setOutput(key, value) {\n57\t  const outputFile = process.env.GITHUB_OUTPUT;\n58\t  if (outputFile) {\n59\t    appendFileSync(outputFile, `${key}=${value}\\n`);\n60\t  }\n61\t}\n62\t\n63\tasync function main() {\n64\t  try {\n65\t    if (shouldPull) {\n66\t      // Pull the latest changes we just pushed\n67\t      await $`git pull origin main`;\n68\t    }\n69\t\n70\t    // Get current version\n71\t    const packageJson = JSON.parse(readFileSync('./package.json', 'utf8'));\n72\t    const currentVersion = packageJson.version;\n73\t    console.log(`Current version to publish: ${currentVersion}`);\n74\t\n75\t    // Check if this version is already published on npm\n76\t    console.log(\n77\t      `Checking if version ${currentVersion} is already published...`\n78\t    );\n79\t    const checkResult =\n80\t      await $`npm view \"${PACKAGE_NAME}@${currentVersion}\" version`.run({\n81\t        capture: true,\n82\t      });\n83\t\n84\t    // command-stream returns { code: 0 } on success, { code: 1 } on failure (e.g., E404)\n85\t    // Exit code 0 means version exists, non-zero means version not found\n86\t    if (checkResult.code === 0) {\n87\t      console.log(`Version ${currentVersion} is already published to npm`);\n88\t      setOutput('published', 'true');\n89\t      setOutput('published_version', currentVersion);\n90\t      setOutput('already_published', 'true');\n91\t      return;\n92\t    } else {\n93\t      // Version not found on npm (E404), proceed with publish\n94\t      console.log(\n95\t        `Version ${currentVersion} not found on npm, proceeding with publish...`\n96\t      );\n97\t    }\n98\t\n99\t    // Publish to npm with retry logic using OIDC trusted publishing\n100\t    for (let i = 1; i <= MAX_RETRIES; i++) {\n101\t      console.log(`Publish attempt ${i} of ${MAX_RETRIES}...`);\n102\t      try {\n103\t        console.log('Publishing with OIDC trusted publishing...');\n104\t        try {\n105\t          await $`npm publish --provenance --access public`;\n106\t        } catch (publishError) {\n107\t          const errorMsg = publishError.message || String(publishError);\n108\t          if (errorMsg.includes('404') || errorMsg.includes('Not Found') || errorMsg.includes('E404')) {\n109\t            console.error(`\\n\\u274C OIDC trusted publishing is not configured for ${PACKAGE_NAME} on npmjs.org.`);\n110\t            console.error(`\\nThe first version of a package must be published manually to establish the package on the registry.`);\n111\t            console.error(`After manual publish, configure OIDC trusted publishing on npmjs.org for automated CI/CD releases.\\n`);\n112\t            console.error(`To publish manually, run these commands locally:\\n`);\n113\t            console.error(`  1. Log in to npm:`);\n114\t            console.error(`     npm login`);\n115\t            console.error(`  2. Navigate to the JS package directory:`);\n116\t            console.error(`     cd js`);\n117\t            console.error(`  3. Publish the package:`);\n118\t            console.error(`     npm publish --access public`);\n119\t            console.error(`  4. Configure OIDC trusted publishing on npmjs.org:`);\n120\t            console.error(`     - Go to https://www.npmjs.com/package/${PACKAGE_NAME}/access`);\n121\t            console.error(`     - Under \"Publishing access\", add a trusted publisher`);\n122\t            console.error(`     - Set repository to: ${process.env.GITHUB_REPOSITORY || 'link-assistant/web-capture'}`);\n123\t            console.error(`     - Set workflow to: js.yml`);\n124\t            console.error(`     - Set environment to: (leave empty or set to your environment name)\\n`);\n125\t            process.exit(1);\n126\t          }\n127\t          throw publishError;\n128\t        }\n129\t\n130\t        // Verify the version was actually published\n131\t        console.log('Verifying publish...');\n132\t        await sleep(5000);\n133\t        const verifyResult =\n134\t          await $`npm view \"${PACKAGE_NAME}@${currentVersion}\" version`.run({\n135\t            capture: true,\n136\t          });\n137\t        if (verifyResult.code !== 0) {\n138\t          throw new Error(\n139\t            `Publish verification failed: version ${currentVersion} not found on npm after publish`\n140\t          );\n141\t        }\n142\t\n143\t        setOutput('published', 'true');\n144\t        setOutput('published_version', currentVersion);\n145\t        console.log(\n146\t          `\\u2705 Published ${PACKAGE_NAME}@${currentVersion} to npm`\n147\t        );\n148\t        return;\n149\t      } catch (error) {\n150\t        if (i < MAX_RETRIES) {\n151\t          console.log(\n152\t            `Publish failed: ${error.message}, waiting ${RETRY_DELAY / 1000}s before retry...`\n153\t          );\n154\t          await sleep(RETRY_DELAY);\n155\t        }\n156\t      }\n157\t    }\n158\t\n159\t    console.error(`\\u274C Failed to publish after ${MAX_RETRIES} attempts`);\n160\t    process.exit(1);\n161\t  } catch (error) {\n162\t    console.error('Error:', error.message);\n163\t    process.exit(1);\n164\t  }\n165\t}\n166\t\n167\tmain();\n168\t"
