[2026-04-14T11:08:12.025Z] [INFO]         "content": "1\t#!/usr/bin/env node\n2\t\n3\t// Detect code changes for CI/CD pipeline\n4\t//\n5\t// Detects what types of files changed in the latest commit and outputs\n6\t// results for use in GitHub Actions workflow conditions.\n7\t//\n8\t// For PRs: GitHub Actions checks out a synthetic merge commit, so we\n9\t// compare HEAD^2^ to HEAD^2 (the PR head's per-commit diff).\n10\t// For pushes: compares HEAD^ to HEAD.\n11\t// This ensures a commit touching only non-code files skips tests,\n12\t// even when earlier commits in the same PR changed code.\n13\t//\n14\t// Excluded from code changes (don't require changesets):\n15\t// - Markdown files in any folder\n16\t// - .changeset/ folder (changeset metadata)\n17\t// - docs/ folder (documentation)\n18\t// - experiments/ folder (experimental scripts)\n19\t// - examples/ folder (example scripts)\n20\t//\n21\t// Outputs (written to GITHUB_OUTPUT):\n22\t//   js-code-changed, js-changed, rust-code-changed, rust-changed,\n23\t//   scripts-changed, js-scripts-changed, rust-scripts-changed,\n24\t//   workflow-changed, js-workflow-changed, rust-workflow-changed,\n25\t//   docs-changed, any-code-changed, any-js-code-changed, any-rust-code-changed\n26\t\n27\timport { execSync } from 'child_process';\n28\timport { appendFileSync } from 'fs';\n29\t\n30\tfunction exec(command) {\n31\t  try {\n32\t    return execSync(command, { encoding: 'utf-8' }).trim();\n33\t  } catch (error) {\n34\t    console.error(`Error executing command: ${command}`);\n35\t    console.error(error.message);\n36\t    return '';\n37\t  }\n38\t}\n39\t\n40\tfunction setOutput(name, value) {\n41\t  const outputFile = process.env.GITHUB_OUTPUT;\n42\t  if (outputFile) {\n43\t    appendFileSync(outputFile, `${name}=${value}\\n`);\n44\t  }\n45\t  console.log(`${name}=${value}`);\n46\t}\n47\t\n48\tfunction isMergeCommit() {\n49\t  const parentCount = exec('git cat-file -p HEAD')\n50\t    .split('\\n')\n51\t    .filter((line) => line.startsWith('parent ')).length;\n52\t  return parentCount > 1;\n53\t}\n54\t\n55\tfunction getChangedFiles() {\n56\t  // GitHub Actions checks out a synthetic merge commit for pull_request\n57\t  // events: HEAD is the merge commit, HEAD^ is the base branch, HEAD^2\n58\t  // is the actual PR head. To get the per-commit diff (what the latest\n59\t  // push actually changed), we compare HEAD^2^ to HEAD^2.\n60\t  // For push events, HEAD is the real commit, so HEAD^ to HEAD works.\n61\t  if (isMergeCommit()) {\n62\t    console.log('Merge commit detected (pull_request event)');\n63\t    console.log('Comparing HEAD^2^ to HEAD^2 (per-commit diff of PR head)');\n64\t    try {\n65\t      const output = exec('git diff --name-only HEAD^2^ HEAD^2');\n66\t      return output ? output.split('\\n').filter(Boolean) : [];\n67\t    } catch {\n68\t      console.log('HEAD^2^ not available (first commit in PR), listing files in HEAD^2');\n69\t      const output = exec('git diff --name-only HEAD^ HEAD^2');\n70\t      return output ? output.split('\\n').filter(Boolean) : [];\n71\t    }\n72\t  }\n73\t\n74\t  console.log('Comparing HEAD^ to HEAD');\n75\t  try {\n76\t    const output = exec('git diff --name-only HEAD^ HEAD');\n77\t    return output ? output.split('\\n').filter(Boolean) : [];\n78\t  } catch {\n79\t    console.log('HEAD^ not available, listing all files in HEAD');\n80\t    const output = exec('git ls-tree --name-only -r HEAD');\n81\t    return output ? output.split('\\n').filter(Boolean) : [];\n82\t  }\n83\t}\n84\t\n85\tfunction isExcludedFromCodeChanges(filePath) {\n86\t  if (filePath.endsWith('.md')) {\n87\t    return true;\n88\t  }\n89\t\n90\t  const excludedFolders = ['.changeset/', 'docs/', 'experiments/', 'examples/'];\n91\t\n92\t  for (const folder of excludedFolders) {\n93\t    if (filePath.startsWith(folder)) {\n94\t      return true;\n95\t    }\n96\t  }\n97\t\n98\t  return false;\n99\t}\n100\t\n101\tfunction detectChanges() {\n102\t  console.log('Detecting file changes for CI/CD...\\n');\n103\t\n104\t  const changedFiles = getChangedFiles();\n105\t\n106\t  console.log('Changed files:');\n107\t  if (changedFiles.length === 0) {\n108\t    console.log('  (none)');\n109\t  } else {\n110\t    changedFiles.forEach((file) => console.log(`  ${file}`));\n111\t  }\n112\t  console.log('');\n113\t\n114\t  // JS-specific detection\n115\t  const jsCodeChanged = changedFiles.some(\n116\t    (f) => f.startsWith('js/') && /\\.(js|mjs|json)$/.test(f)\n117\t  );\n118\t  setOutput('js-code-changed', jsCodeChanged ? 'true' : 'false');\n119\t\n120\t  const jsChanged = changedFiles.some((f) => f.startsWith('js/'));\n121\t  setOutput('js-changed', jsChanged ? 'true' : 'false');\n122\t\n123\t  // Rust-specific detection\n124\t  const rustCodeChanged = changedFiles.some(\n125\t    (f) => f.startsWith('rust/') && /\\.(rs|toml)$/.test(f)\n126\t  );\n127\t  setOutput('rust-code-changed', rustCodeChanged ? 'true' : 'false');\n128\t\n129\t  const rustChanged = changedFiles.some((f) => f.startsWith('rust/'));\n130\t  setOutput('rust-changed', rustChanged ? 'true' : 'false');\n131\t\n132\t  // Scripts detection\n133\t  const scriptsChanged = changedFiles.some((f) => f.startsWith('scripts/'));\n134\t  setOutput('scripts-changed', scriptsChanged ? 'true' : 'false');\n135\t\n136\t  const jsScriptsChanged = changedFiles.some(\n137\t    (f) =>\n138\t      f.startsWith('scripts/') &&\n139\t      !f.startsWith('scripts/rust-') &&\n140\t      f.endsWith('.mjs')\n141\t  );\n142\t  setOutput('js-scripts-changed', jsScriptsChanged ? 'true' : 'false');\n143\t\n144\t  const rustScriptsChanged = changedFiles.some(\n145\t    (f) => f.startsWith('scripts/rust-') && f.endsWith('.mjs')\n146\t  );\n147\t  setOutput('rust-scripts-changed', rustScriptsChanged ? 'true' : 'false');\n148\t\n149\t  // Workflow detection\n150\t  const workflowChanged = changedFiles.some((f) =>\n151\t    f.startsWith('.github/workflows/')\n152\t  );\n153\t  setOutput('workflow-changed', workflowChanged ? 'true' : 'false');\n154\t\n155\t  const jsWorkflowChanged = changedFiles.some(\n156\t    (f) => f === '.github/workflows/js.yml'\n157\t  );\n158\t  setOutput('js-workflow-changed', jsWorkflowChanged ? 'true' : 'false');\n159\t\n160\t  const rustWorkflowChanged = changedFiles.some(\n161\t    (f) => f === '.github/workflows/rust.yml'\n162\t  );\n163\t  setOutput('rust-workflow-changed', rustWorkflowChanged ? 'true' : 'false');\n164\t\n165\t  // Docs detection\n166\t  const docsChanged = changedFiles.some((f) => f.endsWith('.md'));\n167\t  setOutput('docs-changed', docsChanged ? 'true' : 'false');\n168\t\n169\t  // Code changes (excluding docs, changesets, experiments, examples)\n170\t  const codeChangedFiles = changedFiles.filter(\n171\t    (file) => !isExcludedFromCodeChanges(file)\n172\t  );\n173\t\n174\t  console.log('\\nFiles considered as code changes:');\n175\t  if (codeChangedFiles.length === 0) {\n176\t    console.log('  (none)');\n177\t  } else {\n178\t    codeChangedFiles.forEach((file) => console.log(`  ${file}`));\n179\t  }\n180\t  console.log('');\n181\t\n182\t  const codePattern =\n183\t    /\\.(mjs|js|json|rs|toml|yml|yaml|sh|lock)$|\\.github\\/workflows\\//;\n184\t  const anyCodeChanged = codeChangedFiles.some((file) =>\n185\t    codePattern.test(file)\n186\t  );\n187\t  setOutput('any-code-changed', anyCodeChanged ? 'true' : 'false');\n188\t\n189\t  // Composite flags for workflow gating\n190\t  const anyJsCodeChanged =\n191\t    jsCodeChanged || jsScriptsChanged || jsWorkflowChanged;\n192\t  setOutput('any-js-code-changed', anyJsCodeChanged ? 'true' : 'false');\n193\t\n194\t  const anyRustCodeChanged =\n195\t    rustCodeChanged || rustScriptsChanged || rustWorkflowChanged;\n196\t  setOutput('any-rust-code-changed', anyRustCodeChanged ? 'true' : 'false');\n197\t\n198\t  console.log('\\nChange detection completed.');\n199\t}\n200\t\n201\tdetectChanges();\n202\t"
