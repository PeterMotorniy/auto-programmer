{\n539\t      // Always restore stderr.write\n540\t      process.stderr.write = originalStderrWrite;\n541\t\n542\t      // In verbose mode, show what was captured from stderr (for debugging)\n543\t      if (global.verboseMode && stderrBuffer.length > 0) {\n544\t        const captured = stderrBuffer.join('');\n545\t        if (captured.trim()) {\n546\t          console.error('[Suppressed yargs stderr]:', captured);\n547\t        }\n548\t      }\n549\t    }\n550\t  } catch (error) {\n551\t    // Yargs throws errors for validation issues\n552\t    // If the error is about unknown arguments (strict mode), enhance it with suggestions\n553\t    // Check if this error has already been enhanced to avoid re-processing\n554\t    if (error.message && /Unknown argument/.test(error.message) && !error._enhanced) {\n555\t      try {\n556\t        // Enhance the error message with helpful suggestions\n557\t        // Use the yargsInstance we already created, or create a new one if needed\n558\t        const yargsWithConfig = yargsInstance || createYargsConfig(yargs());\n559\t        const enhancedMessage = enhanceErrorMessage(error.message, yargsWithConfig);\n560\t        const enhancedError = new Error(enhancedMessage);\n561\t        enhancedError.name = error.name;\n562\t        enhancedError._enhanced = true; // Mark as enhanced to prevent re-processing\n563\t        throw enhancedError;\n564\t      } catch (enhanceErr) {\n565\t        // If enhancing fails, just throw the original error\n566\t        if (global.verboseMode) {\n567\t          console.error('[VERBOSE] Failed to enhance error message:', enhanceErr.message);\n568\t        }\n569\t        // If the enhance error itself is already enhanced, throw it\n570\t        if (enhanceErr._enhanced) {\n571\t          throw enhanceErr;\n572\t        }\n573\t        throw error;\n574\t      }\n575\t    }\n576\t    // For other validation errors, show a warning in verbose mode\n577\t    if (error.message && global.verboseMode) {\n