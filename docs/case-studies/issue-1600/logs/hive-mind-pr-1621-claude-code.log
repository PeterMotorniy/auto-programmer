[2026-04-17T05:16:22.310Z] [INFO]         "content": "1\t#!/usr/bin/env node\n2\t\n3\t/**\n4\t * Unified models module for hive-mind\n5\t * Single source of truth for all model data, mapping, validation, and info.\n6\t *\n7\t * Consolidates the former:\n8\t * - model-mapping.lib.mjs (model data, maps, tool-model functions)\n9\t * - model-validation.lib.mjs (validation, fuzzy matching, 1M context)\n10\t * - model-info.lib.mjs (display names, models.dev API, PR comment helpers)\n11\t *\n12\t * @see https://github.com/link-assistant/hive-mind/issues/1473\n13\t */\n14\t\n15\t// Check if use is already defined (when imported from solve.mjs)\n16\t// If not, fetch it (when running standalone)\n17\tif (typeof globalThis.use === 'undefined') {\n18\t  globalThis.use = (await eval(await (await fetch('https://unpkg.com/use-m/use.js')).text())).use;\n19\t}\n20\t\n21\timport { log } from '../lib.mjs';\n22\t\n23\t// ─── MODEL DATA ──────────────────────────────────────────────────────────────\n24\t\n25\t// Claude models (Anthropic API)\n26\t// Updated for Opus 4.5/4.6 and Sonnet 4.6 support (Issue #1221, Issue #1238, Issue #1329, Issue #1433)\n27\texport const claudeModels = {\n28\t  sonnet: 'claude-sonnet-4-6', // Sonnet 4.6 (default, Issue #1329)\n29\t  opus: 'claude-opus-4-6', // Opus 4.6 (Issue #1433)\n30\t  haiku: 'claude-haiku-4-5-20251001', // Haiku 4.5\n31\t  'haiku-3-5': 'claude-3-5-haiku-20241022', // Haiku 3.5\n32\t  'haiku-3': 'claude-3-haiku-20240307', // Haiku 3\n33\t  opusplan: 'opusplan', // Special mode: Opus for planning, Sonnet for execution (Issue #1223)\n34\t  // Shorter version aliases (Issue #1221, Issue #1329 - PR comment feedback)\n35\t  'sonnet-4-6': 'claude-sonnet-4-6', // Sonnet 4.6 short alias (Issue #1329)\n36\t  'opus-4-6': 'claude-opus-4-6', // Opus 4.6 short alias\n37\t  'opus-4-5': 'claude-opus-4-5-20251101', // Opus 4.5 short alias\n38\t  'sonnet-4-5': 'claude-sonnet-4-5-20250929', // Sonnet 4.5 short alias (backward compatibility)\n39\t  'haiku-4-5': 'claude-haiku-4-5-20251001', // Haiku 4.5 short alias\n40\t  // Version aliases for backward compatibility (Issue #1221, Issue #1329)\n41\t  'claude-sonnet-4-6': 'claude-sonnet-4-6', // Sonnet 4.6 (Issue #1329)\n42\t  'claude-opus-4-6': 'claude-opus-4-6', // Opus 4.6\n43\t  'claude-opus-4-5': 'claude-opus-4-5-20251101', // Opus 4.5\n44\t  'claude-sonnet-4-5': 'claude-sonnet-4-5-20250929', // Sonnet 4.5 (backward compatibility)\n45\t  'claude-haiku-4-5': 'claude-haiku-4-5-20251001', // Haiku 4.5\n46\t};\n47\t\n48\t// Agent models (OpenCode API and Kilo Gateway via agent CLI)\n49\t// Issue #1300: Updated free models to match agent PR #191\n50\t// Issue #1543: Added qwen3.6-plus-free (former default) and nemotron-3-super-free per agent PR #234\n51\t// Issue #1563: qwen3.6-plus-free free promotion ended (April 2026), nemotron-3-super-free is now default per agent PR #243\n52\texport const agentModels = {\n53\t  // OpenCode Zen free models (current)\n54\t  grok: 'opencode/grok-code',\n55\t  'grok-code': 'opencode/grok-code',\n56\t  'grok-code-fast-1': 'opencode/grok-code',\n57\t  'big-pickle': 'opencode/big-pickle',\n58\t  'gpt-5-nano': 'opencode/gpt-5-nano',\n59\t  'minimax-m2.5-free': 'opencode/minimax-m2.5-free', // Upgraded from M2.1 (Issue #1391)\n60\t  'nemotron-3-super-free': 'opencode/nemotron-3-super-free', // Default: NVIDIA hybrid Mamba-Transformer (Issue #1563)\n61\t  // Kilo Gateway free models (Issue #1282, updated in #1300)\n62\t  // Short names for Kilo-exclusive models (Issue #1300)\n63\t  'glm-5-free': 'kilo/glm-5-free', // Kilo-exclusive\n64\t  'glm-4.5-air-free': 'kilo/glm-4.5-air-free', // Kilo-exclusive: agent-centric model\n65\t  'deepseek-r1-free': 'kilo/deepseek-r1-free', // Kilo-exclusive: reasoning model\n66\t  'giga-potato-free': 'kilo/giga-potato-free', // Kilo-exclusive\n67\t  'trinity-large-preview': 'kilo/trinity-large-preview', // Kilo-exclusive\n68\t  // Full names with kilo/ prefix\n69\t  'kilo/glm-5-free': 'kilo/glm-5-free',\n70\t  'kilo/glm-4.5-air-free': 'kilo/glm-4.5-air-free',\n71\t  'kilo/minimax-m2.5-free': 'kilo/minimax-m2.5-free', // Also on OpenCode Zen\n72\t  'kilo/deepseek-r1-free': 'kilo/deepseek-r1-free',\n73\t  'kilo/giga-potato-free': 'kilo/giga-potato-free',\n74\t  'kilo/trinity-large-preview': 'kilo/trinity-large-preview',\n75\t  // Deprecated free models (kept for backward compatibility)\n76\t  'qwen3.6-plus-free': 'opencode/qwen3.6-plus-free', // Deprecated: free promotion ended April 2026 (Issue #1563)\n77\t  'kimi-k2.5-free': 'opencode/kimi-k2.5-free', // Deprecated: not supported (Issue #1391)\n78\t  'glm-4.7-free': 'opencode/glm-4.7-free', // Deprecated: no longer free\n79\t  'minimax-m2.1-free': 'opencode/minimax-m2.1-free', // Deprecated: replaced by m2.5\n80\t  'kilo/glm-4.7-free': 'kilo/glm-4.7-free', // Deprecated: replaced by glm-4.5-air-free\n81\t  'kilo/kimi-k2.5-free': 'kilo/kimi-k2.5-free', // Deprecated: not recommended\n82\t  'kilo/minimax-m2.1-free': 'kilo/minimax-m2.1-free', // Deprecated: replaced by m2.5\n83\t  // Premium models\n84\t  sonnet: 'anthropic/claude-3-5-sonnet',\n85\t  haiku: 'anthropic/claude-3-5-haiku',\n86\t  opus: 'anthropic/claude-3-opus',\n87\t  'gemini-3-pro': 'google/gemini-3-pro',\n88\t};\n89\t\n90\t// OpenCode models (OpenCode API)\n91\texport const opencodeModels = {\n92\t  gpt4: 'openai/gpt-4',\n93\t  gpt4o: 'openai/gpt-4o',\n94\t  claude: 'anthropic/claude-3-5-sonnet',\n95\t  sonnet: 'anthropic/claude-3-5-sonnet',\n96\t  opus: 'anthropic/claude-3-opus',\n97\t  gemini: 'google/gemini-pro',\n98\t  grok: 'opencode/grok-code',\n99\t  'grok-code': 'opencode/grok-code',\n100\t  'grok-code-fast-1': 'opencode/grok-code',\n101\t};\n102\t\n103\t// Codex models (OpenAI API)\n104\texport const codexModels = {\n105\t  gpt5: 'gpt-5',\n106\t  'gpt-5': 'gpt-5',\n107\t  'gpt-5.4': 'gpt-5.4',\n108\t  'gpt-5.4-mini': 'gpt-5.4-mini',\n109\t  'gpt-5.4-nano': 'gpt-5.4-nano',\n110\t  'gpt-5.2-codex': 'gpt-5.2-codex',\n111\t  'gpt-5.3-codex': 'gpt-5.3-codex',\n112\t  'gpt-5.3-codex-spark': 'gpt-5.3-codex-spark',\n113\t  'gpt-5.1-codex-max': 'gpt-5.1-codex-max',\n114\t  'o3-mini': 'o3-mini',\n115\t  gpt4: 'gpt-4',\n116\t  'gpt-4': 'gpt-4',\n117\t  gpt4o: 'gpt-4o',\n118\t  'gpt-4o': 'gpt-4o',\n119\t};\n120\t\n121\t// Default model for each tool (Issue #1473: centralized to avoid scattered hardcoded defaults)\n122\texport const defaultModels = {\n123\t  claude: 'sonnet',\n124\t  agent: 'nemotron-3-super-free', // Issue #1563: changed from qwen3.6-plus-free (free promotion ended) per agent PR #243\n125\t  opencode: 'grok-code-fast-1',\n126\t  codex: 'gpt-5.4',\n127\t};\n128\t\n129\t// Models that support 1M token context window via [1m] suffix (Issue #1221, Issue #1238, Issue #1329)\n130\t// See: https://code.claude.com/docs/en/model-config\n131\texport const MODELS_SUPPORTING_1M_CONTEXT = [\n132\t  'claude-opus-4-6',\n133\t  'claude-opus-4-5-20251101',\n134\t  'claude-sonnet-4-6', // Sonnet 4.6 (Issue #1329)\n135\t  'claude-sonnet-4-5-20250929',\n136\t  'claude-sonnet-4-5',\n137\t  'sonnet', // Now maps to Sonnet 4.6 (Issue #1329)\n138\t  'sonnet-4-6', // Short alias (Issue #1329)\n139\t  'opus',\n140\t  'opus-4-6', // Short alias (Issue #1221 - PR comment feedback)\n141\t  'opus-4-5', // Short alias (Issue #1238)\n142\t  'sonnet-4-5', // Short alias (Issue #1221 - PR comment feedback)\n143\t];\n144\t\n145\t// Free model to base model mapping for pricing lookup (Issue #1250, Issue #1473)\n146\t// Free models like \"kimi-k2.5-free\" should use pricing from base model \"kimi-k2.5\"\n147\texport const freeToBaseModelMap = {\n148\t  'kimi-k2.5-free': 'kimi-k2.5',\n149\t  'glm-4.7-free': 'glm-4.7',\n150\t  'minimax-m2.1-free': 'minimax-m2.1',\n151\t  'minimax-m2.5-free': 'minimax-m2.5',\n152\t  'qwen3.6-plus-free': 'qwen3.6-plus', // Issue #1543\n153\t  'nemotron-3-super-free': 'nemotron-3-super', // Issue #1543\n154\t  'glm-5-free': 'glm-5',\n155\t  'glm-4.5-air-free': 'glm-4.5-air',\n156\t  'deepseek-r1-free': 'deepseek-r1',\n157\t  'giga-potato-free': 'giga-potato',\n158\t  'trinity-large-preview-free': 'trinity-large-preview',\n159\t};\n160\t\n161\t// ─── VALIDATION-EXTENDED MODEL MAPS ──────────────────────────────────────────\n162\t// These extend the base maps with full model ID identity entries for validation\n163\t// (e.g., 'claude-sonnet-4-5-20250929' → 'claude-sonnet-4-5-20250929')\n164\t// so that full model IDs are also accepted as valid inputs\n165\t\n166\texport const CLAUDE_MODELS = {\n167\t  ...claudeModels,\n168\t  'claude-sonnet-4-5-20250929': 'claude-sonnet-4-5-20250929',\n169\t  'claude-opus-4-5-20251101': 'claude-opus-4-5-20251101',\n170\t  'claude-haiku-4-5-20251001': 'claude-haiku-4-5-20251001',\n171\t  'claude-3-5-haiku-20241022': 'claude-3-5-haiku-20241022',\n172\t  'claude-3-haiku-20240307': 'claude-3-haiku-20240307',\n173\t};\n174\t\n175\texport const OPENCODE_MODELS = {\n176\t  ...opencodeModels,\n177\t  'openai/gpt-4': 'openai/gpt-4',\n178\t  'openai/gpt-4o': 'openai/gpt-4o',\n179\t  'anthropic/claude-3-5-sonnet': 'anthropic/claude-3-5-sonnet',\n180\t  'anthropic/claude-3-opus': 'anthropic/claude-3-opus',\n181\t  'google/gemini-pro': 'google/gemini-pro',\n182\t  'opencode/grok-code': 'opencode/grok-code',\n183\t};\n184\t\n185\texport const CODEX_MODELS = {\n186\t  ...codexModels,\n187\t  'gpt-5': 'gpt-5',\n188\t  'gpt-5.4': 'gpt-5.4',\n189\t  'gpt-5.4-mini': 'gpt-5.4-mini',\n190\t  'gpt-5.4-nano': 'gpt-5.4-nano',\n191\t  'gpt-5.2-codex': 'gpt-5.2-codex',\n192\t  'gpt-5.3-codex': 'gpt-5.3-codex',\n193\t  'gpt-5.3-codex-spark': 'gpt-5.3-codex-spark',\n194\t  'gpt-5.1-codex-max': 'gpt-5.1-codex-max',\n195\t  'gpt-4': 'gpt-4',\n196\t  'gpt-4o': 'gpt-4o',\n197\t};\n198\t\n199\texport const AGENT_MODELS = {\n200\t  ...agentModels,\n201\t  'opencode/grok-code': 'opencode/grok-code',\n202\t  'opencode/big-pickle': 'opencode/big-pickle',\n203\t  'opencode/gpt-5-nano': 'opencode/gpt-5-nano',\n204\t  'opencode/minimax-m2.5-free': 'opencode/minimax-m2.5-free',\n205\t  'opencode/nemotron-3-super-free': 'opencode/nemotron-3-super-free', // Issue #1563: now default\n206\t  'opencode/qwen3.6-plus-free': 'opencode/qwen3.6-plus-free', // Deprecated: free promotion ended (Issue #1563)\n207\t  'opencode/kimi-k2.5-free': 'opencode/kimi-k2.5-free', // Deprecated\n208\t  'opencode/glm-4.7-free': 'opencode/glm-4.7-free', // Deprecated\n209\t  'opencode/minimax-m2.1-free': 'opencode/minimax-m2.1-free', // Deprecated\n210\t  'anthropic/claude-3-5-sonnet': 'anthropic/claude-3-5-sonnet',\n211\t  'anthropic/claude-3-5-haiku': 'anthropic/claude-3-5-haiku',\n212\t  'anthropic/claude-3-opus': 'anthropic/claude-3-opus',\n213\t  'google/gemini-3-pro': 'google/gemini-3-pro',\n214\t};\n215\t\n216\t// ─── MODEL MAPPING FUNCTIONS ─────────────────────────────────────────────────\n217\t\n218\t/**\n219\t * Get the model map object for a given tool\n220\t * @param {string} tool - The tool name (claude, agent, opencode, codex)\n221\t * @returns {Object} The model mapping for the tool\n222\t */\n223\texport const getModelMapForTool = tool => {\n224\t  switch (tool) {\n225\t    case 'claude':\n226\t      return claudeModels;\n227\t    case 'agent':\n228\t      return agentModels;\n229\t    case 'opencode':\n230\t      return opencodeModels;\n231\t    case 'codex':\n232\t      return codexModels;\n233\t    default:\n234\t      return claudeModels;\n235\t  }\n236\t};\n237\t\n238\t/**\n239\t * Get the default model for a given tool\n240\t * @param {string} tool - The tool name (claude, agent, opencode, codex)\n241\t * @returns {string} The default model alias for the tool\n242\t */\n243\texport const getDefaultModelForTool = tool => {\n244\t  return defaultModels[tool] || defaultModels.claude;\n245\t};\n246\t\n247\t/**\n248\t * Map model name to full model ID for a specific tool\n249\t * @param {string} tool - The tool name (claude, agent, opencode, codex)\n250\t * @param {string} model - The model name or alias\n251\t * @returns {string} The full model ID\n252\t */\n253\texport const mapModelForTool = (tool, model) => {\n254\t  switch (tool) {\n255\t    case 'claude':\n256\t      return claudeModels[model] || model;\n257\t    case 'agent':\n258\t      return agentModels[model] || model;\n259\t    case 'opencode':\n260\t      return opencodeModels[model] || model;\n261\t    case 'codex':\n262\t      return codexModels[model] || model;\n263\t    default:\n264\t      return model;\n265\t  }\n266\t};\n267\t\n268\t/**\n269\t * Validate if a model is compatible with a tool\n270\t * @param {string} tool - The tool name (claude, agent, opencode, codex)\n271\t * @param {string} model - The model name or alias\n272\t * @returns {boolean} True if the model is compatible with the tool\n273\t */\n274\texport const isModelCompatibleWithTool = (tool, model) => {\n275\t  const mappedModel = mapModelForTool(tool, model);\n276\t\n277\t  switch (tool) {\n278\t    case 'claude':\n279\t      return mappedModel.startsWith('claude-') || mappedModel === 'opusplan';\n280\t    case 'agent':\n281\t      return mappedModel.includes('/') || Object.keys(agentModels).includes(model);\n282\t    case 'opencode':\n283\t      return mappedModel.includes('/') || Object.keys(opencodeModels).includes(model);\n284\t    case 'codex':\n285\t      return Object.keys(codexModels).includes(model) || mappedModel.startsWith('gpt-');\n286\t    default:\n287\t      return true;\n288\t  }\n289\t};\n290\t\n291\t/**\n292\t * Get a list of valid model names for a tool\n293\t * @param {string} tool - The tool name\n294\t * @returns {string[]} Array of valid model names\n295\t */\n296\texport const getValidModelsForTool = tool => {\n297\t  switch (tool) {\n298\t    case 'claude':\n299\t      return Object.keys(claudeModels);\n300\t    case 'agent':\n301\t      return Object.keys(agentModels);\n302\t    case 'opencode':\n303\t      return Object.keys(opencodeModels);\n304\t    case 'codex':\n305\t      return Object.keys(codexModels);\n306\t    default:\n307\t      return [];\n308\t  }\n309\t};\n310\t\n311\t// Primary (non-alias, non-deprecated) short names shown in CLI help descriptions\n312\t// These are the recommended model names users should see in --model help text\n313\texport const primaryModelNames = {\n314\t  claude: ['opus', 'sonnet', 'haiku', 'opusplan'],\n315\t  opencode: ['grok', 'gpt4o'],\n316\t  codex: ['gpt-5.4', 'gpt-5.4-mini', 'gpt-5.3-codex', 'gpt-5.3-codex-spark', 'gpt-5.2-codex'],\n317\t  agent: ['nemotron-3-super-free', 'minimax-m2.5-free', 'big-pickle', 'gpt-5-nano', 'glm-5-free', 'deepseek-r1-free'],\n318\t};\n319\t\n320\t/**\n321\t * Build the --model CLI option description string dynamically from centralized model data.\n322\t * @returns {string} Description like \"Model to use (for claude: opus, sonnet, ...; for agent: ...)\"\n323\t */\n324\texport const buildModelOptionDescription = () => {\n325\t  const parts = Object.entries(primaryModelNames).map(([tool, names]) => `for ${tool}: ${names.join(', ')}`);\n326\t  return `Model to use (${parts.join('; ')})`;\n327\t};\n328\t\n329\t/**\n330\t * Get the primary choices for Claude model selection (used in review.mjs and task.mjs).\n331\t * Returns short aliases plus key full model IDs for backward compatibility.\n332\t * @returns {string[]}\n333\t */\n334\texport const getClaudeModelChoices = () => {\n335\t  return Object.keys(claudeModels);\n336\t};\n337\t\n338\t/**\n339\t * Validate tool-model compatibility and throw descriptive error if invalid\n340\t * @param {string} tool - The tool name\n341\t * @param {string} model - The model name\n342\t * @throws {Error} If the model is not compatible with the tool\n343\t */\n344\texport const validateToolModelCompatibility = (tool, model) => {\n345\t  if (!isModelCompatibleWithTool(tool, model)) {\n346\t    const validModels = getValidModelsForTool(tool);\n347\t    const mappedModel = mapModelForTool(tool, model);\n348\t\n349\t    throw new Error(`Model '${model}' (mapped to '${mappedModel}') is not compatible with --tool ${tool}.\\n` + `Valid models for ${tool}: ${validModels.join(', ')}\\n` + 'Hint: Different tools use different model APIs and naming conventions.');\n350\t  }\n351\t};\n352\t\n353\t// ─── MODEL VALIDATION FUNCTIONS ──────────────────────────────────────────────\n354\t\n355\t/**\n356\t * Get the model map for a given tool (validation-extended version with full ID entries)\n357\t * @param {string} tool - The tool name ('claude', 'opencode', 'codex', 'agent')\n358\t * @returns {Object} The model mapping for the tool\n359\t */\n360\tconst getValidationModelMapForTool = tool => {\n361\t  switch (tool) {\n362\t    case 'opencode':\n363\t      return OPENCODE_MODELS;\n364\t    case 'codex':\n365\t      return CODEX_MODELS;\n366\t    case 'agent':\n367\t      return AGENT_MODELS;\n368\t    case 'claude':\n369\t    default:\n370\t      return CLAUDE_MODELS;\n371\t  }\n372\t};\n373\t\n374\t/**\n375\t * Get the list of available model names for a tool (for display in help/error messages)\n376\t * @param {string} tool - The tool name ('claude', 'opencode', 'codex', 'agent')\n377\t * @returns {string[]} Array of available model short names\n378\t */\n379\texport const getAvailableModelNames = tool => {\n380\t  const modelMap = getValidationModelMapForTool(tool);\n381\t  // Get unique short names (aliases) - exclude full model IDs that contain '/' or long claude- prefixed IDs\n382\t  const aliases = Object.keys(modelMap).filter(key => {\n383\t    // Keep short aliases only - exclude:\n384\t    // - Full model IDs with slashes (e.g., 'openai/gpt-4')\n385\t    // - Long claude-prefixed model IDs (e.g., 'claude-sonnet-4-5-20250929')\n386\t    // - Full gpt- prefixed IDs that are ONLY version numbers (e.g., 'gpt-4', 'gpt-4o', 'gpt-5')\n387\t    // But keep descriptive aliases like 'gpt-5-nano', 'gpt-5.3-codex', 'o3-mini', 'gpt5', etc.\n388\t    // Issue #1185: Updated regex to not filter out gpt-5-nano (a valid short alias)\n389\t    if (key.includes('/')) return false;\n390\t    if (key.match(/^claude-.*-\\d{8}$/)) return false; // Full claude model IDs with date\n391\t    if (key.match(/^gpt-\\d+[a-z]?$/)) return false; // Full gpt-N or gpt-No model IDs only (e.g., gpt-4, gpt-4o, gpt-5)\n392\t    return true;\n393\t  });\n394\t  return [...new Set(aliases)];\n395\t};\n396\t\n397\t/**\n398\t * Calculate Levenshtein distance between two strings (case-insensitive)\n399\t * @param {string} a - First string\n400\t * @param {string} b - Second string\n401\t * @returns {number} The edit distance between the strings\n402\t */\n403\texport const levenshteinDistance = (a, b) => {\n404\t  const aLower = a.toLowerCase();\n405\t  const bLower = b.toLowerCase();\n406\t\n407\t  if (aLower === bLower) return 0;\n408\t  if (aLower.length === 0) return bLower.length;\n409\t  if (bLower.length === 0) return aLower.length;\n410\t\n411\t  const matrix = [];\n412\t\n413\t  for (let i = 0; i <= bLower.length; i++) {\n414\t    matrix[i] = [i];\n415\t  }\n416\t\n417\t  for (let j = 0; j <= aLower.length; j++) {\n418\t    matrix[0][j] = j;\n419\t  }\n420\t\n421\t  for (let i = 1; i <= bLower.length; i++) {\n422\t    for (let j = 1; j <= aLower.length; j++) {\n423\t      if (bLower.charAt(i - 1) === aLower.charAt(j - 1)) {\n424\t        matrix[i][j] = matrix[i - 1][j - 1];\n425\t      } else {\n426\t        matrix[i][j] = Math.min(\n427\t          matrix[i - 1][j - 1] + 1, // substitution\n428\t          matrix[i][j - 1] + 1, // insertion\n429\t          matrix[i - 1][j] + 1 // deletion\n430\t        );\n431\t      }\n432\t    }\n433\t  }\n434\t\n435\t  return matrix[bLower.length][aLower.length];\n436\t};\n437\t\n438\t/**\n439\t * Find the closest matching model names using fuzzy matching\n440\t * @param {string} input - The user-provided model name\n441\t * @param {string[]} validModels - Array of valid model names\n442\t * @param {number} maxSuggestions - Maximum number of suggestions to return\n443\t * @param {number} maxDistance - Maximum Levenshtein distance to consider\n444\t * @returns {string[]} Array of suggested model names\n445\t */\n446\texport const findSimilarModels = (input, validModels, maxSuggestions = 3, maxDistance = 3) => {\n447\t  const suggestions = validModels\n448\t    .map(model => ({\n449\t      model,\n450\t      distance: levenshteinDistance(input, model),\n451\t    }))\n452\t    .filter(({ distance }) => distance <= maxDistance)\n453\t    .sort((a, b) => a.distance - b.distance)\n454\t    .slice(0, maxSuggestions)\n455\t    .map(({ model }) => model);\n456\t\n457\t  return suggestions;\n458\t};\n459\t\n460\t/**\n461\t * Parse model name to extract base model and optional [1m] suffix\n462\t * @param {string} model - The model name (e.g., \"opus[1m]\", \"claude-opus-4-6[1m]\")\n463\t * @returns {{ baseModel: string, has1mSuffix: boolean }}\n464\t */\n465\texport const parseModelWith1mSuffix = model => {\n466\t  if (!model || typeof model !== 'string') {\n467\t    return { baseModel: model, has1mSuffix: false };\n468\t  }\n469\t\n470\t  const match = model.match(/^(.+?)\\[1m\\]$/i);\n471\t  if (match) {\n472\t    return { baseModel: match[1], has1mSuffix: true };\n473\t  }\n474\t\n475\t  return { baseModel: model, has1mSuffix: false };\n476\t};\n477\t\n478\t/**\n479\t * Check if a model supports the [1m] context window\n480\t * @param {string} model - The base model name (without [1m] suffix)\n481\t * @param {string} tool - The tool name\n482\t * @returns {boolean} True if the model supports 1M context\n483\t */\n484\texport const supports1mContext = (model, tool = 'claude') => {\n485\t  if (tool !== 'claude') {\n486\t    return false;\n487\t  }\n488\t\n489\t  const normalizedModel = model.toLowerCase();\n490\t\n491\t  for (const supportedModel of MODELS_SUPPORTING_1M_CONTEXT) {\n492\t    if (supportedModel.toLowerCase() === normalizedModel) {\n493\t      return true;\n494\t    }\n495\t  }\n496\t\n497\t  const modelMap = getValidationModelMapForTool(tool);\n498\t  const matchedKey = Object.keys(modelMap).find(key => key.toLowerCase() === normalizedModel);\n499\t  if (matchedKey) {\n500\t    const mappedModel = modelMap[matchedKey];\n501\t    for (const supportedModel of MODELS_SUPPORTING_1M_CONTEXT) {\n502\t      if (supportedModel.toLowerCase() === mappedModel.toLowerCase()) {\n503\t        return true;\n504\t      }\n505\t    }\n506\t  }\n507\t\n508\t  return false;\n509\t};\n510\t\n511\t/**\n512\t * Validate a model name against the available models for a tool\n513\t * Supports [1m] suffix for 1 million token context (Issue #1221)\n514\t * @param {string} model - The model name to validate (e.g., \"opus\", \"opus[1m]\", \"claude-opus-4-6[1m]\")\n515\t * @param {string} tool - The tool name ('claude', 'opencode', 'codex')\n516\t * @returns {{ valid: boolean, message?: string, suggestions?: string[], mappedModel?: string, has1mSuffix?: boolean }}\n517\t */\n518\texport const validateModelName = (model, tool = 'claude') => {\n519\t  if (!model || typeof model !== 'string') {\n520\t    return {\n521\t      valid: false,\n522\t      message: 'Model name is required',\n523\t      suggestions: [],\n524\t    };\n525\t  }\n526\t\n527\t  const { baseModel, has1mSuffix } = parseModelWith1mSuffix(model);\n528\t\n529\t  const modelMap = getValidationModelMapForTool(tool);\n530\t  const availableNames = Object.keys(modelMap);\n531\t\n532\t  const normalizedModel = baseModel.toLowerCase();\n533\t  const matchedKey = availableNames.find(key => key.toLowerCase() === normalizedModel);\n534\t\n535\t  if (matchedKey) {\n536\t    const mappedModel = modelMap[matchedKey];\n537\t\n538\t    if (has1mSuffix) {\n539\t      if (!supports1mContext(baseModel, tool)) {\n540\t        const supportedModels = MODELS_SUPPORTING_1M_CONTEXT.filter(m => !m.includes('-')).join(', ');\n541\t        return {\n542\t          valid: false,\n543\t          message: `Model \"${baseModel}\" does not support [1m] context window.\\n   Models supporting 1M context: ${supportedModels}`,\n544\t          suggestions: [],\n545\t        };\n546\t      }\n547\t      return {\n548\t        valid: true,\n549\t        mappedModel: `${mappedModel}[1m]`,\n550\t        has1mSuffix: true,\n551\t      };\n552\t    }\n553\t\n554\t    return {\n555\t      valid: true,\n556\t      mappedModel,\n557\t      has1mSuffix: false,\n558\t    };\n559\t  }\n560\t\n561\t  // Model not found - provide helpful error with suggestions\n562\t  const shortNames = getAvailableModelNames(tool);\n563\t  const suggestions = findSimilarModels(baseModel, shortNames);\n564\t\n565\t  let message = `Unrecognized model: \"${model}\"`;\n566\t\n567\t  if (suggestions.length > 0) {\n568\t    message += `\\n   Did you mean: ${suggestions.map(s => `\"${s}\"`).join(', ')}?`;\n569\t  }\n570\t\n571\t  message += `\\n   Available models for ${tool}: ${shortNames.join(', ')}`;\n572\t\n573\t  if (tool === 'claude') {\n574\t    message += `\\n   Tip: Use [1m] suffix for 1M context (e.g., opus[1m], sonnet[1m])`;\n575\t  }\n576\t\n577\t  return {\n578\t    valid: false,\n579\t    message,\n580\t    suggestions,\n581\t  };\n582\t};\n583\t\n584\t/**\n585\t * Validate model name and exit with error if invalid\n586\t * This is the main entry point for model validation in solve.mjs, hive.mjs, etc.\n587\t * @param {string} model - The model name to validate\n588\t * @param {string} tool - The tool name ('claude', 'opencode', 'codex')\n589\t * @param {Function} exitFn - Function to call for exiting (default: process.exit)\n590\t * @returns {Promise<boolean>} True if valid, exits process if invalid\n591\t */\n592\texport const validateAndExitOnInvalidModel = async (model, tool = 'claude', exitFn = null) => {\n593\t  const result = validateModelName(model, tool);\n594\t\n595\t  if (!result.valid) {\n596\t    await log(`\\u274C ${result.message}`, { level: 'error' });\n597\t\n598\t    if (exitFn) {\n599\t      await exitFn(1, 'Invalid model name');\n600\t    } else {\n601\t      process.exit(1);\n602\t    }\n603\t    return false;\n604\t  }\n605\t\n606\t  return true;\n607\t};\n608\t\n609\t/**\n610\t * Format the list of available models for help text\n611\t * @param {string} tool - The tool name\n612\t * @returns {string} Formatted list of available models\n613\t */\n614\texport const formatAvailableModelsForHelp = (tool = 'claude') => {\n615\t  const names = getAvailableModelNames(tool);\n616\t  return names.join(', ');\n617\t};\n618\t\n619\t// ─── MODEL INFO FUNCTIONS ────────────────────────────────────────────────────\n620\t\n621\t/**\n622\t * Map tool identifier to user-friendly display name.\n623\t * @param {string|null} tool - The tool identifier (claude, codex, opencode, agent)\n624\t * @returns {string} User-friendly display name\n625\t */\n626\texport const getToolDisplayName = tool => {\n627\t  const name = (tool || '').toString().toLowerCase();\n628\t  switch (name) {\n629\t    case 'claude':\n630\t      return 'Anthropic Claude Code';\n631\t    case 'codex':\n632\t      return 'OpenAI Codex';\n633\t    case 'opencode':\n634\t      return 'OpenCode';\n635\t    case 'agent':\n636\t      return 'Agent CLI';\n637\t    default:\n638\t      return 'AI tool';\n639\t  }\n640\t};\n641\t\n642\t/**\n643\t * Cached models.dev API response to avoid repeated network requests.\n644\t */\n645\tlet modelsDevCache = null;\n646\t\n647\t/**\n648\t * Fetch the full models.dev API data with caching.\n649\t * @returns {Promise<Object|null>} The full API response or null on failure\n650\t */\n651\tconst fetchModelsDevApi = async () => {\n652\t  if (modelsDevCache) return modelsDevCache;\n653\t  try {\n654\t    const https = (await globalThis.use('https')).default;\n655\t    return new Promise((resolve, reject) => {\n656\t      https\n657\t        .get('https://models.dev/api.json', res => {\n658\t          let data = '';\n659\t          res.on('data', chunk => {\n660\t            data += chunk;\n661\t          });\n662\t          res.on('end', () => {\n663\t            try {\n664\t              modelsDevCache = JSON.parse(data);\n665\t              resolve(modelsDevCache);\n666\t            } catch (parseError) {\n667\t              reject(parseError);\n668\t            }\n669\t          });\n670\t        })\n671\t        .on('error', err => {\n672\t          reject(err);\n673\t        });\n674\t    });\n675\t  } catch {\n676\t    return null;\n677\t  }\n678\t};\n679\t\n680\t/**\n681\t * Fetch model metadata from models.dev API.\n682\t * @param {string} modelId - The model ID (e.g., \"claude-opus-4-6\", \"opencode/grok-code\")\n683\t * @returns {Promise<Object|null>} Model metadata or null if not found\n684\t */\n685\texport const fetchModelInfoForComment = async modelId => {\n686\t  if (!modelId) return null;\n687\t  try {\n688\t    const apiData = await fetchModelsDevApi();\n689\t    if (!apiData) return null;\n690\t\n691\t    const lookupId = modelId.includes('/') ? modelId.split('/').pop() : modelId;\n692\t\n693\t    if (apiData.anthropic?.models?.[lookupId]) {\n694\t      const modelInfo = { ...apiData.anthropic.models[lookupId] };\n695\t      modelInfo.provider = apiData.anthropic.name || 'Anthropic';\n696\t      return modelInfo;\n697\t    }\n698\t\n699\t    for (const provider of Object.values(apiData)) {\n700\t      if (provider.models && provider.models[lookupId]) {\n701\t        const modelInfo = { ...provider.models[lookupId] };\n702\t        modelInfo.provider = provider.name || provider.id;\n703\t        return modelInfo;\n704\t      }\n705\t    }\n706\t\n707\t    if (lookupId !== modelId) {\n708\t      for (const provider of Object.values(apiData)) {\n709\t        if (provider.models && provider.models[modelId]) {\n710\t          const modelInfo = { ...provider.models[modelId] };\n711\t          modelInfo.provider = provider.name || provider.id;\n712\t          return modelInfo;\n713\t        }\n714\t      }\n715\t    }\n716\t\n717\t    return null;\n718\t  } catch {\n719\t    return null;\n720\t  }\n721\t};\n722\t\n723\t/**\n724\t * Normalize model ID for comparison purposes (strip suffixes, lowercase).\n725\t * @param {string} modelId - A model ID or alias\n726\t * @returns {string} Normalized ID\n727\t */\n728\tconst normalizeForComparison = modelId => {\n729\t  if (!modelId) return '';\n730\t  return modelId\n731\t    .toLowerCase()\n732\t    .replace(/\\[1m\\]$/i, '')\n733\t    .trim();\n734\t};\n735\t\n736\t/**\n737\t * Check if a requested model alias matches an actual model ID.\n738\t * @param {string} requestedModel - The --model flag value (alias or full ID)\n739\t * @param {string} actualModelId - The actual model ID from CLI output\n740\t * @param {string|null} tool - The tool being used\n741\t * @returns {boolean}\n742\t */\n743\tconst doesRequestedMatchActual = (requestedModel, actualModelId, tool) => {\n744\t  if (!requestedModel || !actualModelId) return false;\n745\t  const resolvedRequested = resolveModelId(requestedModel, tool);\n746\t  const normResolved = normalizeForComparison(resolvedRequested);\n747\t  const normActual = normalizeForComparison(actualModelId);\n748\t  if (normResolved === normActual) return true;\n749\t  if (normActual.startsWith(normResolved) || normResolved.startsWith(normActual)) return true;\n750\t  return false;\n751\t};\n752\t\n753\t/**\n754\t * Build model information string for PR/issue comments.\n755\t *\n756\t * @param {Object} options - Model info options\n757\t * @param {string|null} options.requestedModel - The model requested via --model flag\n758\t * @param {string|null} options.tool - The tool used (claude, agent, opencode, codex)\n759\t * @param {Object|null} options.pricingInfo - Pricing info from tool result\n760\t * @param {Object|null} options.modelInfo - Pre-fetched model metadata from models.dev\n761\t * @param {Array<{modelId: string, modelInfo: Object|null}>|null} options.modelsUsed - Actual models used from CLI JSON output\n762\t * @returns {string} Formatted markdown string for model info section\n763\t */\n764\texport const buildModelInfoString = ({ requestedModel = null, tool = null, pricingInfo = null, modelInfo = null, modelsUsed = null } = {}) => {\n765\t  const hasRequested = requestedModel !== null && requestedModel !== undefined;\n766\t  const hasModelsUsed = Array.isArray(modelsUsed) && modelsUsed.length > 0;\n767\t  const hasModelInfo = modelInfo !== null;\n768\t  const hasPricingModel = pricingInfo?.modelId || pricingInfo?.modelName;\n769\t\n770\t  if (!hasRequested && !hasModelsUsed && !hasModelInfo && !hasPricingModel) return '';\n771\t\n772\t  let info = '\\n\\n### \\uD83E\\uDD16 **Models used:**';\n773\t\n774\t  if (tool) {\n775\t    info += `\\n- Tool: ${getToolDisplayName(tool)}`;\n776\t  }\n777\t\n778\t  if (hasRequested) {\n779\t    info += `\\n- Requested: \\`${requestedModel}\\``;\n780\t  }\n781\t\n782\t  if (hasModelsUsed) {\n783\t    const [mainEntry, ...supportingEntries] = modelsUsed;\n784\t    const mainModelId = mainEntry.modelId;\n785\t    const mainModelMeta = mainEntry.modelInfo;\n786\t\n787\t    const mainMatches = hasRequested ? doesRequestedMatchActual(requestedModel, mainModelId, tool) : true;\n788\t\n789\t    const mainModelName = mainModelMeta?.name || mainModelId;\n790\t    const modelLabel = supportingEntries.length > 0 ? 'Main model' : 'Model';\n791\t\n792\t    if (mainMatches) {\n793\t      info += `\\n- **${modelLabel}: ${mainModelName}** (\\`${mainModelId}\\`)`;\n794\t    } else {\n795\t      info += `\\n- **${modelLabel}: ${mainModelName}** (\\`${mainModelId}\\`)`;\n796\t      if (hasRequested) {\n797\t        info += `\\n- \\u26A0\\uFE0F **Warning**: Main model \\`${mainModelId}\\` does not match requested model \\`${requestedModel}\\``;\n798\t      }\n799\t    }\n800\t\n801\t    if (supportingEntries.length > 0) {\n802\t      info += '\\n- **Additional models:**';\n803\t      for (const entry of supportingEntries) {\n804\t        const name = entry.modelInfo?.name || entry.modelId;\n805\t        info += `\\n  *  **${name}** (\\`${entry.modelId}\\`)`;\n806\t      }\n807\t    }\n808\t  } else if (hasModelInfo) {\n809\t    const mainModelName = modelInfo.name || (pricingInfo?.modelId ? pricingInfo.modelId : null) || 'Unknown';\n810\t    info += `\\n- Model: ${mainModelName}`;\n811\t    if (modelInfo.id) info += ` (ID: \\`${modelInfo.id}\\`)`;\n812\t    if (modelInfo.provider) info += `\\n- Provider: ${modelInfo.provider}`;\n813\t    if (modelInfo.knowledge) info += `\\n- Knowledge cutoff: ${modelInfo.knowledge}`;\n814\t  } else if (hasPricingModel) {\n815\t    const modelId = pricingInfo.modelId || null;\n816\t    const modelName = pricingInfo.modelName || modelId || 'Unknown';\n817\t    if (modelId && modelId !== modelName) {\n818\t      info += `\\n- Model: ${modelName} (ID: \\`${modelId}\\`)`;\n819\t    } else {\n820\t      info += `\\n- Model: ${modelName}`;\n821\t    }\n822\t    if (pricingInfo.provider) info += `\\n- Provider: ${pricingInfo.provider}`;\n823\t  }\n824\t\n825\t  return info;\n826\t};\n827\t\n828\t/**\n829\t * Resolve the full model ID from a user-provided alias using the model mapping.\n830\t * @param {string|null} requestedModel - The model alias (e.g., \"opus\", \"sonnet\")\n831\t * @param {string|null} tool - The tool being used\n832\t * @returns {string|null} The full model ID or null\n833\t */\n834\texport const resolveModelId = (requestedModel, tool) => {\n835\t  if (!requestedModel) return null;\n836\t\n837\t  try {\n838\t    const toolName = (tool || 'claude').toString().toLowerCase();\n839\t    const cleanModel = requestedModel.replace(/\\[1m\\]$/i, '');\n840\t    return mapModelForTool(toolName, cleanModel);\n841\t  } catch {\n842\t    return requestedModel;\n843\t  }\n844\t};\n845\t\n846\t/**\n847\t * Fetch model info and build the complete model information string for PR comments.\n848\t * Uses actual models from CLI JSON output when available.\n849\t *\n850\t * @param {Object} options\n851\t * @param {string|null} options.requestedModel - The --model flag value\n852\t * @param {string|null} options.tool - The tool used (claude, agent, opencode, codex)\n853\t * @param {Object|null} options.pricingInfo - Pricing info from tool result\n854\t * @param {Array<string>|null} options.actualModelIds - Actual model IDs from CLI JSON output\n855\t * @returns {Promise<string>} Formatted markdown model info section\n856\t */\n857\texport const getModelInfoForComment = async ({ requestedModel = null, tool = null, pricingInfo = null, actualModelIds = null } = {}) => {\n858\t  let modelIds = [];\n859\t\n860\t  if (Array.isArray(actualModelIds) && actualModelIds.length > 0) {\n861\t    modelIds = actualModelIds;\n862\t  } else if (pricingInfo?.modelId) {\n863\t    modelIds = [pricingInfo.modelId];\n864\t  } else if (requestedModel) {\n865\t    const resolved = resolveModelId(requestedModel, tool);\n866\t    if (resolved) modelIds = [resolved];\n867\t  }\n868\t\n869\t  const modelsUsed = [];\n870\t  for (const modelId of modelIds) {\n871\t    let meta = null;\n872\t    try {\n873\t      meta = await fetchModelInfoForComment(modelId);\n874\t    } catch {\n875\t      await log('  \\u26A0\\uFE0F  Could not fetch model info from models.dev', { verbose: true });\n876\t    }\n877\t    modelsUsed.push({ modelId, modelInfo: meta });\n878\t  }\n879\t\n880\t  const firstModelInfo = modelsUsed.length > 0 ? modelsUsed[0].modelInfo : null;\n881\t\n882\t  return buildModelInfoString({\n883\t    requestedModel,\n884\t    tool,\n885\t    pricingInfo,\n886\t    modelInfo: modelsUsed.length === 0 ? firstModelInfo : null,\n887\t    modelsUsed: modelsUsed.length > 0 ? modelsUsed : null,\n888\t  });\n889\t};\n890\t"
