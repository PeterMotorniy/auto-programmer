id, `sonnet-4-5[1m] should be valid, got: ${result.message}`);\n326\t  assert.strictEqual(result.mappedModel, 'claude-sonnet-4-5-20250929[1m]', 'sonnet-4-5[1m] should map to claude-sonnet-4-5-20250929[1m]');\n327\t  assert.strictEqual(result.has1mSuffix, true, 'Should indicate 1m suffix');\n328\t});\n329\t\n330\ttest('opus-4-5[1m] supports 1M context (Issue #1238)', () => {\n331\t  const result = validateModelName('opus-4-5[1m]', 'claude');\n332\t  assert(result.valid, `opus-4-5[1m] should be valid, got: ${result.message}`);\n333\t  assert.strictEqual(result.mappedModel, 'claude-opus-4-5-20251101[1m]', 'opus-4-5[1m] should map to claude-opus-4-5-20251101[1m]');\n334\t  assert.strictEqual(result.has1mSuffix, true, 'Should indicate 1m suffix');\n335\t});\n336\t\n337\ttest('mapModelToId handles opus-4-6', () => {\n338\t  const result = mapModelToId('opus-4-6');\n339\t  assert.strictEqual(result, 'claude-opus-4-6', 'mapModelToId should map opus-4-6 to claude-opus-4-6');\n340\t});\n341\t\n342\ttest('isOpus46OrLater returns true for opus-4-6', () => {\n343\t  assert.strictEqual(isOpus46OrLater('opus-4-6'), true, 'opus-4-6 should be identified as Opus 4.6+');\n344\t});\n345\t\n346\ttest('getMaxOutputTokensForModel returns opus46 max for opus-4-6', () => {\n347\t  assert.strictEqual(getMaxOutputTokensForModel('opus-4-6'), claudeCode.maxOutputTokensOpus46, 'opus-4-6 should have Opus 4.6 max output tokens');\n348\t});\n349\t\n350\t// ============================================================\n351\t// Section 11: Case Insensitivity Tests (Issue #1238)\n352\t// ============================================================\n353\tconsole.log('\\n=== 11. Case Insensitivity Tests (Issue #1238) ===');\n354\t\n355\ttest('validateModelName handles OPUS (uppercase)', () => {\n356\t  const result = validateModelName('OPUS', 'claude');\n357\t  assert(result.valid, `OPUS should be valid, got: ${result.message}`);\n358\t  assert.strictEqual(result.mappedModel, 'claude-opus-4-6', 'OPUS should map to claude-opus-4-6');\n359\t});\n360\t\n361\ttest('validateModelName handles OPUS[1M] (uppercase)', () => {\n362\t  const result = validateModelName('OPUS[1M]', 'claude');\n363\t  assert(result.valid, `OPUS[1M] should be valid, got: ${result.message}`);\n364\t  assert.strictEqual(result.mappedModel, 'claude-opus-4-6[1m]', 'OPUS[1M] should map to claude-opus-4-6[1m]');\n365\t});\n366\t\n367\t// ============================================================\n368\t// Summary\n369\t// ============================================================\n370\tconsole.log('\\n' + '='.repeat(50));\n371\tconsole.log(`Test Results: ${passed} passed, ${failed} failed`);\n372\tconsole.log('='.repeat(50));\n373\t\n374\tif (failed > 0) {\n375\t  console.log('\\nSome tests failed!');\n376\t  process.exit(1);\n377\t} else {\n378\t  console.log('\\nAll tests passed!');\n379\t  process.exit(0);\n380\t}\n381\t"
