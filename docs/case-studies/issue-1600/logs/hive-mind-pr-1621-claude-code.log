[2026-04-17T05:18:08.392Z] [INFO]         "content": "1\t#!/usr/bin/env node\n2\t// Test file for issue #1221: Claude Opus 4.6 model support\n3\t// Tests model aliases, [1m] suffix support, and backward compatibility\n4\t// Updated for Issue #1329: Sonnet 4.6 support (sonnet alias now maps to Sonnet 4.6)\n5\t\n6\timport assert from 'assert';\n7\t\n8\t// Import the model validation module\n9\tconst { CLAUDE_MODELS, MODELS_SUPPORTING_1M_CONTEXT, validateModelName, parseModelWith1mSuffix, supports1mContext, getAvailableModelNames, claudeModels } = await import('../src/models/index.mjs');\n10\tconst { mapModelToId, availableModels } = await import('../src/claude.lib.mjs');\n11\tconst { isOpus46OrLater, getMaxOutputTokensForModel, getDefaultMaxThinkingBudgetForModel, claudeCode, DEFAULT_MAX_THINKING_BUDGET, DEFAULT_MAX_THINKING_BUDGET_OPUS_46 } = await import('../src/config.lib.mjs');\n12\t\n13\tconsole.log('Testing Claude Opus 4.5/4.6 Model Support (Issue #1221, Issue #1238)\\n');\n14\t\n15\tlet passed = 0;\n16\tlet failed = 0;\n17\t\n18\tconst test = (name, fn) => {\n19\t  try {\n20\t    fn();\n21\t    console.log(`  ${name}`);\n22\t    passed++;\n23\t  } catch (error) {\n24\t    console.log(`  ${name}`);\n25\t    console.log(`   Error: ${error.message}`);\n26\t    failed++;\n27\t  }\n28\t};\n29\t\n30\t// ============================================================\n31\t// Section 1: Opus Default Model Tests (Issue #1433: opus -> Opus 4.6)\n32\t// ============================================================\n33\tconsole.log('\\n=== 1. Opus Default Model Tests (Issue #1433) ===');\n34\t\n35\ttest('opus alias maps to claude-opus-4-6 in CLAUDE_MODELS', () => {\n36\t  assert.strictEqual(CLAUDE_MODELS['opus'], 'claude-opus-4-6', 'opus should map to claude-opus-4-6');\n37\t});\n38\t\n39\ttest('opus alias maps to claude-opus-4-6 in availableModels (claude.lib.mjs)', () => {\n40\t  assert.strictEqual(availableModels['opus'], 'claude-opus-4-6', 'opus should map to claude-opus-4-6');\n41\t});\n42\t\n43\ttest('opus alias maps to claude-opus-4-6 in claudeModels (models/index.mjs)', () => {\n44\t  assert.strictEqual(claudeModels['opus'], 'claude-opus-4-6', 'opus should map to claude-opus-4-6');\n45\t});\n46\t\n47\ttest('validateModelName accepts opus and maps to claude-opus-4-6', () => {\n48\t  const result = validateModelName('opus', 'claude');\n49\t  assert(result.valid, `opus should be valid, got: ${result.message}`);\n50\t  assert.strictEqual(result.mappedModel, 'claude-opus-4-6', 'opus should map to claude-opus-4-6');\n51\t});\n52\t\n53\ttest('mapModelToId maps opus to claude-opus-4-6', () => {\n54\t  const result = mapModelToId('opus');\n55\t  assert.strictEqual(result, 'claude-opus-4-6', 'mapModelToId should map opus to claude-opus-4-6');\n56\t});\n57\t\n58\t// ============================================================\n59\t// Section 2: Direct Model ID Tests\n60\t// ============================================================\n61\tconsole.log('\\n=== 2. Direct Model ID Tests ===');\n62\t\n63\ttest('validateModelName accepts claude-opus-4-6 directly', () => {\n64\t  const result = validateModelName('claude-opus-4-6', 'claude');\n65\t  assert(result.valid, `claude-opus-4-6 should be valid, got: ${result.message}`);\n66\t  assert.strictEqual(result.mappedModel, 'claude-opus-4-6', 'Should map to itself');\n67\t});\n68\t\n69\ttest('mapModelToId passes through claude-opus-4-6 unchanged', () => {\n70\t  const result = mapModelToId('claude-opus-4-6');\n71\t  assert.strictEqual(result, 'claude-opus-4-6', 'Full model ID should pass through unchanged');\n72\t});\n73\t\n74\t// ============================================================\n75\t// Section 3: Backward Compatibility Tests\n76\t// ============================================================\n77\tconsole.log('\\n=== 3. Backward Compatibility Tests ===');\n78\t\n79\ttest('claude-opus-4-5 alias maps to claude-opus-4-5-20251101', () => {\n80\t  const result = validateModelName('claude-opus-4-5', 'claude');\n81\t  assert(result.valid, `claude-opus-4-5 should be valid, got: ${result.message}`);\n82\t  assert.strictEqual(result.mappedModel, 'claude-opus-4-5-20251101', 'claude-opus-4-5 should map to claude-opus-4-5-20251101');\n83\t});\n84\t\n85\ttest('claude-opus-4-5-20251101 (full ID) still works', () => {\n86\t  const result = validateModelName('claude-opus-4-5-20251101', 'claude');\n87\t  assert(result.valid, `claude-opus-4-5-20251101 should be valid, got: ${result.message}`);\n88\t  assert.strictEqual(result.mappedModel, 'claude-opus-4-5-20251101', 'Should map to itself');\n89\t});\n90\t\n91\ttest('sonnet alias still works (now maps to Sonnet 4.6, Issue #1329)', () => {\n92\t  const result = validateModelName('sonnet', 'claude');\n93\t  assert(result.valid, `sonnet should be valid, got: ${result.message}`);\n94\t  assert.strictEqual(result.mappedModel, 'claude-sonnet-4-6', 'sonnet should map to claude-sonnet-4-6');\n95\t});\n96\t\n97\ttest('haiku alias still works (regression test)', () => {\n98\t  const result = validateModelName('haiku', 'claude');\n99\t  assert(result.valid, `haiku should be valid, got: ${result.message}`);\n100\t  assert.strictEqual(result.mappedModel, 'claude-haiku-4-5-20251001', 'haiku should map correctly');\n101\t});\n102\t\n103\t// ============================================================\n104\t// Section 4: [1m] Suffix Parsing Tests\n105\t// ============================================================\n106\tconsole.log('\\n=== 4. [1m] Suffix Parsing Tests ===');\n107\t\n108\ttest('parseModelWith1mSuffix extracts base model and suffix for opus[1m]', () => {\n109\t  const result = parseModelWith1mSuffix('opus[1m]');\n110\t  assert.strictEqual(result.baseModel, 'opus', 'Base model should be opus');\n111\t  assert.strictEqual(result.has1mSuffix, true, 'Should have 1m suffix');\n112\t});\n113\t\n114\ttest('parseModelWith1mSuffix extracts base model and suffix for claude-opus-4-6[1m]', () => {\n115\t  const result = parseModelWith1mSuffix('claude-opus-4-6[1m]');\n116\t  assert.strictEqual(result.baseModel, 'claude-opus-4-6', 'Base model should be claude-opus-4-6');\n117\t  assert.strictEqual(result.has1mSuffix, true, 'Should have 1m suffix');\n118\t});\n119\t\n120\ttest('parseModelWith1mSuffix handles case-insensitive suffix [1M]', () => {\n121\t  const result = parseModelWith1mSuffix('opus[1M]');\n122\t  assert.strictEqual(result.baseModel, 'opus', 'Base model should be opus');\n123\t  assert.strictEqual(result.has1mSuffix, true, 'Should have 1m suffix');\n124\t});\n125\t\n126\ttest('parseModelWith1mSuffix returns no suffix for regular model', () => {\n127\t  const result = parseModelWith1mSuffix('opus');\n128\t  assert.strictEqual(result.baseModel, 'opus', 'Base model should be opus');\n129\t  assert.strictEqual(result.has1mSuffix, false, 'Should not have 1m suffix');\n130\t});\n131\t\n132\t// ============================================================\n133\t// Section 5: [1m] Suffix Validation Tests\n134\t// ============================================================\n135\tconsole.log('\\n=== 5. [1m] Suffix Validation Tests ===');\n136\t\n137\ttest('supports1mContext returns true for opus', () => {\n138\t  assert.strictEqual(supports1mContext('opus', 'claude'), true, 'opus should support 1M context');\n139\t});\n140\t\n141\ttest('supports1mContext returns true for claude-opus-4-6', () => {\n142\t  assert.strictEqual(supports1mContext('claude-opus-4-6', 'claude'), true, 'claude-opus-4-6 should support 1M context');\n143\t});\n144\t\n145\ttest('supports1mContext returns true for sonnet', () => {\n146\t  assert.strictEqual(supports1mContext('sonnet', 'claude'), true, 'sonnet should support 1M context');\n147\t});\n148\t\n149\ttest('supports1mContext returns false for haiku', () => {\n150\t  assert.strictEqual(supports1mContext('haiku', 'claude'), false, 'haiku should not support 1M context');\n151\t});\n152\t\n153\ttest('supports1mContext returns false for non-claude tools', () => {\n154\t  assert.strictEqual(supports1mContext('opus', 'opencode'), false, 'Non-claude tools should not support 1M context');\n155\t});\n156\t\n157\t// ============================================================\n158\t// Section 6: [1m] Suffix with validateModelName Tests\n159\t// ============================================================\n160\tconsole.log('\\n=== 6. [1m] Suffix with validateModelName Tests ===');\n161\t\n162\ttest('validateModelName accepts opus[1m] (now maps to Opus 4.6, Issue #1433)', () => {\n163\t  const result = validateModelName('opus[1m]', 'claude');\n164\t  assert(result.valid, `opus[1m] should be valid, got: ${result.message}`);\n165\t  assert.strictEqual(result.mappedModel, 'claude-opus-4-6[1m]', 'Should map to claude-opus-4-6[1m]');\n166\t  assert.strictEqual(result.has1mSuffix, true, 'Should indicate 1m suffix');\n167\t});\n168\t\n169\ttest('validateModelName accepts claude-opus-4-6[1m]', () => {\n170\t  const result = validateModelName('claude-opus-4-6[1m]', 'claude');\n171\t  assert(result.valid, `claude-opus-4-6[1m] should be valid, got: ${result.message}`);\n172\t  assert.strictEqual(result.mappedModel, 'claude-opus-4-6[1m]', 'Should map to claude-opus-4-6[1m]');\n173\t  assert.strictEqual(result.has1mSuffix, true, 'Should indicate 1m suffix');\n174\t});\n175\t\n176\ttest('validateModelName accepts sonnet[1m] (now maps to Sonnet 4.6, Issue #1329)', () => {\n177\t  const result = validateModelName('sonnet[1m]', 'claude');\n178\t  assert(result.valid, `sonnet[1m] should be valid, got: ${result.message}`);\n179\t  assert.strictEqual(result.mappedModel, 'claude-sonnet-4-6[1m]', 'Should map to claude-sonnet-4-6[1m]');\n180\t  assert.strictEqual(result.has1mSuffix, true, 'Should indicate 1m suffix');\n181\t});\n182\t\n183\ttest('validateModelName rejects haiku[1m] (unsupported)', () => {\n184\t  const result = validateModelName('haiku[1m]', 'claude');\n185\t  assert.strictEqual(result.valid, false, 'haiku[1m] should be invalid');\n186\t  assert(result.message.includes('does not support [1m]'), `Error should mention 1m not supported: ${result.message}`);\n187\t});\n188\t\n189\t// ============================================================\n190\t// Section 7: mapModelToId with [1m] Suffix Tests\n191\t// ============================================================\n192\tconsole.log('\\n=== 7. mapModelToId with [1m] Suffix Tests ===');\n193\t\n194\ttest('mapModelToId handles opus[1m] (now maps to Opus 4.6, Issue #1433)', () => {\n195\t  const result = mapModelToId('opus[1m]');\n196\t  assert.strictEqual(result, 'claude-opus-4-6[1m]', 'mapModelToId should handle opus[1m]');\n197\t});\n198\t\n199\ttest('mapModelToId handles claude-opus-4-6[1m]', () => {\n200\t  const result = mapModelToId('claude-opus-4-6[1m]');\n201\t  assert.strictEqual(result, 'claude-opus-4-6[1m]', 'mapModelToId should handle claude-opus-4-6[1m]');\n202\t});\n203\t\n204\ttest('mapModelToId handles sonnet[1m] (now maps to Sonnet 4.6, Issue #1329)', () => {\n205\t  const result = mapModelToId('sonnet[1m]');\n206\t  assert.strictEqual(result, 'claude-sonnet-4-6[1m]', 'mapModelToId should handle sonnet[1m]');\n207\t});\n208\t\n209\t// ============================================================\n210\t// Section 8: Opus 4.5/4.6 Max Output Tokens Tests (Issue #1238)\n211\t// ============================================================\n212\tconsole.log('\\n=== 8. Opus 4.5/4.6 Max Output Tokens Tests (Issue #1238) ===');\n213\t\n214\ttest('isOpus46OrLater returns true for opus (now maps to Opus 4.6, Issue #1433)', () => {\n215\t  assert.strictEqual(isOpus46OrLater('opus'), true, 'opus should be identified as Opus 4.6+ (now Opus 4.6)');\n216\t});\n217\t\n218\ttest('isOpus46OrLater returns true for claude-opus-4-6', () => {\n219\t  assert.strictEqual(isOpus46OrLater('claude-opus-4-6'), true, 'claude-opus-4-6 should be identified as Opus 4.6+');\n220\t});\n221\t\n222\ttest('isOpus46OrLater returns false for claude-opus-4-5-20251101', () => {\n223\t  assert.strictEqual(isOpus46OrLater('claude-opus-4-5-20251101'), false, 'claude-opus-4-5-20251101 should not be Opus 4.6+');\n224\t});\n225\t\n226\ttest('isOpus46OrLater returns false for sonnet', () => {\n227\t  assert.strictEqual(isOpus46OrLater('sonnet'), false, 'sonnet should not be Opus 4.6+');\n228\t});\n229\t\n230\ttest('getMaxOutputTokensForModel returns 128000 for opus (now Opus 4.6, Issue #1433)', () => {\n231\t  assert.strictEqual(getMaxOutputTokensForModel('opus'), claudeCode.maxOutputTokensOpus46, 'Opus 4.6 should have Opus 4.6 max output tokens');\n232\t});\n233\t\n234\ttest('getMaxOutputTokensForModel returns opus46 max for opus-4-6', () => {\n235\t  assert.strictEqual(getMaxOutputTokensForModel('opus-4-6'), claudeCode.maxOutputTokensOpus46, 'opus-4-6 should have Opus 4.6 max output tokens');\n236\t});\n237\t\n238\ttest('getMaxOutputTokensForModel returns opus46 max for claude-opus-4-6', () => {\n239\t  assert.strictEqual(getMaxOutputTokensForModel('claude-opus-4-6'), claudeCode.maxOutputTokensOpus46, 'claude-opus-4-6 should have Opus 4.6 max output tokens');\n240\t});\n241\t\n242\ttest('getMaxOutputTokensForModel returns default max for sonnet', () => {\n243\t  assert.strictEqual(getMaxOutputTokensForModel('sonnet'), claudeCode.maxOutputTokens, 'Sonnet should have default max output tokens');\n244\t});\n245\t\n246\t// ============================================================\n247\t// Section 9: Opus 4.5/4.6 Thinking Budget Tests (Issue #1238)\n248\t// ============================================================\n249\tconsole.log('\\n=== 9. Opus 4.5/4.6 Thinking Budget Tests (Issue #1238) ===');\n250\t\n251\ttest('DEFAULT_MAX_THINKING_BUDGET_OPUS_46 is 31999 (aligned with standard models, Issue #1238)', () => {\n252\t  assert.strictEqual(DEFAULT_MAX_THINKING_BUDGET_OPUS_46, 31999, 'Opus 4.6 default thinking budget should be 31999');\n253\t});\n254\t\n255\ttest('getDefaultMaxThinkingBudgetForModel returns 31999 for opus (now Opus 4.6, Issue 