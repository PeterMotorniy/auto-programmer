[2026-04-17T05:16:51.009Z] [INFO]         "content": "1\t#!/usr/bin/env node\n2\t// Test file for issue #1185: Agent model validation\n3\t// Tests that all free models are properly supported with --tool agent\n4\t\n5\timport assert from 'assert';\n6\t\n7\t// Import the model validation module\n8\tconst { AGENT_MODELS, validateModelName, getAvailableModelNames } = await import('../src/models/index.mjs');\n9\tconst { mapModelToId } = await import('../src/agent.lib.mjs');\n10\t\n11\tconsole.log('🧪 Testing Agent Model Validation (Issue #1185)\\n');\n12\t\n13\tlet passed = 0;\n14\tlet failed = 0;\n15\t\n16\tconst test = (name, fn) => {\n17\t  try {\n18\t    fn();\n19\t    console.log(`✅ ${name}`);\n20\t    passed++;\n21\t  } catch (error) {\n22\t    console.log(`❌ ${name}`);\n23\t    console.log(`   Error: ${error.message}`);\n24\t    failed++;\n25\t  }\n26\t};\n27\t\n28\t// Test 1: AGENT_MODELS should contain opencode/gpt-5-nano\n29\ttest('AGENT_MODELS contains opencode/gpt-5-nano as key', () => {\n30\t  assert('opencode/gpt-5-nano' in AGENT_MODELS, 'opencode/gpt-5-nano should be a valid key in AGENT_MODELS');\n31\t});\n32\t\n33\t// Test 2: AGENT_MODELS should map gpt-5-nano to opencode/gpt-5-nano\n34\ttest('gpt-5-nano short alias maps to opencode/gpt-5-nano', () => {\n35\t  assert.strictEqual(AGENT_MODELS['gpt-5-nano'], 'opencode/gpt-5-nano', 'gpt-5-nano should map to opencode/gpt-5-nano (not openai/gpt-5-nano)');\n36\t});\n37\t\n38\t// Test 3: AGENT_MODELS should NOT have openai/gpt-5-nano (agent uses OpenCode Zen, not direct OpenAI)\n39\ttest('AGENT_MODELS does not contain openai/gpt-5-nano (wrong provider)', () => {\n40\t  assert(!('openai/gpt-5-nano' in AGENT_MODELS), 'openai/gpt-5-nano should NOT be in AGENT_MODELS - agent uses OpenCode Zen');\n41\t});\n42\t\n43\t// Test 4: validateModelName should accept opencode/gpt-5-nano\n44\ttest('validateModelName accepts opencode/gpt-5-nano for agent tool', () => {\n45\t  const result = validateModelName('opencode/gpt-5-nano', 'agent');\n46\t  assert(result.valid, `opencode/gpt-5-nano should be valid for agent tool, got: ${result.message}`);\n47\t  assert.strictEqual(result.mappedModel, 'opencode/gpt-5-nano', 'Should map to opencode/gpt-5-nano');\n48\t});\n49\t\n50\t// Test 5: validateModelName should accept gpt-5-nano short alias\n51\ttest('validateModelName accepts gpt-5-nano short alias for agent tool', () => {\n52\t  const result = validateModelName('gpt-5-nano', 'agent');\n53\t  assert(result.valid, `gpt-5-nano should be valid for agent tool, got: ${result.message}`);\n54\t  assert.strictEqual(result.mappedModel, 'opencode/gpt-5-nano', 'gpt-5-nano should map to opencode/gpt-5-nano');\n55\t});\n56\t\n57\t// Test 6: AGENT_MODELS should contain opencode/big-pickle\n58\ttest('AGENT_MODELS contains opencode/big-pickle as key', () => {\n59\t  assert('opencode/big-pickle' in AGENT_MODELS, 'opencode/big-pickle should be a valid key in AGENT_MODELS');\n60\t});\n61\t\n62\t// Test 7: validateModelName should accept opencode/big-pickle\n63\ttest('validateModelName accepts opencode/big-pickle for agent tool', () => {\n64\t  const result = validateModelName('opencode/big-pickle', 'agent');\n65\t  assert(result.valid, `opencode/big-pickle should be valid for agent tool, got: ${result.message}`);\n66\t  assert.strictEqual(result.mappedModel, 'opencode/big-pickle', 'Should map to opencode/big-pickle');\n67\t});\n68\t\n69\t// Test 8: validateModelName should accept big-pickle short alias\n70\ttest('validateModelName accepts big-pickle short alias for agent tool', () => {\n71\t  const result = validateModelName('big-pickle', 'agent');\n72\t  assert(result.valid, `big-pickle should be valid for agent tool, got: ${result.message}`);\n73\t  assert.strictEqual(result.mappedModel, 'opencode/big-pickle', 'big-pickle should map to opencode/big-pickle');\n74\t});\n75\t\n76\t// Test 9: mapModelToId should map gpt-5-nano to opencode/gpt-5-nano\n77\ttest('mapModelToId maps gpt-5-nano to opencode/gpt-5-nano', () => {\n78\t  const result = mapModelToId('gpt-5-nano');\n79\t  assert.strictEqual(result, 'opencode/gpt-5-nano', 'mapModelToId should map gpt-5-nano to opencode/gpt-5-nano');\n80\t});"
