 ${result}`);\n385\t  assert.ok(result.includes('OpenAI'), `Expected OpenAI provider from pricingInfo but got: ${result}`);\n386\t});\n387\t\n388\t// ============================================================================\n389\t// Issue #1454: Multi-model display regression tests\n390\t// ============================================================================\n391\t\n392\tconsole.log('\\n📋 Issue #1454: Multi-model display Tests\\n');\n393\t\n394\ttest('buildModelInfoString shows \"Main model\" + \"Additional models\" for opus+haiku (Issue #1454)', () => {\n395\t  // This is the exact scenario from Issue #1454: Claude Code used both opus and haiku,\n396\t  // but only opus was displayed because session JSONL didn't contain haiku entries\n397\t  const result = buildModelInfoString({\n398\t    requestedModel: 'opus',\n399\t    tool: 'claude',\n400\t    modelsUsed: [\n401\t      { modelId: 'claude-opus-4-6', modelInfo: { name: 'Claude Opus 4.6', provider: 'Anthropic' } },\n402\t      { modelId: 'claude-haiku-4-5-20251001', modelInfo: { name: 'Claude Haiku 4.5', provider: 'Anthropic' } },\n403\t    ],\n404\t  });\n405\t  assert.ok(result.includes('### 🤖 **Models used:**'), `Expected header but got: ${result}`);\n406\t  assert.ok(result.includes('Tool: Anthropic Claude Code'), `Expected tool name but got: ${result}`);\n407\t  assert.ok(result.includes('Requested: `opus`'), `Expected requested model but got: ${result}`);\n408\t  assert.ok(result.includes('**Main model: Claude Opus 4.6**'), `Expected \"Main model\" label but got: ${result}`);\n409\t  assert.ok(result.includes('(`claude-opus-4-6`)'), `Expected opus ID but got: ${result}`);\n410\t  assert.ok(result.includes('**Additional models:**'), `Expected \"Additional models:\" but got: ${result}`);\n411\t  assert.ok(result.includes('**Claude Haiku 4.5**'), `Expected haiku in additional models but got: ${result}`);\n412\t  assert.ok(result.includes('(`claude-haiku-4-5-20251001`)'), `Expected haiku ID but got: ${result}`);\n413\t});\n414\t\n415\ttest('buildModelInfoString shows \"Model\" (not \"Main model\") for single model (Issue #1454)', () => {\n416\t  // When only one model is used, the label should be \"Model\" not \"Main model\"\n417\t  const result = buildModelInfoString({\n418\t    requestedModel: 'opus',\n419\t    tool: 'claude',\n420\t    modelsUsed: [{ modelId: 'claude-opus-4-6', modelInfo: { name: 'Claude Opus 4.6', provider: 'Anthropic' } }],\n421\t  });\n422\t  assert.ok(result.includes('**Model: Claude Opus 4.6**'), `Expected \"Model\" label but got: ${result}`);\n423\t  assert.ok(!result.includes('Main model'), `Should NOT have \"Main model\" for single model but got: ${result}`);\n424\t  assert.ok(!result.includes('Additional models'), `Should NOT have \"Additional models\" for single model but got: ${result}`);\n425\t});\n426\t\n427\ttest('buildModelInfoString handles three models correctly (Issue #1454)', () => {\n428\t  const result = buildModelInfoString({\n429\t    requestedModel: 'opus',\n430\t    tool: 'claude',\n431\t    modelsUsed: [\n432\t      { modelId: 'claude-opus-4-6', modelInfo: { name: 'Claude Opus 4.6', provider: 'Anthropic' } },\n433\t      { modelId: 'claude-haiku-4-5-20251001', modelInfo: { name: 'Claude Haiku 4.5', provider: 'Anthropic' } },\n434\t      { modelId: 'claude-sonnet-4-6', modelInfo: { name: 'Claude Sonnet 4.6', provider: 'Anthropic' } },\n435\t    ],\n436\t  });\n437\t  assert.ok(result.includes('**Main model: Claude Opus 4.6**'), `Expected main model but got: ${result}`);\n438\t  assert.ok(result.includes('**Additional models:**'), `Expected additional models section but got: ${result}`);\n439\t  assert.ok(result.includes('**Claude Haiku 4.5**'), `Expected haiku but got: ${result}`);\n440\t  assert.ok(result.includes('**Claude Sonnet 4.6**'), `Expected sonnet but got: ${result}`);\n441\t});\n442\t\n443\t// ============================================================================\n444\t// getModelInfoForComment - Async tests with mocked metadata\n445\t// ============================================================================\n446\t\n447\tconsole.log('\\n📋 getModelInfoForComment - Async Tests\\n');\n448\t\n449\tasync function asyncTest(name, fn) {\n450\t  try {\n451\t    await fn();\n452\t    console.log(`✅ ${name}`);\n453\t    testsPassed++;\n454\t  } catch (error) {\n455\t    console.log(`❌ ${name}`);\n456\t    console.log(`   Error: ${error.message}`);\n457\t    testsFailed++;\n458\t  }\n459\t}\n460\t\n461\t// Import getModelInfoForComment for async tests\n462\tconst { getModelInfoForComment } = await import('../src/models/index.mjs');\n463\t\n464\tawait asyncTest('getModelInfoForComment returns string (no crash)', async () => {\n465\t  const result = await getModelInfoForComment({ requestedModel: 'sonnet', tool: 'claude' });\n466\t  assert.equal(typeof result, 'string', `Expected string but got: ${typeof result}`);\n467\t});\n468\t\n469\tawait asyncTest('getModelInfoForComment with null inputs returns string', async () => {\n470\t  const result = await getModelInfoForComment({});\n471\t  assert.equal(typeof result, 'string', `Expected string but got: ${typeof result}`);\n472\t  assert.equal(result, '', 'Expected empty string for no inputs');\n473\t});\n474\t\n475\tawait asyncTest('getModelInfoForComment with agent tool and pricingInfo', async () => {\n476\t  const result = await getModelInfoForComment({\n477\t    requestedModel: 'grok',\n478\t    tool: 'agent',\n479\t    pricingInfo: { modelId: 'opencode/grok-code', modelName: 'grok-code' },\n480\t    actualModelIds: ['opencode/grok-code'],\n481\t  });\n482\t  assert.equal(typeof result, 'string', `Expected string but got: ${typeof result}`);\n483\t  assert.ok(result.includes('grok-code') || result.includes('opencode/grok-code'), `Expected grok model in output but got: ${result}`);\n484\t});\n485\t\n486\tawait asyncTest('getModelInfoForComment with codex tool and actual model IDs', async () => {\n487\t  const result = await getModelInfoForComment({\n488\t    requestedModel: 'gpt5',\n489\t    tool: 'codex',\n490\t    actualModelIds: ['gpt-5'],\n491\t  });\n492\t  assert.equal(typeof result, 'string', `Expected string but got: ${typeof result}`);\n493\t  assert.ok(result.includes('gpt-5') || result.includes('Codex'), `Expected codex/gpt model in output but got: ${result}`);\n494\t});\n495\t\n496\tawait asyncTest('getModelInfoForComment with opencode tool and actual model IDs', async () => {\n497\t  const result = await getModelInfoForComment({\n498\t    requestedModel: 'grok',\n499\t    tool: 'opencode',\n500\t    actualModelIds: ['opencode/grok-code'],\n501\t  });\n502\t  assert.equal(typeof result, 'string', `Expected string but got: ${typeof result}`);\n503\t  assert.ok(result.includes('OpenCode') || result.includes('grok'), `Expected opencode/grok in output but got: ${result}`);\n504\t});\n505\t\n506\tawait asyncTest('getModelInfoForComment with multiple actual models (main + supporting)', async () => {\n507\t  const result = await getModelInfoForComment({\n508\t    requestedModel: 'opus',\n509\t    tool: 'claude',\n510\t    actualModelIds: ['claude-opus-4-5-20251101', 'claude-haiku-4-5-20251001'],\n511\t  });\n512\t  assert.equal(typeof result, 'string', `Expected string but got: ${typeof result}`);\n513\t  assert.ok(result.includes('claude-opus'), `Expected opus model in output but got: ${result}`);\n514\t  assert.ok(result.includes('claude-haiku') || result.includes('Additional'), `Expected additional model in output but got: ${result}`);\n515\t});\n516\t\n517\tawait asyncTest('getModelInfoForComment pricingInfo model used when no actualModelIds', async () => {\n518\t  const result = await getModelInfoForComment({\n519\t    tool: 'agent',\n520\t    pricingInfo: { modelId: 'opencode/grok-code', modelName: 'grok-code', provider: 'OpenCode Zen' },\n521\t  });\n522\t  assert.equal(typeof result, 'string', `Expected string but got: ${typeof result}`);\n523\t  // pricingInfo.modelId should be used when no actualModelIds\n524\t  assert.ok(result.includes('grok'), `Expected grok model from pricingInfo but got: ${result}`);\n525\t});\n526\t\n527\tawait asyncTest('getModelInfoForComment falls back to resolved model when nothing else provided', async () => {\n528\t  const result = await getModelInfoForComment({\n529\t    requestedModel: 'sonnet',\n530\t    tool: 'claude',\n531\t  });\n532\t  assert.equal(typeof result, 'string', `Expected string but got: ${typeof result}`);\n533\t  // Should at minimum show the requested model\n534\t  assert.ok(result.includes('sonnet') || result.includes('claude-sonnet'), `Expected sonnet model in output but got: ${result}`);\n535\t});\n536\t\n537\t// ============================================================================\n538\t// Summary\n539\t// ============================================================================\n540\t\n541\tconsole.log('\\n' + '='.repeat(60));\n542\tconsole.log(`\\n📊 Results: ${testsPassed} passed, ${testsFailed} failed, ${testsPassed + testsFailed} total\\n`);\n543\t\n544\tif (testsFailed > 0) {\n545\t  process.exit(1);\n546\t}\n547\t"
