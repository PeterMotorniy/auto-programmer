.includes('Model: Claude Opus 4.6'), `Expected model name but got: ${result}`);\n230\t  assert.ok(result.includes('Anthropic'), `Expected provider but got: ${result}`);\n231\t  assert.ok(result.includes('2025-05'), `Expected knowledge cutoff but got: ${result}`);\n232\t});\n233\t\n234\ttest('buildModelInfoString falls back to pricingInfo when no modelsUsed or modelInfo', () => {\n235\t  const result = buildModelInfoString({\n236\t    pricingInfo: { modelId: 'opencode/grok-code', modelName: 'grok-code', provider: 'OpenCode Zen' },\n237\t  });\n238\t  assert.ok(result.includes('grok-code'), `Expected model name from pricingInfo but got: ${result}`);\n239\t  assert.ok(result.includes('OpenCode Zen'), `Expected provider from pricingInfo but got: ${result}`);\n240\t});\n241\t\n242\ttest('buildModelInfoString with modelsUsed with no metadata shows model ID', () => {\n243\t  const result = buildModelInfoString({\n244\t    requestedModel: 'opus',\n245\t    modelsUsed: [{ modelId: 'claude-opus-4-5-20251101', modelInfo: null }],\n246\t  });\n247\t  assert.ok(result.includes('claude-opus-4-5-20251101'), `Expected model ID but got: ${result}`);\n248\t});\n249\t\n250\t// ============================================================================\n251\t// resolveModelId - Per-tool coverage for all supported tools\n252\t// ============================================================================\n253\t\n254\tconsole.log('\\n📋 resolveModelId - All Tools Coverage\\n');\n255\t\n256\ttest('resolveModelId resolves \"opus\" for opencode tool', () => {\n257\t  const result = resolveModelId('opus', 'opencode');\n258\t  assert.ok(result.includes('claude') || result.includes('opus'), `Expected opus-related ID but got: ${result}`);\n259\t});\n260\t\n261\ttest('resolveModelId resolves \"gpt4\" for opencode tool', () => {\n262\t  const result = resolveModelId('gpt4', 'opencode');\n263\t  assert.equal(result, 'openai/gpt-4');\n264\t});\n265\t\n266\ttest('resolveModelId resolves \"gpt4o\" for opencode tool', () => {\n267\t  const result = resolveModelId('gpt4o', 'opencode');\n268\t  assert.equal(result, 'openai/gpt-4o');\n269\t});\n270\t\n271\ttest('resolveModelId resolves \"grok\" for opencode tool', () => {\n272\t  const result = resolveModelId('grok', 'opencode');\n273\t  assert.equal(result, 'opencode/grok-code');\n274\t});\n275\t\n276\ttest('resolveModelId resolves \"gpt-5.3-codex\" for codex tool', () => {\n277\t  const result = resolveModelId('gpt-5.3-codex', 'codex');\n278\t  assert.equal(result, 'gpt-5.3-codex');\n279\t});\n280\t\n281\ttest('resolveModelId resolves \"gpt4o\" for codex tool', () => {\n282\t  const result = resolveModelId('gpt4o', 'codex');\n283\t  assert.equal(result, 'gpt-4o');\n284\t});\n285\t\n286\ttest('resolveModelId resolves \"opus\" for codex tool', () => {\n287\t  const result = resolveModelId('opus', 'codex');\n288\t  assert.ok(result.includes('claude') || result.includes('opus'), `Expected opus-related ID but got: ${result}`);\n289\t});\n290\t\n291\ttest('resolveModelId resolves \"opus\" for agent tool', () => {\n292\t  const result = resolveModelId('opus', 'agent');\n293\t  assert.ok(result.includes('claude') || result.includes('opus'), `Expected opus-related ID but got: ${result}`);\n294\t});\n295\t\n296\ttest('resolveModelId resolves \"haiku\" for agent tool', () => {\n297\t  const result = resolveModelId('haiku', 'agent');\n298\t  assert.ok(result.includes('haiku'), `Expected haiku ID but got: ${result}`);\n299\t});\n300\t\n301\ttest('resolveModelId returns model as-is when not in map for agent tool', () => {\n302\t  const result = resolveModelId('custom-model-123', 'agent');\n303\t  assert.equal(result, 'custom-model-123');\n304\t});\n305\t\n306\t// ============================================================================\n307\t// buildModelInfoString - Per-tool coverage for all supported tools\n308\t// ============================================================================\n309\t\n310\tconsole.log('\\n📋 buildModelInfoString - All Tools Coverage\\n');\n311\t\n312\ttest('buildModelInfoString shows \"Codex\" tool name for codex', () => {\n313\t  const result = buildModelInfoString({\n314\t    tool: 'codex',\n315\t    requestedModel: 'gpt5',\n316\t    modelsUsed: [{ modelId: 'gpt-5', modelInfo: { name: 'GPT-5', provider: 'OpenAI' } }],\n317\t  });\n318\t  assert.ok(result.includes('Tool: OpenAI Codex'), `Expected \"Tool: OpenAI Codex\" but got: ${result}`);\n319\t  assert.ok(result.includes('**Model: GPT-5**'), `Expected bold model name but got: ${result}`);\n320\t  assert.ok(result.includes('(`gpt-5`)'), `Expected model ID in compact format but got: ${result}`);\n321\t});\n322\t\n323\ttest('buildModelInfoString shows \"OpenCode\" tool name for opencode', () => {\n324\t  const result = buildModelInfoString({\n325\t    tool: 'opencode',\n326\t    requestedModel: 'grok',\n327\t    modelsUsed: [{ modelId: 'opencode/grok-code', modelInfo: { name: 'Grok Code', provider: 'xAI' } }],\n328\t  });\n329\t  assert.ok(result.includes('Tool: OpenCode'), `Expected \"Tool: OpenCode\" but got: ${result}`);\n330\t  assert.ok(result.includes('Grok Code'), `Expected model name but got: ${result}`);\n331\t});\n332\t\n333\ttest('buildModelInfoString shows \"Agent\" tool name for agent', () => {\n334\t  const result = buildModelInfoString({\n335\t    tool: 'agent',\n336\t    requestedModel: 'grok',\n337\t    modelsUsed: [{ modelId: 'opencode/grok-code', modelInfo: { name: 'Grok Code', provider: 'OpenCode Zen' } }],\n338\t  });\n339\t  assert.ok(result.includes('Tool: Agent CLI'), `Expected \"Tool: Agent CLI\" but got: ${result}`);\n340\t});\n341\t\n342\ttest('buildModelInfoString shows warning for codex when actual model does not match requested', () => {\n343\t  const result = buildModelInfoString({\n344\t    tool: 'codex',\n345\t    requestedModel: 'gpt5',\n346\t    modelsUsed: [{ modelId: 'gpt-4o', modelInfo: { name: 'GPT-4o', provider: 'OpenAI' } }],\n347\t  });\n348\t  assert.ok(result