   ${cmd}\\n`);\n26\t};\n27\t/** Format numbers with spaces as thousands separator (no commas) */\n28\texport const formatNumber = num => {\n29\t  if (num === null || num === undefined) return 'N/A';\n30\t  const parts = num.toString().split('.');\n31\t  const integerPart = parts[0];\n32\t  const decimalPart = parts[1];\n33\t  const formattedInteger = integerPart.replace(/\\B(?=(\\d{3})+(?!\\d))/g, ' ');\n34\t  return decimalPart !== undefined ? `${formattedInteger}.${decimalPart}` : formattedInteger;\n35\t};\n36\t// Model mapping to translate aliases to full model IDs\n37\t// Supports [1m] suffix for 1 million token context (Issue #1221)\n38\texport const mapModelToId = model => {\n39\t  if (!model || typeof model !== 'string') return model;\n40\t  // Check for [1m] suffix (case-insensitive)\n41\t  const match = model.match(/^(.+?)\\[1m\\]$/i);\n42\t  if (match) {\n43\t    const baseModel = match[1];\n44\t    const mappedBase = availableModels[baseModel] || baseModel;\n45\t    return `${mappedBase}[1m]`;\n46\t  }\n47\t  return availableModels[model] || model;\n48\t};\n49\t// Function to validate Claude CLI connection with retry logic\n50\texport const validateClaudeConnection = async (model = 'haiku') => {\n51\t  // Map model alias to full ID\n52\t  const mappedModel = mapModelToId(model);\n53\t  const maxRetries = 3;\n54\t  const baseDelay = timeouts.retryBaseDelay;\n55\t  let retryCount = 0;\n56\t  const attemptValidation = async () => {\n57\t    try {\n58\t      if (retryCount === 0) {\n59\t        await log('🔍 Validating Claude CLI connection...');\n60\t      } else {\n61\t        await log(`🔄 Retry attempt ${retryCount}/${maxRetries} for Claude CLI validation...`);\n62\t      }\n63\t      try {\n64\t        const versionResult = await $`timeout ${Math.floor(timeouts.claudeCli / 6000)} claude --version`;\n65\t        if (versionResult.code === 0) {\n66\t          const version = versionResult.stdout?.toString().trim();\n67\t          detectedClaudeVersion = version; // issue #1146\n68\t          if (retryCount === 0) {\n69\t            await log(`📦 Claude CLI version: ${version}`);\n70\t          }\n71\t        }\n72\t      } catch (versionError) {\n73\t        // Version check failed, but we'll continue with the main validation\n74\t        if (retryCount === 0) {\n75\t          await log(`⚠️  Claude CLI version check failed (${versionError.code}), proceeding with connection test...`);\n76\t        }\n77\t      }\n78\t      let result;\n79\t      try {\n80\t        // Primary validation: use printf piping with specified model\n81\t        result = await $`printf hi | claude --model ${mappedModel} -p`;\n82\t      } catch (pipeError) {\n83\t        await log(`⚠️  Pipe validation failed (${pipeError.code}), trying timeout approach...`);\n84\t        try {\n85\t          result = await $`timeout ${Math.floor(timeouts.claudeCli / 1000)} claude --model ${mappedModel} -p hi`;\n86\t        } catch (timeoutError) {\n87\t          if (timeoutError.code === 124) {\n88\t            await log(`❌ Claude CLI timed out after ${Math.floor(timeouts.claudeCli / 1000)} seconds`, {\n89\t              level: 'error',\n90\t            });\n91\t            await log('   💡 This may indicate Claude CLI is taking too long to respond', { level: 'error' });\n92\t            await log(`   💡 Try running 'claude --model ${mappedModel} -p hi' manually to verify it works`, {\n93\t              level: 'error',\n94\t            });\n95\t            return false;\n96\t          }\n97\t          throw timeoutError;\n98\t        }\n99\t      }\n100\t      const stdout = result.stdout?.toString() || '';"
