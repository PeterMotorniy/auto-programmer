[2026-04-17T05:16:41.697Z] [INFO]         "content": "447\t};\n448\t\n449\t// Function to create yargs configuration - avoids duplication\n450\texport const createYargsConfig = yargsInstance => {\n451\t  let config = yargsInstance\n452\t    .usage('Usage: solve.mjs <issue-url> [options]')\n453\t    .command('$0 <issue-url>', 'Solve a GitHub issue or pull request', yargs => {\n454\t      yargs.positional('issue-url', {\n455\t        type: 'string',\n456\t        description: 'The GitHub issue URL to solve',\n457\t      });\n458\t    })\n459\t    .fail((msg, err) => {\n460\t      // Custom fail handler to suppress yargs error output\n461\t      // Errors will be handled in the parseArguments catch block\n462\t      if (err) throw err; // Rethrow actual errors\n463\t      // For validation errors, throw a clean error object with the message\n464\t      const error = new Error(msg);\n465\t      error.name = 'YargsValidationError';\n466\t      throw error;\n467\t    });\n468\t\n469\t  // Register all options from the definitions map\n470\t  for (const [name, def] of Object.entries(SOLVE_OPTION_DEFINITIONS)) {\n471\t    config = config.option(name, def);\n472\t  }\n473\t\n474\t  // 'model' has a dynamic default function, so it's defined inline (not in SOLVE_OPTION_DEFINITIONS)\n475\t  config = config\n476\t    .option('model', {\n477\t      type: 'string',\n478\t      description: buildModelOptionDescription(),\n479\t      alias: ['m', 'worker-model'],\n480\t      default: currentParsedArgs => {\n481\t        // Dynamic default based on tool selection (Issue #1473: centralized in models/index.mjs)\n482\t        return defaultModels[currentParsedArgs?.tool] || defaultModels.claude;\n483\t      },\n484\t    })\n485\t    .parserConfiguration({\n486\t      'boolean-negation': true,\n487\t    })\n488\t    // Use yargs built-in strict mode to reject unrecognized options\n489\t    // This prevents issues like #453 and #482 where unknown options are silently ignored\n490\t    .strict()\n491\t    .help('h')\n492\t    .alias('h', 'help');\n493\t\n494\t  return config;\n495\t};\n496\t\n497\t// Parse command line arguments - now needs yargs and hideBin passed in\n498\texport const parseArguments = async (yargs, hideBin) => {\n499\t  const rawArgs = hideBin(process.argv);\n500\t\n501\t  // Issue #1092: Detect malformed flag patterns BEFORE yargs parsing\n502\t  // This catches cases like \"-- model\" which yargs silently treats as positional arguments\n503\t  const malformedResult = detectMalformedFlags(rawArgs);\n504\t  if (malformedResult.malformed.length > 0) {\n505\t    const error = new Error(malformedResult.errors.join('\\n'));\n506\t    error.name = 'MalformedArgumentError';\n507\t    throw error;\n508\t  }\n509\t\n510\t  // Use .parse() instead of .argv to ensure .strict() mode works correctly\n511\t  // When you call yargs(args) and use .argv, strict mode doesn't trigger\n512\t  // See: https://github.com/yargs/yargs/issues - .strict() only works with .parse()\n513\t\n514\t  let argv;\n515\t  let yargsInstance;\n516\t  try {\n517\t    // Suppress stderr output from yargs during parsing to prevent validation errors from appearing\n518\t    // This prevents \"YError: Not enough arguments\" from polluting stderr (issue #583)\n519\t    // Save the original stderr.write\n520\t    const originalStderrWrite = process.stderr.write;\n521\t    const stderrBuffer = [];\n522\t\n523\t    // Temporarily override stderr.write to capture output\n524\t    process.stderr.write = function (chunk, encoding, callback) {\n525\t      stderrBuffer.push(chunk.toString());\n526\t      // Call the callback if provided (for compatibility)\n527\t      if (typeof encoding === 'function') {\n528\t        encoding();\n529\t      } else if (typeof callback === 'function') {\n530\t        callback();\n531\t      }\n532\t      return true;\n533\t    };\n534\t\n535\t    try {\n536\t      yargsInstance = createYargsConfig(yargs());\n537\t      argv = await yargsInstance.parse(rawArgs);\n538\t    } finally {\n539\t      // Always restore stderr.write\n540\t      process.stderr.write = originalStderrWrite;\n541\t\n542\t      // In verbose mode, show what was captured from stderr (for debugging)\n543\t      if (global.verboseMode && stderrBuffer.length > 0) {\n544\t        const captured = stderrBuffer.join('');\n545\t        if (captured.trim()) {\n546\t          console.error('[Suppressed yargs stderr]:', captured);\n547\t        }\n548\t      }\n549\t    }\n550\t  } catch (error) {\n551\t    // Yargs throws errors for validation issues\n552\t    // If the error is about unknown arguments (strict mode), enhance it with suggestions\n553\t    // Check if this error has already been enhanced to avoid re-processing\n554\t    if (error.message && /Unknown argument/.test(error.message) && !error._enhanced) {\n555\t      try {\n556\t        // Enhance the error message with helpful suggestions\n557\t        // Use the yargsInstance we already created, or create a new one if needed\n558\t        const yargsWithConfig = yargsInstance || createYargsConfig(yargs());\n559\t        const enhancedMessage = enhanceErrorMessage(error.message, yargsWithConfig);\n560\t        const enhancedError = new Error(enhancedMessage);\n561\t        enhancedError.name = error.name;\n562\t        enhancedError._enhanced = true; // Mark as enhanced to prevent re-processing\n563\t        throw enhancedError;\n564\t      } catch (enhanceErr) {\n565\t        // If enhancing fails, just throw the original error\n566\t        if (global.verboseMode) {\n567\t          console.error('[VERBOSE] Failed to enhance error message:', enhanceErr.message);\n568\t        }\n569\t        // If the enhance error itself is already enhanced, throw it\n570\t        if (enhanceErr._enhanced) {\n571\t          throw enhanceErr;\n572\t        }\n573\t        throw error;\n574\t      }\n575\t    }\n576\t    // For other validation errors, show a warning in verbose mode\n577\t    if (error.message && global.verboseMode) {\n578\t      console.error('Yargs parsing warning:', error.message);\n579\t    }\n580\t    // Try to get the argv even with the error\n581\t    argv = error.argv || {};\n582\t  }\n583\t\n584\t  // Post-processing: Fix model default for opencode and codex tools\n585\t  // Yargs doesn't properly handle dynamic defaults based on other arguments,\n586\t  // so we need to handle this manually after parsing\n587\t  const modelExplicitlyProvided = rawArgs.includes('--model') || rawArgs.includes('-m') || rawArgs.includes('--worker-model');\n588\t  const planModelExplicitlyProvided = rawArgs.includes('--plan-model');\n589\t\n590\t  // --plan flag expansion (Issue #1223)\n591\t  // When --plan is set, it acts as a shortcut for --plan-model opus --worker-model sonnet\n592\t  // Explicit --plan-model and --model/--worker-model values take precedence\n593\t  if (argv && argv.plan) {\n594\t    if (!planModelExplicitlyProvided) {\n595\t      argv.planModel = 'opus';\n596\t    }\n597\t    if (!modelExplicitlyProvided) {\n598\t      argv.model = 'sonnet';\n599\t    }\n600\t  }\n601\t\n602\t  // Normalize alias flags: legacy --skip-tool-check and --skip-claude-check behave like --skip-tool-connection-check\n603\t  if (argv) {\n604\t    // Support deprecated flags\n605\t    if (argv.skipToolCheck || argv.skipClaudeCheck) {\n606\t      argv.skipToolConnectionCheck = true;\n607\t    }\n608\t    // Support negated deprecated flag: --no-tool-check becomes --no-tool-connection-check\n609\t    if (argv.toolCheck === false) {\n610\t      argv.toolConnectionCheck = false;\n611\t    }\n612\t  }\n613\t\n614\t  // --finalize normalization\n615\t  // Issue #1383: When finalize is enabled (as boolean or number), normalize to iteration count\n616\t  // NOTE: promptEnsureAllRequirementsAreMet is NOT set here — it is only enabled during\n617\t  // the finalize cycle iterations themselves (not the first regular worker model run)\n618\t  if (argv && argv.finalize) {\n619\t    // Normalize: if passed as boolean true (flag without value), treat as 1 iteration\n620\t    if (argv.finalize === true) {\n621\t      argv.finalize = 1;\n622\t    }\n623\t  }\n624\t\n625\t  // --working-session-live-progress normalization\n626\t  // When passed as --working-session-live-progress (no value), yargs gives true for string type\n627\t  // Normalize: true → \"comment\", validate known values\n628\t  if (argv && argv.workingSessionLiveProgress) {\n629\t    const val = argv.workingSessionLiveProgress;\n630\t    if (val === true || val === 'true') {\n631\t      argv.workingSessionLiveProgress = 'comment';\n632\t    } else if (typeof val === 'string' && !['comment', 'pr'].includes(val.toLowerCase())) {\n633\t      throw new Error(`Invalid --working-session-live-progress value: \"${val}\". Expected \"comment\" or \"pr\".`);\n634\t    } else if (typeof val === 'string') {\n635\t      argv.workingSessionLiveProgress = val.toLowerCase();\n636\t    }\n637\t  }\n638\t\n639\t  // Validate --base-branch value (issue #1482: reject URLs and invalid git branch names)\n640\t  if (argv.baseBranch) {\n641\t    const branchValidation = validateBranchName(argv.baseBranch);\n642\t    if (!branchValidation.valid) {\n643\t      throw new Error(`Invalid --base-branch value: ${branchValidation.reason}`);\n644\t    }\n645\t  }\n646\t"
