[2026-04-17T05:16:51.396Z] [INFO]         "content": "1\t#!/usr/bin/env node\n2\t\n3\t/**\n4\t * Central configuration module for all configurable values\n5\t * Provides environment variable overrides with sensible defaults\n6\t */\n7\t\n8\t// Use use-m to dynamically import modules\n9\tif (typeof globalThis.use === 'undefined') {\n10\t  try {\n11\t    globalThis.use = (await eval(await (await fetch('https://unpkg.com/use-m/use.js')).text())).use;\n12\t  } catch (error) {\n13\t    console.error('❌ Fatal error: Failed to load dependencies for configuration');\n14\t    console.error(`   ${error.message}`);\n15\t    console.error('   This might be due to network issues or missing dependencies.');\n16\t    console.error('   Please check your internet connection and try again.');\n17\t    process.exit(1);\n18\t  }\n19\t}\n20\t\n21\tconst getenvModule = await use('getenv');\n22\t// Node 24 CJS/ESM interop may return the whole module object instead of the function directly\n23\tconst getenv = typeof getenvModule === 'function' ? getenvModule : getenvModule.default || getenvModule;\n24\t\n25\t// Use semver package for version comparison (see issue #1146)\n26\timport semver from 'semver';\n27\t\n28\t// Import lino for parsing Links Notation format\n29\tconst { lino } = await import('./lino.lib.mjs');\n30\t\n31\t// Helper function to safely parse integers with fallback\n32\tconst parseIntWithDefault = (envVar, defaultValue) => {\n33\t  const value = getenv(envVar, defaultValue.toString());\n34\t  const parsed = parseInt(value);\n35\t  return isNaN(parsed) ? defaultValue : parsed;\n36\t};\n37\t\n38\t// Helper function to safely parse floats with fallback\n39\tconst parseFloatWithDefault = (envVar, defaultValue) => {\n40\t  const value = getenv(envVar, defaultValue.toString());\n41\t  const parsed = parseFloat(value);\n42\t  return isNaN(parsed) ? defaultValue : parsed;\n43\t};\n44\t\n45\t// Timeout configurations (in milliseconds)\n46\texport const timeouts = {\n47\t  claudeCli: parseIntWithDefault('HIVE_MIND_CLAUDE_TIMEOUT_SECONDS', 60) * 1000,\n48\t  opencodeCli: parseIntWithDefault('HIVE_MIND_OPENCODE_TIMEOUT_SECONDS', 60) * 1000,\n49\t  codexCli: parseIntWithDefault('HIVE_MIND_CODEX_TIMEOUT_SECONDS', 60) * 1000,\n50\t  githubApiDelay: parseIntWithDefault('HIVE_MIND_GITHUB_API_DELAY_MS', 5000),\n51\t  githubRepoDelay: parseIntWithDefault('HIVE_MIND_GITHUB_REPO_DELAY_MS', 2000),\n52\t  retryBaseDelay: parseIntWithDefault('HIVE_MIND_RETRY_BASE_DELAY_MS', 5000),\n53\t  retryBackoffDelay: parseIntWithDefault('HIVE_MIND_RETRY_BACKOFF_DELAY_MS', 1000),\n54\t  // Issue #1280: Timeout (ms) to wait for stream close after result event before force-killing\n55\t  // command-stream's stream() waits for process exit + pipe close; if stdout stays open, it hangs\n56\t  resultStreamCloseMs: parseIntWithDefault('HIVE_MIND_RESULT_STREAM_CLOSE_MS', 30000),\n57\t  // Issue #1472/#1475: Timeout (ms) to wait for first stream output from Claude CLI after startup.\n58\t  // If no stdout/stderr output is received within this period, the process is considered stuck\n59\t  // and will be force-killed. Both affected sessions showed ~4.5h with zero output from Claude CLI.\n60\t  // Default: 120000ms (2 minutes) — Claude CLI normally emits system.init within 1-3 seconds.\n61\t  streamStartupMs: parseIntWithDefault('HIVE_MIND_STREAM_STARTUP_MS', 120000),\n62\t  // Issue #1472: Activity timeout (ms) — if no new stream output is received for this duration\n63\t  // after at least one event was received, the process is considered hung mid-session.\n64\t  // This catches the case where Claude CLI starts producing output but then stops (e.g., the\n65\t  // original Issue #1472 where CLI was stuck for 4.5h with all output arriving only at CTRL+C).\n66\t  // Issue #1510: Increased from 300000ms (5 min) to 3600000ms (1 hour) because Claude Code can\n67\t  // legitimately wait for long-running operations (docker builds, CI polls, large compilations).\n68\t  // The 5-minute timeout was force-killing sessions during `sleep 300 && gh run view ...` commands.\n69\t  // Default: 3600000ms (1 hour). Set to 0 to disable. Configurable via environment variable.\n70\t  streamActivityMs: parseIntWithDefault('HIVE_MIND_STREAM_ACTIVITY_MS', 3600000),\n71\t};\n72\t\n73\t// Auto-continue configurations\n74\texport const autoContinue = {\n75\t  ageThresholdHours: parseIntWithDefault('HIVE_MIND_AUTO_CONTINUE_AGE_HOURS', 24),\n76\t};\n77\t\n78\t// Auto-resume on limit reset configurations\n79\t// See: https://github.com/link-assistant/hive-mind/issues/1152\n80\t// See: https://github.com/link-assistant/hive-mind/issues/1236\n81\texport const limitReset = {\n82\t  // Buffer time to wait after limit reset (in milliseconds)\n83\t  // Default: 10 minutes - accounts for server time differences and API propagation delays\n84\t  // Increased from 5 to 10 minutes to reduce risk of hitting limits again immediately\n85\t  // See: https://github.com/link-assistant/hive-mind/issues/1236\n86\t  bufferMs: parseIntWithDefault('HIVE_MIND_LIMIT_RESET_BUFFER_MS', 10 * 60 * 1000),\n87\t  // Random jitter added to buffer to avoid thundering herd problem (in milliseconds)\n88\t  // When multiple instances wait for the same limit reset, jitter distributes their\n89\t  // resume times to reduce simultaneous API load\n90\t  // Default: 5 minutes (0 to 5 minutes random) - total wait after reset: 10-15 minutes\n91\t  // See: https://github.com/link-assistant/hive-mind/issues/1236\n92\t  jitterMs: parseIntWithDefault('HIVE_MIND_LIMIT_RESET_JITTER_MS', 5 * 60 * 1000),\n93\t};\n94\t\n95\t// GitHub API limits\n96\texport const githubLimits = {\n97\t  commentMaxSize: parseIntWithDefault('HIVE_MIND_GITHUB_COMMENT_MAX_SIZE', 65536),\n98\t  fileMaxSize: parseIntWithDefault('HIVE_MIND_GITHUB_FILE_MAX_SIZE', 25 * 1024 * 1024),\n99\t  issueBodyMaxSize: parseIntWithDefault('HIVE_MIND_GITHUB_ISSUE_BODY_MAX_SIZE', 60000),\n100\t  attachmentMaxSize: parseIntWithDefault('HIVE_MIND_GITHUB_ATTACH