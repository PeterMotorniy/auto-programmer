[2026-04-17T05:16:38.783Z] [INFO]         "content": "150\t    choices: ['new', 'resume', 'auto-resume', 'auto-restart'],\n151\t    default: 'new',\n152\t    hidden: true,\n153\t  },\n154\t  'auto-resume-on-errors': {\n155\t    type: 'boolean',\n156\t    description: 'Automatically resume on network errors (503, etc.) with exponential backoff',\n157\t    default: false,\n158\t  },\n159\t  'auto-continue-only-on-new-comments': {\n160\t    type: 'boolean',\n161\t    description: 'Explicitly fail on absence of new comments in auto-continue or continue mode',\n162\t    default: false,\n163\t  },\n164\t  'auto-commit-uncommitted-changes': {\n165\t    type: 'boolean',\n166\t    description: 'Automatically commit and push uncommitted changes made by Claude (disabled by default)',\n167\t    default: false,\n168\t  },\n169\t  'auto-restart-on-uncommitted-changes': {\n170\t    type: 'boolean',\n171\t    description: 'Automatically restart when uncommitted changes are detected to allow the tool to handle them (default: true, use --no-auto-restart-on-uncommitted-changes to disable)',\n172\t    default: true,\n173\t  },\n174\t  'auto-restart-max-iterations': {\n175\t    type: 'number',\n176\t    description: 'Maximum number of auto-restart iterations when uncommitted changes are detected (default: 3)',\n177\t    default: 3,\n178\t  },\n179\t  'auto-merge': {\n180\t    type: 'boolean',\n181\t    description: 'Automatically merge the pull request when the working session is finished and all CI/CD statuses pass and PR is mergeable. Implies --auto-restart-until-mergeable.',\n182\t    default: false,\n183\t  },\n184\t  'auto-restart-until-mergeable': {\n185\t    type: 'boolean',\n186\t    description: 'Auto-restart until PR becomes mergeable (no iteration limit). Restarts on new comments from non-bot users, CI failures, merge conflicts, or other issues. Does NOT auto-merge.',\n187\t    default: true,\n188\t  },\n189\t  'wait-for-all-actions-in-repository-before-mergeable': {\n190\t    type: 'boolean',\n191\t    description: 'Wait for ALL active GitHub Actions workflow runs in the entire repository to complete before declaring PR mergeable. When enabled, blocks merge if ANY CI/CD run in the repository is active, regardless of branch — this is a strict safety mode for repositories with cross-branch CI/CD coupling. Disabled by default.',\n192\t    default: false,\n193\t  },\n194\t  'wait-for-all-actions-in-repository-before-mergable': {\n195\t    type: 'boolean',\n196\t    description: 'Deprecated alias for --wait-for-all-actions-in-repository-before-mergeable (fixes typo).',\n197\t    hidden: true,\n198\t  },\n199\t  'auto-restart-on-non-updated-pull-request-description': {\n200\t    type: 'boolean',\n201\t    description: 'Automatically restart if PR title or description still contains auto-generated placeholder text after agent execution. Restarts with a hint about what was not updated.',\n202\t    default: false,\n203\t  },\n204\t  'continue-only-on-feedback': {\n205\t    type: 'boolean',\n206\t    description: 'Only continue if feedback is detected (works only with pull request link or issue link with --auto-continue)',\n207\t    default: false,\n208\t  },\n209\t  watch: {\n210\t    type: 'boolean',\n211\t    description: 'Monitor continuously for feedback and auto-restart when detected (stops when PR is merged)',\n212\t    alias: 'w',\n213\t    default: false,\n214\t  },\n215\t  'watch-interval': {\n216\t    type: 'number',\n217\t    description: 'Interval in seconds for checking feedback in watch mode (default: 60)',\n218\t    default: 60,\n219\t  },\n220\t  'min-disk-space': {\n221\t    type: 'number',\n222\t    description: 'Minimum required disk space in MB (default: 2048)',\n223\t    default: 2048,\n224\t  },\n225\t  'log-dir': {\n226\t    type: 'string',\n227\t    description: 'Directory to save log files (defaults to current working directory)',\n228\t    alias: 'l',\n229\t  },\n230\t  think: {\n231\t    type: 'string',\n232\t    description: 'Thinking level hint. For Claude, translated to --thinking-budget for Claude Code >= 2.1.12 (off=0, low=~8000, medium=~16000, high=~24000, max=31999). For Codex, mapped to reasoning effort (off=none, low=low, medium=medium, high=high, max=xhigh).',\n233\t    choices: ['off', 'low', 'medium', 'high', 'max'],\n234\t    default: undefined,\n235\t  },\n236\t  'thinking-budget': {\n237\t    type: 'number',\n238\t    description: 'Thinking token budget. For Claude Code, controls MAX_THINKING_TOKENS (0-31999 by default). For Codex, enables finer reasoning-effort mapping including minimal/low/medium/high/xhigh.',\n239\t    default: undefined,\n240\t  },\n241\t  'thinking-budget-claude-minimum-version': {\n242\t    type: 'string',\n243\t    description: 'Minimum Claude Code version that supports --thinking-budget (MAX_THINKING_TOKENS env var). Versions below this use thinking keywords instead.',\n244\t    default: '2.1.12',\n245\t  },\n246\t  'max-thinking-budget': {\n247\t    type: 'number',\n248\t    description: 'Maximum thinking budget for calculating --think level mappings (default: 31999 for Claude Code). Values: off=0, low=max/4, medium=max/2, high=max*3/4, max=max.',\n249\t    default: 31999,\n250\t  },\n251\t  'prompt-plan-sub-agent': {\n252\t    type: 'boolean',\n253\t    description: 'Encourage AI to use a planning sub-agent or planning workflow for initial planning. Supported for --tool claude and --tool codex.',\n254\t    default: false,\n255\t  },\n256\t  'base-branch': {\n257\t    type: 'string',\n258\t    description: 'Target branch for the pull request (defaults to repository default branch)',\n259\t    alias: 'b',\n260\t  },\n261\t  sentry: {\n262\t    type: 'boolean',\n263\t    description: 'Enable Sentry error tracking and monitoring (disabled by default for privacy; use --sentry to enable)',\n264\t    default: false,\n265\t  },\n266\t  'auto-cleanup': {\n267\t    type: 'boolean',\n268\t    description: 'Automatically delete temporary working directory on completion (error, success, or CTRL+C). Default: true for private repos, false for public repos. Use explicit flag to override.',\n269\t    default: undefined,\n270\t  },\n271\t  'auto-merge-default-branch-to-pull-request-branch': {\n272\t    type: 'boolean',\n273\t    description: 'Automatically merge the default branch to the pull request branch when continuing work (only in continue mode)',\n274\t    default: false,\n275\t  },\n276\t  'allow-fork-divergence-resolution-using-force-push-with-lease': {\n277\t    type: 'boolean',\n278\t    description: 'Allow automatic force-push (--force-with-lease) when fork diverges from upstream (DANGEROUS: can overwrite fork history)',\n279\t    default: false,\n280\t  },\n281\t  'allow-force-non-fork-repository-deletion': {\n282\t    type: 'boolean',\n283\t    description: 'Allow deletion of non-fork repositories even when they contain additional commits that would be lost (DANGEROUS: data loss possible)',\n284\t    default: false,\n285\t  },\n286\t  'allow-to-push-to-contributors-pull-requests-as-maintainer': {\n287\t    type: 'boolean',\n288\t    description: 'When continuing a fork PR as a maintainer, attempt to push directly to the contributor\\'s fork if \"Allow edits by maintainers\" is enabled. Requires --auto-fork to be enabled.',\n289\t    default: false,\n290\t  },\n291\t  'prefix-fork-name-with-owner-name': {\n292\t    type: 'boolean',\n293\t    description: 'Prefix fork name with original owner name (e.g., \"owner-repo\" instead of \"repo\"). Useful when forking repositories with same name from different owners.',\n294\t    default: true,\n295\t  },\n296\t  tool: {\n297\t    type: 'string',\n298\t    description: 'AI tool to use for solving issues',\n299\t    choices: ['claude', 'opencode', 'codex', 'agent'],\n300\t    default: 'claude',\n301\t  },\n302\t  plan: {\n303\t    type: 'boolean',\n304\t    description: 'Enable plan mode: uses opus for planning, sonnet for execution (shortcut for --plan-model opus --worker-model sonnet). Only works with --tool claude.',\n305\t    default: false,\n306\t  },\n307\t  'plan-model': {\n308\t    type: 'string',\n309\t    description: 'Model to use for plan mode (e.g., opus). When specified, auto-switches to opusplan mode and sets ANTHROPIC_DEFAULT_OPUS_MODEL. Use with --model/--worker-model to set separate plan and execution models (e.g., --plan-model opus --model sonnet). Only works with --tool claude.',\n310\t    default: undefined,\n311\t  },\n312\t  'worker-model': {\n313\t    type: 'string',\n314\t    description: 'Alias for --model: Model to use for execution/worker mode when --plan-model is specified. When used with --plan-model, sets ANTHROPIC_DEFAULT_SONNET_MODEL for Claude Code opusplan mode.',\n315\t    default: undefined,\n316\t  },\n317\t  'execute-tool-with-bun': {\n318\t    type: 'boolean',\n319\t    description: 'Execute the AI tool using bunx (experimental, may improve speed and memory usage)',\n320\t    default: false,\n321\t  },\n322\t  'enable-workspaces': {\n323\t    type: 'boolean',\n324\t    description: 'Use separate workspace directory structure with repository/ and tmp/ folders. Works with all tools (claude, opencode, codex, agent). Experimental feature.',\n325\t    default: false,\n326\t  },\n327\t  'interactive-mode': {\n328\t    type: 'boolean',\n329\t    description: '[EXPERIMENTAL] Post tool output as PR comments in real-time. Supported for --tool claude and --tool codex.',\n330\t    default: false,\n331\t  },\n332\t  'prompt-explore-sub-agent': {\n333\t    type: 'boolean',\n334\t    description: 'Encourage AI to use Explore-style sub-agent workflow for codebase exploration. Supported for --tool claude and --tool codex.',\n335\t    default: false,\n336\t  },\n337\t  'prompt-general-purpose-sub-agent': {\n338\t    type: 'boolean',\n339\t    description: 'Prompt AI to use general-purpose sub agents for processing large tasks with multiple files/folders. Supported for --tool claude and --tool codex.',\n340\t    default: false,\n341\t  },\n342\t  'tokens-budget-stats': {\n343\t    type: 'boolean',\n344\t    description: '[EXPERIMENTAL] Show detailed token budget statistics including context window usage and ratios. Supported for --tool claude, --tool codex, and any tool that returns detailed token usage.',\n345\t    default: false,\n346\t  },\n347\t  'prompt-issue-reporting': {\n348\t    type: 'boolean',\n349\t    description: 'Enable automatic issue creation for spotted bugs/errors not related to main task. Issues will include reproducible examples, workarounds, and fix suggestions. Works for both current and third-party repositories. Supported for --tool claude and --tool codex.',\n350\t    default: false,\n351\t  },\n352\t  'prompt-architecture-care': {\n353\t    type: 'boolean',\n354\t    description: '[EXPERIMENTAL] Include guidance for managing REQUIREMENTS.md and ARCHITECTURE.md files. When enabled, agents will update these documentation files when changes affect requirements or architecture.',\n355\t    default: false,\n356\t  },\n357\t  'prompt-case-studies': {\n358\t    type: 'boolean',\n359\t    description: 'Create comprehensive case study documentation for the issue including logs, analysis, timeline, root cause investigation, and proposed solutions. Organizes findings into ./docs/case-studies/issue-{id}/ directory. Supported for --tool claude and --tool codex.',\n360\t    default: false,\n361\t  },\n362\t  'prompt-playwright-mcp': {\n363\t    type: 'boolean',\n364\t    description: 'Enable Playwright MCP browser automation hints in system prompt (enabled by default, only takes effect if Playwright MCP is installed). Use --no-prompt-playwright-mcp to disable. Supported for --tool claude and --tool codex.',\n365\t    default: true,\n366\t  },\n367\t  'prompt-check-sibling-pull-requests': {\n368\t    type: 'boolean',\n369\t    description: 'Include prompt to check related/sibling pull requests when studying related work. Enabled by default, use --no-prompt-check-sibling-pull-requests to disable.',\n370\t    default: true,\n371\t  },\n372\t  'prompt-experiments-folder': {\n373\t    type: 'string',\n374\t    description: 'Path to experiments folder used in system prompt. Set to empty string to disable experiments folder prompt. Default: ./experiments',\n375\t    default: './experiments',\n376\t  },\n377\t  'prompt-examples-folder': {\n378\t    type: 'string',\n379\t    description: 'Path to examples folder used in system prompt. Set to empty string to disable examples folder prompt. Default: ./examples',\n380\t    default: './examples',\n381\t  },\n382\t  'playwright-mcp-auto-cleanup': {\n383\t    type: 'boolean',\n384\t    description: 'Automatically remove .playwright-mcp/ folder before checking for uncommitted changes. This prevents browser automation artifacts from triggering auto-restart. Use --no-playwright-mcp-auto-cleanup to keep the folder for debugging.',\n385\t    default: true,\n386\t  },\n387\t  'auto-gh-configuration-repair': {\n388\t    type: 'boolean',\n389\t    description: 'Automatically repair git configuration using gh-setup-git-identity --repair when git identity is not configured. Requires gh-setup-git-identity to be installed.',\n390\t    default: false,\n391\t  },\n392\t  'prompt-subagents-via-agent-commander': {\n393\t    type: 'boolean',\n394\t    description: 'Guide AI to use agent-commander CLI (start-agent) instead of native tool-specific delegation for subagent work. Allows using any supported agent type (claude, opencode, codex, agent) with a unified API. Supported for --tool claude and --tool codex and requires agent-commander to be installed.',\n395\t    default: false,\n396\t  },\n397\t  'auto-init-repository': {\n398\t    type: 'boolean',\n399\t    description: 'Automatically initialize empty repositories by creating a simple README.md file. Only works when you have write access to the repository. This allows branch creation and pull request workflows to proceed on repositories that have no commits.',\n400\t    default: false,\n401\t  },\n402\t  'auto-report-issue': {\n403\t    type: 'boolean',\n404\t    description: 'Automatically create a GitHub issue on failure without prompting (non-interactive mode). The issue includes error details, logs, and case study analysis instructions. Sets issue type and label to bug.',\n405\t    default: false,\n406\t  },\n407\t  'disable-report-issue': {\n408\t    type: 'boolean',\n409\t    description: 'Disable error issue creation entirely (no prompt, no automatic creation). Overrides --auto-report-issue if both are specified.',\n410\t    default: false,\n411\t  },\n412\t  'attach-solution-summary': {\n413\t    type: 'boolean',\n414\t    description: 'Attach the AI solution summary (from the result field) as a comment to the PR/issue after completion. The summary is extracted from the AI tool JSON output and posted under a \"Solution summary\" header.',\n415\t    default: false,\n416\t  },\n417\t  'auto-attach-solution-summary': {\n418\t    type: 'boolean',\n419\t    description: 'Automatically attach solution summary only if the AI did not create any comments during the session. This provides visible feedback when the AI completes silently.',\n420\t    default: false,\n421\t  },\n422\t  'auto-accept-invite': {\n423\t    type: 'boolean',\n424\t    description: 'Automatically accept the pending GitHub repository or organization invitation for the specific repository/organization being solved, before checking write access. Unlike /accept_invites which accepts all pending invitations, this only accepts the invite for the target repo/org.',\n425\t    default: false,\n426\t  },\n427\t  'prompt-ensure-all-requirements-are-met': {\n428\t    type: 'boolean',\n429\t    description: '[EXPERIMENTAL] Add a prompt hint to the system prompt to ensure all changes are correct, consistent, validated, tested, logged and fully meet all discussed requirements. Enabled automatically by --finalize during finalize cycle iterations only.',\n430\t    default: false,\n431\t  },\n432\t  finalize: {\n433\t    type: 'number',\n434\t    description: '[EXPERIMENTAL] After the main solve completes, automatically restart the AI tool N times (default: 1) with a requirements-check prompt to verify all requirements are met. Use --finalize-model to override the model for finalize iterations.',\n435\t    default: 0,\n436\t  },\n437\t  'finalize-model': {\n438\t    type: 'string',\n439\t    description: '[EXPERIMENTAL] Model to use for --finalize iterations. Defaults to the same model as --model.',\n440\t    default: undefined,\n441\t  },\n442\t  'working-session-live-progress': {\n443\t    type: 'string',\n444\t    description: '[EXPERIMENTAL] Enable live progress monitoring. Accepts \"comment\" (default, updates a per-session PR comment) or \"pr\" (updates PR description). Plain --working-session-live-progress means \"comment\". Works with or without --interactive-mode.',\n445\t    default: false,\n446\t  },\n447\t};\n448\t\n449\t// Function to create yargs configuration - avoids duplication"
