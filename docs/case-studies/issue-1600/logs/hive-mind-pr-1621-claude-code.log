[2026-04-17T05:16:47.783Z] [INFO]         "content": "1\t#!/usr/bin/env node\n2\t/**\n3\t * Model Information Library Unit Tests\n4\t *\n5\t * Tests for the models/index.mjs module (model info functions), including:\n6\t * - getToolDisplayName() mapping\n7\t * - buildModelInfoString() output formatting\n8\t * - resolveModelId() alias resolution\n9\t * - modelsUsed actual-vs-requested display\n10\t *\n11\t * Run with: node tests/model-info.test.mjs\n12\t *\n13\t * @see https://github.com/link-assistant/hive-mind/issues/1225\n14\t */\n15\t\n16\timport assert from 'node:assert/strict';\n17\timport { getToolDisplayName, buildModelInfoString, resolveModelId } from '../src/models/index.mjs';\n18\t\n19\t// Test utilities\n20\tlet testsPassed = 0;\n21\tlet testsFailed = 0;\n22\t\n23\tfunction test(name, fn) {\n24\t  try {\n25\t    fn();\n26\t    console.log(`✅ ${name}`);\n27\t    testsPassed++;\n28\t  } catch (error) {\n29\t    console.log(`❌ ${name}`);\n30\t    console.log(`   Error: ${error.message}`);\n31\t    testsFailed++;\n32\t  }\n33\t}\n34\t\n35\t// ============================================================================\n36\t// getToolDisplayName Tests\n37\t// ============================================================================\n38\t\n39\tconsole.log('\\n📋 getToolDisplayName Tests\\n');\n40\t\n41\ttest('getToolDisplayName returns \"Anthropic Claude Code\" for claude', () => {\n42\t  assert.equal(getToolDisplayName('claude'), 'Anthropic Claude Code');\n43\t});\n44\t\n45\ttest('getToolDisplayName returns \"OpenAI Codex\" for codex', () => {\n46\t  assert.equal(getToolDisplayName('codex'), 'OpenAI Codex');\n47\t});\n48\t\n49\ttest('getToolDisplayName returns \"OpenCode\" for opencode', () => {\n50\t  assert.equal(getToolDisplayName('opencode'), 'OpenCode');\n51\t});\n52\t\n53\ttest('getToolDisplayName returns \"Agent CLI\" for agent', () => {\n54\t  assert.equal(getToolDisplayName('agent'), 'Agent CLI');\n55\t});\n56\t\n57\ttest('getToolDisplayName returns \"AI tool\" for unknown', () => {\n58\t  assert.equal(getToolDisplayName('unknown'), 'AI tool');\n59\t});\n60\t\n61\ttest('getToolDisplayName returns \"AI tool\" for null', () => {\n62\t  assert.equal(getToolDisplayName(null), 'AI tool');\n63\t});\n64\t\n65\ttest('getToolDisplayName returns \"AI tool\" for undefined', () => {\n66\t  assert.equal(getToolDisplayName(undefined), 'AI tool');\n67\t});\n68\t\n69\ttest('getToolDisplayName is case-insensitive', () => {\n70\t  assert.equal(getToolDisplayName('Claude'), 'Anthropic Claude Code');\n71\t  assert.equal(getToolDisplayName('CLAUDE'), 'Anthropic Claude Code');\n72\t  assert.equal(getToolDisplayName('CODEX'), 'OpenAI Codex');\n73\t});\n74\t\n75\t// ============================================================================\n76\t// resolveModelId Tests\n77\t// ============================================================================\n78\t\n79\tconsole.log('\\n📋 resolveModelId Tests\\n');\n80\t\n81\ttest('resolveModelId resolves \"opus\" for claude tool', () => {\n82\t  // opus maps to claude-opus-4-5 in current mapping\n83\t  const result = resolveModelId('opus', 'claude');\n84\t  assert.ok(result.startsWith('claude-opus'), `Expected claude-opus prefix but got: ${result}`);\n85\t});\n86\t\n87\ttest('resolveModelId resolves \"sonnet\" for claude tool', () => {\n88\t  const result = resolveModelId('sonnet', 'claude');\n89\t  assert.ok(result.startsWith('claude-sonnet'), `Expected claude-sonnet prefix but got: ${result}`);\n90\t});\n91\t\n92\ttest('resolveModelId resolves \"haiku\" for claude tool', () => {\n93\t  const result = resolveModelId('haiku', 'claude');\n94\t  assert.ok(result.startsWith('claude-haiku'), `Expected claude-haiku prefix but got: ${result}`);\n95\t});\n96\t\n97\ttest('resolveModelId resolves \"grok\" for agent tool', () => {\n98\t  assert.equal(resolveModelId('grok', 'agent'), 'opencode/grok-code');\n99\t});\n100\t\n101\ttest('resolveModelId resolves \"sonnet\" for agent tool', () => {\n102\t  assert.equal(resolveModelId('sonnet', 'agent'), 'anthropic/claude-3-5-sonnet');\n103\t});\n104\t\n105\ttest('resolveModelId resolves \"gpt5\" for codex tool', () => {\n106\t  assert.equal(resolveModelId('gpt5', 'codex'), 'gpt-5');\n107\t});\n108\t\n109\ttest('resolveModelId strips [1m] suffix', () => {\n110\t  const result = resolveModelId('opus[1m]', 'claude');\n111\t  assert.ok(result.startsWith('claude-opus'), `Expected claude-opus prefix but got: ${result}`);\n112\t  const result2 = resolveModelId('sonnet[1M]', 'claude');\n113\t  assert.ok(result2.startsWith('claude-sonnet'), `Expected claude-sonnet prefix but got: ${result2}`);\n114\t});\n115\t\n116\ttest('resolveModelId returns null for null input', () => {\n117\t  assert.equal(resolveModelId(null, 'claude'), null);\n118\t});\n119\t\n120\ttest('resolveModelId returns model as-is for unknown alias', () => {\n121\t  assert.equal(resolveModelId('custom-model', 'claude'), 'custom-model');\n122\t});\n123\t\n124\ttest('resolveModelId defaults to claude tool when tool is null', () => {\n125\t  const result = resolveModelId('opus', null);\n126\t  assert.ok(result.startsWith('claude-opus'), `Expected claude-opus prefix but got: ${result}`);\n127\t});\n128\t\n129\t// ============================================================================\n130\t// buildModelInfoString Tests - New format with modelsUsed\n131\t// ============================================================================\n132\t\n133\tconsole.log('\\n📋 buildModelInfoString Tests\\n');\n134\t\n135\ttest('buildModelInfoString returns empty string when no data', () => {\n136\t  assert.equal(buildModelInfoString({}), '');\n137\t  assert.equal(buildModelInfoString(), '');\n138\t});\n139\t\n140\ttest('buildModelInfoString includes tool name', () => {\n141\t  const result = buildModelInfoString({\n142\t    tool: 'claude',\n143\t    requestedModel: 'opus',\n144\t    modelsUsed: [{ modelId: 'claude-opus-4-5-20251101', modelInfo: null }],\n145\t  });\n146\t  assert.ok(result.includes('Tool: Anthropic Claude Code'), `Expected \"Tool: Anthropic Claude Code\" but got: ${result}`);\n147\t});\n148\t\n149\ttest('buildModelInfoString includes requested model', () => {\n150\t  const result = buildModelInfoString({\n151\t    requestedModel: 'opus',\n152\t    modelsUsed: [{ modelId: 'claude-opus-4-5-20251101', modelInfo: null }],\n153\t  });\n154\t  assert.ok(result.includes('Requested: `opus`'), `Expected \"Requested: \\`opus\\`\" but got: ${result}`);\n155\t});\n156\t\n157\ttest('buildModelInfoString shows header emoji', () => {\n158\t  const result = buildModelInfoString({\n159\t    requestedModel: 'opus',\n160\t    modelsUsed: [{ modelId: 'claude-opus-4-5-20251101', modelInfo: null }],\n161\t  });\n162\t  assert.ok(result.includes('### 🤖 **Models used:**'), `Expected header but got: ${result}`);\n163\t});\n164\t\n165\ttest('buildModelInfoString shows model in bold when matches requested (single model)', () => {\n166\t  const result = buildModelInfoString({\n167\t    requestedModel: 'opus',\n168\t    tool: 'claude',\n169\t    modelsUsed: [\n170\t      {\n171\t        modelId: 'claude-opus-4-6',\n172\t        modelInfo: { name: 'Claude Opus 4.6', provider: 'Anthropic', knowledge: '2025-05' },\n173\t      },\n174\t    ],\n175\t  });\n176\t  assert.ok(result.includes('**Model: Claude Opus 4.6**'), `Expected bold model but got: ${result}`);\n177\t  assert.ok(!result.includes('⚠️'), `Should not have warning when model matches but got: ${result}`);\n178\t});\n179\t\n180\ttest('buildModelInfoString shows warning when model does not match requested', () => {\n181\t  const result = buildModelInfoString({\n182\t    requestedModel: 'opus',\n183\t    tool: 'claude',\n184\t    modelsUsed: [\n185\t      {\n186\t        modelId: 'claude-sonnet-4-6',\n187\t        modelInfo: { name: 'Claude Sonnet 4.6', provider: 'Anthropic' },\n188\t      },\n189\t    ],\n190\t  });\n191\t  assert.ok(result.includes('**Model: Claude Sonnet 4.6**'), `Expected 