onst interpretation = normalizeInterpretation(request.interpretation);\n948\t  const kind = String(interpretation.kind || '').toLowerCase();\n949\t  const formalSystem = request.formalSystem || request.formal_system || 'rml';\n950\t  const dependencies = request.dependencies || [];\n951\t  const rawExpression =\n952\t    interpretation.expression ||\n953\t    interpretation.formalExpression ||\n954\t    interpretation.formal_expression ||\n955\t    interpretation.lino ||\n956\t    normalizeQuestionExpression(request.text);\n957\t\n958\t  const canUseArithmetic =\n959\t    formalSystem === 'rml-arithmetic' ||\n960\t    formalSystem === 'arithmetic' ||\n961\t    kind.startsWith('arithmetic');\n962\t\n963\t  if (canUseArithmetic && rawExpression) {\n964\t    const valueKind = kind.includes('equal') || splitTopLevelEquals(rawExpression) ? 'truth-value' : 'number';\n965\t    try {\n966\t      const formal = buildArithmeticFormalization(rawExpression, valueKind);\n967\t      return {\n968\t        type: 'rml-formalization',\n969\t        sourceText: request.text || '',\n970\t        interpretation,\n971\t        formalSystem,\n972\t        dependencies,\n973\t        computable: true,\n974\t        formalizationLevel: 3,\n975\t        unknowns: [],\n976\t        valueKind: formal.valueKind,\n977\t        ast: formal.ast,\n978\t        lino: formal.lino,\n979\t      };\n980\t    } catch (error) {\n981\t      return partialFormalization(request, interpretation, ['unsupported-arithmetic-shape', error.message], 1);\n982\t    }\n983\t  }\n984\t\n985\t  if ((interpretation.lino || interpretation.formalExpression || interpretation.formal_expression) && rawExpression) {\n986\t    try {\n987\t      const ast = parseExpressionShape(rawExpression);\n988\t      return {\n989\t        type: 'rml-formalization',\n990\t        sourceText: request.text || '',\n991\t        interpretation,\n992\t        formalSystem,\n993\t        dependencies,\n994\t        computable: true,\n995\t        formalizationLevel: 3,\n996\t        unknowns: [],\n997\t        valueKind: Array.isArray(ast) && ast[0] === '?' ? 'query' : 'truth-value',\n998\t        ast,\n999\t        lino: keyOf(ast),\n1000\t      };\n1001\t    } catch (error) {\n1002\t      return partialFormalization(request, interpretation, ['unsupported-lino-shape', error.message], 1);\n1003\t    }\n1004\t  }\n1005\t\n1006\t  const dependencyUnknowns = dependencies\n1007\t    .filter(dep => dep && ['missing', 'unknown', 'partial'].includes(dep.status))\n1008\t    .map(dep => `dependency:${dep.id || 'unknown'}`);\n1009\t  return partialFormalization(request, interpretation, [\n1010\t    'selected-subject',\n1011\t    'selected-relation',\n1012\t    'evidence-source',\n1013\t    'formal-shape',\n1014\t    ...dependencyUnknowns,\n1015\t  ]);\n1016\t}\n1017\t\n1018\tfunction evaluateFormalization(formalization, options = {}) {\n1019\t  if (!formalization || !formalization.computable || !formalization.ast) {\n1020\t    return {\n1021\t      computable: false,\n1022\t      formalizationLevel: formalization?.formalizationLevel || 0,\n1023\t      unknowns: formalization?.unknowns || ['formalization'],\n1024\t      result: { kind: 'partial', value: 'unknown', deterministic: false },\n1025\t    };\n1026\t  }\n1027\t\n1028\t  const env = new Env(options.env || options);\n1029\t  const evaluated = evalNode(formalization.ast, env);\n1030\t  const value = evaluated && evaluated.query ? evaluated.value : evaluated;\n1031\t  const kind =\n1032\t    formalization.valueKind === 'truth-value' ? 'truth-value' :\n1033\t    formalization.valueKind === 'query' && typeof value === 'string' ? 'type' :\n1034\t    'number';\n1035\t\n1036\t  return {\n1037\t    computable: true,\n1038\t    formalizationLevel: formalization.formalizationLevel,\n1039\t    unknowns: [],\n1040\t    result: { kind, value, deterministic: true },\n1041\t  };\n1042\t}\n1043\t\n1044\t// ---------- Runner ----------\n1045\tfunction run(text, options){\n1046\t  const forms = parseLinoForms(text);\n1047\t\n1048\t  const env = new Env(options);\n1049\t  const outs = [];\n1050\t  for (let form of forms) {\n1051\t    // Unwrap single-element arrays (LiNo wraps everything in outer parens)\n1052\t    while (Array.isArray(form) && form.length === 1 && Array.isArray(form[0])) {\n1053\t      form = form[0];\n1054\t    }\n1055\t    const res = evalNode(form, env);\n1056\t    if (res && res.query) {\n1057\t      if (res.typeQuery) {\n1058\t        // Type queries return string results\n1059\t        outs.push(res.value);\n1060\t      } else {\n1061\t        outs.push(res.value);\n1062\t      }\n1063\t    }\n1064\t  }\n1065\t  return outs;\n1066\t}\n1067\t\n1068\t// CLI\n1069\tif (import.meta.url === `file://${process.argv[1]}`) {\n1070\t  const file = process.argv[2];\n1071\t  if (!file) {\n1072\t    console.error('Usage: node src/rml-links.mjs <kb.lino>');\n1073\t    process.exit(1);\n1074\t  }\n1075\t  const text = fs.readFileSync(file, 'utf8');\n1076\t  const { results, diagnostics } = evaluate(text, { file });\n1077\t  for (const v of results) {\n1078\t    if (typeof v === 'string') {\n1079\t      console.log(v);\n1080\t    } else {\n1081\t      console.log(String(+v.toFixed(6)).replace(/\\.0+$/,''));\n1082\t    }\n1083\t  }\n1084\t  for (const diag of diagnostics) {\n1085\t    console.error(formatDiagnostic(diag, text));\n1086\t  }\n1087\t  if (diagnostics.length > 0) process.exit(1);\n1088\t}\n1089\t\n1090\texport {\n1091\t  run,\n1092\t  evaluate,\n1093\t  Diagnostic,\n1094\t  RmlError,\n1095\t  formatDiagnostic,\n1096\t  computeFormSpans,\n1097\t  parseLino,\n1098\t  tokenizeOne,\n1099\t  parseOne,\n1100\t  Env,\n1101\t  evalNode,\n1102\t  quantize,\n1103\t  decRound,\n1104\t  keyOf,\n1105\t  isNum,\n1106\t  isStructurallySame,\n1107\t  parseBinding,\n1108\t  parseBindings,\n1109\t  substitute,\n1110\t  formalizeSelectedInterpretation,\n1111\t  evaluateFormalization,\n1112\t};\n1113\t"
