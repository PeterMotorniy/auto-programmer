        "content": "300\t    fn read(tokens: &[String], i: &mut usize) -> Result<Node, String> {\n301\t        if *i >= tokens.len() || tokens[*i] != \"(\" {\n302\t            return Err(\"expected \\\"(\\\"\".to_string());\n303\t        }\n304\t        *i += 1;\n305\t        let mut arr = Vec::new();\n306\t        while *i < tokens.len() && tokens[*i] != \")\" {\n307\t            if tokens[*i] == \"(\" {\n308\t                arr.push(read(tokens, i)?);\n309\t            } else {\n310\t                arr.push(Node::Leaf(tokens[*i].clone()));\n311\t                *i += 1;\n312\t            }\n313\t        }\n314\t        if *i >= tokens.len() || tokens[*i] != \")\" {\n315\t            return Err(\"expected \\\")\\\"\".to_string());\n316\t        }\n317\t        *i += 1;\n318\t        Ok(Node::List(arr))\n319\t    }\n320\t\n321\t    let ast = read(tokens, &mut i)?;\n322\t    if i != tokens.len() {\n323\t        return Err(\"extra tokens after link\".to_string());\n324\t    }\n325\t    Ok(ast)\n326\t}\n327\t\n328\t/// Check if a string is numeric (including negative).\n329\tpub fn is_num(s: &str) -> bool {\n330\t    let s = s.trim();\n331\t    if s.is_empty() {\n332\t        return false;\n333\t    }\n334\t    let s = if let Some(stripped) = s.strip_prefix('-') {\n335\t        stripped\n336\t    } else {\n337\t        s\n338\t    };\n339\t    if s.is_empty() {\n340\t        return false;\n341\t    }\n342\t    if let Some(rest) = s.strip_prefix('.') {\n343\t        // .digits\n344\t        !rest.is_empty() && rest.chars().all(|c| c.is_ascii_digit())\n345\t    } else {\n346\t        // digits or digits.digits\n347\t        let parts: Vec<&str> = s.splitn(2, '.').collect();\n348\t        if parts.is_empty() || !parts[0].chars().all(|c| c.is_ascii_digit()) || parts[0].is_empty()\n349\t        {\n350\t            return false;\n351\t        }\n352\t        if parts.len() == 2 {\n353\t            parts[1].chars().all(|c| c.is_ascii_digit())\n354\t        } else {\n355\t            true\n356\t        }\n357\t    }\n358\t}\n359\t\n360\t/// Create a canonical key representation of a node.\n361\tpub fn key_of(node: &Node) -> String {\n362\t    match node {\n363\t        Node::Leaf(s) => s.clone(),\n364\t        Node::List(children) => {\n365\t            let inner: Vec<String> = children.iter().map(key_of).collect();\n366\t            format!(\"({})\", inner.join(\" \"))\n367\t        }\n368\t    }\n369\t}\n370\t\n371\t/// Check structural equality of two nodes.\n372\tpub fn is_structurally_same(a: &Node, b: &Node) -> bool {\n373\t    match (a, b) {\n374\t        (Node::Leaf(sa), Node::Leaf(sb)) => sa == sb,\n375\t        (Node::List(la), Node::List(lb)) => {\n376\t            la.len() == lb.len()\n377\t                && la\n378\t                    .iter()\n379\t                    .zip(lb.iter())\n380\t                    .all(|(x, y)| is_structurally_same(x, y))\n381\t        }\n382\t        _ => false,\n383\t    }\n384\t}\n385\t\n386\t// ========== Decimal-precision arithmetic ==========\n387\t// Round to at most DECIMAL_PRECISION significant decimal places to eliminate\n388\t// IEEE-754 floating-point artefacts (e.g. 0.1+0.2 → 0.3, not 0.30000000000000004).\n389\tconst DECIMAL_PRECISION: i32 = 12;\n390\t\n391\tpub fn dec_round(x: f64) -> f64 {\n392\t    if !x.is_finite() {\n393\t        return x;\n394\t    }\n395\t    let factor = 10f64.powi(DECIMAL_PRECISION);\n396\t    (x * factor).round() / factor\n397\t}\n398\t\n399\t// ========== Quantization ==========\n400\t\n401\t/// Quantize a value to N discrete levels in range [lo, hi].\n402\t/// For N=2 (Boolean): levels are {lo, hi}\n403\t/// For N=3 (ternary): levels are {lo, mid, hi}\n404\t/// For N<2 (continuous/unary): no quantization\n405\t/// See: https://en.wikipedia.org/wiki/Many-valued_logic\n406\tpub fn quantize(x: f64, valence: u32, lo: f64, hi: f64) -> f64 {\n407\t    if valence < 2 {\n408\t        return x; // unary or continuous — no quantization\n409\t    }\n410\t    let step = (hi - lo) / (valence as f64 - 1.0);\n411\t    let level = ((x - lo) / step).round();\n412\t    let level = level.max(0.0).min(valence as f64 - 1.0);\n413\t    lo + level * step\n414\t}\n415\t\n416\t// ========== Aggregator Types ==========\n417\t\n418\t/// Supported aggregator types for AND/OR operators.\n419\t#[derive(Debug, Clone, Copy, PartialEq)]\n420\tpub enum Aggregator {\n421\t    Avg,\n422\t    Min,\n423\t    Max,\n424\t    Prod,\n425\t    Ps, // Probabilistic sum: 1 - ∏(1-xi)\n426\t}\n427\t\n428\timpl Aggregator {\n429\t    pub fn apply(&self, xs: &[f64], lo: f64) -> f64 {\n430\t        if xs.is_empty() {\n431\t            return lo;\n432\t        }\n433\t        match self {\n434\t            Aggregator::Avg => xs.iter().sum::<f64>() / xs.len() as f64,\n435\t            Aggregator::Min => xs.iter().copied().fold(f64::INFINITY, f64::min),\n436\t            Aggregator::Max => xs.iter().copied().fold(f64::NEG_INFINITY, f64::max),\n437\t            Aggregator::Prod => xs.iter().copied().fold(1.0, |a, b| a * b),\n438\t            Aggregator::Ps => 1.0 - xs.iter().copied().fold(1.0, |a, b| a * (1.0 - b)),\n439\t        }\n440\t    }\n441\t\n442\t    pub fn from_name(name: &str) -> Option<Self> {\n443\t        match name {\n444\t            \"avg\" => Some(Aggregator::Avg),\n445\t            \"min\" => Some(Aggregator::Min),\n446\t            \"max\" => Some(Aggregator::Max),\n447\t            \"product\" | \"prod\" => Some(Aggregator::Prod),\n448\t            \"probabilistic_sum\" | \"ps\" => Some(Aggregator::Ps),\n449\t            _ => None,\n450\t        }\n451\t    }\n452\t}\n453\t\n454\t// ========== Operator ==========\n455\t\n456\t/// Operator types supported by the environment.\n457\t#[derive(Debug, Clone)]\n458\tpub enum Op {\n459\t    /// Negation: mirrors around midpoint. not(x) = hi - (x - lo)\n460\t    Not,\n461\t    /// Aggregator-based operator (for and/or).\n462\t    Agg(Aggregator),\n463\t    /// Equality operator: checks assigned probability or structural equality.\n464\t    Eq,\n465\t    /// Inequality: not(eq(...))\n466\t    Neq,\n467\t    /// Composition: outer(inner(...))\n468\t    Compose {\n469\t        outer: String,\n470\t        inner: String,\n471\t    },\n472\t    /// Arithmetic: +, -, *, / (decimal-precision)\n473\t    Add,\n474\t    Sub,\n475\t    Mul,\n476\t    Div,\n477\t}\n478\t\n479\t// ========== Environment ==========\n480\t\n481\t/// Options for creating an Env.\n482\t#[derive(Debug, Clone)]\n483\tpub struct EnvOptions {\n484\t    pub lo: f64,\n485\t    pub hi: f64,\n486\t    pub valence: u32,\n487\t}\n488\t\n489\timpl Default for EnvOptions {\n490\t    fn default() -> Self {\n491\t        Self {\n492\t            lo: 0.0,\n493\t            hi: 1.0,\n494\t            valence: 0,\n495\t        }\n496\t    }\n497\t}\n498\t\n499\t/// A stored lambda definition (param name, param type, body).\n500\t#[derive(Debug, Clone)]\n501\tpub struct Lambda {\n502\t    pub param: String,\n503\t    pub param_type: String,\n504\t    pub body: Node,\n505\t}\n506\t\n507\t/// The evaluation environment: holds terms, assignments, operators, and range/valence config.\n508\tpub struct Env {\n509\t    pub terms: HashSet<String>,\n510\t    pub assign: HashMap<String, f64>,\n511\t    pub symbol_prob: HashMap<String, f64>,\n512\t    pub lo: f64,\n513\t    pub hi: f64,\n514\t    pub valence: u32,\n515\t    pub ops: HashMap<String, Op>,\n516\t    pub types: HashMap<String, String>,\n517\t    pub lambdas: HashMap<String, Lambda>,\n518\t}\n519\t\n520\timpl Env {\n521\t    pub fn new(options: Option<EnvOptions>) -> Self {\n522\t        let opts = options.unwrap_or_default();\n523\t        let mut ops = HashMap::new();\n524\t        ops.insert(\"not\".to_string(), Op::Not);\n525\t        ops.insert(\"and\".to_string(), Op::Agg(Aggregator::Avg));\n526\t        ops.insert(\"or\".to_string(), Op::Agg(Aggregator::Max));\n527\t        // Belnap operators: AND-altering operators for four-valued logic\n528\t        // \"both\" (gullibility): avg — contradiction resolves to midpoint\n529\t        // \"neither\" (consensus): product — gap resolves to zero (no info propagates)\n530\t        // See: https://en.wikipedia.org/wiki/Four-valued_logic#Belnap\n531\t        ops.insert(\"both\".to_string(), Op::Agg(Aggregator::Avg));\n532\t        ops.insert(\"neither\".to_string(), Op::Agg(Aggregator::Prod));\n533\t        ops.insert(\"=\".to_string(), Op::Eq);\n534\t        ops.insert(\"!=\".to_string(), Op::Neq);\n535\t        ops.insert(\"+\".to_string(), Op::Add);\n536\t        ops.insert(\"-\".to_string(), Op::Sub);\n537\t        ops.insert(\"*\".to_string(), Op::Mul);\n538\t        ops.insert(\"/\".to_string(), Op::Div);\n539\t\n540\t        let mut env = Self {\n541\t            terms: HashSet::new(),\n542\t            assign: HashMap::new(),\n543\t            symbol_prob: HashMap::new(),\n544\t            lo: opts.lo,\n545\t            hi: opts.hi,\n546\t            valence: opts.valence,\n547\t            ops,\n548\t            types: HashMap::new(),\n549\t            lambdas: HashMap::new(),\n550\t        };\n551\t\n552\t        // Initialize truth constants: true, false, unknown, undefined\n553\t        // These are predefined symbol probabilities based on the current range.\n554\t        // By default: (false: min(range)), (true: max(range)),\n555\t        //             (unknown: mid(range)), (undefined: mid(range))\n556\t        // They can be redefined by the user via (true: <value>), (false: <value>), etc.\n557\t        env.init_truth_constants();\n558\t        env\n559\t    }\n560\t\n561\t    /// Midpoint of the range.\n562\t    pub fn mid(&self) -> f64 {\n563\t        (self.lo + self.hi) / 2.0\n564\t    }\n565\t\n566\t    /// Initialize truth constants based on current range.\n567\t    /// (false: min(range)), (true: max(range)),\n568\t    /// (unknown: mid(range)), (undefined: mid(range))\n569\t    pub fn init_truth_constants(&mut self) {\n570\t        self.symbol_prob.insert(\"true\".to_string(), self.hi);\n571\t        self.symbol_prob.insert(\"false\".to_string(), self.lo);\n572\t        let mid = self.mid();\n573\t        self.symbol_prob.insert(\"unknown\".to_string(), mid);\n574\t        self.symbol_prob.insert(\"undefined\".to_string(), mid);\n575\t        // Note: \"both\" and \"neither\" are operators (not constants) — see Env::new()\n576\t        // See: https://en.wikipedia.org/wiki/Four-valued_logic#Belnap\n577\t    }\n578\t\n579\t    /// Clamp and optionally quantize a value to the valid range.\n580\t    pub fn clamp(&self, x: f64) -> f64 {\n581\t        let clamped = x.max(self.lo).min(self.hi);\n582\t        if self.valence >= 2 {\n583\t            quantize(clamped, self.valence, self.lo, self.hi)\n584\t        } else {\n585\t            clamped\n586\t        }\n587\t    }\n588\t\n589\t    /// Parse a numeric string respecting current range.\n590\t    pub fn to_num(&self, s: &str) -> f64 {\n591\t        self.clamp(s.parse::<f64>().unwrap_or(0.0))\n592\t    }\n593\t\n594\t    pub fn define_op(&mut self, name: &str, op: Op) {\n595\t        self.ops.insert(name.to_string(), op);\n596\t    }\n597\t\n598\t    pub fn get_op(&self, name: &str) -> Option<&Op> {\n599\t        self.ops.get(name)\n600\t    }\n601\t\n602\t    pub fn set_expr_prob(&mut self, expr_node: &Node, p: f64) {\n603\t        self.assign.insert(key_of(expr_node), self.clamp(p));\n604\t    }\n605\t\n606\t    pub fn set_symbol_prob(&mut self, sym: &str, p: f64) {\n607\t        self.symbol_prob.insert(sym.to_string(), self.clamp(p));\n608\t    }\n609\t\n610\t    pub fn get_symbol_prob(&self, sym: &str) -> f64 {\n611\t        self.symbol_prob\n612\t            .get(sym)\n613\t            .copied()\n614\t            .unwrap_or_else(|| self.mid())\n615\t    }\n616\t\n617\t    pub fn set_type(&mut self, expr: &str, type_expr: &str) {\n618\t        self.types.insert(expr.to_string(), type_expr.to_string());\n619\t    }\n620\t\n621\t    pub fn get_type(&self, expr: &str) -> Option<&String> {\n622\t        self.types.get(expr)\n623\t    }\n624\t\n625\t    pub fn set_lambda(&mut self, name: &str, lambda: Lambda) {\n626\t        self.lambdas.insert(name.to_string(), lambda);\n627\t    }\n628\t\n629\t    pub fn get_lambda(&self, name: &str) -> Option<&Lambda> {\n630\t        self.lambdas.get(name)\n631\t    }\n632\t\n633\t    /// Apply an operator by name to the given values.\n634\t    pub fn apply_op(&self, name: &str, vals: &[f64]) -> f64 {\n635\t        let op = match self.ops.get(name) {\n636\t            Some(op) => op.clone(),\n637\t            None => panic!(\"Unknown op: {}\", name),\n638\t        };\n639\t        match op {\n640\t            Op::Not => {\n641\t                if vals.is_empty() {\n642\t                    self.lo\n643\t                } else {\n644\t                    self.hi - (vals[0] - self.lo)\n645\t                }\n646\t            }\n647\t            Op::Agg(agg) => dec_round(agg.apply(vals, self.lo)),\n648\t            Op::Eq | Op::Neq => self.lo,\n649\t            Op::Compose {\n650\t                ref outer,\n651\t                ref inner,\n652\t            } => {\n653\t                let inner_result = self.apply_op(inner, vals);\n654\t                self.apply_op(outer, &[inner_result])\n655\t            }\n656\t            Op::Add => {\n657\t                if vals.len() >= 2 {\n658\t                    dec_round(vals[0] + vals[1])\n659\t                } else {\n660\t                    0.0\n661\t                }\n662\t            }\n663\t            Op::Sub => {\n664\t                if vals.len() >= 2 {\n665\t                    dec_round(vals[0] - vals[1])\n666\t                } else {\n667\t                    0.0\n668\t                }\n669\t            }\n670\t            Op::Mul => {\n671\t                if vals.len() >= 2 {\n672\t                    dec_round(vals[0] * vals[1])\n673\t                } else {\n674\t                    0.0\n675\t                }\n676\t            }\n677\t            Op::Div => {\n678\t                if vals.len() >= 2 && vals[1] != 0.0 {\n679\t                    dec_round(vals[0] / vals[1])\n680\t                } else {\n681\t                    0.0\n682\t                }\n683\t            }\n684\t        }\n685\t    }\n686\t\n687\t    /// Apply equality operator, checking assigned probabilities first.\n688\t    pub fn apply_eq(&self, left: &Node, right: &Node) -> f64 {\n689\t        // Check prefix form: (= L R)\n690\t        let k_prefix = key_of(&Node::List(vec![\n691\t            Node::Leaf(\"=\".to_string()),\n692\t            left.clone(),\n693\t            right.clone(),\n694\t        ]));\n695\t        if let Some(&v) = self.assign.get(&k_prefix) {\n696\t            return v;\n697\t        }\n698\t        // Check infix form: (L = R)\n699\t        let k_infix = key_of(&Node::List(vec!["
