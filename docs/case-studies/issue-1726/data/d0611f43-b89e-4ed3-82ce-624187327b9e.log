        "content": "1\t#!/usr/bin/env node\n2\t// RML — minimal relative meta-logic over LiNo (Links Notation)\n3\t// Supports many-valued logics from unary (1-valued) through continuous probabilistic (∞-valued).\n4\t// See: https://en.wikipedia.org/wiki/Many-valued_logic\n5\t//\n6\t// - Uses official links-notation parser to parse links\n7\t// - Terms are defined via (x: x is x)\n8\t// - Probabilities are assigned ONLY via: ((<expr>) has probability <p>)\n9\t// - Redefinable ops: (=: ...), (!=: not =), (and: avg|min|max|product|probabilistic_sum), (or: ...), (not: ...), (both: ...), (neither: ...)\n10\t// - Range: (range: 0 1) for [0,1] or (range: -1 1) for [-1,1] (balanced/symmetric)\n11\t// - Valence: (valence: N) to restrict truth values to N discrete levels (N=2 → Boolean, N=3 → ternary, etc.)\n12\t// - Query: (? <expr>)\n13\t\n14\timport fs from 'node:fs';\n15\timport { Parser } from 'links-notation';\n16\t\n17\t// ---------- Structured Diagnostics ----------\n18\t// Every parser/evaluator error is reported as a `Diagnostic` with an error\n19\t// code, human-readable message, and source span (file/line/col, 1-based).\n20\t// See `docs/DIAGNOSTICS.md` for the full code list.\n21\tclass Diagnostic {\n22\t  constructor({ code, message, span }) {\n23\t    this.code = code;\n24\t    this.message = message;\n25\t    this.span = span || { file: null, line: 1, col: 1, length: 0 };\n26\t  }\n27\t}\n28\t\n29\t// Internal error class used to carry a code + span across throw sites so the\n30\t// outer `evaluate()` boundary can convert them into Diagnostics.\n31\tclass RmlError extends Error {\n32\t  constructor(code, message, span) {\n33\t    super(message);\n34\t    this.name = 'RmlError';\n35\t    this.code = code;\n36\t    this.span = span || null;\n37\t  }\n38\t}\n39\t\n40\t// Format a diagnostic for human-readable CLI output:\n41\t//   <file>:<line>:<col>: <CODE>: <message>\n42\t//       <source line>\n43\t//       ^\n44\tfunction formatDiagnostic(diag, sourceText) {\n45\t  const span = diag.span || { file: null, line: 1, col: 1, length: 0 };\n46\t  const file = span.file || '<input>';\n47\t  const lines = [`${file}:${span.line}:${span.col}: ${diag.code}: ${diag.message}`];\n48\t  if (typeof sourceText === 'string') {\n49\t    const srcLines = sourceText.split('\\n');\n50\t    const lineText = srcLines[span.line - 1];\n51\t    if (lineText !== undefined) {\n52\t      lines.push(lineText);\n53\t      const caretCount = Math.max(1, span.length || 1);\n54\t      lines.push(' '.repeat(Math.max(0, span.col - 1)) + '^'.repeat(caretCount));\n55\t    }\n56\t  }\n57\t  return lines.join('\\n');\n58\t}\n59\t\n60\t// ---------- helpers: canonical keys & tokenization of a single link string ----------\n61\tfunction tokenizeOne(s) {\n62\t  // s is a single-link string like \"( (a = a) has probability 1 )\"\n63\t  // Strip inline comments (everything after #) but balance parens\n64\t  const commentIdx = s.indexOf('#');\n65\t  if (commentIdx !== -1) {\n66\t    s = s.substring(0, commentIdx);\n67\t    // Count unmatched opening parens and add closing parens to balance\n68\t    let depth = 0;\n69\t    for (let i = 0; i < s.length; i++) {\n70\t      if (s[i] === '(') depth++;\n71\t      else if (s[i] === ')') depth--;\n72\t    }\n73\t    // Add missing closing parens\n74\t    while (depth > 0) {\n75\t      s += ')';\n76\t      depth--;\n77\t    }\n78\t  }\n79\t\n80\t  const out = [];\n81\t  let i = 0;\n82\t  const isWS = c => /\\s/.test(c);\n83\t  while (i < s.length) {\n84\t    const c = s[i];\n85\t    if (isWS(c)) { i++; continue; }\n86\t    if (c === '(' || c === ')') { out.push(c); i++; continue; }\n87\t    let j = i;\n88\t    while (j < s.length && !isWS(s[j]) && s[j] !== '(' && s[j] !== ')') j++;\n89\t    out.push(s.slice(i, j));\n90\t    i = j;\n91\t  }\n92\t  return out;\n93\t}\n94\tfunction parseOne(tokens) {\n95\t  let i = 0;\n96\t  function read() {\n97\t    if (tokens[i] !== '(') throw new RmlError('E002', 'expected \"(\"');\n98\t    i++;\n99\t    const arr = [];\n100\t    while (i < tokens.length && tokens[i] !== ')') {\n101\t      if (tokens[i] === '(') arr.push(read());\n102\t      else { arr.push(tokens[i]); i++; }\n103\t    }\n104\t    if (tokens[i] !== ')') throw new RmlError('E002', 'expected \")\"');\n105\t    i++;\n106\t    return arr;\n107\t  }\n108\t  const ast = read();\n109\t  if (i !== tokens.length) throw new RmlError('E002', 'extra tokens after link');\n110\t  return ast;\n111\t}\n112\tconst isNum = s => /^-?(\\d+(\\.\\d+)?|\\.\\d+)$/.test(s);\n113\tconst clamp01 = x => Math.max(0, Math.min(1, x));\n114\t\n115\t// ---------- Decimal-precision arithmetic ----------\n116\t// Round to at most `digits` significant decimal places to eliminate\n117\t// IEEE-754 floating-point artefacts (e.g. 0.1+0.2 → 0.3, not 0.30000000000000004).\n118\tconst DECIMAL_PRECISION = 12;\n119\tfunction decRound(x) {\n120\t  if (!Number.isFinite(x)) return x;\n121\t  return +(Math.round(x + 'e' + DECIMAL_PRECISION) + 'e-' + DECIMAL_PRECISION);\n122\t}\n123\tfunction keyOf(node) {\n124\t  if (Array.isArray(node)) return '(' + node.map(keyOf).join(' ') + ')';\n125\t  return String(node);\n126\t}\n127\tfunction isStructurallySame(a,b){\n128\t  if (Array.isArray(a) && Array.isArray(b)){\n129\t    if (a.length !== b.length) return false;\n130\t    for (let i=0;i<a.length;i++) if (!isStructurallySame(a[i],b[i])) return false;\n131\t    return true;\n132\t  }\n133\t  return String(a) === String(b);\n134\t}\n135\t\n136\t// ---------- Quantization for N-valued logics ----------\n137\t// Given N discrete levels and a range [lo, hi], quantize a value to the nearest level.\n138\t// For N=2 (Boolean): levels are {lo, hi} (e.g. {0, 1} or {-1, 1})\n139\t// For N=3 (ternary): levels are {lo, mid, hi} (e.g. {0, 0.5, 1} or {-1, 0, 1})\n140\t// For N=0 or Infinity (continuous): no quantization\n141\t// See: https://en.wikipedia.org/wiki/Many-valued_logic\n142\tfunction quantize(x, valence, lo, hi) {\n143\t  if (valence < 2) return x; // unary or continuous — no quantization\n144\t  const step = (hi - lo) / (valence - 1);\n145\t  const level = Math.round((x - lo) / step);\n146\t  return lo + Math.max(0, Math.min(valence - 1, level)) * step;\n147\t}\n148\t\n149\t// ---------- Environment ----------\n150\tclass Env {\n151\t  constructor(options){\n152\t    const opts = options || {};\n153\t    this.terms = new Set();                     // declared terms (via (x: x is x))\n154\t    this.assign = new Map();                    // key(expr) -> truth value\n155\t    this.symbolProb = new Map();                // optional symbol priors if you want (x: 0.7)\n156\t    this.types = new Map();                     // key(expr) -> type expression (as string)\n157\t    this.lambdas = new Map();                   // name -> { param, paramType, body } for named lambdas\n158\t\n159\t    // Range: [lo, hi] — default [0, 1] (standard probabilistic)\n160\t    // Use [-1, 1] for balanced/symmetric range\n161\t    // See: https://en.wikipedia.org/wiki/Balanced_ternary\n162\t    this.lo = opts.lo !== undefined ? opts.lo : 0;\n163\t    this.hi = opts.hi !== undefined ? opts.hi : 1;\n164\t\n165\t    // Valence: number of discrete truth values (0 or Infinity = continuous)\n166\t    // N=1: unary logic (trivial, only one truth value)\n167\t    // N=2: binary/Boolean logic — https://en.wikipedia.org/wiki/Boolean_algebra\n168\t    // N=3: ternary logic — https://en.wikipedia.org/wiki/Three-valued_logic\n169\t    // N=4+: N-valued logic — https://en.wikipedia.org/wiki/Many-valued_logic\n170\t    // N=0/Infinity: continuous probabilistic / fuzzy logic — https://en.wikipedia.org/wiki/Fuzzy_logic\n171\t    this.valence = opts.valence !== undefined ? opts.valence : 0;\n172\t\n173\t    // ops (redefinable)\n174\t    this.ops = new Map(Object.entries({\n175\t      'not': (x)=> this.hi - (x - this.lo),  // negation: mirrors around midpoint\n176\t      'and': (...xs)=> xs.length ? xs.reduce((a,b)=>a+b,0)/xs.length : this.lo, // avg\n177\t      'or' : (...xs)=> xs.length ? Math.max(...xs) : this.lo,\n178\t      // Belnap operators: AND-altering operators for four-valued logic\n179\t      // \"both\" (gullibility): avg — contradiction resolves to midpoint\n180\t      'both': (...xs)=> xs.length ? decRound(xs.reduce((a,b)=>a+b,0)/xs.length) : this.lo,\n181\t      // \"neither\" (consensus): product — gap resolves to zero (no info propagates)\n182\t      'neither': (...xs)=> xs.length ? decRound(xs.reduce((a,b)=>a*b,1)) : this.lo,\n183\t      '='  : (L,R,ctx)=> {\n184\t        // If assigned explicitly, use that (check both prefix and infix key forms)\n185\t        const kPrefix = keyOf(['=',L,R]);\n186\t        if (this.assign.has(kPrefix)) return this.assign.get(kPrefix);\n187\t        const kInfix = keyOf([L,'=',R]);\n188\t        if (this.assign.has(kInfix)) return this.assign.get(kInfix);\n189\t        // Default: syntactic equality of terms/trees\n190\t        return isStructurallySame(L,R) ? this.hi : this.lo;\n191\t      },\n192\t    }));\n193\t    // sugar: \"!=\" as not of \"=\" (can be redefined)\n194\t    this.defineOp('!=', (...args)=> this.getOp('not')( this.getOp('=')(...args) ));\n195\t\n196\t    // Arithmetic operators (decimal-precision by default)\n197\t    this.defineOp('+', (a,b)=> decRound(a + b));\n198\t    this.defineOp('-', (a,b)=> decRound(a - b));\n199\t    this.defineOp('*', (a,b)=> decRound(a * b));\n200\t    this.defineOp('/', (a,b)=> b === 0 ? 0 : decRound(a / b));\n201\t\n202\t    // Initialize truth constants: true, false, unknown, undefined\n203\t    // These are predefined symbol probabilities based on the current range.\n204\t    // By default: (false: min(range)), (true: max(range)),\n205\t    //             (unknown: mid(range)), (undefined: mid(range))\n206\t    // They can be redefined by the user via (true: <value>), (false: <value>), etc.\n207\t    this._initTruthConstants();\n208\t  }\n209\t\n210\t  // Clamp and optionally quantize a value to the valid range\n211\t  clamp(x) {\n212\t    const clamped = Math.max(this.lo, Math.min(this.hi, x));\n213\t    if (this.valence >= 2) return quantize(clamped, this.valence, this.lo, this.hi);\n214\t    return clamped;\n215\t  }\n216\t\n217\t  // Parse a numeric string respecting current range\n218\t  toNum(s) {\n219\t    return this.clamp(parseFloat(s));\n220\t  }\n221\t\n222\t  // Midpoint of the range (useful for paradox resolution, default symbol prob, etc.)\n223\t  get mid() { return (this.lo + this.hi) / 2; }\n224\t\n225\t  // Initialize truth constants based on current range.\n226\t  // (false: min(range)), (true: max(range)),\n227\t  // (unknown: mid(range)), (undefined: mid(range))\n228\t  _initTruthConstants() {\n229\t    this.symbolProb.set('true', this.hi);\n230\t    this.symbolProb.set('false', this.lo);\n231\t    this.symbolProb.set('unknown', this.mid);\n232\t    this.symbolProb.set('undefined', this.mid);\n233\t    // Belnap's four-valued logic operators:\n234\t    // \"both\" and \"neither\" are AND-altering operators (not constants).\n235\t    // \"both\" = conjunction under contradiction (gullibility) — default: avg\n236\t    //   (true both false) = 0.5 (both true and false → contradiction/paradox)\n237\t    // \"neither\" = conjunction under gap (consensus) — default: product\n238\t    //   (true neither false) = 0 (neither true nor false → gap/no info)\n239\t    // Both are redefinable via (both: min), (neither: max), etc.\n240\t    // See: https://en.wikipedia.org/wiki/Four-valued_logic#Belnap\n241\t  }\n242\t\n243\t  getOp(name){\n244\t    if (!this.ops.has(name)) throw new RmlError('E001', `Unknown op: ${name}`);\n245\t    return this.ops.get(name);\n246\t  }\n247\t  defineOp(name, fn){ this.ops.set(name, fn); }\n248\t\n249\t  setExprProb(exprNode, p){\n250\t    this.assign.set(keyOf(exprNode), this.clamp(p));\n251\t  }\n252\t  setType(exprNode, typeExpr){\n253\t    const key = typeof exprNode === 'string' ? exprNode : keyOf(exprNode);\n254\t    this.types.set(key, typeof typeExpr === 'string' ? typeExpr : keyOf(typeExpr));\n255\t  }\n256\t  getType(exprNode){\n257\t    const key = typeof exprNode === 'string' ? exprNode : keyOf(exprNode);\n258\t    return this.types.get(key) || null;\n259\t  }\n260\t  setLambda(name, param, paramType, body){\n261\t    this.lambdas.set(name, { param, paramType, body });\n262\t  }\n263\t  getLambda(name){\n264\t    return this.lambdas.get(name) || null;\n265\t  }\n266\t  setSymbolProb(sym, p){ this.symbolProb.set(sym, this.clamp(p)); }\n267\t  getSymbolProb(sym){ return this.symbolProb.has(sym) ? this.symbolProb.get(sym) : this.mid; }\n268\t}\n269\t\n270\t// ---------- Binding parser ----------\n271\t// Parse a binding form in two supported syntaxes:\n272\t// 1. Colon form: (x: A) as ['x:', A] — standard LiNo link definition syntax\n273\t// 2. Prefix type form: (A x) as ['A', 'x'] — type-first notation for lambda/Pi bindings\n274\t//    e.g. (Natural x), used in (lambda (Natural x) body)\n275\t// Returns { paramName, paramType } or null if not a valid binding.\n276\tfunction parseBinding(binding) {\n277\t  if (!Array.isArray(binding)) return null;\n278\t  // ['x:', A] — two elements where first ends with colon (standard LiNo link definition)\n279\t  if (binding.length === 2 && typeof binding[0] === 'string' && binding[0].endsWith(':')) {\n280\t    return { paramName: binding[0].slice(0, -1), paramType: binding[1] };\n281\t  }\n282\t  // ['A', 'x'] — prefix type form: type name first, then variable name\n283\t  // Type names must start with uppercase (convention from Lean/Rocq)\n284\t  if (binding.length === 2 && typeof binding[0] === 'string' && typeof binding[1] === 'string'\n285\t      && /^[A-Z]/.test(binding[0]) && !binding[1].endsWith(':')) {\n286\t    return { paramName: binding[1], paramType: binding[0] };\n287\t  }\n288\t  return null;\n289\t}\n290\t\n291\t// ---------- Multi-binding parser ----------\n292\t// Parse comma-separated bindings: (Natural x, Natural y) → [{paramName:'x', paramType:'Natural'}, ...]\n293\t// Tokens arrive as ['Natural', 'x,', 'Natural', 'y'] or ['Natural', 'x'] (single binding)\n294\tfunction parseBindings(binding) {\n295\t  if (!Array.isArray(binding)) return null;\n296\t  // Try single binding first\n297\t  const single = parseBinding(binding);\n298\t  if (single) return [single];\n299\t  // Try comma-separated: flatten tokens, split by commas\n300\t  const tokens = [];\n301\t  for (const tok of binding) {\n302\t    if (typeof tok === 'string') {\n303\t      // Split tokens that end with comma: 'x,' → 'x', separator\n304\t      if (tok.endsWith(',')) {\n305\t        tokens.push(tok.slice(0, -1));\n306\t        tokens.push(',');\n307\t      } else {\n308\t        tokens.push(tok);\n309\t      }\n310\t    } else {\n311\t      tokens.push(tok);\n312\t    }\n313\t  }\n314\t  // Group into pairs separated by commas\n315\t  const bindings = [];\n316\t  let i = 0;\n317\t  while (i < tokens.length) {\n318\t    if (tokens[i] === ',') { i++; continue; }\n319\t    if (i + 1 < tokens.length && typeof tokens[i] === 'string' && typeof tokens[i+1] === 'string' && tokens[i+1] !== ',') {\n320\t      const pair = parseBinding([tokens[i], tokens[i+1]]);\n321\t      if (pair) {\n322\t        bindings.push(pair);\n323\t        i += 2;\n324\t        continue;\n325\t      }\n326\t    }\n327\t    return null; // invalid binding format\n328\t  }\n329\t  return bindings.length > 0 ? bindings : null;\n330\t}\n331\t\n332\t// ---------- Substitution (for beta-reduction) ----------\n333\t// Substitute all occurrences of variable `name` with `replacement` in `expr`.\n334\t// Both expr and replacement can be strings or arrays (AST nodes).\n335\tfunction substitute(expr, name, replacement) {\n336\t  if (typeof expr === 'string') {\n337\t    return expr === name ? replacement : expr;\n338\t  }\n339\t  if (Array.isArray(expr)) {\n340\t    // Don't substitute inside a binding that shadows the variable\n341\t    if (expr.length === 3