t: Option<Node>,\n1615\t    pub lino: Option<String>,\n1616\t}\n1617\t\n1618\t/// Result value from evaluating a formalization.\n1619\t#[derive(Debug, Clone, PartialEq)]\n1620\tpub enum FormalizationResultValue {\n1621\t    Number(f64),\n1622\t    TruthValue(f64),\n1623\t    Type(String),\n1624\t    Partial(String),\n1625\t}\n1626\t\n1627\t/// Evaluation result for the meta-expression adapter.\n1628\t#[derive(Debug, Clone, PartialEq)]\n1629\tpub struct FormalizationEvaluation {\n1630\t    pub computable: bool,\n1631\t    pub formalization_level: u8,\n1632\t    pub unknowns: Vec<String>,\n1633\t    pub result: FormalizationResultValue,\n1634\t}\n1635\t\n1636\tfn normalize_question_expression(text: &str) -> String {\n1637\t    let mut out = text.trim().trim_end_matches('?').trim().to_string();\n1638\t    let lower = out.to_lowercase();\n1639\t    if lower.starts_with(\"what is \") {\n1640\t        out = out[8..].trim().to_string();\n1641\t    }\n1642\t    out\n1643\t}\n1644\t\n1645\tfn split_top_level_equals(expression: &str) -> Option<(String, String)> {\n1646\t    let mut depth: i32 = 0;\n1647\t    let chars: Vec<char> = expression.chars().collect();\n1648\t    for (i, c) in chars.iter().enumerate() {\n1649\t        match c {\n1650\t            '(' => depth += 1,\n1651\t            ')' => depth -= 1,\n1652\t            '=' if depth == 0 => {\n1653\t                if i > 0 && chars[i - 1] == '!' {\n1654\t                    continue;\n1655\t                }\n1656\t                if i + 1 < chars.len() && chars[i + 1] == '=' {\n1657\t                    continue;\n1658\t                }\n1659\t                let left: String = chars[..i].iter().collect();\n1660\t                let right: String = chars[i + 1..].iter().collect();\n1661\t                return Some((left.trim().to_string(), right.trim().to_string()));\n1662\t            }\n1663\t            _ => {}\n1664\t        }\n1665\t    }\n1666\t    None\n1667\t}\n1668\t\n1669\tfn parse_expression_shape(expression: &str, unwrap_single: bool) -> Result<Node, String> {\n1670\t    let trimmed = expression.trim();\n1671\t    if trimmed.is_empty() {\n1672\t        return Err(\"empty expression\".to_string());\n1673\t    }\n1674\t    let source = if trimmed.starts_with('(') && trimmed.ends_with(')') {\n1675\t        trimmed.to_string()\n1676\t    } else {\n1677\t        format!(\"({})\", trimmed)\n1678\t    };\n1679\t    let mut ast = parse_one(&tokenize_one(&source))?;\n1680\t    loop {\n1681\t        match ast {\n1682\t            Node::List(ref children) if children.len() == 1 => {\n1683\t                if unwrap_single || matches!(&children[0], Node::List(_)) {\n1684\t                    ast = children[0].clone();\n1685\t                    continue;\n1686\t                }\n1687\t                return Ok(ast);\n1688\t            }\n1689\t            _ => return Ok(ast),\n1690\t        }\n1691\t    }\n1692\t}\n1693\t\n1694\tfn unique_unknowns(unknowns: Vec<String>) -> Vec<String> {\n1695\t    let mut out = Vec::new();\n1696\t    for unknown in unknowns {\n1697\t        if !out.contains(&unknown) {\n1698\t            out.push(unknown);\n1699\t        }\n1700\t    }\n1701\t    out\n1702\t}\n1703\t\n1704\tfn partial_formalization(\n1705\t    request: FormalizationRequest,\n1706\t    unknowns: Vec<String>,\n1707\t    formalization_level: u8,\n1708\t) -> Formalization {\n1709\t    Formalization {\n1710\t        source_text: request.text,\n1711\t        interpretation: request.interpretation,\n1712\t        formal_system: request.formal_system,\n1713\t        dependencies: request.dependencies,\n1714\t        computable: false,\n1715\t        formalization_level,\n1716\t        unknowns: unique_unknowns(unknowns),\n1717\t        value_kind: \"partial\".to_string(),\n1718\t        ast: None,\n1719\t        lino: None,\n1720\t    }\n1721\t}\n1722\t\n1723\tfn build_arithmetic_formalization(\n1724\t    expression: &str,\n1725\t    value_kind: &str,\n1726\t) -> Result<(Node, String), String> {\n1727\t    let ast = if value_kind == \"truth-value\" {\n1728\t        if let Some((left, right)) = split_top_level_equals(expression) {\n1729\t            Node::List(vec![\n1730\t                parse_expression_shape(&left, true)?,\n1731\t                Node::Leaf(\"=\".to_string()),\n1732\t                parse_expression_shape(&right, true)?,\n1733\t            ])\n1734\t        } else {\n1735\t            parse_expression_shape(expression, true)?\n1736\t        }\n1737\t    } else {\n1738\t        parse_expression_shape(expression, true)?\n1739\t    };\n1740\t    let lino = key_of(&ast);\n1741\t    Ok((ast, lino))\n1742\t}\n1743\t\n1744\t/// Convert an explicitly selected interpretation into an executable or partial RML formalization.\n1745\tpub fn formalize_selected_interpretation(request: FormalizationRequest) -> Formalization {\n1746\t    let kind = request.interpretation.kind.to_lowercase();\n1747\t    let raw_expression = request\n1748\t        .interpretation\n1749\t        .expression\n1750\t        .clone()\n1751\t        .or_else(|| request.interpretation.lino.clone())\n1752\t        .unwrap_or_else(|| normalize_question_expression(&request.text));\n1753\t    let can_use_arithmetic = request.formal_system == \"rml-arithmetic\"\n1754\t        || request.formal_system == \"arithmetic\"\n1755\t        || kind.starts_with(\"arithmetic\");\n1756\t\n1757\t    if can_use_arithmetic && !raw_expression.is_empty() {\n1758\t        let value_kind =\n1759\t            if kind.contains(\"equal\") || split_top_level_equals(&raw_expression).is_some() {\n1760\t                \"truth-value\"\n1761\t            } else {\n1762\t                \"number\"\n1763\t            };\n1764\t        match build_arithmetic_formalization(&raw_expression, value_kind) {\n1765\t            Ok((ast, lino)) => Formalization {\n1766\t                source_text: request.text,\n1767\t                interpretation: request.interpretation,\n1768\t                formal_system: request.formal_system,\n1769\t                dependencies: request.dependencies,\n1770\t                computable: true,\n1771\t                formalization_level: 3,\n1772\t                unknowns: vec![],\n1773\t                value_kind: value_kind.to_string(),\n1774\t                ast: Some(ast),\n1775\t                lino: Some(lino),\n1776\t            },\n1777\t            Err(error) => partial_formalization(\n1778\t                request,\n1779\t                vec![\"unsupported-arithmetic-shape\".to_string(), error],\n1780\t                1,\n1781\t            ),\n1782\t        }\n1783\t    } else if request.interpretation.lino.is_some() && !raw_expression.is_empty() {\n1784\t        match parse_expression_shape(&raw_expression, false) {\n1785\t            Ok(ast) => {\n1786\t                let lino = key_of(&ast);\n1787\t                Formalization {\n1788\t                    source_text: request.text,\n1789\t                    interpretation: request.interpretation,\n1790\t                    formal_system: request.formal_system,\n1791\t                    dependencies: request.dependencies,\n1792\t                    computable: true,\n1793\t                    formalization_level: 3,\n1794\t                    unknowns: vec![],\n1795\t                    value_kind: if matches!(&ast, Node::List(children) if matches!(children.first(), Some(Node::Leaf(head)) if head == \"?\"))\n1796\t                    {\n1797\t                        \"query\".to_string()\n1798\t                    } else {\n1799\t                        \"truth-value\".to_string()\n1800\t                    },\n1801\t                    ast: Some(ast),\n1802\t                    lino: Some(lino),\n1803\t                }\n1804\t            }\n1805\t            Err(error) => partial_formalization(\n1806\t                request,\n1807\t                vec![\"unsupported-lino-shape\".to_string(), error],\n1808\t                1,\n1809\t            ),\n1810\t        }\n1811\t    } else {\n1812\t        let mut unknowns = vec![\n1813\t            \"selected-subject\".to_string(),\n1814\t            \"selected-relation\".to_string(),\n1815\t            \"evidence-source\".to_string(),\n1816\t            \"formal-shape\".to_string(),\n1817\t        ];\n1818\t        for dependency in &request.dependencies {\n1819\t            if dependency.status == \"missing\"\n1820\t                || dependency.status == \"unknown\"\n1821\t                || dependency.status == \"partial\"\n1822\t            {\n1823\t                unknowns.push(format!(\"dependency:{}\", dependency.id));\n1824\t            }\n1825\t        }\n1826\t        partial_formalization(request, unknowns, 2)\n1827\t    }\n1828\t}\n1829\t\n1830\t/// Evaluate a formalization when it has an executable RML AST.\n1831\tpub fn evaluate_formalization(formalization: &Formalization) -> FormalizationEvaluation {\n1832\t    let Some(ast) = formalization.ast.as_ref() else {\n1833\t        return FormalizationEvaluation {\n1834\t            computable: false,\n1835\t            formalization_level: formalization.formalization_level,\n1836\t            unknowns: formalization.unknowns.clone(),\n1837\t            result: FormalizationResultValue::Partial(\"unknown\".to_string()),\n1838\t        };\n1839\t    };\n1840\t\n1841\t    if !formalization.computable {\n1842\t        return FormalizationEvaluation {\n1843\t            computable: false,\n1844\t            formalization_level: formalization.formalization_level,\n1845\t            unknowns: formalization.unknowns.clone(),\n1846\t            result: FormalizationResultValue::Partial(\"unknown\".to_string()),\n1847\t        };\n1848\t    }\n1849\t\n1850\t    let mut env = Env::new(None);\n1851\t    let evaluated = eval_node(ast, &mut env);\n1852\t    let result = match formalization.value_kind.as_str() {\n1853\t        \"truth-value\" => FormalizationResultValue::TruthValue(evaluated.as_f64()),\n1854\t        \"query\" => match evaluated {\n1855\t            EvalResult::TypeQuery(s) => FormalizationResultValue::Type(s),\n1856\t            other => FormalizationResultValue::Number(other.as_f64()),\n1857\t        },\n1858\t        _ => FormalizationResultValue::Number(evaluated.as_f64()),\n1859\t    };\n1860\t\n1861\t    FormalizationEvaluation {\n1862\t        computable: true,\n1863\t        formalization_level: formalization.formalization_level,\n1864\t        unknowns: vec![],\n1865\t        result,\n1866\t    }\n1867\t}\n1868\t\n1869\t// ========== Runner ==========\n1870\t\n1871\t/// A result from running a query: either a numeric value or a type string.\n1872\t#[derive(Debug, Clone, PartialEq)]\n1873\tpub enum RunResult {\n1874\t    Num(f64),\n1875\t    Type(String),\n1876\t}\n1877\t\n1878\t/// Evaluate a complete LiNo knowledge base and return both results and any\n1879\t/// diagnostics emitted by the parser, evaluator, or type checker.\n1880\t///\n1881\t/// Each diagnostic carries a code (`E001`, `E002`, ...), a message, and a\n1882\t/// source span (1-based line/col).  See `docs/DIAGNOSTICS.md` for the\n1883\t/// full code list.  Errors do not abort evaluation: independent forms\n1884\t/// continue to be processed after a failing one.\n1885\tpub fn evaluate(text: &str, file: Option<&str>, options: Option<EnvOptions>) -> EvaluateResult {\n1886\t    let mut diagnostics: Vec<Diagnostic> = Vec::new();\n1887\t    let spans = compute_form_spans(text, file);\n1888\t\n1889\t    let links = parse_lino(text);\n1890\t    let forms: Vec<Node> = links\n1891\t        .iter()\n1892\t        .filter(|link_str| {\n1893\t            let s = link_str.trim();\n1894\t            !(s.starts_with(\"(#\") && s.chars().nth(2).map_or(false, |c| c.is_whitespace()))\n1895\t        })\n1896\t        .filter_map(|link_str| {\n1897\t            let toks = tokenize_one(link_str);\n1898\t            match parse_one(&toks) {\n1899\t                Ok(node) => Some(node),"
