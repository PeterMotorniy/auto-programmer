        "tool_use_id": "toolu_01FKXy4WTSBdKufJjBmZb7LZ",
        "type": "tool_result",
        "content": "1\t// Tests for structured diagnostics (issue #28).\n2\t// Covers the evaluate() API, error codes, source spans, and CLI-style\n3\t// formatting. The Rust suite mirrors these cases in\n4\t// rust/tests/diagnostics_tests.rs to keep the two implementations in lock-step.\n5\t\n6\timport { describe, it } from 'node:test';\n7\timport assert from 'node:assert';\n8\timport {\n9\t  evaluate,\n10\t  formatDiagnostic,\n11\t  Diagnostic,\n12\t  RmlError,\n13\t  computeFormSpans,\n14\t} from '../src/rml-links.mjs';\n15\t\n16\tdescribe('evaluate() returns a structured result', () => {\n17\t  it('produces results and an empty diagnostics array on a clean input', () => {\n18\t    const out = evaluate('(valence: 2)\\n(p has probability 1)\\n(? p)');\n19\t    assert.ok(Array.isArray(out.results));\n20\t    assert.ok(Array.isArray(out.diagnostics));\n21\t    assert.strictEqual(out.diagnostics.length, 0);\n22\t    assert.strictEqual(out.results.length, 1);\n23\t    assert.strictEqual(out.results[0], 1);\n24\t  });\n25\t\n26\t  it('does not throw on bad input — returns a Diagnostic instead', () => {\n27\t    let threw = false;\n28\t    let out;\n29\t    try {\n30\t      out = evaluate('(=: missing_op identity)');\n31\t    } catch (_) {\n32\t      threw = true;\n33\t    }\n34\t    assert.strictEqual(threw, false, 'evaluate() must not throw');\n35\t    assert.ok(out.diagnostics.length >= 1);\n36\t  });\n37\t});\n38\t\n39\tdescribe('Diagnostic shape and error codes', () => {\n40\t  it('E001 — unknown op surfaces with file/line/col span', () => {\n41\t    const out = evaluate('(=: missing_op identity)', { file: 'inline.lino' });\n42\t    assert.strictEqual(out.diagnostics.length, 1);\n43\t    const d = out.diagnostics[0];\n44\t    assert.ok(d instanceof Diagnostic);\n45\t    assert.strictEqual(d.code, 'E001');\n46\t    assert.match(d.message, /Unknown op/);\n47\t    assert.strictEqual(d.span.file, 'inline.lino');\n48\t    assert.strictEqual(d.span.line, 1);\n49\t    assert.strictEqual(d.span.col, 1);\n50\t  });"
      }
    ]
  },
  "parent_tool_use_id": null,
  "session_id": "28a784f8-3dce-46c6-bfe0-3826da2572a7",
  "uuid": "c4bf6607-6a97-4123-8e96-6129ac453572",
  "timestamp": "2026-04-29T16:01:50.543Z",
  "tool_use_result": {
    "type": "text",
    "file": {
      "filePath": "/tmp/gh-issue-solver-1777477820370/js/tests/diagnostics.test.mjs",
      "content": "// Tests for structured diagnostics (issue #28).\n// Covers the evaluate() API, error codes, source spans, and CLI-style\n// formatting. The Rust suite mirrors these cases in\n// rust/tests/diagnostics_tests.rs to keep the two implementations in lock-step.\n\nimport { describe, it } from 'node:test';\nimport assert from 'node:assert';\nimport {\n  evaluate,\n  formatDiagnostic,\n  Diagnostic,\n  RmlError,\n  computeFormSpans,\n} from '../src/rml-links.mjs';\n\ndescribe('evaluate() returns a structured result', () => {\n  it('produces results and an empty diagnostics array on a clean input', () => {\n    const out = evaluate('(valence: 2)\\n(p has probability 1)\\n(? p)');\n    assert.ok(Array.isArray(out.results));\n    assert.ok(Array.isArray(out.diagnostics));\n    assert.strictEqual(out.diagnostics.length, 0);\n    assert.strictEqual(out.results.length, 1);\n    assert.strictEqual(out.results[0], 1);\n  });\n\n  it('does not throw on bad input — returns a Diagnostic instead', () => {\n    let threw = false;\n    let out;\n    try {\n      out = evaluate('(=: missing_op identity)');\n    } catch (_) {\n      threw = true;\n    }\n    assert.strictEqual(threw, false, 'evaluate() must not throw');\n    assert.ok(out.diagnostics.length >= 1);\n  });\n});\n\ndescribe('Diagnostic shape and error codes', () => {\n  it('E001 — unknown op surfaces with file/line/col span', () => {\n    const out = evaluate('(=: missing_op identity)', { file: 'inline.lino' });\n    assert.strictEqual(out.diagnostics.length, 1);\n    const d = out.diagnostics[0];\n    assert.ok(d instanceof Diagnostic);\n    assert.strictEqual(d.code, 'E001');\n    assert.match(d.message, /Unknown op/);\n    assert.strictEqual(d.span.file, 'inline.lino');\n    assert.strictEqual(d.span.line, 1);\n    assert.strictEqual(d.span.col, 1);\n  });",
      "numLines": 50,
      "startLine": 1,
      "totalLines": 138
    }
  }
}
