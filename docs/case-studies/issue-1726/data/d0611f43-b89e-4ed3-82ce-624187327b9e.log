t off = 0; off < text.length; off++) {\n790\t    const ch = text[off];\n791\t    if (ch === '\\n') {\n792\t      inLineComment = false;\n793\t      lineNum++;\n794\t      colNum = 1;\n795\t      continue;\n796\t    }\n797\t    if (inLineComment) { colNum++; continue; }\n798\t    // Detect a full-line comment (line begins with optional whitespace + #).\n799\t    if (ch === '#' && depth === 0) {\n800\t      // Check if the line so far contains only whitespace.\n801\t      const lineSoFar = lines[lineNum - 1].slice(0, colNum - 1);\n802\t      if (/^[ \\t]*$/.test(lineSoFar)) {\n803\t        inLineComment = true;\n804\t        colNum++;\n805\t        continue;\n806\t      }\n807\t    }\n808\t    if (ch === '(') {\n809\t      if (depth === 0) {\n810\t        pendingStart = { line: lineNum, col: colNum };\n811\t      }\n812\t      depth++;\n813\t    } else if (ch === ')') {\n814\t      depth--;\n815\t      if (depth === 0 && pendingStart) {\n816\t        spans.push({ file: file || null, line: pendingStart.line, col: pendingStart.col, length: 1 });\n817\t        pendingStart = null;\n818\t      }\n819\t    }\n820\t    colNum++;\n821\t  }\n822\t  return spans;\n823\t}\n824\t\n825\t// New structured evaluator: returns { results, diagnostics }. Existing\n826\t// callers can keep using `run`, which now delegates to this and surfaces only\n827\t// the result list (preserving its previous signature for tests/CLI consumers).\n828\tfunction evaluate(code, options) {\n829\t  const opts = options || {};\n830\t  const file = opts.file || null;\n831\t  const sourceText = String(code);\n832\t  const env = new Env(opts.env || opts);\n833\t  const results = [];\n834\t  const diagnostics = [];\n835\t\n836\t  // Pre-compute spans for each top-level form so error reporting can attach\n837\t  // a real source location even when the parser/evaluator throw deep inside.\n838\t  const formSpans = computeFormSpans(sourceText, file);\n839\t\n840\t  let forms;\n841\t  try {\n842\t    forms = parseL