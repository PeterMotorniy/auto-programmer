v.lo = parseFloat(node[1]);\n386\t    env.hi = parseFloat(node[2]);\n387\t    // Re-initialize ops for new range\n388\t    _reinitOps(env);\n389\t    return 1;\n390\t  }\n391\t\n392\t  // Valence configuration: (valence N) prefix form\n393\t  if (node.length === 2 && node[0] === 'valence' && isNum(node[1])) {\n394\t    env.valence = parseInt(node[1], 10);\n395\t    return 1;\n396\t  }\n397\t\n398\t  // Query: (? expr)\n399\t  if (node[0] === '?') {\n400\t    const v = evalNode(node[1], env);\n401\t    // If inner result is already a query (e.g. from (type of x)), pass it through\n402\t    if (v && typeof v === 'object' && v.query) return v;\n403\t    return { query:true, value: env.clamp(v) };\n404\t  }\n405\t\n406\t  // Infix arithmetic: (A + B), (A - B), (A * B), (A / B)\n407\t  // Arithmetic uses raw numeric values (not clamped to the logic range)\n408\t  if (node.length === 3 && typeof node[1] === 'string' && ['+','-','*','/'].includes(node[1])) {\n409\t    const op = env.getOp(node[1]);\n410\t    const L = evalArith(node[0], env);\n411\t    const R = evalArith(node[2], env);\n412\t    return op(L,R);\n413\t  }\n414\t\n415\t  // Infix AND/OR/BOTH/NEITHER: ((A) and (B))  /  ((A) or (B))  /  ((A) both (B))  /  ((A) neither (B))\n416\t  if (node.length === 3 && typeof node[1] === 'string' && (node[1]==='and' || node[1]==='or' || node[1]==='both' || node[1]==='neither')) {\n417\t    const op = env.getOp(node[1]);\n418\t    const L = evalNode(node[0], env);\n419\t    const R = evalNode(node[2], env);\n420\t    return env.clamp(op(L,R));\n421\t  }\n422\t\n423\t  // Composite natural language operators: (both A and B [and C ...]), (neither A nor B [nor C ...])\n424\t  if (node.length >= 4 && typeof node[0] === 'string' && (node[0]==='both' || node[0]==='neither')) {\n425\t    const sep = node[0]==='both' ? 'and' : 'nor';\n426\t    // Validate pattern: operator, value, sep, value [, sep, value ...]\n427\t    let valid = node.length % 2 === 0; // both + (n values) + (n-1 seps) = 1 + n + (n-1) = 2n, always even\n428\t    if (valid) {\n429\t      for (let i = 2; i < node.length; i += 2) {\n430\t        if (node[i] !== sep) { valid = false; break; }\n431\t      }\n432\t    }\n433\t    if (valid) {\n434\t      const op = env.getOp(node[0]);\n435\t      const vals = [];\n436\t      for (let i = 1; i < node.length; i += 2) {\n437\t        vals.push(evalNode(node[i], env));\n438\t      }\n439\t      return env.clamp(op(...vals));\n440\t    }\n441\t  }\n442\t\n443\t  // Infix equality/inequality: (L = R), (L != R)\n444\t  if (node.length === 3 && typeof node[1] === 'string' && (node[1]==='=' || node[1]==='!=')) {\n445\t    const op = env.getOp(node[1]);\n446\t    // Equality checks assigned probability first, then structural equality,\n447\t    // then falls back to numeric comparison of evaluated values (decimal-precision)\n448\t    const raw = op(node[0], node[2], keyOf);\n449\t    // If structural/assigned equality already gave a definitive answer, use it\n450\t    if (raw === env.hi || raw === env.lo) {\n451\t      // Check if there's an explicit assignment — if so, trust it\n452\t      const kPrefix = keyOf(['=',node[0],node[2]]);\n453\t      const kInfix = keyOf([node[0],'=',node[2]]);\n454\t      if (env.assign.has(kPrefix) || env.assign.has(kInfix) || isStructurallySame(node[0], node[2])) {\n455\t        return env.clamp(raw);\n456\t      }\n457\t      // No explicit assignment and not structurally same — try numeric comparison\n458\t      const L = evalNode(node[0], env);\n459\t      const R = evalNode(node[2], env);\n460\t      const numEq = decRound(L) === decRound(R) ? env.hi : env.lo;\n461\t      if (node[1] === '!=') return env.clamp(env.getOp('not')(numEq));\n462\t      return env.clamp(numEq);\n463\t    }\n464\t    return env.clamp(raw);\n465\t  }\n466\t\n467\t  // ---------- Type System: \"everything is a link\" ----------\n468\t\n469\t  // Type universe: (Type N) — the sort at universe level N\n470\t  if (node.length === 2 && node[0] === 'Type') {\n471\t    const level = isNum(node[1]) ? parseInt(node[1], 10) : 0;\n472\t    // (Type N) has type (Type N+1)\n473\t    env.setType(node, ['Type', String(level + 1)]);\n474\t    return 1; // valid expression\n475\t  }\n476\t\n477\t  // Prop: (Prop) is sugar for (Type 0) in the propositions-as-types interpretation\n478\t  if (node.length === 1 && node[0] === 'Prop') {\n479\t    env.setType(['Prop'], ['Type', '1']);\n480\t    return 1;\n481\t  }\n482\t\n483\t  // Dependent product (Pi-type): (Pi (A x) B) or (Pi (x: A) B)\n484\t  if (node.length === 3 && node[0] === 'Pi') {\n485\t    const binding = node[1];\n486\t    const parsed = parseBinding(binding);\n487\t    if (parsed) {\n488\t      const { paramName, paramType } = parsed;\n489\t      env.terms.add(paramName);\n490\t      env.setType(paramName, paramType);\n491\t      env.setType(node, ['Type', '0']);\n492\t    }\n493\t    return 1;\n494\t  }\n495\t\n496\t  // Lambda abstraction: (lambda (A x) body) or (lambda (x: A) body)\n497\t  // Also supports multi-param: (lambda (A x, B y) body)\n498\t  if (node.length === 3 && node[0] === 'lambda') {\n499\t    const binding = node[1];\n500\t    const bindings = parseBindings(binding);\n501\t    if (bindings && bindings.length > 0) {\n502\t      // For single binding — standard case\n503\t      const { paramName, paramType } = bindings[0];\n504\t      const body = node[2];\n505\t      env.terms.add(paramName);\n506\t      env.setType(paramName, paramType);\n507\t      // Register additional bindings\n508\t      for (let i = 1; i < bindings.length; i++) {\n509\t        env.terms.add(bindings[i].paramName);\n510\t        env.setType(bindings[i].paramName, bindings[i].paramType);\n511\t      }\n512\t      const bodyType = env.getType(body);\n513\t      const paramTypeKey = typeof paramType === 'string' ? paramType : keyOf(paramType);\n514\t      const bodyTypeKey = bodyType || 'unknown';\n515\t      env.setType(node, '(Pi (' + paramTypeKey + ' ' + paramName + ') ' + bodyTypeKey + ')');\n516\t    }\n517\t    return 1;\n518\t  }\n519\t\n520\t  // Application: (apply f x) — explicit application with beta-reduction\n521\t  if (node.length === 3 && node[0] === 'apply') {\n522\t    const fn = node[1];\n523\t    const arg = node[2];\n524\t\n525\t    // Check if fn is a lambda: (lambda (A x) body)\n526\t    if (Array.isArray(fn) && fn.length === 3 && fn[0] === 'lambda') {\n527\t      const parsed = parseBinding(fn[1]);\n528\t      if (parsed) {\n529\t        const body = fn[2];\n530\t        const result = substitute(body, parsed.paramName, arg);\n531\t        return evalNode(result, env);\n532\t      }\n533\t    }\n534\t\n535\t    // Check if fn is a named lambda\n536\t    if (typeof fn === 'string') {\n537\t      const lambda = env.getLambda(fn);\n538\t      if (lambda) {\n539\t        const result = substitute(lambda.body, lambda.param, arg);\n540\t        return evalNode(result, env);\n541\t      }\n542\t    }\n543\t\n544\t    // Otherwise evaluate fn and arg normally\n545\t    const fVal = evalNode(fn, env);\n546\t    const aVal = evalNode(arg, env);\n547\t    return typeof fVal === 'number' ? fVal : (fVal && fVal.value !== undefined ? fVal.value : 0);\n548\t  }\n549\t\n550\t  // Type query: (type of expr) — returns the type of an expression\n551\t  // e.g. (? (type of x)) → returns the type string\n552\t  if (node.length === 3 && node[0] === 'type' && node[1] === 'of') {\n553\t    const expr = node[2];\n554\t    const typeStr = env.getType(expr);\n555\t    if (typeStr) {\n556\t      return { query: true, value: typeStr, typeQuery: true };\n557\t    }\n558\t    return { query: true, value: 'unknown', typeQuery: true };\n559\t  }\n560\t\n561\t  // Type check query: (expr of Type) — checks if expr has the given type\n562\t  // e.g. (? (x of Natural)) → returns 1 or 0\n563\t  if (node.length === 3 && node[1] === 'of') {\n564\t    const expr = node[0];\n565\t    const expectedType = node[2];\n566\t    const actualType = env.getType(expr);\n567\t    if (actualType) {\n568\t      const expectedKey = typeof expectedType === 'string' ? expectedType : keyOf(expectedType);\n569\t      return actualType === expectedKey ? env.hi : env.lo;\n570\t    }\n571\t    return env.lo;\n572\t  }\n573\t\n574\t  // Prefix: (not X), (and X Y ...), (or X Y ...)\n575\t  const [head, ...args] = node;\n576\t  if (typeof head === 'string' && env.ops.has(head)) {\n577\t    const op = env.getOp(head);\n578\t    const vals = args.map(a => evalNode(a, env));\n579\t    return env.clamp(op(...vals));\n580\t  }\n581\t\n582\t  // Fall through: prefix application (f x y ...) for named lambdas\n583\t  if (typeof head === 'string' && args.length >= 1) {\n584\t    const lambda = env.getLambda(head);\n585\t    if (lambda) {\n586\t      // Apply first argument, then recursively apply rest\n587\t      let result = substitute(lambda.body, lambda.param, args[0]);\n588\t      if (args.length === 1) {\n589\t        return evalNode(result, env);\n590\t      }\n591\t      // Curry: apply remaining args\n592\t      let current = evalNode(result, env);\n593\t      for (let i = 1; i < args.length; i++) {\n594\t        // If current result is a lambda, apply next arg\n595\t        current = evalNode(args[i], env);\n596\t      }\n597\t      return current;\n598\t    }\n599\t  }\n600\t\n601\t  return 0;\n602\t}\n603\t\n604\t// Re-initialize default ops when range changes\n605\tfunction _reinitOps(env) {\n606\t  env.ops.set('not', (x) => env.hi - (x - env.lo));\n607\t  env.ops.set('and', (...xs) => xs.length ? xs.reduce((a,b)=>a+b,0)/xs.length : env.lo);\n608\t  env.ops.set('or', (...xs) => xs.length ? Math.max(...xs) : env.lo);\n609\t  env.ops.set('both', (...xs) => xs.length ? decRound(xs.reduce((a,b)=>a+b,0)/xs.length) : env.lo);\n610\t  env.ops.set('neither', (...xs) => xs.length ? decRound(xs.reduce((a,b)=>a*b,1)) : env.lo);\n611\t  env.ops.set('=', (L,R,ctx) => {\n612\t    const kPrefix = keyOf(['=',L,R]);\n613\t    if (env.assign.has(kPrefix)) return env.assign.get(kPrefix);\n614\t    const kInfix = keyOf([L,'=',R]);\n615\t    if (env.assign.has(kInfix)) return env.assign.get(kInfix);\n616\t    return isStructurallySame(L,R) ? env.hi : env.lo;\n617\t  });\n618\t  env.ops.set('!=', (...args) => env.getOp('not')( env.getOp('=')(...args) ));\n619\t  env.ops.set('+', (a,b) => decRound(a + b));\n620\t  env.ops.set('-', (a,b) => decRound(a - b));\n621\t  env.ops.set('*', (a,b) => decRound(a * b));\n622\t  env.ops.set('/', (a,b) => b === 0 ? 0 : decRound(a / b));\n623\t  // Re-initialize truth constants for new range\n624\t  env._initTruthConstants();\n625\t}\n626\t\n627\tfunction defineForm(head, rhs, env){\n628\t  // Term definition: (a: a is a)  → declare 'a' as a term (no probability assignment)\n629\t  if (rhs.length === 3 && typeof rhs[0]==='string' && rhs[1]==='is' && typeof rhs[2]==='string' && rhs[0]===head && rhs[2]===head) {\n630\t    env.terms.add(head);\n631\t    return 1;\n632\t  }\n633\t\n634\t  // Prefix type notation: (name: TypeName name) → typed self-referential declaration\n635\t  // e.g. (zero: Natural zero), (boolean: Type boolean), (true: Boolean true)\n636\t  if (rhs.length === 2 && typeof rhs[0] === 'string' && typeof rhs[1] === 'string' && rhs[1] === head) {\n637\t    const typeName = rhs[0];\n638\t    // Only if typeName starts with uppercase (type convention) and is not an operator\n639\t    if (/^[A-Z]/.test(typeName)) {\n640\t      env.terms.add(head);\n641\t      env.setType(head, typeName);\n642\t      return 1;\n643\t    }\n644\t  }\n645\t\n646\t  // Prefix type notation with complex type: (name: (Type 0) name) → typed self-referential declaration\n647\t  if (rhs.length === 2 && Array.isArray(rhs[0]) && typeof rhs[1] === 'string' && rhs[1] === head) {\n648\t    const typeExpr = rhs[0];\n649\t    env.terms.add(head);\n650\t    env.setType(head, typeExpr);\n651\t    evalNode(typeExpr, env);\n652\t    return 1;\n653\t  }\n654\t\n655\t  // Typed declaration with complex type expression: (succ: (Pi (Natural n) Natural))\n656\t  // Only complex expressions (arrays) are accepted as type annotations in single-element form.\n657\t  // Simple name type annotations like (x: Natural) are NOT supported — use (x: Natural x) prefix form instead.\n658\t  if (rhs.length === 1 && Array.isArray(rhs[0])) {\n659\t    const isOp = ['=','!=','and','or','not','is','?:','both','neither'].includes(head) || /[=!]/.test(head);\n660\t    if (!isOp) {\n661\t      const typeExpr = rhs[0];\n662\t      env.terms.add(head);\n663\t      env.setType(head, typeExpr);\n664\t      evalNode(typeExpr, env);\n665\t      return 1;\n666\t    }\n667\t  }\n668\t\n669\t  // Range configuration: (range: lo hi) — sets the truth value range\n670\t  if (head === 'range' && rhs.length === 2 && isNum(rhs[0]) && isNum(rhs[1])) {\n671\t    env.lo = parseFloat(rhs[0]);\n672\t    env.hi = parseFloat(rhs[1]);\n673\t    _reinitOps(env);\n674\t    return 1;\n675\t  }\n676\t\n677\t  // Valence configuration: (valence: N) — sets the number of truth values\n678\t  // N=1: unary (trivial), N=2: binary (Boolean), N=3: ternary, N=0: continuous\n679\t  if (head === 'valence' && rhs.length === 1 && isNum(rhs[0])) {\n680\t    env.valence = parseInt(rhs[0], 10);\n681\t    return 1;\n682\t  }\n683\t\n684\t  // Optional symbol prior: (a: 0.7) — not required for your use-case, but allowed\n685\t  if (rhs.length === 1 && isNum(rhs[0])) {\n686\t    env.setSymbolProb(head, parseFloat(rhs[0]));\n687\t    return env.toNum(rhs[0]);\n688\t  }\n689\t\n690\t  // Operator redefinitions\n691\t  if (['=','!=','and','or','not','is','?:','both','neither'].includes(head) || /[=!]/.test(head)) {\n692\t\n693\t    // Composition like: (!=: not =)   or  (=: =) (no-op)\n694\t    if (rhs.length === 2 && typeof rhs[0]==='string' && typeof rhs[1]==='string') {\n695\t      const outer = env.getOp(rhs[0]);\n696\t      const inner = env.getOp(rhs[1]);\n697\t      env.defineOp(head, (...xs) => env.clamp( outer( inner(