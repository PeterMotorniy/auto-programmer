        "type": "tool_result",
        "content": "1\t// Tests for structured diagnostics (issue #28).\n2\t// Mirrors js/tests/diagnostics.test.mjs so any drift between the two\n3\t// implementations fails both test suites.\n4\t\n5\tuse rml::{\n6\t    compute_form_spans, evaluate, format_diagnostic, Diagnostic, RunResult, Span,\n7\t};\n8\t\n9\t#[test]\n10\tfn evaluate_clean_input_returns_results_and_no_diagnostics() {\n11\t    let out = evaluate(\"(valence: 2)\\n(p has probability 1)\\n(? p)\", None, None);\n12\t    assert_eq!(out.diagnostics.len(), 0);\n13\t    assert_eq!(out.results.len(), 1);\n14\t    match &out.results[0] {\n15\t        RunResult::Num(n) => assert!((*n - 1.0).abs() < 1e-9),\n16\t        other => panic!(\"expected numeric result, got {:?}\", other),\n17\t    }\n18\t}\n19\t\n20\t#[test]\n21\tfn evaluate_does_not_panic_on_unknown_op() {\n22\t    let out = evaluate(\"(=: missing_op identity)\", Some(\"inline.lino\"), None);\n23\t    assert!(out.diagnostics.len() >= 1);\n24\t}\n25\t\n26\t#[test]\n27\tfn unknown_op_surfaces_as_e001_with_span() {\n28\t    let out = evaluate(\"(=: missing_op identity)\", Some(\"inline.lino\"), None);\n29\t    assert_eq!(out.diagnostics.len(), 1);\n30\t    let d = &out.diagnostics[0];\n31\t    assert_eq!(d.code, \"E001\");\n32\t    assert!(d.message.contains(\"Unknown op\"), \"msg was: {}\", d.message);\n33\t    assert_eq!(d.span.file.as_deref(), Some(\"inline.lino\"));\n34\t    assert_eq!(d.span.line, 1);\n35\t    assert_eq!(d.span.col, 1);\n36\t}\n37\t\n38\t#[test]\n39\tfn unknown_aggregator_surfaces_as_e004() {\n40\t    let out = evaluate(\"(and: bogus_agg)\", Some(\"agg.lino\"), None);\n41\t    assert_eq!(out.diagnostics.len(), 1);\n42\t    let d = &out.diagnostics[0];\n43\t    assert_eq!(d.code, \"E004\");\n44\t    assert!(\n45\t        d.message.to_lowercase().contains(\"aggregator\"),\n46\t        \"msg was: {}\",\n47\t        d.message\n48\t    );\n49\t    assert_eq!(d.span.line, 1);\n50\t}\n51\t\n52\t#[test]\n53\tfn span_tracks_line_for_form_after_blank_lines() {\n54\t    let src = \"(valence: 2)\\n\\n(=: missing identity)\";\n55\t    let out = evaluate(src, Some(\"multi.lino\"), None);\n56\t    assert_eq!(out.diagnostics.len(), 1);\n57\t    assert_eq!(out.diagnostics[0].code, \"E001\");\n58\t    assert_eq!(out.diagnostics[0].span.line, 3);\n59\t    assert_eq!(out.diagnostics[0].span.col, 1);\n60\t}\n61\t\n62\t#[test]\n63\tfn good_results_are_kept_when_a_later_form_errors() {\n64\t    let src = \"(valence: 2)\\n(p has probability 1)\\n(? p)\\n(=: missing identity)\";\n65\t    let out = evaluate(src, Some(\"mix.lino\"), None);\n66\t    assert_eq!(out.results.len(), 1);\n67\t    match &out.results[0] {\n68\t        RunResult::Num(n) => assert!((*n - 1.0).abs() < 1e-9),\n69\t        other => panic!(\"expected numeric result, got {:?}\", other),\n70\t    }\n71\t    assert_eq!(out.diagnostics.len(), 1);\n72\t    assert_eq!(out.diagnostics[0].code, \"E001\");\n73\t    assert_eq!(out.diagnostics[0].span.line, 4);\n74\t}\n75\t\n76\t#[test]\n77\tfn format_diagnostic_renders_caret_under_offending_token() {\n78\t    let src = \"(=: missing_op identity)\";\n79\t    let out = evaluate(src, Some(\"demo.lino\"), None);\n80\t    assert_eq!(out.diagnostics.len(), 1);\n81\t    let text = format_diagnostic(&out.diagnostics[0], Some(src));\n82\t    let lines: Vec<&str> = text.split('\\n').collect();\n83\t    assert!(\n84\t        lines[0].starts_with(\"demo.lino:1:1: E001:\"),\n85\t        \"line[0] was: {}\",\n86\t        lines[0]\n87\t    );\n88\t    assert_eq!(lines[1], \"(=: missing_op identity)\");\n89\t    assert_eq!(lines[2], \"^\");\n90\t}\n91\t\n92\t#[test]\n93\tfn format_diagnostic_for_second_line() {\n94\t    let src = \"(valence: 2)\\n(=: missing_op identity)\";\n95\t    let out = evaluate(src, Some(\"caret.lino\"), None);\n96\t    assert_eq!(out.diagnostics.len(), 1);\n97\t    let text = format_diagnostic(&out.diagnostics[0], Some(src));\n98\t    let lines: Vec<&str> = text.split('\\n').collect();\n99\t    assert!(\n100\t        lines[0].starts_with(\"caret.lino:2:1:\"),\n101\t        \"line[0] was: {}\",\n102\t        lines[0]\n103\t    );\n104\t    assert_eq!(lines[1], \"(=: missing_op identity)\");\n105\t    assert_eq!(lines[2], \"^\");\n106\t}\n107\t\n108\t#[test]\n109\tfn diagnostic_struct_carries_code_message_span() {\n110\t    let span = Span::new(Some(\"x.lino\".to_string()), 2, 3, 1);\n111\t    let diag = Diagnostic::new(\"E001\", \"Unknown op: foo\", span.clone());\n112\t    assert_eq!(diag.code, \"E001\");\n113\t    assert_eq!(diag.message, \"Unknown op: foo\");\n114\t    assert_eq!(diag.span, span);\n115\t}\n116\t\n117\t#[test]\n118\tfn compute_form_spans_returns_one_span_per_top_level_form() {\n119\t    let text = \"(a)\\n  (b)\\n\\n(c)\";\n120\t    let spans = compute_form_spans(text, Some(\"spans.lino\"));\n121\t    assert_eq!(spans.len(), 3);\n122\t    let lc: Vec<(usize, usize)> = spans.iter().map(|s| (s.line, s.col)).collect();\n123\t    assert_eq!(lc, vec![(1, 1), (2, 3), (4, 1)]);\n124\t    for s in &spans {\n125\t        assert_eq!(s.file.as_deref(), Some(\"spans.lino\"));\n126\t    }\n127\t}\n128\t"
