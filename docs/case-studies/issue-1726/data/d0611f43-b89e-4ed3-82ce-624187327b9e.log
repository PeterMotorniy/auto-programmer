        "tool_use_id": "toolu_01BCq386Txwt59cKfed5aMTX",
        "type": "tool_result",
        "content": "1\t// RML — minimal relative meta-logic over LiNo (Links Notation)\n2\t// Supports many-valued logics from unary (1-valued) through continuous probabilistic (∞-valued).\n3\t// See: https://en.wikipedia.org/wiki/Many-valued_logic\n4\t//\n5\t// - Uses official links-notation crate to parse LiNo text into links\n6\t// - Terms are defined via (x: x is x)\n7\t// - Probabilities are assigned ONLY via: ((<expr>) has probability <p>)\n8\t// - Redefinable ops: (=: ...), (!=: not =), (and: avg|min|max|product|probabilistic_sum), (or: ...), (not: ...), (both: ...), (neither: ...)\n9\t// - Range: (range: 0 1) for [0,1] or (range: -1 1) for [-1,1] (balanced/symmetric)\n10\t// - Valence: (valence: N) to restrict truth values to N discrete levels (N=2 → Boolean, N=3 → ternary, etc.)\n11\t// - Query: (? <expr>)\n12\t\n13\tuse std::collections::{HashMap, HashSet};\n14\tuse std::fmt;\n15\tuse std::panic::{catch_unwind, AssertUnwindSafe};\n16\t\n17\t// ========== Structured Diagnostics ==========\n18\t// Every parser/evaluator error is reported as a `Diagnostic` with an error\n19\t// code, human-readable message, and source span (file/line/col, 1-based).\n20\t// See `docs/DIAGNOSTICS.md` for the full code list.\n21\t\n22\t/// A source span: 1-based `line`/`col`, optional file path, and a `length`\n23\t/// of the offending region (used to render carets in the CLI).\n24\t#[derive(Debug, Clone, PartialEq)]\n25\tpub struct Span {\n26\t    pub file: Option<String>,\n27\t    pub line: usize,\n28\t    pub col: usize,\n29\t    pub length: usize,\n30\t}\n31\t\n32\timpl Span {\n33\t    pub fn new(file: Option<String>, line: usize, col: usize, length: usize) -> Self {\n34\t        Self {\n35\t            file,\n36\t            line,\n37\t            col,\n38\t            length,\n39\t        }\n40\t    }\n41\t\n42\t    pub fn unknown() -> Self {\n43\t        Self {\n44\t            file: None,\n45\t            line: 1,\n46\t            col: 1,\n47\t            length: 0,\n48\t        }\n49\t    }\n50\t}\n51\t\n52\t/// A single diagnostic emitted by parser, evaluator, or type checker.\n53\t#[derive(Debug, Clone, PartialEq)]\n54\tpub struct Diagnostic {\n55\t    pub code: String,\n56\t    pub message: String,\n57\t    pub span: Span,\n58\t}\n59\t\n60\timpl Diagnostic {\n61\t    pub fn new(code: &str, message: impl Into<String>, span: Span) -> Self {\n62\t        Self {\n63\t            code: code.to_string(),\n64\t            message: message.into(),\n65\t            span,\n66\t        }\n67\t    }\n68\t}\n69\t\n70\t/// Result of `evaluate(src)`: a list of query results (numeric or type) plus\n71\t/// any diagnostics emitted while parsing/evaluating.\n72\t#[derive(Debug, Clone, Default)]\n73\tpub struct EvaluateResult {\n74\t    pub results: Vec<RunResult>,\n75\t    pub diagnostics: Vec<Diagnostic>,\n76\t}\n77\t\n78\t/// Format a diagnostic for human-readable CLI output:\n79\t///     `<file>:<line>:<col>: <CODE>: <message>`\n80\t///         `<source line>`\n81\t///         `^`\n82\tpub fn format_diagnostic(diag: &Diagnostic, source: Option<&str>) -> String {\n83\t    let file = diag.span.file.as_deref().unwrap_or(\"<input>\");\n84\t    let mut out = format!(\n85\t        \"{}:{}:{}: {}: {}\",\n86\t        file, diag.span.line, diag.span.col, diag.code, diag.message\n87\t    );\n88\t    if let Some(src) = source {\n89\t        let lines: Vec<&str> = src.split('\\n').collect();\n90\t        if diag.span.line >= 1 && diag.span.line <= lines.len() {\n91\t            let line_text = lines[diag.span.line - 1];\n92\t            out.push('\\n');\n93\t            out.push_str(line_text);\n94\t            out.push('\\n');\n95\t            let pad = diag.span.col.saturating_sub(1);\n96\t            let caret_count = diag.span.length.max(1);\n97\t            out.push_str(&\" \".repeat(pad));\n98\t            out.push_str(&\"^\".repeat(caret_count));\n99\t        }\n100\t    }\n101\t    out\n102\t}\n103\t\n104\t/// Compute (line, col) source positions for every top-level link in `text`.\n105\t/// Mirrors `compute_form_spans` in the JavaScript implementation.\n106\tpub fn compute_form_spans(text: &str, file: Option<&str>) -> Vec<Span> {\n107\t    let mut spans = Vec::new();\n108\t    let mut depth: i32 = 0;\n109\t    let mut line: usize = 1;\n110\t    let mut col: usize = 1;\n111\t    let mut pending_start: Option<(usize, usize)> = None;\n112\t    let mut in_line_comment = false;\n113\t    let mut line_start_idx: usize = 0;\n114\t    let bytes = text.as_bytes();\n115\t    for (off, &b) in bytes.iter().enumerate() {\n116\t        let ch = b as char;\n117\t        if ch == '\\n' {\n118\t            in_line_comment = false;\n119\t            line += 1;\n120\t            col = 1;\n121\t            line_start_idx = off + 1;\n122\t            continue;\n123\t        }\n124\t        if in_line_comment {\n125\t            col += 1;\n126\t            continue;\n127\t        }\n128\t        if ch == '#' && depth == 0 {\n129\t            // Determine if the line so far contains only whitespace.\n130\t            let line_so_far = &text[line_start_idx..off];\n131\t            if line_so_far.chars().all(|c| c == ' ' || c == '\\t') {\n132\t                in_line_comment = true;\n133\t                col += 1;\n134\t                continue;\n135\t            }\n136\t        }\n137\t        if ch == '(' {\n138\t            if depth == 0 {\n139\t                pending_start = Some((line, col));\n140\t            }\n141\t            depth += 1;\n142\t        } else if ch == ')' {\n143\t            depth -= 1;\n144\t            if depth == 0 {\n145\t                if let Some((sl, sc)) = pending_start.take() {\n146\t                    spans.push(Span::new(file.map(|s| s.to_string()), sl, sc, 1));\n147\t                }\n148\t            }\n149\t        }\n150\t        col += 1;\n151\t    }\n152\t    spans\n153\t}\n154\t\n155\t// ========== LiNo Parser ==========\n156\t// Uses the official links-notation crate for parsing LiNo