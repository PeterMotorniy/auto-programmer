rse each segment separately.\n203\t    let mut all_links = Vec::new();\n204\t    for segment in stripped.split(\"\\n\\n\") {\n205\t        let trimmed = segment.trim();\n206\t        if trimmed.is_empty() {\n207\t            continue;\n208\t        }\n209\t        match links_notation::parse_lino_to_links(trimmed) {\n210\t            Ok(links) => {\n211\t                for link in links {\n212\t                    all_links.push(link.to_string());\n213\t                }\n214\t            }\n215\t            Err(_) => {}\n216\t        }\n217\t    }\n218\t    all_links\n219\t}\n220\t\n221\t// ========== AST ==========\n222\t\n223\t/// AST node: either a leaf string or a list of child nodes.\n224\t#[derive(Debug, Clone, PartialEq)]\n225\tpub enum Node {\n226\t    Leaf(String),\n227\t    List(Vec<Node>),\n228\t}\n229\t\n230\timpl fmt::Display for Node {\n231\t    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {\n232\t        match self {\n233\t            Node::Leaf(s) => write!(f, \"{}\", s),\n234\t            Node::List(children) => {\n235\t                write!(f, \"(\")?;\n236\t                for (i, child) in children.iter().enumerate() {\n237\t                    if i > 0 {\n238\t                        write!(f, \" \")?;\n239\t                    }\n240\t                    write!(f, \"{}\", child)?;\n241\t                }\n242\t                write!(f, \")\")\n243\t            }\n244\t        }\n245\t    }\n246\t}\n247\t\n248\t// ========== Helpers ==========\n249\t\n250\t/// Tokenize a single link string into tokens (parens and words).\n251\tpub fn tokenize_one(s: &str) -> Vec<String> {\n252\t    let mut s = s.to_string();\n253\t\n254\t    // Strip inline comments (everything after #) but balance parens\n255\t    if let Some(comment_idx) = s.find('#') {\n256\t        s = s[..comment_idx].to_string();\n257\t        // Count unmatched opening parens and add closing parens to balance\n258\t        let mut depth: i32 = 0;\n259\t        for c in s.ch