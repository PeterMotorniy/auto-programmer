    "oldString": "  // Assignment: ((expr) has probability p)\n  if (node.length === 4 && node[1] === 'has' && node[2] === 'probability' && isNum(node[3])) {\n    env.setExprProb(node[0], parseFloat(node[3]));\n    return env.toNum(node[3]);\n  }",
