y(String),\n749\t}\n750\t\n751\timpl EvalResult {\n752\t    pub fn as_f64(&self) -> f64 {\n753\t        match self {\n754\t            EvalResult::Value(v) | EvalResult::Query(v) => *v,\n755\t            EvalResult::TypeQuery(_) => 0.0,\n756\t        }\n757\t    }\n758\t\n759\t    pub fn is_query(&self) -> bool {\n760\t        matches!(self, EvalResult::Query(_) | EvalResult::TypeQuery(_))\n761\t    }\n762\t\n763\t    pub fn is_type_query(&self) -> bool {\n764\t        matches!(self, EvalResult::TypeQuery(_))\n765\t    }\n766\t\n767\t    pub fn type_string(&self) -> Option<&str> {\n768\t        match self {\n769\t            EvalResult::TypeQuery(s) => Some(s),\n770\t            _ => None,\n771\t        }\n772\t    }\n773\t}\n774\t\n775\t// ========== Binding Parser ==========\n776\t\n777\t/// Parse a binding form in two supported syntaxes:\n778\t/// 1. Colon form: (x: A) as [\"x:\", A] — standard LiNo link definition syntax\n779\t/// 2. Prefix type form: (A x) as [\"A\", \"x\"] — type-first notation for lambda/Pi bindings\n780\t///    e.g. (Natural x), used in (lambda (Natural x) body)\n781\t/// Returns (param_name, param_type_key) or None.\n782\tpub fn parse_binding(binding: &Node) -> Option<(String, String)> {\n783\t    if let Node::List(children) = binding {\n784\t        if children.len() == 2 {\n785\t            // Colon form: [\"x:\", A]\n786\t            if let Node::Leaf(ref s) = children[0] {\n787\t                if s.ends_with(':') {\n788\t                    let param_name = s[..s.len() - 1].to_string();\n789\t                    let param_type = match &children[1] {\n790\t                        Node::Leaf(s) => s.clone(),\n791\t                        other => key_of(other),\n792\t                    };\n793\t                    return Some((param_name, param_type));\n794\t                }\n795\t            }\n796\t            // Prefix type form: [\"A\", \"x\"] — type name first (must start with uppercase)\n797\t            if let (Node::Leaf(ref type_name), Node::Leaf(ref var_name)) =\n798\t                (&children[0], &children[1])\n799\t            {\n800\t                if type_name.starts_with(|c: char| c.is_uppercase()) && !var_name.ends_with(':') {\n801\t                    return Some((var_name.clone(), type_name.clone()));\n802\t                }\n803\t            }\n804\t        }\n805\t    }\n806\t    None\n807\t}\n808\t\n809\t/// Parse comma-separated bindings: (Natural x, Natural y) → vec of (name, type) pairs.\n810\t/// Tokens arrive as [\"Natural\", \"x,\", \"Natural\", \"y\"] or [\"Natural\", \"x\"] (single binding).\n811\tpub fn parse_bindings(binding: &Node) -> Option<Vec<(String, String)>> {\n812\t    // Try single binding first\n813\t    if let Some(single) = parse_binding(binding) {\n814\t        return Some(vec![single]);\n815\t    }\n816\t    // Try comma-separated\n817\t    if let Node::List(children) = binding {\n818\t        let mut tokens: Vec<String> = Vec::new();\n819\t        for child in children {\n820\t            if let Node::Leaf(ref s) = child {\n821\t                if s.ends_with(',') {\n822\t                    tokens.push(s[..s.len() - 1].to_string());\n823\t                    tokens.push(\",\".to_string());\n824\t                } else {\n825\t                    tokens.push(s.clone());\n826\t                }\n827\t            } else {\n828\t                return None;\n829\t            }\n830\t        }\n831\t        let mut bindings = Vec::new();\n832\t        let mut i = 0;\n833\t        while i < tokens.len() {\n834\t            if tokens[i] == \",\" {\n835\t                i += 1;\n836\t                continue;\n837\t            }\n838\t            if i + 1 < tokens.len() && tokens[i + 1] != \",\" {\n839\t                let type_name = &tokens[i];\n840\t                let var_name = &tokens[i + 1];\n841\t                if type_name.starts_with(|c: char| c.is_uppercase()) {\n842\t                    bindings.push((var_name.clone(), type_name.clone()));\n843\t                    i += 2;\n844\t                    continue;\n845\t                }\n846\t            }\n847\t            return None;\n848\t        }\n849\t        if !bindings.is_empty() {\n850\t            return Some(bindings);\n851\t        }\n852\t    }\n853\t    None\n854\t}\n855\t\n856\t// ========== Substitution ==========\n857\t\n858\t/// Substitute all occurrences of variable `name` with `replacement` in `expr`.\n859\tpub fn substitute(expr: &Node, name: &str, replacement: &Node) -> Node {\n860\t    match expr {\n861\t        Node::Leaf(s) => {\n862\t            if s == name {\n863\t                replacement.clone()\n864\t            } else {\n865\t                expr.clone()\n866\t            }\n867\t        }\n868\t        Node::List(children) => {\n869\t            // Don't substitute inside a binding that shadows the variable\n870\t            if children.len() == 3 {\n871\t                if let Node::Leaf(ref head) = children[0] {\n872\t                    if head == \"lambda\" || head == \"Pi\" {\n873\t                        if let Some((param, _)) = parse_binding(&children[1]) {\n874\t                            if param == name {\n875\t                                return expr.clone(); // shadowed\n876\t                            }\n877\t                        }\n878\t                    }\n879\t                }\n880\t            }\n881\t            Node::List(\n882\t                children\n883\t                    .iter()\n884\t                    .map(|child| substitute(child, name, replacement))\n885\t                    .collect(),\n886\t            )\n887\t        }\n888\t    }\n889\t}\n890\t\n891\t// ========== Evaluator ==========\n892\t\n893\t/// Evaluate a node in arithmetic context — numeric literals are NOT clamped to the logic range.\n894\tfn eval_arith(node: &Node, env: &mut Env) -> f64 {\n895\t    if let Node::Leaf(ref s) = node {\n896\t        if is_num(s) {\n897\t            return s.parse::<f64>().unwrap_or(0.0);\n898\t        }\n899\t    }\n900\t    eval_node(node, env).as_f64()\n901\t}\n902\t\n903\t/// Evaluate an AST node in the given environment.\n904\tpub fn eval_node(node: &Node, env: &mut Env) -> EvalResult {\n905\t    match node {\n906\t        Node::Leaf(s) => {\n907\t            if is_num(s) {\n908\t                EvalResult::Value(env.to_num(s))\n909\t            } else {\n910\t                EvalResult::Value(env.get_symbol_prob(s))\n911\t            }\n912\t        }\n913\t        Node::List(children) => {\n914\t            if children.is_empty() {\n915\t                return EvalResult::Value(0.0);\n916\t            }\n917\t\n918\t            // Definitions & operator redefs: (head: ...) form\n919\t            if let Node::Leaf(ref s) = children[0] {\n920\t                if s.ends_with(':') {\n921\t                    let head = &s[..s.len() - 1];\n922\t                    return define_form(head, &children[1..], env);\n923\t                }\n924\t            }\n925\t\n926\t            // Note: (x : A) with spaces as a standalone colon separator is NOT supported.\n927\t            // Use (x: A) instead — the colon must be part of the link name.\n928\t\n929\t            // Assignment: ((expr) has probability p)\n930\t            if children.len() == 4 {\n931\t                if let (Node::Leaf(ref w1), Node::Leaf(ref w2), Node::Leaf(ref w3)) =\n932\t                    (&children[1], &children[2], &children[3])\n933\t                {\n934\t                    if w1 == \"has\" && w2 == \"probability\" && is_num(w3) {\n935\t                        let p: f64 = w3.parse().unwrap_or(0.0);\n936\t                        env.set_expr_prob(&children[0], p);\n937\t                        return EvalResult::Value(env.to_num(w3));\n938\t                    }\n939\t                }\n940\t            }\n941\t\n942\t            // Range configuration: (range lo hi) prefix form\n943\t            if children.len() == 3 {\n944\t                if let Node::Leaf(ref first) = children[0] {\n945\t                    if first == \"range\" {\n946\t                        if let (Node::Leaf(ref lo_s), Node::Leaf(ref hi_s)) =\n947\t                            (&children[1], &children[2])\n948\t                        {\n949\t                            if is_num(lo_s) && is_num(hi_s) {\n950\t                                env.lo = lo_s.parse().unwrap_or(0.0);\n951\t                                env.hi = hi_s.parse().unwrap_or(1.0);\n952\t                                env.reinit_ops();\n953\t                                return EvalResult::Value(1.0);\n954\t                            }\n955\t                        }\n956\t                    }\n957\t                }\n958\t            }\n959\t\n960\t            // Valence configuration: (valence N) prefix form\n961\t            if children.len() == 2 {\n962\t                if let Node::Leaf(ref first) = children[0] {\n963\t                    if first == \"valence\" {\n964\t                        if let Node::Leaf(ref val_s) = children[1] {\n965\t                            if is_num(val_s) {\n966\t                                env.valence = val_s.parse::<f64>().unwrap_or(0.0) as u32;\n967\t                                return EvalResult::Value(1.0);\n968\t                            }\n969\t                        }\n970\t                    }\n971\t                }\n972\t            }\n973\t\n974\t            // Query: (? expr)\n975\t            if let Node::Leaf(ref first) = children[0] {\n976\t                if first == \"?\" {\n977\t                    let result = eval_node(&children[1], env);\n978\t                    // If inner result is already a type query, pass it through\n979\t                    if result.is_type_query() {\n980\t                        return result;\n981\t                    }\n982\t                    let v = result.as_f64();\n983\t                    return EvalResult::Query(env.clamp(v));\n984\t                }\n985\t            }\n986\t\n987\t            // Infix arithmetic: (A + B), (A - B), (A * B), (A / B)\n988\t            // Arithmetic uses raw numeric values (not clamped to the logic range)\n989\t            if children.len() == 3 {\n990\t                if let Node::Leaf(ref op_name) = children[1] {\n991\t                    if op_name == \"+\" || op_name == \"-\" || op_name == \"*\" || op_name == \"/\" {\n992\t                        let l = eval_arith(&children[0], env);\n993\t                        let r = eval_arith(&children[2], env);\n994\t                        return EvalResult::Value(env.apply_op(op_name, &[l, r]));\n995\t                    }\n996\t                }\n997\t            }\n998\t\n999\t            // Infix AND/OR/BOTH/NEITHER: ((A) and (B)) / ((A) or (B)) / ((A) both (B)) / ((A) neither (B))\n1000\t            if children.len() == 3 {\n1001\t                if let Node::Leaf(ref op_name) = children[1] {\n1002\t                    if op_name == \"and\"\n1003\t                        || op_name == \"or\"\n1004\t                        || op_name == \"both\"\n1005\t                        || op_name == \"neither\"\n1006\t                    {\n1007\t                        let l = eval_node(&children[0], env).as_f64();\n1008\t                        let r = eval_node(&children[2], env).as_f64();\n1009\t                        return EvalResult::Value(env.clamp(env.apply_op(op_name, &[l, r])));\n1010\t                    }\n1011\t                }\n1012\t            }\n1013\t\n1014\t            // Composite natural language operators: (both A and B [and C ...]), (neither A nor B [nor C ...])\n1015\t            if children.len() >= 4 && children.len() % 2 == 0 {\n1016\t                if let Node::Leaf(ref head) = children[0] {\n1017\t                    if head == \"both\" || head == \"neither\" {\n1018\t                        let sep = if head == \"both\" { \"and\" } else { \"nor\" };\n1019\t                        let mut valid = true;\n1020\t                        for i in (2..children.len()).step_by(2) {\n1021\t                            if let Node::Leaf(ref s) = children[i] {\n1022\t                                if s != sep {\n1023\t                                    valid = false;\n1024\t                                    break;\n1025\t                                }\n1026\t                            } else {\n1027\t                                valid = false;\n1028\t                                break;\n1029\t                            }\n1030\t                        }\n1031\t                        if valid {\n1032\t                            let head_str = head.clone();\n1033\t                            let vals: Vec<f64> = (1..children.len())\n1034\t                                .step_by(2)\n1035\t                                .map(|i| eval_node(&children[i], env).as_f64())\n1036\t                                .collect();\n1037\t                            return EvalResult::Value(env.clamp(env.apply_op(&head_str, &vals)));\n1038\t                        }\n1039\t                    }\n1040\t                }\n1041\t            }\n1042\t\n1043\t            // Infix equality/inequality: (L = R), (L != R)\n1044\t            if children.len() == 3 {\n1045\t                if let Node::Leaf(ref op_name) = children[1] {\n1046\t                    if op_name == \"=\" {\n1047\t                        match env.ops.get(\"=\").cloned() {\n1048\t                            Some(Op::Compose { outer, inner }) => {\n1049\t                                let inner_val = apply_named_op_on_nodes(\n1050\t                                    env,\n1051\t                                    &inner,\n1052\t                                    &children[0],\n1053\t                                    &children[2],\n1054\t                                );\n1055\t                                let outer_val = env.apply_op(&outer, &[inner_val]);\n1056\t                                return EvalResult::Value(env.clamp(outer_val));\n1057\t                            }\n1058\t                            _ => {\n1059\t                                let raw = env.apply_eq(&children[0], &children[2]);\n1060\t                                // If there's an explicit assignment or structural match, trust it\n1061\t                                let k_prefix = key_of(&Node::List(vec![\n1062\t                                    Node::Leaf(\"=\".to_string()),\n1063\t                                    children[0].clone(),\n1064\t                                    children[2].clone(),\n1065\t                                ]));\n1066\t                                let k_infix = key_of(&Node::List(vec![\n1067\t                                    children[0].clone(),\n1068\t                                    Node::Leaf(\"=\".to_string()),\n1069\t                                    children[2].clone(),\n1070\t                                ]));\n1071\t                                if env.assign.contains_key(&k_prefix)\n1072\t                                    || env.assign.contains_key(&k_infix)\n1073\t                                    || is_structurally_same(&children[0], &children[2])\n1074\t                                {\n1075\t                                    return EvalResult::Value(env.clamp(raw));\n1076\t                                }\n1077\t                                // No explicit assignment — try numeric comparison (decimal-precision)\n1078\t                                let l = eval_arith(&children[0], env);\n1079\t                                let r = eval_arith(&children[2], env);\n1080\t                                let num_eq = if dec_round(l) == dec_round(r) {\n1081\t                                    env.hi\n1082\t                                } else {\n1083\t                                    env.lo\n1084\t                                };\n1085\t                                return EvalResult::Value(env.clamp(num_eq));\n1086\t                            }\n1087\t                        }\n1088\t                    }\n1089\t                    if op_name == \"!=\" {\n1090\t                        match env.ops.get(\"!=\").cloned() {\n1091\t                            Some(Op::Compose { outer, inner }) => {\n1092\t                                let inner_val = apply_named_op_on_nodes(\n1093\t                                    env,\n1094\t                                    &inner,\n1095\t                                    &children[0],\n1096\t                                    &children[2],\n1097\t                                );\n1098\t                                let outer_val = env.apply_op(&outer, &[inner_val]);\n1099\t                                return EvalResult::Value(env.clamp(outer_val));"
