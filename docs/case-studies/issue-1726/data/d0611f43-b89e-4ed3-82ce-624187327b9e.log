                 }\n1193\t                                let body_key = key_of(&children[2]);\n1194\t                                let body_type = env\n1195\t                                    .get_type(&body_key)\n1196\t                                    .cloned()\n1197\t                                    .unwrap_or_else(|| \"unknown\".to_string());\n1198\t                                let key = key_of(&Node::List(children.clone()));\n1199\t                                env.set_type(\n1200\t                                    &key,\n1201\t                                    &format!(\"(Pi ({} {}) {})\", param_type, param_name, body_type),\n1202\t                                );\n1203\t                            }\n1204\t                        }\n1205\t                        return EvalResult::Value(1.0);\n1206\t                    }\n1207\t                }\n1208\t            }\n1209\t\n1210\t            // Application: (apply f x) — explicit application with beta-reduction\n1211\t            if children.len() == 3 {\n1212\t                if let Node::Leaf(ref first) = children[0] {\n1213\t                    if first == \"apply\" {\n1214\t                        let fn_node = &children[1];\n1215\t                        let arg = &children[2];\n1216\t\n1217\t                        // Check if fn is a lambda: (lambda (A x) body)\n1218\t                        if let Node::List(ref fn_children) = fn_node {\n1219\t                            if fn_children.len() == 3 {\n1220\t                                if let Node::Leaf(ref fn_head) = fn_children[0] {\n1221\t                                    if fn_head == \"lambda\" {\n1222\t                                        if let Some((param_name, _)) =\n1223\t                                            parse_binding(&fn_children[1])\n1224\t                                        {\n1225\t                                            let body = &fn_children[2];\n1226\t                                            let result = substitute(body, &param_name, arg);\n1227\t                                            return eval_node(&result, env);\n1228\t                                        }\n1229\t                                    }\n1230\t                                }\n1231\t                            }\n1232\t                        }\n1233\t\n1234\t                        // Check if fn is a named lambda\n1235\t                        if let Node::Leaf(ref fn_name) = fn_node {\n1236\t                            if let Some(lambda) = env.get_lambda(fn_name).cloned() {\n1237\t                                let result = substitute(&lambda.body, &lambda.param, arg);\n1238\t                                return eval_node(&result, env);\n1239\t                            }\n1240\t                        }\n1241\t\n1242\t                        // Otherwise evaluate both\n1243\t                        let f_val = eval_node(fn_node, env).as_f64();\n1244\t                        return EvalResult::Value(f_val);\n1245\t                    }\n1246\t                }\n1247\t            }\n1248\t\n1249\t            // Type query: (type of expr) — returns the type of an expression\n1250\t            // e.g. (? (type of x)) → returns the type string\n1251\t            if children.len() == 3 {\n1252\t                if let (Node::Leaf(ref first), Node::Leaf(ref mid)) = (&children[0], &children[1]) {\n1253\t                    if first == \"type\" && mid == \"of\" {\n1254\t                        let expr_key = match &children[2] {\n1255\t                            Node::Leaf(s) => s.clone(),\n1256\t                            other => key_of(other),\n1257\t                        };\n1258\t                        let type_str = env\n1259\t                            .get_type(&expr_key)\n1260\t                            .cloned()\n1261\t                            .unwrap_or_else(|| \"unknown\".to_string());\n1262\t                        return EvalResult::TypeQuery(type_str);\n1263\t                    }\n1264\t                }\n1265\t            }\n1266\t\n1267\t            // Type check query: (expr of Type) — checks if expr has the given type\n1268\t            // e.g. (? (x of Natural)) → returns 1 or 0\n1269\t            if children.len() == 3 {\n1270\t                if let Node::Leaf(ref mid) = children[1] {\n1271\t                    if mid == \"of\" {\n1272\t                        let expr_key = match &children[0] {\n1273\t                            Node::Leaf(s) => s.clone(),\n1274\t                            other => key_of(other),\n1275\t                        };\n1276\t                        let expected_key = match &children[2] {\n1277\t                            Node::Leaf(s) => s.clone(),\n1278\t                            other => key_of(other),\n1279\t                        };\n1280\t                        if let Some(actual) = env.get_type(&expr_key) {\n1281\t                            return EvalResult::Value(if *actual == expected_key {\n1282\t                                env.hi\n1283\t                            } else {\n1284\t                                env.lo\n1285\t                            });\n1286\t                        }\n1287\t                        return EvalResult::Value(env.lo);\n1288\t                    }\n1289\t                }\n1290\t            }\n1291\t\n1292\t            // Prefix: (not X), (and X Y ...), (or X Y ...)\n1293\t            if let Node::Leaf(ref head) = children[0] {\n1294\t                let head_str = head.clone();\n1295\t                if env.ops.contains_key(&head_str) {\n1296\t                    let vals: Vec<f64> = children[1..]\n1297\t                        .iter()\n1298\t                        .map(|a| eval_node(a, env).as_f64())\n1299\t                        .collect();\n1300\t                    return EvalResult::Value(env.clamp(env.apply_op(&head_str, &vals)));\n1301\t                }\n1302\t\n1303\t                // Named lambda application: (name arg ...)\n1304\t                if children.len() >= 2 {\n1305\t                    if let Some(lambda) = env.get_lambda(&head_str).cloned() {\n1306\t                        let result = substitute(&lambda.body, &lambda.param, &children[1]);\n1307\t                        if children.len() == 2 {\n1308\t                            return eval_node(&result, env);\n1309\t                        }\n1310\t                        // For now, just apply first argument\n1311\t                        return eval_node(&result, env);\n1312\t                    }\n1313\t                }\n1314\t            }\n1315\t\n1316\t            EvalResult::Value(0.0)\n1317\t        }\n1318\t    }\n1319\t}\n1320\t\n1321\t/// Helper for applying a named op when dealing with node-based equality.\n1322\tfn apply_named_op_on_nodes(env: &Env, op_name: &str, left: &Node, right: &Node) -> f64 {\n1323\t    match env.ops.get(op_name) {\n1324\t        Some(Op::Eq) => env.apply_eq(left, right),\n1325\t        Some(Op::Neq) => env.apply_neq(left, right),\n1326\t        _ => env.lo,\n1327\t    }\n1328\t}\n1329\t\n1330\t/// Process definition forms: (head: rhs...)\n1331\tfn define_form(head: &str, rhs: &[Node], env: &mut Env) -> EvalResult {\n1332\t    // Term definition: (a: a is a) → declare 'a' as a term\n1333\t    if rhs.len() == 3 {\n1334\t        if let (Node::Leaf(ref r0), Node::Leaf(ref r1), Node::Leaf(ref r2)) =\n1335\t            (&rhs[0], &rhs[1], &rhs[2])\n1336\t        {\n1337\t            if r1 == \"is\" && r0 == head && r2 == head {\n1338\t                env.terms.insert(head.to_string());\n1339\t                return EvalResult::Value(1.0);\n1340\t            }\n1341\t        }\n1342\t    }\n1343\t\n1344\t    // Prefix type notation: (name: TypeName name) → typed self-referential declaration\n1345\t    // e.g. (zero: Natural zero), (boolean: Type boolean), (true: Boolean true)\n1346\t    if rhs.len() == 2 {\n1347\t        if let Node::Leaf(ref last) = rhs[1] {\n1348\t            if last == head {\n1349\t                match &rhs[0] {\n1350\t                    Node::Leaf(ref type_name)\n1351\t                        if type_name.starts_with(|c: char| c.is_uppercase()) =>\n1352\t                    {\n1353\t                        env.terms.insert(head.to_string());\n1354\t                        env.types.insert(head.to_string(), type_name.clone());\n1355\t                        return EvalResult::Value(1.0);\n1356\t                    }\n1357\t                    Node::List(_) => {\n1358\t                        env.terms.insert(head.to_string());\n1359\t                        let type_key = key_of(&rhs[0]);\n1360\t                        env.types.insert(head.to_string(), type_key);\n1361\t                        eval_node(&rhs[0], env);\n1362\t                        return EvalResult::Value(1.0);\n1363\t                    }\n1364\t                    _ => {}\n1365\t                }\n1366\t            }\n1367\t        }\n1368\t    }\n1369\t\n1370\t    // Range configuration: (range: lo hi)\n1371\t    if head == \"range\" && rhs.len() == 2 {\n1372\t        if let (Node::Leaf(ref lo_s), Node::Leaf(ref hi_s)) = (&rhs[0], &rhs[1]) {\n1373\t            if is_num(lo_s) && is_num(hi_s) {\n1374\t                env.lo = lo_s.parse().unwrap_or(0.0);\n1375\t                env.hi = hi_s.parse().unwrap_or(1.0);\n1376\t                env.reinit_ops();\n1377\t                return EvalResult::Value(1.0);\n1378\t            }\n1379\t        }\n1380\t    }\n1381\t\n1382\t    // Valence configuration: (valence: N)\n1383\t    if head == \"valence\" && rhs.len() == 1 {\n1384\t        if let Node::Leaf(ref val_s) = rhs[0] {\n1385\t            if is_num(val_s) {\n1386\t                env.valence = val_s.parse::<f64>().unwrap_or(0.0) as u32;\n1387\t                return EvalResult::Value(1.0);\n1388\t            }\n1389\t        }\n1390\t    }\n1391\t\n1392\t    // Optional symbol prior: (a: 0.7)\n1393\t    if rhs.len() == 1 {\n1394\t        if let Node::Leaf(ref val_s) = rhs[0] {\n1395\t            if is_num(val_s) {\n1396\t                let p: f64 = val_s.parse().unwrap_or(0.0);\n1397\t                env.set_symbol_prob(head, p);\n1398\t                return EvalResult::Value(env.to_num(val_s));\n1399\t            }"
