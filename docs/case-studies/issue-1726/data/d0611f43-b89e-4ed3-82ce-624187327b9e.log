          "+pub struct TraceEvent {",
          "+    pub kind: String,",
          "+    pub detail: String,",
          "+    pub span: Span,",
          "+}",
          "+",
          "+impl TraceEvent {",
          "+    pub fn new(kind: &str, detail: impl Into<String>, span: Span) -> Self {",
