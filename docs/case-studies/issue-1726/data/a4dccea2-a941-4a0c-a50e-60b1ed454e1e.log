        "content": "478\t\n479\t// ========== Environment ==========\n480\t\n481\t/// Options for creating an Env.\n482\t#[derive(Debug, Clone)]\n483\tpub struct EnvOptions {\n484\t    pub lo: f64,\n485\t    pub hi: f64,\n486\t    pub valence: u32,\n487\t}\n488\t\n489\timpl Default for EnvOptions {\n490\t    fn default() -> Self {\n491\t        Self {\n492\t            lo: 0.0,\n493\t            hi: 1.0,\n494\t            valence: 0,\n495\t        }\n496\t    }\n497\t}\n498\t\n499\t/// A stored lambda definition (param name, param type, body).\n500\t#[derive(Debug, Clone)]\n501\tpub struct Lambda {\n502\t    pub param: String,\n503\t    pub param_type: String,\n504\t    pub body: Node,\n505\t}\n506\t\n507\t/// The evaluation environment: holds terms, assignments, operators, and range/valence config.\n508\tpub struct Env {\n509\t    pub terms: HashSet<String>,\n510\t    pub assign: HashMap<String, f64>,\n511\t    pub symbol_prob: HashMap<String, f64>,\n512\t    pub lo: f64,\n513\t    pub hi: f64,\n514\t    pub valence: u32,\n515\t    pub ops: HashMap<String, Op>,\n516\t    pub types: HashMap<String, String>,\n517\t    pub lambdas: HashMap<String, Lambda>,\n518\t}\n519\t\n520\timpl Env {\n521\t    pub fn new(options: Option<EnvOptions>) -> Self {\n522\t        let opts = options.unwrap_or_default();\n523\t        let mut ops = HashMap::new();\n524\t        ops.insert(\"not\".to_string(), Op::Not);\n525\t        ops.insert(\"and\".to_string(), Op::Agg(Aggregator::Avg));\n526\t        ops.insert(\"or\".to_string(), Op::Agg(Aggregator::Max));\n527\t        // Belnap operators: AND-altering operators for four-valued logic\n528\t        // \"both\" (gullibility): avg — contradiction resolves to midpoint\n529\t        // \"neither\" (consensus): product — gap resolves to zero (no info propagates)\n530\t        // See: https://en.wikipedia.org/wiki/Four-valued_logic#Belnap\n531\t        ops.insert(\"both\".to_string(), Op::Agg(Aggregator::Avg));\n532\t        ops.insert(\"neither\".to_string(), Op::Agg(Aggregator::Prod));\n533\t        ops.insert(\"=\".to_string(), Op::Eq);\n534\t        ops.insert(\"!=\".to_string(), Op::Neq);\n535\t        ops.insert(\"+\".to_string(), Op::Add);\n536\t        ops.insert(\"-\".to_string(), Op::Sub);\n537\t        ops.insert(\"*\".to_string(), Op::Mul);\n538\t        ops.insert(\"/\".to_string(), Op::Div);\n539\t\n540\t        let mut env = Self {\n541\t            terms: HashSet::new(),\n542\t            assign: HashMap::new(),\n543\t            symbol_prob: HashMap::new(),\n544\t            lo: opts.lo,\n545\t            hi: opts.hi,\n546\t            valence: opts.valence,\n547\t            ops,\n548\t            types: HashMap::new(),\n549\t            lambdas: HashMap::new(),\n550\t        };\n551\t\n552\t        // Initialize truth constants: true, false, unknown, undefined\n553\t        // These are predefined symbol probabilities based on the current range.\n554\t        // By default: (false: min(range)), (true: max(range)),\n555\t        //             (unknown: mid(range)), (undefined: mid(range))\n556\t        // They can be redefined by the user via (true: <value>), (false: <value>), etc.\n557\t        env.init_truth_constants();"
