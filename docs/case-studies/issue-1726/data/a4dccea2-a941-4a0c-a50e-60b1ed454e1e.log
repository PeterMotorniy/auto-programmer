155\t// ========== LiNo Parser ==========\n156\t// Uses the official links-notation crate for parsing LiNo text.\n157\t// See: https://github.com/link-foundation/links-notation\n158\t\n159\t// Find the index of an inline comment marker `#` that follows a `)` plus\n160\t// whitespace, mirroring the JS regex `(\\)[ \\t]+)#.*$`.\n161\tfn inline_comment_index(line: &str) -> Option<usize> {\n162\t    let bytes = line.as_bytes();\n163\t    let mut last_close: Option<usize> = None;\n164\t    for (i, b) in bytes.iter().enumerate() {\n165\t        match *b {\n166\t            b')' => last_close = Some(i),\n167\t            b'#' => {\n168\t                if let Some(close_idx) = last_close {\n169\t                    let between = &line[close_idx + 1..i];\n170\t                    if !between.is_empty() && between.chars().all(|c| c == ' ' || c == '\\t') {\n171\t                        return Some(i);\n172\t                    }\n173\t                }\n174\t            }\n175\t            _ => {}\n176\t        }\n177\t    }\n178\t    None\n179\t}\n180\t\n181\t/// Parse LiNo text into a vector of link strings (each a top-level parenthesized expression).\n182\tpub fn parse_lino(text: &str) -> Vec<String> {\n183\t    // Strip both full-line and inline comments (# ...) before parsing —\n184\t    // the LiNo parser doesn't handle them and an inline comment containing a\n185\t    // colon would otherwise be misread as a binding.\n186\t    let stripped: String = text\n187\t        .lines()\n188\t        .map(|line| {\n189\t            let trimmed = line.trim_start();\n190\t            if trimmed.starts_with('#') {\n191\t                String::new()\n192\t            } else if let Some(idx) = inline_comment_index(line) {\n193\t                line[..idx].trim_end().to_string()\n194\t            } else {\n195\t                line.to_string()\n196\t            }\n197\t        })\n198\t        .collect::<Vec<String>>()\n199\t        .join(\"\\n\");\n200\t\n201\t    // The links-notation crate treats blank lines as group separators,\n202\t    // so we split the input by blank lines and parse each segment separately.\n203\t    let mut all_links = Vec::new();\n204\t    for segment in stripped.split(\"\\n\\n\") {\n205\t        let trimmed = segment.trim();\n206\t        if trimmed.is_empty() {\n207\t            continue;\n208\t        }\n209\t        match links_notation::parse_lino_to_links(trimmed) {\n210\t            Ok(links) => {\n211\t                for link in links {\n212\t                    all_links.push(link.to_string());\n213\t                }\n214\t            }\n215\t            Err(_) => {}\n216\t        }\n217\t    }\n218\t    all_links\n219\t}\n220\t\n221\t// ========== AST ==========\n222\t\n223\t/// AST node: either a leaf string or a list of child nodes.\n224\t#[derive(Debug, Clone, PartialEq)]\n225\tpub enum Node {\n226\t    Leaf(String),\n227\t    List(Vec<Node>),\n228\t}\n229\t\n230\timpl fmt::Display for Node {\n231\t    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {\n232\t        match self {\n233\t            Node::Leaf(s) => write!(f, \"{}\", s),\n234\t            Node::List(children) => {\n235\t                write!(f, \"(\")?;\n236\t                for (i, child) in children.iter().enumerate() {\n237\t                    if i > 0 {\n238\t                        write!(f, \" \")?;\n239\t                    }\n240\t                    write!(f, \"{}\", child)?;\n241\t                }\n242\t                write!(f, \")\")\n243\t            }\n244\t        }\n245\t    }\n246\t}\n247\t\n248\t// ========== Helpers ==========\n249\t\n250\t/// Tokenize a single link string into tokens (parens and words).\n251\tpub fn tokenize_one(s: &str) -> Vec<String> {\n252\t    let mut s = s.to_string();\n253\t\n254\t    // Strip inline comments (everything after #) but balance parens\n255\t    if let Some(comment_idx) = s.find('#') {\n256\t        s = s[..comment_idx].to_string();\n257\t        // Count unmatched opening parens and add closing parens to balance\n258\t        let mut depth: i32 = 0;\n259\t        for c in s.chars() {\n260\t            if c == '(' {\n261\t                depth += 1;\n262\t            } else if c == ')' {\n263\t                depth -= 1;\n264\t            }\n265\t        }\n266\t        while depth > 0 {\n267\t            s.push(')');\n268\t            depth -= 1;\n269\t        }\n270\t    }\n271\t\n272\t    let mut out = Vec::new();\n273\t    let chars: Vec<char> = s.chars().collect();\n274\t    let mut i = 0;\n275\t\n276\t    while i < chars.len() {\n277\t        let c = chars[i];\n278\t        if c.is_whitespace() {\n279\t            i += 1;\n280\t            continue;\n281\t        }\n282\t        if c == '(' || c == ')' {\n283\t            out.push(c.to_string());\n284\t            i += 1;\n285\t            continue;\n286\t        }\n287\t        let j_start = i;\n288\t        while i < chars.len() && !chars[i].is_whitespace() && chars[i] != '(' && chars[i] != ')' {\n289\t            i += 1;\n290\t        }\n291\t        out.push(chars[j_start..i].iter().collect());\n292\t    }\n293\t    out\n294\t}\n295\t\n296\t/// Parse tokens into an AST node.\n297\tpub fn parse_one(tokens: &[String]) -> Result<Node, String> {\n298\t    let mut i = 0;\n299\t\n300\t    fn read(tokens: &[String], i: &mut usize) -> Result<Node, String> {\n301\t        if *i >= tokens.len() || tokens[*i] != \"(\" {\n302\t            return Err(\"expected \\\"(\\\"\".to_string());\n303\t        }\n304\t        *i += 1;\n305\t        let mut arr = Vec::new();\n306\t        while *i < tokens.len() && tokens[*i] != \")\" {\n307\t            if tokens[*i] == \"(\" {\n308\t                arr.push(read(tokens, i)?);\n309\t            } else {\n310\t                arr.push(Node::Leaf(tokens[*i].clone()));\n311\t                *i += 1;\n312\t            }\n313\t        }\n314\t        if *i >= tokens.len() || tokens[*i] != \")\" {\n315\t            return Err(\"expected \\\")\\\"\".to_string());\n316\t        }\n317\t        *i += 1;\n318\t        Ok(Node::List(arr))\n319\t    }\n320\t\n321\t    let ast = read(tokens, &mut i)?;\n322\t    if i != tokens.len() {\n323\t        return Err(\"extra tokens after link\".to_string());\n324\t    }\n325\t    Ok(ast)\n326\t}\n327\t\n328\t/// Check if a string is numeric (including negative).\n329\tpub fn is_num(s: &str) -> bool {\n330\t    let s = s.trim();\n331\t    if s.is_empty() {\n332\t        return false;\n333\t    }\n334\t    let s = if let Some(stripped) = s.strip_prefix('-') {\n335\t        stripped\n336\t    } else {\n337\t        s\n338\t    };\n339\t    if s.is_empty() {\n340\t        return false;\n341\t    }\n342\t    if let Some(rest) = s.strip_prefix('.') {\n343\t        // .digits\n344\t        !rest.is_empty() && rest.chars().all(|c| c.is_ascii_digit())\n345\t    } else {\n346\t        // digits or digits.digits\n347\t        let parts: Vec<&str> = s.splitn(2, '.').collect();\n348\t        if parts.is_empty() || !parts[0].chars().all(|c| c.is_ascii_digit()) || parts[0].is_empty()\n349\t        {\n350\t            return false;\n351\t        }\n352\t        if parts.len() == 2 {\n353\t            parts[1].chars().all(|c| c.is_ascii_digit())\n354\t        } else {\n355\t            true\n356\t        }\n357\t    }\n358\t}\n359\t\n360\t/// Create a canonical key representation of a node.\n361\tpub fn key_of(node: &Node) -> String {\n362\t    match node {\n363\t        Node::Leaf(s) => s.clone(),\n364\t        Node::List(children) => {\n365\t            let inner: Vec<String> = children.iter().map(key_of).collect();\n366\t            format!(\"({})\", inner.join(\" \"))\n367\t        }\n368\t    }\n369\t}\n370\t\n371\t/// Check structural equality of two nodes.\n372\tpub fn is_structurally_same(a: &Node, b: &Node) -> bool {\n373\t    match (a, b) {\n374\t        (Node::Leaf(sa), Node::Leaf(sb)) => sa == sb,\n375\t        (Node::List(la), Node::List(lb)) => {\n376\t            la.len() == lb.len