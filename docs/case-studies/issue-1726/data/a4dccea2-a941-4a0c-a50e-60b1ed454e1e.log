    "role": "user",
    "content": [
      {
        "tool_use_id": "toolu_017XM7vcjGEjroffvP1Rz8Bq",
        "type": "tool_result",
        "content": "1\t#!/usr/bin/env node\n2\t// RML — minimal relative meta-logic over LiNo (Links Notation)\n3\t// Supports many-valued logics from unary (1-valued) through continuous probabilistic (∞-valued).\n4\t// See: https://en.wikipedia.org/wiki/Many-valued_logic\n5\t//\n6\t// - Uses official links-notation parser to parse links\n7\t// - Terms are defined via (x: x is x)\n8\t// - Probabilities are assigned ONLY via: ((<expr>) has probability <p>)\n9\t// - Redefinable ops: (=: ...), (!=: not =), (and: avg|min|max|product|probabilistic_sum), (or: ...), (not: ...), (both: ...), (neither: ...)\n10\t// - Range: (range: 0 1) for [0,1] or (range: -1 1) for [-1,1] (balanced/symmetric)\n11\t// - Valence: (valence: N) to restrict truth values to N discrete levels (N=2 → Boolean, N=3 → ternary, etc.)\n12\t// - Query: (? <expr>)\n13\t\n14\timport fs from 'node:fs';\n15\timport { Parser } from 'links-notation';\n16\t\n17\t// ---------- Structured Diagnostics ----------\n18\t// Every parser/evaluator error is reported as a `Diagnostic` with an error\n19\t// code, human-readable message, and source span (file/line/col, 1-based).\n20\t// See `docs/DIAGNOSTICS.md` for the full code list.\n21\tclass Diagnostic {\n22\t  constructor({ code, message, span }) {\n23\t    this.code = code;\n24\t    this.message = message;\n25\t    this.span = span || { file: null, line: 1, col: 1, length: 0 };\n26\t  }\n27\t}\n28\t\n29\t// Internal error class used to carry a code + span across throw sites so the\n30\t// outer `evaluate()` boundary can convert them into Diagnostics.\n31\tclass RmlError extends Error {\n32\t  constructor(code, message, span) {\n33\t    super(message);\n34\t    this.name = 'RmlError';\n35\t    this.code = code;\n36\t    this.span = span || null;\n37\t  }\n38\t}\n39\t\n40\t// Format a diagnostic for human-readable CLI output:\n41\t//   <file>:<line>:<col>: <CODE>: <message>\n42\t//       <source line>\n43\t//       ^\n44\tfunction formatDiagnostic(diag, sourceText) {\n45\t  const span = diag.span || { file: null, line: 1, col: 1, length: 0 };\n46\t  const file = span.file || '<input>';\n47\t  const lines = [`${file}:${span.line}:${span.col}: ${diag.code}: ${diag.message}`];\n48\t  if (typeof sourceText === 'string') {\n49\t    const srcLines = sourceText.split('\\n');\n50\t    const lineText = srcLines[span.line - 1];\n51\t    if (lineText !== undefined) {\n52\t      lines.push(lineText);\n53\t      const caretCount = Math.max(1, span.length || 1);\n54\t      lines.push(' '.repeat(Math.max(0, span.col - 1)) + '^'.repeat(caretCount));\n55\t    }\n56\t  }\n57\t  return lines.join('\\n');\n58\t}\n59\t\n60\t// ---------- helpers: canonical keys & tokenization of a single link string ----------\n61\tfunction tokenizeOne(s) {\n62\t  // s is a single-link string like \"( (a = a) has probability 1 )\"\n63\t  // Strip inline comments (everything after #) but balance parens\n64\t  const commentIdx = s.indexOf('#');\n65\t  if (commentIdx !== -1) {\n66\t    s = s.substring(0, commentIdx);\n67\t    // Count unmatched opening parens and add closing parens to balance\n68\t    let depth = 0;\n69\t    for (let i = 0; i < s.length; i++) {\n70\t      if (s[i] === '(') depth++;\n71\t      else if (s[i] === ')') depth--;\n72\t    }\n73\t    // Add missing closing parens\n74\t    while (depth > 0) {\n75\t      s += ')';\n76\t      depth--;\n77\t    }\n78\t  }\n79\t\n80\t  const out = [];\n81\t  let i = 0;\n82\t  const isWS = c => /\\s/.test(c);\n83\t  while (i < s.length) {\n84\t    const c = s[i];\n85\t    if (isWS(c)) { i++; continue; }\n86\t    if (c === '(' || c === ')') { out.push(c); i++; continue; }\n87\t    let j = i;\n88\t    while (j < s.length && !isWS(s[j]) && s[j] !== '(' && s[j] !== ')') j++;\n89\t    out.push(s.slice(i, j));\n90\t    i = j;\n91\t  }\n92\t  return out;\n93\t}\n94\tfunction parseOne(tokens) {\n95\t  let i = 0;\n96\t  function read() {\n97\t    if (tokens[i] !== '(') throw new RmlError('E002', 'expected \"(\"');\n98\t    i++;\n99\t    const arr = [];\n100\t    while (i < tokens.length && tokens[i] !== ')') {\n101\t      if (tokens[i] === '(') arr.push(read());\n102\t      else { arr.push(tokens[i]); i++; }\n103\t    }\n104\t    if (tokens[i] !== ')') throw new RmlError('E002', 'expected \")\"');\n105\t    i++;\n106\t    return arr;\n107\t  }\n108\t  const ast = read();\n109\t  if (i !== tokens.length) throw new RmlError('E002', 'extra tokens after link');\n110\t  return ast;\n111\t}\n112\tconst isNum = s => /^-?(\\d+(\\.\\d+)?|\\.\\d+)$/.test(s);\n113\tconst clamp01 = x => Math.max(0, Math.min(1, x));\n114\t\n115\t// ---------- Decimal-precision arithmetic ----------\n116\t// Round to at most `digits` significant decimal places to eliminate\n117\t// IEEE-754 floating-point artefacts (e.g. 0.1+0.2 → 0.3, not 0.30000000000000004).\n118\tconst DECIMAL_PRECISION = 12;\n119\tfunction decRound(x) {\n120\t  if (!Number.isFinite(x)) return x;\n121\t  return +(Math.round(x + 'e' + DECIMAL_PRECISION) + 'e-' + DECIMAL_PRECISION);\n122\t}\n123\tfunction keyOf(node) {\n124\t  if (Array.isArray(node)) return '(' + node.map(keyOf).join(' ') + ')';\n125\t  return String(node);\n126\t}\n127\tfunction isStructurallySame(a,b){\n128\t  if (Array.isArray(a) && Array.isArray(b)){\n129\t    if (a.length !== b.length) return false;\n130\t    for (let i=0;i<a.length;i++) if (!isStructurallySame(a[i],b[i])) return false;\n131\t    return true;\n132\t  }\n133\t  return String(a) === String(b);\n134\t}\n135\t\n136\t// ---------- Quantization for N-valued logics ----------\n137\t// Given N discrete levels and a range [lo, hi], quantize a value to the nearest level.\n138\t// For N=2 (Boolean): levels are {lo, hi} (e.g. {0, 1} or {-1, 1})\n139\t// For N=3 (ternary): levels are {lo, mid, hi} (e.g. {0, 0.5, 1} or {-1, 0, 1})\n140\t// For N=0 or Infinity (continuous): no quantization\n141\t// See: https://en.wikipedia.org/wiki/Many-valued_logic\n142\tfunction quantize(x, valence, lo, hi) {\n143\t  if (valence < 2) return x; // unary or continuous — no quantization\n144\t  const step = (hi - lo) / (valence - 1);\n145\t  const level = Math.round((x - lo) / step);\n146\t  return lo + Math.max(0, Math.min(valence - 1, level)) * step;\n147\t}\n148\t\n149\t// ---------- Environment ----------\n150\tclass Env {\n151\t  constructor(options){\n152\t    const opts = options || {};\n153\t    this.terms = new Set();                     // declared terms (via (x: x is x))\n154\t    this.assign = new Map();                    // key(expr) -> truth value\n155\t    this.symbolProb = new Map();                // optional symbol priors if you want (x: 0.7)\n156\t    this.types = new Map();                     // key(expr) -> type expression (as string)\n157\t    this.lambdas = new Map();                   // name -> { param, paramType, body } for named lambdas\n158\t\n159\t    // Range: [lo, hi] — default [0, 1] (standard probabilistic)\n160\t    // Use [-1, 1] for balanced/symmetric range\n161\t    // See: https://en.wikipedia.org/wiki/Balanced_ternary\n162\t    this.lo = opts.lo !== undefined ? opts.lo : 0;\n163\t    this.hi = opts.hi !== undefined ? opts.hi : 1;\n164\t\n165\t    // Valence: number of discrete truth values (0 or Infinity = continuous)\n166\t    // N=1: unary logic (trivial, only one truth value)\n167\t    // N=2: binary/Boolean logic — https://en.wikipedia.org/wiki/Boolean_algebra\n168\t    // N=3: ternary logic — https://en.wikipedia.org/wiki/Three-valued_logic\n169\t    // N=4+: N-valued logic — https://en.wikipedia.org/wiki/Many-valued_logic\n170\t    // N=0/Infinity: continuous probabilistic / fuzzy logic — https://en.wikipedia.org/wiki/Fuzzy_logic\n171\t    this.valence = opts.valence !== undefined ? opts.valence : 0;\n172\t\n173\t    // ops (redefinable)\n174\t    this.ops = new Map(Object.entries({\n175\t      'not': (x)=> this.hi - (x - this.lo),  // negation: mirrors around midpoint\n176\t      'and': (...xs)=> xs.length ? xs.reduce((a,b)=>a+b,0)/xs.length : this.lo, // avg\n177\t      'or' : (...xs)=> xs.length ? Math.max(...xs) : this.lo,\n178\t      // Belnap operators: AND-altering operators for four-valued logic\n179\t      // \"both\" (gullibility): avg — contradiction resolves to midpoint\n180\t      'both': (...xs)=> xs.length ? decRound(xs.reduce((a,b)=>a+b,0)/xs.length) : this.lo,\n181\t      // \"neither\" (consensus): product — gap resolves to zero (no info propagates)\n182\t      'neither': (...xs)=> xs.length ? decRound(xs.reduce((a,b)=>a*b,1)) : this.lo,\n183\t      '='  : (L,R,ctx)=> {\n184\t        // If assigned explicitly, use that (check both prefix and infix key forms)\n185\t        const kPrefix = keyOf(['=',L,R]);\n186\t        if (this.assign.has(kPrefix)) return this.assign.get(kPrefix);\n187\t        const kInfix = keyOf([L,'=',R]);\n188\t        if (this.assign.has(kInfix)) return this.assign.get(kInfix);\n189\t        // Default: syntactic equality of terms/trees\n190\t        return isStructurallySame(L,R) ? this.hi : this.lo;\n191\t      },\n192\t    }));\n193\t    // sugar: \"!=\" as not of \"=\" (can be redefined)\n194\t    this.defineOp('!=', (...args)=> this.getOp('not')( this.getOp('=')(...args) ));\n195\t\n196\t    // Arithmetic operators (decimal-precision by default)\n197\t    this.defineOp('+', (a,b)=> decRound(a + b));\n198\t    this.defineOp('-', (a,b)=> decRound(a - b));\n199\t    this.defineOp('*', (a,b)=> decRound(a * b));\n200\t    this.defineOp('/', (a,b)=> b === 0 ? 0 : decRound(a / b));\n201\t\n202\t    // Initialize truth constants: true, false, unknown, undefined\n203\t    // These are predefined symbol probabilities based on the current range.\n204\t    // By default: (false: min(range)), (true: max(range)),\n205\t    //             (unknown: mid(range)), (undefined: mid(range))\n206\t    // They can be redefined by the user via (true: <value>), (false: <value>), etc.\n207\t    this._initTruthConstants();\n208\t  }\n209\t\n210\t  // Clamp and optionally quantize a value to the valid range\n211\t  clamp(x) {\n212\t    const clamped = Math.max(this.lo, Math.min(this.hi, x));\n213\t    if (this.valence >= 2) return quantize(clamped, this.valence, this.lo, this.hi);\n214\t    return clamped;\n215\t  }\n216\t\n217\t  // Parse a numeric string respecting current range\n218\t  toNum(s) {\n219\t    return this.clamp(parseFloat(s));\n220\t  }\n221\t\n222\t  // Midpoint of the range (useful for paradox resolution, default symbol prob, etc.)\n223\t  get mid() { return (this.lo + this.hi) / 2; }\n224\t\n225\t  // Initialize truth constants based on current range.\n226\t  // (false: min(range)), (true: max(range)),\n227\t  // (unknown: mid(range)), (undefined: mid(range))\n228\t  _initTruthConstants() {\n229\t    this.symbolProb.set('true', this.hi);\n230\t    this.symbolProb.set('false', this.lo);\n231\t    this.symbolProb.set('unknown', this.mid);\n232\t    this.symbolProb.set('undefined', this.mid);\n233\t    // Belnap's four-valued logic operators:\n234\t    // \"both\" and \"neither\" are AND-altering operators (not constants).\n235\t    // \"both\" = conjunction under contradiction (gullibility) — default: avg\n236\t    //   (true both false) = 0.5 (both true and false → contradiction/paradox)\n237\t    // \"neither\" = conjunction under gap (consensus) — default: product\n238\t    //   (true neither false) = 0 (neither true nor false → gap/no info)\n239\t    // Both are redefinable via (both: min), (neither: max), etc.\n240\t    // See: https://en.wikipedia.org/wiki/Four-valued_logic#Belnap\n241\t  }\n242\t\n243\t  getOp(name){\n244\t    if (!this.ops.has(name)) throw new RmlError('E001', `Unknown op: ${name}`);\n245\t    return this.ops.get(name);\n246\t  }\n247\t  defineOp(name, fn){ this.ops.set(name, fn); }\n248\t\n249\t  setExprProb(exprNode, p){\n250\t    this.assign.set(keyOf(exprNode), this.clamp(p));\n251\t  }\n252\t  setType(exprNode, typeExpr){\n253\t    const key = typeof exprNode === 'string' ? exprNode : keyOf(exprNode);\n254\t    this.types.set(key, typeof typeExpr === 'string' ? typeExpr : keyOf(typeExpr));\n255\t  }\n256\t  getType(exprNode){\n257\t    const key = typeof exprNode === 'string' ? exprNode : keyOf(exprNode);\n258\t    return this.types.get(key) || null;\n259\t  }\n260\t  setLambda(name, param, paramType, body){\n261\t    this.lambdas.set(name, { param, paramType, body });\n262\t  }\n263\t  getLambda(name){\n264\t    return this.lambdas.get(name) || null;\n265\t  }\n266\t  setSymbolProb(sym, p){ this.symbolProb.set(sym, this.clamp(p)); }\n267\t  getSymbolProb(sym){ return this.symbolProb.has(sym) ? this.symbolProb.get(sym) : this.mid; }\n268\t}\n269\t\n270\t// ---------- Binding parser ----------\n271\t// Parse a binding form in two supported syntaxes:\n272\t// 1. Colon form: (x: A) as ['x:', A] — standard LiNo link definition syntax\n273\t// 2. Prefix type form: (A x) as ['A', 'x'] — type-first notation for lambda/Pi bindings\n274\t//    e.g. (Natural x), used in (lambda (Natural x) body)\n275\t// Returns { paramName, paramType } or null if not a valid binding.\n276\tfunction parseBinding(binding) {\n277\t  if (!Array.isArray(binding)) return null;\n278\t  // ['x:', A] — two elements where first ends with colon (standard LiNo link definition)\n279\t  if (binding.length === 2 && typeof binding[0] === 'string' && binding[0].endsWith(':')) {\n280\t    return { paramName: binding[0].slice(0, -1), paramType: binding[1] };\n281\t  }\n282\t  // ['A', 'x'] — prefix type form: type name first, then variable name\n283\t  // Type names must start with uppercase (convention from Lean/Rocq)\n284\t  if (binding.length === 2 && typeof binding[0] === 'string' && typeof binding[1] === 'string'\n285\t      && /^[A-Z]/.test(binding[0]) && !binding[1].endsWith(':')) {\n286\t    return { paramName: binding[1], paramType: binding[0] };\n287\t  }\n288\t  return null;\n289\t}\n290\t\n291\t// ---------- Multi-binding parser ----------\n292\t// Parse comma-separated bindings: (Natural x, Natural y) → [{paramName:'x', paramType:'Natural'}, ...]\n293\t// Tokens arrive as ['Natural', 'x,', 'Natural', 'y'] or ['Natural', 'x'] (single binding)\n294\tfunction parseBindings(binding) {\n295\t  if (!Array.isArray(binding)) return null;\n296\t  // Try single binding first\n297\t  const single = parseBinding(binding);\n298\t  if (single) return [single];\n299\t  // Try comma-separated: flatten tokens, split by commas\n300\t  const tokens = [];\n301\t  for (const tok of binding) {\n302\t    if (typeof tok === 'string') {\n303\t      // Split tokens that end with comma: 'x,' → 'x', separator\n304\t      if (tok.endsWith(',')) {\n305\t        tokens.push(tok.slice(0, -1));\n306\t        tokens.push(',');\n307\t      } else {\n308\t        tokens.push(tok);\n309\t      }\n310\t    } else {\n311\t      tokens.push(tok);\n312\t    }\n313\t  }\n314\t  // Group into pairs separated by commas\n315\t  const bindings = [];\n316\t  let i = 0;\n317\t  while (i < tokens.length) {\n318\t    if (tokens[i] === ',') { i++; continue; }\n319\t    if (i + 1 < tokens.length && typeof tokens[i] === 'string' && typeof tokens[i+1] === 'string' && tokens[i+1] !== ',') {\n320\t      const pair = parseBinding([tokens[i], tokens[i+1]]);\n321\t      if (pair) {\n322\t        bindings.push(pair);\n323\t        i += 2;\n324\t        continue;\n325\t      }\n326\t    }\n327\t    return null; // invalid binding format\n328\t  }\n329\t  return bindings.length > 0 ? bindings : null;\n330\t}\n331\t\n332\t// ---------- Substitution (for beta-reduction) ----------\n333\t// Substitute all occurrences of variable `name` with `replacement` in `expr`.\n334\t// Both expr and replacement can be strings or arrays (AST nodes).\n335\tfunction substitute(expr, name, replacement) {\n336\t  if (typeof expr === 'string') {\n337\t    return expr === name ? replacement : expr;\n338\t  }\n339\t  if (Array.isArray(expr)) {\n340\t    // Don't substitute inside a binding that shadows the variable\n341\t    if (expr.length === 3 && (expr[0] === 'lambda' || expr[0] === 'Pi') && Array.isArray(expr[1])) {\n342\t      const parsed = parseBinding(expr[1]);\n343\t      if (parsed && parsed.paramName === name) {\n344\t        return expr; // shadowed\n345\t      }\n346\t    }\n347\t    return expr.map(child => substitute(child, name, replacement));\n348\t  }\n349\t  return expr;\n350\t}\n351\t\n352\t// ---------- Eval ----------\n353\t// Evaluate a node in arithmetic context — numeric literals are NOT clamped to the logic range.\n354\tfunction evalArith(node, env){\n355\t  if (typeof node === 'string' && isNum(node)) return parseFloat(node);\n356\t  return evalNode(node, env);\n357\t}\n358\t\n359\tfunction evalNode(node, env){\n360\t  if (typeof node === 'string') {\n361\t    if (isNum(node)) return env.toNum(node);\n362\t    // bare symbol → optional prior probability if set; otherwise irrelevant in calc\n363\t    return env.getSymbolProb(node);\n364\t  }\n365\t\n366\t  // Definitions & operator redefs:  (head: ...)\n367\t  if (typeof node[0] === 'string' && node[0].endsWith(':')) {\n368\t    const head = node[0].slice(0,-1);\n369\t    return defineForm(head, node.slice(1), env);\n370\t  }\n371\t  // Note: (x : A) with spaces as a standalone colon separator is NOT supported.\n372\t  // Use (x: A) instead — the colon must be part of the link name.\n373\t\n374\t  // Assignment: ((expr) has probability p)\n375\t  if (node.length === 4 && node[1] === 'has' && node[2] === 'probability' && isNum(node[3])) {\n376\t    env.setExprProb(node[0], parseFloat(node[3]));\n377\t    return env.toNum(node[3]);\n378\t  }\n379\t\n380\t  // Range configuration: (range: lo hi) — sets the truth value range\n381\t  // (range: 0 1) for standard [0,1] or (range: -1 1) for balanced [-1,1]\n382\t  // See: https://en.wikipedia.org/wiki/Balanced_ternary\n383\t  // Must be checked in evalNode for (range lo hi) prefix form\n384\t  if (node.length === 3 && node[0] === 'range' && isNum(node[1]) && isNum(node[2])) {\n385\t    env.lo = parseFloat(node[1]);\n386\t    env.hi = parseFloat(node[2]);\n387\t    // Re-initialize ops for new range\n388\t    _reinitOps(env);\n389\t    return 1;\n390\t  }\n391\t\n392\t  // Valence configuration: (valence N) prefix form\n393\t  if (node.length === 2 && node[0] === 'valence' && isNum(node[1])) {\n394\t    env.valence = parseInt(node[1], 10);\n395\t    return 1;\n396\t  }\n397\t\n398\t  // Query: (? expr)\n399\t  if (node[0] === '?') {\n400\t    const v = evalNode(node[1], env);\n401\t    // If inner result is already a query (e.g. from (type of x)), pass it through\n402\t    if (v && typeof v === 'object' && v.query) return v;\n403\t    return { query:true, value: env.clamp(v) };\n404\t  }\n405\t\n406\t  // Infix arithmetic: (A + B), (A - B), (A * B), (A / B)\n407\t  // Arithmetic uses raw numeric values (not clamped to the logic range)\n408\t  if (node.length === 3 && typeof node[1] === 'string' && ['+','-','*','/'].includes(node[1])) {\n409\t    const op = env.getOp(node[1]);\n410\t    const L = evalArith(node[0], env);\n411\t    const R = evalArith(node[2], env);\n412\t    return op(L,R);\n413\t  }\n414\t\n415\t  // Infix AND/OR/BOTH/NEITHER: ((A) and (B))  /  ((A) or (B))  /  ((A) both (B))  /  ((A) neither (B))\n416\t  if (node.length === 3 && typeof node[1] === 'string' && (node[1]==='and' || node[1]==='or' || node[1]==='both' || node[1]==='neither')) {\n417\t    const op = env.getOp(node[1]);\n418\t    const L = evalNode(node[0], env);\n419\t    const R = evalNode(node[2], env);\n420\t    return env.clamp(op(L,R));\n421\t  }\n422\t\n423\t  // Composite natural language operators: (both A and B [and C ...]), (neither A nor B [nor C ...])\n424\t  if (node.length >= 4 && typeof node[0] === 'string' && (node[0]==='both' || node[0]==='neither')) {\n425\t    const sep = node[0]==='both' ? 'and' : 'nor';\n426\t    // Validate pattern: operator, value, sep, value [, sep, value ...]\n427\t    let valid = node.length % 2 === 0; // both + (n values) + (n-1 seps) = 1 + n + (n-1) = 2n, always even\n428\t    if (valid) {\n429\t      for (let i = 2; i < node.length; i += 2) {\n430\t        if (node[i] !== sep) { valid = false; break; }\n431\t      }\n432\t    }\n433\t    if (valid) {\n434\t      const op = env.getOp(node[0]);\n435\t      const vals = [];\n436\t      for (let i = 1; i < node.length; i += 2) {\n437\t        vals.push(evalNode(node[i], env));\n438\t      }\n439\t      return env.clamp(op(...vals));\n440\t    }\n441\t  }\n442\t\n443\t  // Infix equality/inequality: (L = R), (L != R)\n444\t  if (node.length === 3 && typeof node[1] === 'string' && (node[1]==='=' || node[1]==='!=')) {\n445\t    const op = env.getOp(node[1]);\n446\t    // Equality checks assigned probability first, then structural equality,\n447\t    // then falls back to numeric comparison of evaluated values (decimal-precision)\n448\t    const raw = op(node[0], node[2], keyOf);\n449\t    // If structural/assigned equality already gave a definitive answer, use it\n450\t    if (raw === env.hi || raw === env.lo) {\n451\t      // Check if there's an explicit assignment — if so, trust it\n452\t      const kPrefix = keyOf(['=',node[0],node[2]]);\n453\t      const kInfix = keyOf([node[0],'=',node[2]]);\n454\t      if (env.assign.has(kPrefix) || env.assign.has(kInfix) || isStructurallySame(node[0], node[2])) {\n455\t        return env.clamp(raw);\n456\t      }\n457\t      // No explicit assignment and not structurally same — try numeric comparison\n458\t      const L = evalNode(node[0], env);\n459\t      const R = evalNode(node[2], env);\n460\t      const numEq = decRound(L) === decRound(R) ? env.hi : env.lo;\n461\t      if (node[1] === '!=') return env.clamp(env.getOp('not')(numEq));\n462\t      return env.clamp(numEq);\n463\t    }\n464\t    return env.clamp(raw);\n465\t  }\n466\t\n467\t  // ---------- Type System: \"everything is a link\" ----------\n468\t\n469\t  // Type universe: (Type N) — the sort at universe level N\n470\t  if (node.length === 2 && node[0] === 'Type') {\n471\t    const level = isNum(node[1]) ? parseInt(node[1], 10) : 0;\n472\t    // (Type N) has type (Type N+1)\n473\t    env.setType(node, ['Type', String(level + 1)]);\n474\t    return 1; // valid expression\n475\t  }\n476\t\n477\t  // Prop: (Prop) is sugar for (Type 0) in the propositions-as-types interpretation\n478\t  if (node.length === 1 && node[0] === 'Prop') {\n479\t    env.setType(['Prop'], ['Type', '1']);\n480\t    return 1;\n481\t  }\n482\t\n483\t  // Dependent product (Pi-type): (Pi (A x) B) or (Pi (x: A) B)\n484\t  if (node.length === 3 && node[0] === 'Pi') {\n485\t    const binding = node[1];\n486\t    const parsed = parseBinding(binding);\n487\t    if (parsed) {\n488\t      const { paramName, paramType } = parsed;\n489\t      env.terms.add(paramName);\n490\t      env.setType(paramName, paramType);\n491\t      env.setType(node, ['Type', '0']);\n492\t    }\n493\t    return 1;\n494\t  }\n495\t\n496\t  // Lambda abstraction: (lambda (A x) body) or (lambda (x: A) body)\n497\t  // Also supports multi-param: (lambda (A x, B y) body)\n498\t  if (node.length === 3 && node[0] === 'lambda') {\n499\t    const binding = node[1];\n500\t    const bindings = parseBindings(binding);\n501\t    if (bindings && bindings.length > 0) {\n502\t      // For single binding — standard case\n503\t      const { paramName, paramType } = bindings[0];\n504\t      const body = node[2];\n505\t      env.terms.add(paramName);\n506\t      env.setType(paramName, paramType);\n507\t      // Register additional bindings\n508\t      for (let i = 1; i < bindings.length; i++) {\n509\t        env.terms.add(bindings[i].paramName);\n510\t        env.setType(bindings[i].paramName, bindings[i].paramType);\n511\t      }\n512\t      const bodyType = env.getType(body);\n513\t      const paramTypeKey = typeof paramType === 'string' ? paramType : keyOf(paramType);\n514\t      const bodyTypeKey = bodyType || 'unknown';\n515\t      env.setType(node, '(Pi (' + paramTypeKey + ' ' + paramName + ') ' + bodyTypeKey + ')');\n516\t    }\n517\t    return 1;\n518\t  }\n519\t\n520\t  // Application: (apply f x) — explicit application with beta-reduction\n521\t  if (node.length === 3 && node[0] === 'apply') {\n522\t    const fn = node[1];\n523\t    const arg = node[2];\n524\t\n525\t    // Check if fn is a lambda: (lambda (A x) body)\n526\t    if (Array.isArray(fn) && fn.length === 3 && fn[0] === 'lambda') {\n527\t      const parsed = parseBinding(fn[1]);\n528\t      if (parsed) {\n529\t        const body = fn[2];\n530\t        const result = substitute(body, parsed.paramName, arg);\n531\t        return evalNode(result, env);\n532\t      }\n533\t    }\n534\t\n535\t    // Check if fn is a named lambda\n536\t    if (typeof fn === 'string') {\n537\t      const lambda = env.getLambda(fn);\n538\t      if (lambda) {\n539\t        const result = substitute(lambda.body, lambda.param, arg);\n540\t        return evalNode(result, env);\n541\t      }\n542\t    }\n543\t\n544\t    // Otherwise evaluate fn and arg normally\n545\t    const fVal = evalNode(fn, env);\n546\t    const aVal = evalNode(arg, env);\n547\t    return typeof fVal === 'number' ? fVal : (fVal && fVal.value !== undefined ? fVal.value : 0);\n548\t  }\n549\t\n550\t  // Type query: (type of expr) — returns the type of an expression\n551\t  // e.g. (? (type of x)) → returns the type string\n552\t  if (node.length === 3 && node[0] === 'type' && node[1] === 'of') {\n553\t    const expr = node[2];\n554\t    const typeStr = env.getType(expr);\n555\t    if (typeStr) {\n556\t      return { query: true, value: typeStr, typeQuery: true };\n557\t    }\n558\t    return { query: true, value: 'unknown', typeQuery: true };\n559\t  }\n560\t\n561\t  // Type check query: (expr of Type) — checks if expr has the given type\n562\t  // e.g. (? (x of Natural)) → returns 1 or 0\n563\t  if (node.length === 3 && node[1] === 'of') {\n564\t    const expr = node[0];\n565\t    const expectedType = node[2];\n566\t    const actualType = env.getType(expr);\n567\t    if (actualType) {\n568\t      const expectedKey = typeof expectedType === 'string' ? expectedType : keyOf(expectedType);\n569\t      return actualType === expectedKey ? env.hi : env.lo;\n570\t    }\n571\t    return env.lo;\n572\t  }\n573\t\n574\t  // Prefix: (not X), (and X Y ...), (or X Y ...)\n575\t  const [head, ...args] = node;\n576\t  if (typeof head === 'string' && env.ops.has(head)) {\n577\t    const op = env.getOp(head);\n578\t    const vals = args.map(a => evalNode(a, env));\n579\t    return env.clamp(op(...vals));\n580\t  }\n581\t\n582\t  // Fall through: prefix application (f x y ...) for named lambdas\n583\t  if (typeof head === 'string' && args.length >= 1) {\n584\t    const lambda = env.getLambda(head);\n585\t    if (lambda) {\n586\t      // Apply first argument, then recursively apply rest\n587\t      let result = substitute(lambda.body, lambda.param, args[0]);\n588\t      if (args.length === 1) {\n589\t        return evalNode(result, env);\n590\t      }\n591\t      // Curry: apply remaining args\n592\t      let current = evalNode(result, env);\n593\t      for (let i = 1; i < args.length; i++) {\n594\t        // If current result is a lambda, apply next arg\n595\t        current = evalNode(args[i], env);\n596\t      }\n597\t      return current;\n598\t    }\n599\t  }\n600\t\n601\t  return 0;\n602\t}\n603\t\n604\t// Re-initialize default ops when range changes\n605\tfunction _reinitOps(env) {\n606\t  env.ops.set('not', (x) => env.hi - (x - env.lo));\n607\t  env.ops.set('and', (...xs) => xs.length ? xs.reduce((a,b)=>a+b,0)/xs.length : env.lo);\n608\t  env.ops.set('or', (...xs) => xs.length ? Math.max(...xs) : env.lo);\n609\t  env.ops.set('both', (...xs) => xs.length ? decRound(xs.reduce((a,b)=>a+b,0)/xs.length) : env.lo);\n610\t  env.ops.set('neither', (...xs) => xs.length ? decRound(xs.reduce((a,b)=>a*b,1)) : env.lo);\n611\t  env.ops.set('=', (L,R,ctx) => {\n612\t    const kPrefix = keyOf(['=',L,R]);\n613\t    if (env.assign.has(kPrefix)) return env.assign.get(kPrefix);\n614\t    const kInfix = keyOf([L,'=',R]);\n615\t    if (env.assign.has(kInfix)) return env.assign.get(kInfix);\n616\t    return isStructurallySame(L,R) ? env.hi : env.lo;\n617\t  });\n618\t  env.ops.set('!=', (...args) => env.getOp('not')( env.getOp('=')(...args) ));\n619\t  env.ops.set('+', (a,b) => decRound(a + b));\n620\t  env.ops.set('-', (a,b) => decRound(a - b));\n621\t  env.ops.set('*', (a,b) => decRound(a * b));\n622\t  env.ops.set('/', (a,b) => b === 0 ? 0 : decRound(a / b));\n623\t  // Re-initialize truth constants for new range\n624\t  env._initTruthConstants();\n625\t}\n626\t\n627\tfunction defineForm(head, rhs, env){\n628\t  // Term definition: (a: a is a)  → declare 'a' as a term (no probability assignment)\n629\t  if (rhs.length === 3 && typeof rhs[0]==='string' && rhs[1]==='is' && typeof rhs[2]==='string' && rhs[0]===head && rhs[2]===head) {\n630\t    env.terms.add(head);\n631\t    return 1;\n632\t  }\n633\t\n634\t  // Prefix type notation: (name: TypeName name) → typed self-referential declaration\n635\t  // e.g. (zero: Natural zero), (boolean: Type boolean), (true: Boolean true)\n636\t  if (rhs.length === 2 && typeof rhs[0] === 'string' && typeof rhs[1] === 'string' && rhs[1] === head) {\n637\t    const typeName = rhs[0];\n638\t    // Only if typeName starts with uppercase (type convention) and is not an operator\n639\t    if (/^[A-Z]/.test(typeName)) {\n640\t      env.terms.add(head);\n641\t      env.setType(head, typeName);\n642\t      return 1;\n643\t    }\n644\t  }\n645\t\n646\t  // Prefix type notation with complex type: (name: (Type 0) name) → typed self-referential declaration\n647\t  if (rhs.length === 2 && Array.isArray(rhs[0]) && typeof rhs[1] === 'string' && rhs[1] === head) {\n648\t    const typeExpr = rhs[0];\n649\t    env.terms.add(head);\n650\t    env.setType(head, typeExpr);\n651\t    evalNode(typeExpr, env);\n652\t    return 1;\n653\t  }\n654\t\n655\t  // Typed declaration with complex type expression: (succ: (Pi (Natural n) Natural))\n656\t  // Only complex expressions (arrays) are accepted as type annotations in single-element form.\n657\t  // Simple name type annotations like (x: Natural) are NOT supported — use (x: Natural x) prefix form instead.\n658\t  if (rhs.length === 1 && Array.isArray(rhs[0])) {\n659\t    const isOp = ['=','!=','and','or','not','is','?:','both','neither'].includes(head) || /[=!]/.test(head);\n660\t    if (!isOp) {\n661\t      const typeExpr = rhs[0];\n662\t      env.terms.add(head);\n663\t      env.setType(head, typeExpr);\n664\t      evalNode(typeExpr, env);\n665\t      return 1;\n666\t    }\n667\t  }\n668\t\n669\t  // Range configuration: (range: lo hi) — sets the truth value range\n670\t  if (head === 'range' && rhs.length === 2 && isNum(rhs[0]) && isNum(rhs[1])) {\n671\t    env.lo = parseFloat(rhs[0]);\n672\t    env.hi = parseFloat(rhs[1]);\n673\t    _reinitOps(env);\n674\t    return 1;\n675\t  }\n676\t\n677\t  // Valence configuration: (valence: N) — sets the number of truth values\n678\t  // N=1: unary (trivial), N=2: binary (Boolean), N=3: ternary, N=0: continuous\n679\t  if (head === 'valence' && rhs.length === 1 && isNum(rhs[0])) {\n680\t    env.valence = parseInt(rhs[0], 10);\n681\t    return 1;\n682\t  }\n683\t\n684\t  // Optional symbol prior: (a: 0.7) — not required for your use-case, but allowed\n685\t  if (rhs.length === 1 && isNum(rhs[0])) {\n686\t    env.setSymbolProb(head, parseFloat(rhs[0]));\n687\t    return env.toNum(rhs[0]);\n688\t  }\n689\t\n690\t  // Operator redefinitions\n691\t  if (['=','!=','and','or','not','is','?:','both','neither'].includes(head) || /[=!]/.test(head)) {\n692\t\n693\t    // Composition like: (!=: not =)   or  (=: =) (no-op)\n694\t    if (rhs.length === 2 && typeof rhs[0]==='string' && typeof rhs[1]==='string') {\n695\t      const outer = env.getOp(rhs[0]);\n696\t      const inner = env.getOp(rhs[1]);\n697\t      env.defineOp(head, (...xs) => env.clamp( outer( inner(...xs) ) ));\n698\t      return 1;\n699\t    }\n700\t\n701\t    // Aggregator selection: (and: avg|min|max|product|probabilistic_sum)\n702\t    if ((head==='and' || head==='or' || head==='both' || head==='neither') && rhs.length===1 && typeof rhs[0]==='string') {\n703\t      const sel = rhs[0];\n704\t      const lo = env.lo;\n705\t      const agg =\n706\t        sel==='avg' ? xs=>xs.reduce((a,b)=>a+b,0)/xs.length :\n707\t        sel==='min' ? xs=>xs.length? Math.min(...xs) : lo :\n708\t        sel==='max' ? xs=>xs.length? Math.max(...xs) : lo :\n709\t        sel==='product' || sel==='prod' ? xs=>xs.reduce((a,b)=>a*b,1) :\n710\t        sel==='probabilistic_sum' || sel==='ps' ? xs=> 1 - xs.reduce((a,b)=>a*(1-b),1) : null;\n711\t      if (!agg) throw new RmlError('E004', `Unknown aggregator \"${sel}\"`);\n712\t      env.defineOp(head, (...xs)=> xs.length? agg(xs) : lo);\n713\t      return 1;\n714\t    }\n715\t\n716\t    throw new RmlError('E003', `Unsupported operator definition for \"${head}\"`);\n717\t  }\n718\t\n719\t  // Lambda definition: (name: lambda (A x) body)\n720\t  if (rhs.length >= 2 && rhs[0] === 'lambda') {\n721\t    if (rhs.length === 3 && Array.isArray(rhs[1])) {\n722\t      const parsed = parseBinding(rhs[1]);\n723\t      if (parsed) {\n724\t        const { paramName, paramType } = parsed;\n725\t        const body = rhs[2];\n726\t        env.terms.add(head);\n727\t        env.setLambda(head, paramName, paramType, body);\n728\t        const paramTypeKey = typeof paramType === 'string' ? paramType : keyOf(paramType);\n729\t        const bodyTypeKey = env.getType(body) || (typeof body === 'string' ? body : keyOf(body));\n730\t        env.setType(head, '(Pi (' + paramTypeKey + ' ' + paramName + ') ' + bodyTypeKey + ')');\n731\t        return 1;\n732\t      }\n733\t    }\n734\t  }\n735\t\n736\t  // Typed definition: (name : Type) — just a type annotation (no body)\n737\t  // Already handled by the (x: A) form in evalNode\n738\t\n739\t  // Generic symbol al