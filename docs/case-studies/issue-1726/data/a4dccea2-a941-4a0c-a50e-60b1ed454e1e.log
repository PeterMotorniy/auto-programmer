        "content": "1\t// Tests for structured diagnostics (issue #28).\n2\t// Covers the evaluate() API, error codes, source spans, and CLI-style\n3\t// formatting. The Rust suite mirrors these cases in\n4\t// rust/tests/diagnostics_tests.rs to keep the two implementations in lock-step.\n5\t\n6\timport { describe, it } from 'node:test';\n7\timport assert from 'node:assert';\n8\timport {\n9\t  evaluate,\n10\t  formatDiagnostic,\n11\t  Diagnostic,\n12\t  RmlError,\n13\t  computeFormSpans,\n14\t} from '../src/rml-links.mjs';\n15\t\n16\tdescribe('evaluate() returns a structured result', () => {\n17\t  it('produces results and an empty diagnostics array on a clean input', () => {\n18\t    const out = evaluate('(valence: 2)\\n(p has probability 1)\\n(? p)');\n19\t    assert.ok(Array.isArray(out.results));\n20\t    assert.ok(Array.isArray(out.diagnostics));\n21\t    assert.strictEqual(out.diagnostics.length, 0);\n22\t    assert.strictEqual(out.results.length, 1);\n23\t    assert.strictEqual(out.results[0], 1);\n24\t  });\n25\t\n26\t  it('does not throw on bad input — returns a Diagnostic instead', () => {\n27\t    let threw = false;\n28\t    let out;\n29\t    try {\n30\t      out = evaluate('(=: missing_op identity)');\n31\t    } catch (_) {\n32\t      threw = true;\n33\t    }\n34\t    assert.strictEqual(threw, false, 'evaluate() must not throw');\n35\t    assert.ok(out.diagnostics.length >= 1);\n36\t  });\n37\t});\n38\t\n39\tdescribe('Diagnostic shape and error codes', () => {\n40\t  it('E001 — unknown op surfaces with file/line/col span', () => {\n41\t    const out = evaluate('(=: missing_op identity)', { file: 'inline.lino' });\n42\t    assert.strictEqual(out.diagnostics.length, 1);\n43\t    const d = out.diagnostics[0];\n44\t    assert.ok(d instanceof Diagnostic);\n45\t    assert.strictEqual(d.code, 'E001');\n46\t    assert.match(d.message, /Unknown op/);\n47\t    assert.strictEqual(d.span.file, 'inline.lino');\n48\t    assert.strictEqual(d.span.line, 1);\n49\t    assert.strictEqual(d.span.col, 1);\n50\t  });\n51\t\n52\t  it('E006 — LiNo parse error is reported as a diagnostic, not thrown', () => {\n53\t    const out = evaluate('(=: foo bar', { file: 'inline.lino' });\n54\t    assert.strictEqual(out.diagnostics.length, 1);\n55\t    const d = out.diagnostics[0];\n56\t    assert.strictEqual(d.code, 'E006');\n57\t    assert.strictEqual(d.span.file, 'inline.lino');\n58\t    assert.strictEqual(d.span.line, 1);\n59\t  });\n60\t\n61\t  it('E004 — unknown aggregator surfaces', () => {\n62\t    const out = evaluate('(and: bogus_agg)', { file: 'agg.lino' });\n63\t    assert.strictEqual(out.diagnostics.length, 1);\n64\t    const d = out.diagnostics[0];\n65\t    assert.strictEqual(d.code, 'E004');\n66\t    assert.match(d.message, /aggregator/i);\n67\t    assert.strictEqual(d.span.line, 1);\n68\t  });\n69\t\n70\t  it('E001 — span tracks line for forms that follow blank lines', () => {\n71\t    const src = '(valence: 2)\\n\\n(=: missing identity)';\n72\t    const out = evaluate(src, { file: 'multi.lino' });\n73\t    assert.strictEqual(out.diagnostics.length, 1);\n74\t    assert.strictEqual(out.diagnostics[0].code, 'E001');\n75\t    assert.strictEqual(out.diagnostics[0].span.line, 3);\n76\t    assert.strictEqual(out.diagnostics[0].span.col, 1);\n77\t  });\n78\t\n79\t  it('keeps good results even when a later form errors', () => {\n80\t    const src = '(valence: 2)\\n(p has probability 1)\\n(? p)\\n(=: missing identity)';"
