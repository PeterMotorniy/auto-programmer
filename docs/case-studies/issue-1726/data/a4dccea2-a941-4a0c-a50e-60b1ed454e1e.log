        "tool_use_id": "toolu_01XKrUi3KhFDHTVu8YY8Wz3n",
        "type": "tool_result",
        "content": "483\tpub struct EnvOptions {\n484\t    pub lo: f64,\n485\t    pub hi: f64,\n486\t    pub valence: u32,\n487\t}\n488\t\n489\timpl Default for EnvOptions {\n490\t    fn default() -> Self {\n491\t        Self {\n492\t            lo: 0.0,\n493\t            hi: 1.0,\n494\t            valence: 0,\n495\t        }\n496\t    }\n497\t}\n498\t\n499\t/// A stored lambda definition (param name, param type, body).\n500\t#[derive(Debug, Clone)]\n501\tpub struct Lambda {\n502\t    pub param: String,\n503\t    pub param_type: String,\n504\t    pub body: Node,\n505\t}\n506\t\n507\t/// The evaluation environment: holds terms, assignments, operators, and range/valence config.\n508\tpub struct Env {\n509\t    pub terms: HashSet<String>,\n510\t    pub assign: HashMap<String, f64>,\n511\t    pub symbol_prob: HashMap<String, f64>,\n512\t    pub lo: f64,\n513\t    pub hi: f64,\n514\t    pub valence: u32,\n515\t    pub ops: HashMap<String, Op>,\n516\t    pub types: HashMap<String, String>,\n517\t    pub lambdas: HashMap<String, Lambda>,\n518\t}\n519\t\n520\timpl Env {\n521\t    pub fn new(options: Option<EnvOptions>) -> Self {\n522\t        let opts = options.unwrap_or_default();\n523\t        let mut ops = HashMap::new();\n524\t        ops.insert(\"not\".to_string(), Op::Not);\n525\t        ops.insert(\"and\".to_string(), Op::Agg(Aggregator::Avg));\n526\t        ops.insert(\"or\".to_string(), Op::Agg(Aggregator::Max));\n527\t        // Belnap operators: AND-altering operators for four-valued logic\n528\t        // \"both\" (gullibility): avg — contradiction resolves to midpoint\n529\t        // \"neither\" (consensus): product — gap resolves to zero (no info propagates)\n530\t        // See: https://en.wikipedia.org/wiki/Four-valued_logic#Belnap\n531\t        ops.insert(\"both\".to_string(), Op::Agg(Aggregator::Avg));\n532\t        ops.insert(\"neither\".to_string(), Op::Agg(Aggregator::Prod));\n533\t        ops.insert(\"=\".to_string(), Op::Eq);\n534\t        ops.insert(\"!=\".to_string(), Op::Neq);\n535\t        ops.insert(\"+\".to_string(), Op::Add);\n536\t        ops.insert(\"-\".to_string(), Op::Sub);\n537\t        ops.insert(\"*\".to_string(), Op::Mul);\n538\t        ops.insert(\"/\".to_string(), Op::Div);\n539\t\n540\t        let mut env = Self {\n541\t            terms: HashSet::new(),\n542\t            assign: HashMap::new(),\n543\t            symbol_prob: HashMap::new(),\n544\t            lo: opts.lo,\n545\t            hi: opts.hi,\n546\t            valence: opts.valence,\n547\t            ops,\n548\t            types: HashMap::new(),\n549\t            lambdas: HashMap::new(),\n550\t        };\n551\t\n552\t        // Initialize truth constants: true, false, unknown, undefined\n553\t        // These are predefined symbol probabilities based on the current range.\n554\t        // By default: (false: min(range)), (true: max(range)),\n555\t        //             (unknown: mid(range)), (undefined: mid(range))\n556\t        // They can be redefined by the user via (true: <value>), (false: <value>), etc.\n557\t        env.init_truth_constants();\n558\t        env\n559\t    }\n560\t\n561\t    /// Midpoint of the range.\n562\t    pub fn mid(&self) -> f64 {\n563\t        (self.lo + self.hi) / 2.0\n564\t    }\n565\t\n566\t    /// Initialize truth constants based on current range.\n567\t    /// (false: min(range)), (true: max(range)),\n568\t    /// (unknown: mid(range)), (undefined: mid(range))\n569\t    pub fn init_truth_constants(&mut self) {\n570\t        self.symbol_prob.insert(\"true\".to_string(), self.hi);\n571\t        self.symbol_prob.insert(\"false\".to_string(), self.lo);\n572\t        let mid = self.mid();\n573\t        self.symbol_prob.insert(\"unknown\".to_string(), mid);\n574\t        self.symbol_prob.insert(\"undefined\".to_string(), mid);\n575\t        // Note: \"both\" and \"neither\" are operators (not constants) — see Env::new()\n576\t        // See: https://en.wikipedia.org/wiki/Four-valued_logic#Belnap\n577\t    }\n578\t\n579\t    /// Clamp and optionally quantize a value to the valid range.\n580\t    pub fn clamp(&self, x: f64) -> f64 {\n581\t        let clamped = x.max(self.lo).min(self.hi);\n582\t        if self.valence >= 2 {\n583\t            quantize(clamped, self.valence, self.lo, self.hi)\n584\t        } else {\n585\t            clamped\n586\t        }\n587\t    }\n588\t\n589\t    /// Parse a numeric string respecting current range.\n590\t    pub fn to_num(&self, s: &str) -> f64 {\n591\t        self.clamp(s.parse::<f64>().unwrap_or(0.0))\n592\t    }\n593\t\n594\t    pub fn define_op(&mut self, name: &str, op: Op) {\n595\t        self.ops.insert(name.to_string(), op);\n596\t    }\n597\t\n598\t    pub fn get_op(&self, name: &str) -> Option<&Op> {\n599\t        self.ops.get(name)\n600\t    }\n601\t\n602\t    pub fn set_expr_prob(&mut self, expr_node: &Node, p: f64) {\n603\t        self.assign.insert(key_of(expr_node), self.clamp(p));\n604\t    }\n605\t\n606\t    pub fn set_symbol_prob(&mut self, sym: &str, p: f64) {\n607\t        self.symbol_prob.insert(sym.to_string(), self.clamp(p));\n608\t    }\n609\t\n610\t    pub fn get_symbol_prob(&self, sym: &str) -> f64 {\n611\t        self.symbol_prob\n612\t            .get(sym)\n613\t            .copied()\n614\t            .unwrap_or_else(|| self.mid())\n615\t    }\n616\t\n617\t    pub fn set_type(&mut self, expr: &str, type_expr: &str) {\n618\t        self.types.insert(expr.to_string(), type_expr.to_string());\n619\t    }\n620\t\n621\t    pub fn get_type(&self, expr: &str) -> Option<&String> {\n622\t        self.types.get(expr)\n623\t    }\n624\t\n625\t    pub fn set_lambda(&mut self, name: &str, lambda: Lambda) {\n626\t        self.lambdas.insert(name.to_string(), lambda);\n627\t    }\n628\t\n629\t    pub fn get_lambda(&self, name: &str) -> Option<&Lambda> {\n630\t        self.lambdas.get(name)\n631\t    }\n632\t\n633\t    /// Apply an operator by name to the given values.\n634\t    pub fn apply_op(&self, name: &str, vals: &[f64]) -> f64 {\n635\t        let op = match self.ops.get(name) {\n636\t            Some(op) => op.clone(),\n637\t            None => panic!(\"Unknown op: {}\", name),\n638\t        };\n639\t        match op {\n640\t            Op::Not => {\n641\t                if vals.is_empty() {\n642\t                    self.lo\n643\t                } else {\n644\t                    self.hi - (vals[0] - self.lo)\n645\t                }\n646\t            }\n647\t            Op::Agg(agg) => dec_round(agg.apply(vals, self.lo)),\n648\t            Op::Eq | Op::Neq => self.lo,\n649\t            Op::Compose {\n650\t                ref outer,\n651\t                ref inner,\n652\t            } => {\n653\t                let inner_result = self.apply_op(inner, vals);\n654\t                self.apply_op(outer, &[inner_result])\n655\t            }\n656\t            Op::Add => {\n657\t                if vals.len() >= 2 {\n658\t                    dec_round(vals[0] + vals[1])\n659\t                } else {\n660\t                    0.0\n661\t                }\n662\t            }\n663\t            Op::Sub => {\n664\t                if vals.len() >= 2 {\n665\t                    dec_round(vals[0] - vals[1])\n666\t                } else {\n667\t                    0.0\n668\t                }\n669\t            }\n670\t            Op::Mul => {\n671\t                if vals.len() >= 2 {\n672\t                    dec_round(vals[0] * vals[1])\n673\t                } else {\n674\t                    0.0\n675\t                }\n676\t            }\n677\t            Op::Div => {\n678\t                if vals.len() >= 2 && vals[1] != 0.0 {\n679\t                    dec_round(vals[0] / vals[1])\n680\t                } else {\n681\t                    0.0\n682\t                }"
