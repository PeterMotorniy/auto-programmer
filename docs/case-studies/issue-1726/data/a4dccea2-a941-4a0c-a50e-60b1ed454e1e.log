t off = 0; off < text.length; off++) {\n790\t    const ch = text[off];\n791\t    if (ch === '\\n') {\n792\t      inLineComment = false;\n793\t      lineNum++;\n794\t      colNum = 1;\n795\t      continue;\n796\t    }\n797\t    if (inLineComment) { colNum++; continue; }\n798\t    // Detect a full-line comment (line begins with optional whitespace + #).\n799\t    if (ch === '#' && depth === 0) {\n800\t      // Check if the line so far contains only whitespace.\n801\t      const lineSoFar = lines[lineNum - 1].slice(0, colNum - 1);\n802\t      if (/^[ \\t]*$/.test(lineSoFar)) {\n803\t        inLineComment = true;\n804\t        colNum++;\n805\t        continue;\n806\t      }\n807\t    }\n808\t    if (ch === '(') {\n809\t      if (depth === 0) {\n810\t        pendingStart = { line: lineNum, col: colNum };\n811\t      }\n812\t      depth++;\n813\t    } else if (ch === ')') {\n814\t      depth--;\n815\t      if (depth === 0 && pendingStart) {\n816\t        spans.push({ file: file || null, line: pendingStart.line, col: pendingStart.col, length: 1 });\n817\t        pendingStart = null;\n818\t      }\n819\t    }\n820\t    colNum++;\n821\t  }\n822\t  return spans;\n823\t}\n824\t\n825\t// New structured evaluator: returns { results, diagnostics }. Existing\n826\t// callers can keep using `run`, which now delegates to this and surfaces only\n827\t// the result list (preserving its previous signature for tests/CLI consumers).\n828\tfunction evaluate(code, options) {\n829\t  const opts = options || {};\n830\t  const file = opts.file || null;\n831\t  const sourceText = String(code);\n832\t  const env = new Env(opts.env || opts);\n833\t  const results = [];\n834\t  const diagnostics = [];\n835\t\n836\t  // Pre-compute spans for each top-level form so error reporting can attach\n837\t  // a real source location even when the parser/evaluator throw deep inside.\n838\t  const formSpans = computeFormSpans(sourceText, file);\n839\t\n840\t  let forms;\n841\t  try {\n842\t    forms = parseLinoForms(sourceText);\n843\t  } catch (err) {\n844\t    const diag = err && err.code\n845\t      ? new Diagnostic({ code: err.code, message: err.message, span: { file, line: 1, col: 1, length: 0 } })\n846\t      : new Diagnostic({ code: 'E006', message: `LiNo parse failure: ${err && err.message ? err.message : String(err)}`, span: { file, line: 1, col: 1, length: 0 } });\n847\t    diagnostics.push(diag);\n848\t    return { results, diagnostics };\n849\t  }\n850\t\n851\t  for (let idx = 0; idx < forms.length; idx++) {\n852\t    let form = forms[idx];\n853\t    while (Array.isArray(form) && form.length === 1 && Array.isArray(form[0])) {\n854\t      form = form[0];\n855\t    }\n856\t    const span = formSpans[idx] || { file, line: 1, col: 1, length: 0 };\n857\t    try {\n858\t      const res = evalNode(form, env);\n859\t      if (res && res.query) {\n860\t        results.push(res.value);\n861\t      }\n862\t    } catch (err) {\n863\t      const diagSpan = (err && err.span) || span;\n864\t      const code = (err && err.code) || 'E000';\n865\t      const message = err && err.message ? err.message : String(err);\n866\t      diagnostics.push(new Diagnostic({ code, message, span: diagSpan }));\n867\t    }\n868\t  }\n869\t  return { results, diagnostics };\n870\t}\n871\t\n872\t// ---------- Meta-expression adapter ----------\n873\tfunction normalizeInterpretation(interpretation) {\n874\t  if (!interpretation) return {};\n875\t  if (typeof interpretation === 'string') return { kind: interpretation, summary: interpretation };\n876\t  return interpretation;\n877\t}\n878\t\n879\tfunction normalizeQuestionExpression(text) {\n880\t  return String(text || '')\n881\t    .trim()\n882\t    .replace(/\\?+$/g, '')\n883\t    .replace(/^what\\s+is\\s+/i, '')\n884\t    .trim();\n885\t}\n886\t\n887\tfunction splitTopLevelEquals(expression) {\n888\t  let depth = 0;\n889\t  const s = String(expression);\n890\t  for (let i = 0; i < s.length; i++) {\n891\t    const c = s[i];\n892\t    if (c === '(') depth++;\n893\t    else if (c === ')') depth--;\n894\t    else if (c === '=' && depth === 0) {\n895\t      if (s[i - 1] === '!' || s[i + 1] === '=') continue;\n896\t      return [s.slice(0, i).trim(), s.slice(i + 1).trim()];\n897\t    }\n898\t  }\n899\t  return null;\n900\t}\n901\t\n902\tfunction parseExpressionShape(expression, options = {}) {\n903\t  const trimmed = String(expression || '').trim();\n904\t  if (!trimmed) throw new RmlError('E005', 'empty expression');\n905\t  const source = trimmed.startsWith('(') && trimmed.endsWith(')') ? trimmed : `(${trimmed})`;\n906\t  let ast = parseOne(tokenizeOne(source));\n907\t  while (\n908\t    Array.isArray(ast) &&\n909\t    ast.length === 1 &&\n910\t    (options.unwrapSingle || Array.isArray(ast[0]))\n911\t  ) {\n912\t    ast = ast[0];\n913\t  }\n914\t  return ast;\n915\t}\n916\t\n917\tfunction buildArithmeticFormalization(expression, valueKind) {\n918\t  const eq = valueKind === 'truth-value' ? splitTopLevelEquals(expression) : null;\n919\t  const ast = eq\n920\t    ? [parseExpressionShape(eq[0], { unwrapSingle: true }), '=', parseExpressionShape(eq[1], { unwrapSingle: true })]\n921\t    : parseExpressionShape(expression, { unwrapSingle: true });\n922\t  return {\n923\t    ast,\n924\t    lino: keyOf(ast),\n925\t    valueKind,\n926\t  };\n927\t}\n928\t\n929\tfunction partialFormalization(request, interpretation, unknowns, level = 2) {\n930\t  const uniqueUnknowns = [...new Set(unknowns)];\n931\t  return {\n932\t    type: 'rml-formalization',\n933\t    sourceText: request?.text || '',\n934\t    interpretation,\n935\t    formalSystem: request?.formalSystem || request?.formal_system || 'rml',\n936\t    dependencies: request?.dependencies || [],\n937\t    computable: false,\n938\t    formalizationLevel: level,\n939\t    unknowns: uniqueUnknowns,\n940\t    valueKind: 'partial',\n941\t    ast: null,\n942\t    lino: null,\n943\t  };\n944\t}\n945\t\n946\tfunction formalizeSelectedInterpretation(request = {}) {\n947\t  const interpretation = normalizeInterpretation(request.interpretation);\n948\t  const kind = String(interpretation.kind || '').toLowerCase();\n949\t  const formalSystem = request.formalSystem || request.formal_system || 'rml';\n950\t  const dependencies = request.dependencies || [];\n951\t  const rawExpression =\n952\t    interpretation.expression ||\n953\t    interpretation.formalExpression ||\n954\t    interpretation.formal_expression ||\n955\t    interpretation.lino ||\n956\t    normalizeQuestionExpression(request.text);\n957\t\n958\t  const canUseArithmetic =\n959\t    formalSystem === 'rml-arithmetic' ||\n960\t    formalSystem === 'arithmetic' ||\n961\t    kind.startsWith('arithmetic');\n962\t\n963\t  if (canUseArithmetic && rawExpression) {\n964\t    const valueKind = kind.includes('equal') || splitTopLevelEquals(rawExpression) ? 'truth-value' : 'number';\n965\t    try {\n966\t      const formal = buildArithmeticFormalization(rawExpression, valueKind);\n967\t      return {\n968\t        type: 'rml-formalization',\n969\t        sourceText: request.text || '',\n970\t        interpretation,\n971\t        formalSystem,\n972\t        dependencies,\n973\t        computable: true,\n974\t        formalizationLevel: 3,\n975\t        unknowns: [],\n976\t        valueKind: formal.valueKind,\n977\t        ast: formal.ast,\n978\t        lino: formal.lino,\n979\t      };\n980\t    } catch (error) {\n981\t      return partialFormalization(request, interpretation, ['unsupported-arithmetic-shape', error.message], 1);\n982\t    }\n983\t  }\n984\t\n985\t  if ((interpretation.lino || interpretation.formalExpression || interpretation.formal_expression) && rawExpression) {\n986\t    try {\n987\t      const ast = parseExpressionShape(rawExpression);\n988\t      return {\n989\t        type: 'rml-formalization',\n990\t        sourceText: request.text || '',\n991\t        interpretation,\n992\t        formalSystem,\n993\t        dependencies,\n994\t        computable: true,\n995\t        formalizationLevel: 3,\n996\t        unknowns: [],\n997\t        valueKind: Array.isArray(ast) && ast[0] === '?' ? 'query' : 'truth-value',\n998\t        ast,\n999\t        lino: keyOf(ast),\n1000\t      };\n1001\t    } catch (error) {\n1002\t      return partialFormalization(request, interpretation, ['unsupported-lino-shape', error.message], 1);\n1003\t    }\n1004\t  }\n1005\t\n1006\t  const dependencyUnknowns = dependencies\n1007\t    .filter(dep => dep && ['missing', 'unknown', 'partial'].includes(dep.status))\n1008\t    .map(dep => `dependency:${dep.id || 'unknown'}`);\n1009\t  return partialFormalization(request, interpretation, [\n1010\t    'selected-subject',\n1011\t    'selected-relation',\n1012\t    'evidence-source',\n1013\t    'formal-shape',\n1014\t    ...dependencyUnknowns,\n1015\t  ]);\n1016\t}\n1017\t\n1018\tfunction evaluateFormalization(formalization, options = {}) {\n1019\t  if (!formalization || !formalization.computable || !formalization.ast) {\n1020\t    return {\n1021\t      computable: false,\n1022\t      formalizationLevel: formalization?.formalizationLevel || 0,\n1023\t      unknowns: formalization?.unknowns || ['formalization'],\n1024\t      result: { kind: 'partial', value: 'unknown', deterministic: false },\n1025\t    };\n1026\t  }\n1027\t\n1028\t  const env = new Env(options.env || options);\n1029\t  const evaluated = evalNode(formalization.ast, env);\n1030\t  const value = evaluated && evaluated.query ? evaluated.value : evaluated;\n1031\t  const kind =\n1032\t    formalization.valueKind === 'truth-value' ? 'truth-value' :\n1033\t    formalization.valueKind === 'query' && typeof value === 'string' ? 'type' :\n1034\t    'number';\n1035\t\n1036\t  return {\n1037\t    computable: true,\n1038\t    formalizationLevel: formalization.formalizationLevel,\n1039\t    unknowns: [],\n1040\t    result: { kind, value, deterministic: true },\n1041\t  };\n1042\t}\n1043\t\n1044\t// ---------- Runner ----------\n1045\tfunction run(text, options){\n1046\t  const forms = parseLinoForms(text);\n1047\t\n1048\t  const env = new Env(options);\n1049\t  const outs = [];\n1050\t  for (let form of forms) {\n1051\t    // Unwrap single-element arrays (LiNo wraps everything in outer parens)\n1052\t    while (Array.isArray(form) && form.length === 1 && Array.isArray(form[0])) {\n1053\t      form = form[0];\n1054\t    }\n1055\t    const res = evalNode(form, env);\n1056\t    if (res && res.query) {\n1057\t      if (res.typeQuery) {\n1058\t        // Type queries return string results\n1059\t        outs.push(res.value);\n1060\t      } else {\n1061\t        outs.push(res.value);\n1062\t      }\n1063\t    }\n1064\t  }\n1065\t  return outs;\n1066\t}\n1067\t\n1068\t// CLI\n1069\tif (import.meta.url === `file://${process.argv[1]}`) {\n1070\t  const file = process.argv[2];\n1071\t  if (!file) {\n1072\t    console.error('Usage: node src/rml-links.mjs <kb.lino>');\n1073\t    process.exit(1);\n1074\t  }\n1075\t  const text = fs.readFileSync(file, 'utf8');\n1076\t  const { results, diagnostics } = evaluate(text, { file });\n1077\t  for (const v of results) {\n1078\t    if (typeof v === 'string') {\n1079\t      console.log(v);\n1080\t    } else {\n1081\t      console.log(String(+v.toFixed(6)).replace(/\\.0+$/,''));\n1082\t    }\n1083\t  }\n1084\t  for (const diag of diagnostics) {\n1085\t    console.error(formatDiagnostic(diag, text));\n1086\t  }\n1087\t  if (diagnostics.length > 0) process.exit(1);\n1088\t}\n1089\t\n1090\texport {\n1091\t  run,\n1092\t  evaluate,\n1093\t  Diagnostic,\n1094\t  RmlError,\n1095\t  formatDiagnostic,\n1096\t  computeFormSpans,\n1097\t  parseLino,\n1098\t  tokenizeOne,\n1099\t  parseOne,\n1100\t  Env,\n1101\t  evalNode,\n1102\t  quantize,\n1103\t  decRound,\n1104\t  keyOf,\n1105\t  isNum,\n1106\t  isStructurallySame,\n1107\t  parseBinding,\n1108\t  parseBindings,\n1109\t  substitute,\n1110\t  formalizeSelectedInterpretation,\n1111\t  evaluateFormalization,\n1112\t};\n1113\t"
