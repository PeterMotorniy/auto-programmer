        "type": "tool_result",
        "content": "1873\tpub enum RunResult {\n1874\t    Num(f64),\n1875\t    Type(String),\n1876\t}\n1877\t\n1878\t/// Evaluate a complete LiNo knowledge base and return both results and any\n1879\t/// diagnostics emitted by the parser, evaluator, or type checker.\n1880\t///\n1881\t/// Each diagnostic carries a code (`E001`, `E002`, ...), a message, and a\n1882\t/// source span (1-based line/col).  See `docs/DIAGNOSTICS.md` for the\n1883\t/// full code list.  Errors do not abort evaluation: independent forms\n1884\t/// continue to be processed after a failing one.\n1885\tpub fn evaluate(text: &str, file: Option<&str>, options: Option<EnvOptions>) -> EvaluateResult {\n1886\t    let mut diagnostics: Vec<Diagnostic> = Vec::new();\n1887\t    let spans = compute_form_spans(text, file);\n1888\t\n1889\t    let links = parse_lino(text);\n1890\t    let forms: Vec<Node> = links\n1891\t        .iter()\n1892\t        .filter(|link_str| {\n1893\t            let s = link_str.trim();\n1894\t            !(s.starts_with(\"(#\") && s.chars().nth(2).map_or(false, |c| c.is_whitespace()))\n1895\t        })\n1896\t        .filter_map(|link_str| {\n1897\t            let toks = tokenize_one(link_str);\n1898\t            match parse_one(&toks) {\n1899\t                Ok(node) => Some(node),\n1900\t                Err(msg) => {\n1901\t                    diagnostics.push(Diagnostic::new(\n1902\t                        \"E002\",\n1903\t                        msg,\n1904\t                        Span::new(file.map(|s| s.to_string()), 1, 1, 0),\n1905\t                    ));\n1906\t                    None\n1907\t                }\n1908\t            }\n1909\t        })\n1910\t        .collect();\n1911\t\n1912\t    let mut env = Env::new(options);\n1913\t    let mut results: Vec<RunResult> = Vec::new();\n1914\t\n1915\t    // Silence the default panic hook while we deliberately catch evaluator\n1916\t    // panics — otherwise they'd leak to stderr alongside the diagnostics.\n1917\t    let prev_hook = std::panic::take_hook();\n1918\t    std::panic::set_hook(Box::new(|_| {}));\n1919\t\n1920\t    for (idx, form) in forms.into_iter().enumerate() {\n1921\t        let mut form = form;\n1922\t        loop {\n1923\t            match form {\n1924\t                Node::List(ref children) if children.len() == 1 => {\n1925\t                    if let Node::List(_) = &children[0] {\n1926\t                        form = children[0].clone();\n1927\t                    } else {\n1928\t                        break;\n1929\t                    }\n1930\t                }\n1931\t                _ => break,\n1932\t            }\n1933\t        }\n1934\t        let span = spans\n1935\t            .get(idx)\n1936\t            .cloned()\n1937\t            .unwrap_or_else(|| Span::new(file.map(|s| s.to_string()), 1, 1, 0));\n1938\t        let result = catch_unwind(AssertUnwindSafe(|| eval_node(&form, &mut env)));\n1939\t        match result {\n1940\t            Ok(EvalResult::Query(v)) => results.push(RunResult::Num(v)),\n1941\t            Ok(EvalResult::TypeQuery(s)) => results.push(RunResult::Type(s)),\n1942\t            Ok(_) => {}\n1943\t            Err(payload) => {\n1944\t                let (code, message) = decode_panic_payload(&payload);\n1945\t                diagnostics.push(Diagnostic::new(&code, message, span));\n1946\t            }\n1947\t        }\n1948\t    }\n1949\t\n1950\t    std::panic::set_hook(prev_hook);\n1951\t\n1952\t    EvaluateResult {\n1953\t        results,\n1954\t        diagnostics,\n1955\t    }\n1956\t}\n1957\t\n1958\t/// Map a panic payload to a diagnostic `(code, message)` pair.  Known panic\n1959\t/// messages emitted by the evaluator are mapped to the canonical `E001`/etc.\n1960\t/// codes; anything else falls back to `E000`.\n1961\tfn decode_panic_payload(payload: &Box<dyn std::any::Any + Send>) -> (String, String) {\n1962\t    let raw_msg: String = if let Some(s) = payload.downcast_ref::<&'static str>() {\n1963\t        (*s).to_string()\n1964\t    } else if let Some(s) = payload.downcast_ref::<String>() {\n1965\t        s.clone()\n1966\t    } else {\n1967\t        \"evaluation panicked\".to_string()\n1968\t    };\n1969\t    if raw_msg.starts_with(\"Unknown op:\") {\n1970\t        (\"E001\".to_string(), raw_msg)\n1971\t    } else if raw_msg.starts_with(\"Unknown aggregator\") {\n1972\t        (\"E004\".to_string(), raw_msg)\n1973\t    } else {\n1974\t        (\"E000\".to_string(), raw_msg)\n1975\t    }\n1976\t}\n1977\t\n1978\t/// Run a complete LiNo knowledge base and return query results (including type queries).\n1979\tpub fn run_typed(text: &str, options: Option<EnvOptions>) -> Vec<RunResult> {\n1980\t    let links = parse_lino(text);\n1981\t    let forms: Vec<Node> = links\n1982\t        .iter()\n1983\t        .filter(|link_str| {\n1984\t            let s = link_str.trim();\n1985\t            !(s.starts_with(\"(#\") && s.chars().nth(2).map_or(false, |c| c.is_whitespace()))\n1986\t        })\n1987\t        .filter_map(|link_str| {\n1988\t            let toks = tokenize_one(link_str);\n1989\t            parse_one(&toks).ok()\n1990\t        })\n1991\t        .collect();\n1992\t\n1993\t    let mut env = Env::new(options);\n1994\t    let mut outs = Vec::new();\n1995\t\n1996\t    for form in forms {\n1997\t        let mut form = form;\n1998\t        loop {\n1999\t            match form {\n2000\t                Node::List(ref children) if children.len() == 1 => {\n2001\t                    if let Node::List(_) = &children[0] {\n2002\t                        form = children[0].clone();\n2003\t                    } else {\n2004\t                        break;\n2005\t                    }\n2006\t                }\n2007\t                _ => break,\n2008\t            }\n2009\t        }\n2010\t        let res = eval_node(&form, &mut env);\n2011\t        match res {\n2012\t            EvalResult::Query(v) => outs.push(RunResult::Num(v)),\n2013\t            EvalResult::TypeQuery(s) => outs.push(RunResult::Type(s)),\n2014\t            _ => {}\n2015\t        }\n2016\t    }\n2017\t    outs\n2018\t}\n2019\t\n2020\t/// Run a complete LiNo knowledge base and return query results.\n2021\tpub fn run(text: &str, options: Option<EnvOptions>) -> Vec<f64> {\n2022\t    let links = parse_lino(text);\n2023\t\n2024\t    // Filter out comment-only links and parse each link\n2025\t    let forms: Vec<Node> = links\n2026\t        .iter()\n2027\t        .filter(|link_str| {\n2028\t            let s = link_str.trim();\n2029\t            // Skip if it's just a comment link like \"(# ...)\"\n2030\t            !(s.starts_with(\"(#\") && s.chars().nth(2).map_or(false, |c| c.is_whitespace()))\n2031\t        })\n2032\t        .filter_map(|link_str| {\n2033\t            let toks = tokenize_one(link_str);\n2034\t            parse_one(&toks).ok()\n2035\t        })\n2036\t        .collect();\n2037\t\n2038\t    let mut env = Env::new(options);\n2039\t    let mut outs = Vec::new();\n2040\t\n2041\t    for form in forms {\n2042\t        // Unwrap single-element arrays (LiNo wraps everything in outer parens)\n2043\t        let mut form = form;\n2044\t        loop {\n2045\t            match form {\n2046\t                Node::List(ref children) if children.len() == 1 => {\n2047\t                    if let Node::List(_) = &children[0] {\n2048\t                        form = children[0].clone();\n2049\t                    } else {\n2050\t                        break;\n2051\t                    }\n2052\t                }\n2053\t                _ => break,\n2054\t            }\n2055\t        }\n2056\t        let res = eval_node(&form, &mut env);\n2057\t        if let EvalResult::Query(v) = res {\n2058\t            outs.push(v);\n2059\t        }\n2060\t    }\n2061\t    outs\n2062\t}\n2063\t\n2064\t// Tests are in the tests/ directory (integration tests).\n2065\t// To run: cargo test\n2066\t"
