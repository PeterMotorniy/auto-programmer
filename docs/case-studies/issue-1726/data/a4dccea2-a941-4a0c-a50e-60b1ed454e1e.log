        "content": "1\t// Tests for structured diagnostics (issue #28).\n2\t// Mirrors js/tests/diagnostics.test.mjs so any drift between the two\n3\t// implementations fails both test suites.\n4\t\n5\tuse rml::{\n6\t    compute_form_spans, evaluate, format_diagnostic, Diagnostic, RunResult, Span,\n7\t};\n8\t\n9\t#[test]\n10\tfn evaluate_clean_input_returns_results_and_no_diagnostics() {\n11\t    let out = evaluate(\"(valence: 2)\\n(p has probability 1)\\n(? p)\", None, None);\n12\t    assert_eq!(out.diagnostics.len(), 0);\n13\t    assert_eq!(out.results.len(), 1);\n14\t    match &out.results[0] {\n15\t        RunResult::Num(n) => assert!((*n - 1.0).abs() < 1e-9),\n16\t        other => panic!(\"expected numeric result, got {:?}\", other),\n17\t    }\n18\t}\n19\t\n20\t#[test]\n21\tfn evaluate_does_not_panic_on_unknown_op() {\n22\t    let out = evaluate(\"(=: missing_op identity)\", Some(\"inline.lino\"), None);\n23\t    assert!(out.diagnostics.len() >= 1);\n24\t}\n25\t\n26\t#[test]\n27\tfn unknown_op_surfaces_as_e001_with_span() {\n28\t    let out = evaluate(\"(=: missing_op identity)\", Some(\"inline.lino\"), None);\n29\t    assert_eq!(out.diagnostics.len(), 1);\n30\t    let d = &out.diagnostics[0];\n31\t    assert_eq!(d.code, \"E001\");\n32\t    assert!(d.message.contains(\"Unknown op\"), \"msg was: {}\", d.message);\n33\t    assert_eq!(d.span.file.as_deref(), Some(\"inline.lino\"));\n34\t    assert_eq!(d.span.line, 1);\n35\t    assert_eq!(d.span.col, 1);\n36\t}\n37\t\n38\t#[test]\n39\tfn unknown_aggregator_surfaces_as_e004() {\n40\t    let out = evaluate(\"(and: bogus_agg)\", Some(\"agg.lino\"), None);\n41\t    assert_eq!(out.diagnostics.len(), 1);\n42\t    let d = &out.diagnostics[0];\n43\t    assert_eq!(d.code, \"E004\");\n44\t    assert!(\n45\t        d.message.to_lowercase().contains(\"aggregator\"),\n46\t        \"msg was: {}\",\n47\t        d.message\n48\t    );\n49\t    assert_eq!(d.span.line, 1);\n50\t}"
